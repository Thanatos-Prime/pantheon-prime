from __future__ import annotations

from dataclasses import dataclass
from typing import Dict, List, Tuple

from depth_memory import DepthMemory, DepthRecord


@dataclass
class DepthLearningRecommendation:
    adjusted_depth: int
    confidence: float
    reason: str
    supporting_examples: int


class DepthLearner:
    """
    Learns which depth tends to work best for similar problems.

    Current strategy:
    - Use a simple problem signature
    - Compare historical average outcome by chosen depth
    - Bias future depth toward the best-performing bucket
    """

    def __init__(self, memory: DepthMemory):
        self.memory = memory

    def recommend_depth(
        self,
        problem_signature: str,
        baseline_depth: int
    ) -> DepthLearningRecommendation:
        records = self.memory.query_by_signature(problem_signature)

        if len(records) < 3:
            return DepthLearningRecommendation(
                adjusted_depth=baseline_depth,
                confidence=0.20,
                reason="Insufficient history; using baseline depth",
                supporting_examples=len(records)
            )

        grouped: Dict[int, List[float]] = {}
        for r in records:
            grouped.setdefault(r.chosen_depth, []).append(r.overall_outcome_score)

        scored_depths: List[Tuple[int, float, int]] = []
        for depth, scores in grouped.items():
            avg = sum(scores) / len(scores)
            scored_depths.append((depth, avg, len(scores)))

        scored_depths.sort(key=lambda x: (x[1], x[2]), reverse=True)
        best_depth, best_score, count = scored_depths[0]

        # Keep adjustments bounded so the system does not swing wildly.
        if best_depth > baseline_depth + 1:
            adjusted = baseline_depth + 1
        elif best_depth < baseline_depth - 1:
            adjusted = baseline_depth - 1
        else:
            adjusted = best_depth

        confidence = min(0.95, 0.30 + (0.08 * count))

        return DepthLearningRecommendation(
            adjusted_depth=max(1, min(5, adjusted)),
            confidence=confidence,
            reason=(
                f"Historical outcomes for signature '{problem_signature}' "
                f"favor depth {best_depth} with avg score {best_score:.2f}"
            ),
            supporting_examples=count
        )

    def record_outcome(self, record: DepthRecord) -> None:
        self.memory.append(record)


