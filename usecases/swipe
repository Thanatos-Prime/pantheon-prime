function clamp(v, a, b) { return Math.min(Math.max(v, a), b); }
function shuffle(arr) { return […arr].sort(() => Math.random() - 0.5); }

const ERA = (releaseDate) => {
if (!releaseDate) return “Unknown”;
const y = parseInt(releaseDate.slice(0, 4));
if (y <= 2002) return “Base/Neo Era”;
if (y <= 2007) return “EX Era”;
if (y <= 2010) return “DP/HGSS Era”;
if (y <= 2013) return “BW Era”;
if (y <= 2019) return “XY/SM Era”;
if (y <= 2022) return “SwSh Era”;
return “SV Era”;
};

