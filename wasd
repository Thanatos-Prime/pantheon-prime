class HippoController:
    def step(self, S, F, alpha, w, key):
        if key == "W":  # advance
            alpha *= 1.2
        elif key == "S":  # brake
            alpha *= 0.5
        elif key == "A":  # explore
            F = self.perturb(F, direction="left")
            w *= 0.8
        elif key == "D":  # exploit
            F = self.refine(F)
            w *= 1.1
        S_hat = self.predict(F)
        return S + alpha * (S_hat - S) * w, F, alpha, w

