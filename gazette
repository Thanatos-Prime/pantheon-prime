<script>
  // The prank — fires after 8 seconds of reading
  let prankFired = false;
  setTimeout(() => {
    if (!prankFired) {
      prankFired = true;
      document.getElementById('prankModal').classList.add('active');
      // Count how long they sit in the modal
      let seconds = 0;
      const countEl = document.getElementById('prankCount');
      const counter = setInterval(() => {
        seconds++;
        countEl.textContent = `You have been sitting in this alert for ${seconds} second${seconds !== 1 ? 's' : ''}. Sisyphus is watching.`;
        if (seconds > 10) {
          countEl.style.color = '#c0392b';
          countEl.textContent = `${seconds} seconds. The Hound daemon is filing a formal report.`;
        }
      }, 1000);
      document.querySelector('.modal-close').addEventListener('click', () => clearInterval(counter));
    }
  }, 8000);

  // Second prank — if they scroll to the bottom and stay
  let bottomPrank = false;
  window.addEventListener('scroll', () => {
    const nearBottom = (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 100;
    if (nearBottom && !bottomPrank && prankFired) {
      bottomPrank = true;
      setTimeout(() => {
        const msg = document.createElement('div');
        msg.style.cssText = `position:fixed;bottom:1rem;right:1rem;background:#111;color:#f2efe8;font-family:'DM Mono',monospace;font-size:0.65rem;padding:1rem 1.5rem;letter-spacing:0.1em;z-index:9998;line-height:1.8;border-left:3px solid #c0392b;max-width:280px;`;
        msg.innerHTML = `<strong style="color:#c0392b;display:block;letter-spacing:0.2em;margin-bottom:0.3rem">ORACLE WEAVE · REBIRTH CYCLE</strong>You have reached the bottom.<br>There is no bottom.<br>The loop has been reset.<br>Go build something.<br><span style="color:#666;font-size:0.55rem;cursor:pointer" onclick="this.parentElement.remove()">[ dismiss ]</span>`;
        document.body.appendChild(msg);
        setTimeout(() => msg.remove(), 12000);
      }, 1500);
    }
  });
</script>

