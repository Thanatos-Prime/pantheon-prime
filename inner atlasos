// ─── HELPERS ──────────────────────────────────────────────────────────────────
function uid() {
return Math.random().toString(36).slice(2, 10);
}

function fmtTime(ts) {
return new Date(ts).toLocaleTimeString([], { hour: “2-digit”, minute: “2-digit” });
}

function fmtDate(ts) {
return new Date(ts).toLocaleDateString([], { month: “short”, day: “numeric” });
}

function computeDelta(curr, prev) {
if (!curr || !prev) return [];
return curr.markers.map(m => {
const p = prev.markers.find(x => x.zone === m.zone && x.type === m.type);
return { zone: m.zone, type: m.type, delta: m.intensity - (p?.intensity ?? 0) };
}).filter(d => d.delta !== 0);
}

function findClusters(snapshots) {
const counts = {};
snapshots.forEach(s => s.markers.forEach(m => {
const key = `${m.zone}__${m.type}`;
counts[key] = (counts[key] || 0) + 1;
}));
return Object.entries(counts)
.sort((a, b) => b[1] - a[1])
.slice(0, 5)
.map(([key, count]) => {
const [zone, type] = key.split(”__”);
return { zone, type, count };
});
}

function getZone(id) { return BODY_ZONES.find(z => z.id === id); }
function getType(id) { return MARKER_TYPES.find(t => t.id === id); }

