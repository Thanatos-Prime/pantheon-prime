Pseudocode

class LoopEngine:
    def __init__(self, graph, delta_engine, scorer, compressor):
        self.graph = graph
        self.delta_engine = delta_engine
        self.scorer = scorer
        self.compressor = compressor

    def traverse(self, start_state, max_steps=1000):
        current = start_state
        history = []
        
        for step in range(max_steps):
            next_candidates = self.graph.next_states(current)
            if not next_candidates:
                break

            ranked = self.scorer.rank_candidates(current, next_candidates, history)
            next_state = ranked[0]

            delta = self.delta_engine.diff(current, next_state)
            history.append(delta)
            current = next_state

            if self.scorer.is_low_yield_loop(history):
                break

        return self.compressor.compress(history)


