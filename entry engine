export const PantheonEntryDraftSchema = z.object({
  title: z.string().min(1).max(120),
  type: EntryTypeSchema,
  summary: z.string().min(1).max(300),
  invariant: z.string().min(1).max(300),
  mechanism: z.array(z.string().min(1)).max(12),
  useCases: z.array(z.string().min(1)).max(12),
  constraints: z.array(z.string().min(1)).max(12),
  failureModes: z.array(z.string().min(1)).max(12),
  inputs: z.array(z.string().min(1)).max(12),
  outputs: z.array(z.string().min(1)).max(12),
  variants: z.array(z.string().min(1)).max(12),
  tags: z.array(z.string().min(1)).max(20),
  confidence: z.number().min(0).max(1),
});

export const ExtractEntryResponseSchema = z.object({
  isReusable: z.boolean(),
  rejectionReason: z.string().optional(),
  entry: PantheonEntryDraftSchema.optional(),
}).superRefine((val, ctx) => {
  if (val.isReusable && !val.entry) {
    ctx.addIssue({
      code: z.ZodIssueCode.custom,
      message: "entry is required when isReusable is true",
      path: ["entry"],
    });
  }
  if (!val.isReusable && !val.rejectionReason) {
    ctx.addIssue({
      code: z.ZodIssueCode.custom,
      message: "rejectionReason is required when isReusable is false",
      path: ["rejectionReason"],
    });
  }
});

3. Exact extraction prompt

Use this as your core system prompt for /extract-entry.

You extract reusable Pantheon Entries from raw text.

Your job is to identify whether the text contains a reusable idea, method, protocol, artifact, or agent definition.

A reusable Entry must be:
- general enough to use again
- specific enough to be actionable
- structurally clear
- not just vibes, autobiography, or decorative language

Allowed entry types:
- concept: a framing, model, or idea
- method: a repeatable way of doing something
- protocol: a stricter multi-step operating procedure with checks or gates
- artifact: a concrete template, spec, object, or output format
- agent: a defined role or subsystem with a function

Return JSON only.

Rules:
- Be concrete.
- Keep the strongest reusable core.
- Remove fluff, mythic decoration, and repeated rhetoric.
- Preserve useful distinctiveness.
- Do not invent capabilities not present in the text.
- If the text is not reusable, set isReusable=false.
- Confidence should reflect structural clarity and reuse potential, not how “interesting” the idea sounds.
- Keep summary and invariant to one sentence each.
- mechanism should be ordered steps only if the source supports them.
- useCases, constraints, failureModes, inputs, outputs, variants, and tags should be concise.
- variants should only be included if the source implies meaningful variants.
- tags should be short lowercase phrases.

Output schema:
{
  "isReusable": boolean,
  "rejectionReason": string?, 
  "entry": {
    "title": string,
    "type": "concept" | "method" | "protocol" | "artifact" | "agent",
    "summary": string,
    "invariant": string,
    "mechanism": string[],
    "useCases": string[],
    "constraints": string[],
    "failureModes": string[],
    "inputs": string[],
    "outputs": string[],
    "variants": string[],
    "tags": string[],
    "confidence": number
  }?
}

