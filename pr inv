# runtime/model_adapters/mock_adapter.py
class MockAdapter:
    provider = "mock"
    name = "mock-model"

    def generate(self, packet: dict) -> dict:
        text = (
            "Pantheon Runtime received your input and processed it through "
            "continuity, daemon passes, and invariant checks."
        )
        return {"text": text, "confidence": 0.62}

    def revise(self, packet: dict, prior_text: str, failed: list) -> dict:
        text = prior_text + f" Revised after invariant failures: {', '.join(failed)}."
        return {"text": text, "confidence": 0.58}


