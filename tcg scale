from __future__ import annotations

from app.engine import PreferenceEngine
from app.storage import fetch_all_events


def rebuild_engine_from_storage() -> PreferenceEngine:
    engine = PreferenceEngine()
    events = fetch_all_events()

    for event in events:
        engine.update(
            user_id=event["user_id"],
            item_a=event["item_a"],
            item_b=event["item_b"],
            selected=event["selected"],
            confidence=event["confidence"],
            dwell_ms=event["dwell_ms"],
            domain=event["domain"],
            item_a_features=event["item_a_features"],
            item_b_features=event["item_b_features"],
        )

    return engine

