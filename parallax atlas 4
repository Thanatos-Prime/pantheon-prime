// TIMELINE
// ═══════════════════════════════════════════════════════════
function buildTimeline(){
  const leg=document.getElementById('tlLeg');leg.innerHTML='';
  const targets=BODIES.filter(b=>b!==S.obs);
  targets.forEach(n=>{
    const ph=PHYS[n];
    const d=document.createElement('div');d.className='tll';
    d.innerHTML=`<div class="tld" style="background:${ph.col}"></div>${ph.sym} ${n}`;
    leg.appendChild(d);
  });
  drawTimeline();
}

function drawTimeline(){
  const wrap=document.getElementById('tlC').parentElement;
  const wH=wrap.clientHeight-40;
  const targets=BODIES.filter(b=>b!==S.obs);
  const TRACK_H=Math.max(28,Math.floor(wH/targets.length));
  const CW=Math.max(wrap.clientWidth,3200);
  const CH=targets.length*TRACK_H;
  const tlC=document.getElementById('tlC');
  tlC.width=CW;tlC.height=CH;
  const tlX=tlC.getContext('2d');

  tlX.fillStyle='rgba(5,7,14,.98)';tlX.fillRect(0,0,CW,CH);

  const pixPerDay=CW/S.span;
  const STEP=Math.max(S.step,15);

  // Year markers
  for(let yr=0;yr*365.25<=S.span;yr++){
    const px=yr*365.25*pixPerDay;
    const big=yr%10===0;
    tlX.beginPath();tlX.moveTo(px,0);tlX.lineTo(px,CH);
    tlX.strokeStyle=big?'rgba(212,150,26,.12)':'rgba(100,130,200,.04)';
    tlX.lineWidth=big?1:.3;tlX.stroke();
    if(big&&yr>0){
      tlX.fillStyle='rgba(212,150,26,.35)';tlX.font='7px "IBM Plex Mono"';
      tlX.textAlign='center';tlX.fillText(`yr${yr}`,px,9);
    }
  }

  targets.forEach((name,ti)=>{
    const yBase=ti*TRACK_H+TRACK_H*.5;
    const ph=PHYS[name];

    // track bg
    tlX.fillStyle=ti%2===0?'rgba(255,255,255,.007)':'transparent';
    tlX.fillRect(0,ti*TRACK_H,CW,TRACK_H);

    // label
    tlX.fillStyle=ph.col+'cc';tlX.font=`8px "IBM Plex Mono"`;
    tlX.textAlign='left';tlX.textBaseline='middle';
    tlX.fillText(`${ph.sym} ${name}`,3,yBase-TRACK_H*.25);

    const maxBForTrack=S.metrics.find(m=>m.name===name)?.maxB||.01;

    // brightness/visibility line
    let prevX=0,prevY=yBase,prevVis=false;
    for(let t=0;t<=S.span;t+=STEP){
      const op=helioXYZ(S.obs,t),tp=helioXYZ(name,t);
      const rel=[tp[0]-op[0],tp[1]-op[1],tp[2]-op[2]];
      const dist=Math.hypot(rel[0],rel[1],rel[2]);
      const sLen=Math.hypot(op[0],op[1],op[2]);
      const cosE=(rel[0]*(-op[0]/sLen)+rel[1]*(-op[1]/sLen)+rel[2]*(-op[2]/sLen))/dist;
      const elong=Math.acos(Math.max(-1,Math.min(1,cosE)))*180/Math.PI;
      const vis=elong>=S.elongVis,mid=elong>=S.elongMid;

      const tLen=Math.hypot(tp[0],tp[1],tp[2]);
      const cosP=Math.max(-1,Math.min(1,(-tp[0]/tLen)*(-rel[0]/dist)+(-tp[1]/tLen)*(-rel[1]/dist)+(-tp[2]/tLen)*(-rel[2]/dist)));
      const phase=(1+Math.cos(Math.acos(cosP)))/2;
      const B=(ph.R*ph.R*ph.A*phase)/(dist*dist);
      const bn=Math.min(1,B/maxBForTrack);

      const px=t*pixPerDay;
      const py=yBase+TRACK_H*.38*(1-bn*1.5);
      const col=mid?ph.col:vis?ph.col+'88':'transparent';

      if(t>0&&vis){
        tlX.beginPath();tlX.moveTo(prevX,prevY);tlX.lineTo(px,py);
        tlX.strokeStyle=mid?ph.col+'cc':ph.col+'55';tlX.lineWidth=mid?1.5:.8;tlX.stroke();
      }
      prevX=px;prevY=py;prevVis=vis;
    }

    tlX.strokeStyle='rgba(100,130,200,.08)';tlX.lineWidth=.4;
    tlX.beginPath();tlX.moveTo(0,(ti+1)*TRACK_H);tlX.lineTo(CW,(ti+1)*TRACK_H);tlX.stroke();
  });

  // Current time cursor
  const tx=S.t*pixPerDay;
  tlX.beginPath();tlX.moveTo(tx,0);tlX.lineTo(tx,CH);
  tlX.strokeStyle='rgba(212,150,26,.85)';tlX.lineWidth=1.5;tlX.stroke();
  wrap.scrollLeft=Math.max(0,tx-wrap.clientWidth/2);
}

