// ── SWIPEABLE CARD ───────────────────────────────────────────────────────────
function SwipeCard({ card, onSwipe, isTop, stackIndex }) {
const theme = TYPE_THEME[card.primaryType] || TYPE_THEME.Normal;
const [drag, setDrag] = useState({ x: 0, y: 0, dragging: false });
const [expanded, setExpanded] = useState(false);
const [imgError, setImgError] = useState(false);
const [exiting, setExiting] = useState(null); // “left” | “right” | null
const startPos = useRef(null);
const cardRef = useRef(null);

const rotation = drag.x * 0.08;
const likeOpacity = clamp(drag.x / 80, 0, 1);
const nopeOpacity = clamp(-drag.x / 80, 0, 1);

// Touch / mouse handlers
const onPointerDown = (e) => {
if (expanded) return;
startPos.current = { x: e.clientX || e.touches?.[0]?.clientX, y: e.clientY || e.touches?.[0]?.clientY };
setDrag(d => ({ …d, dragging: true }));
};

const onPointerMove = useCallback((e) => {
if (!drag.dragging || !startPos.current) return;
const cx = e.clientX || e.touches?.[0]?.clientX;
const cy = e.clientY || e.touches?.[0]?.clientY;
setDrag(d => ({ …d, x: cx - startPos.current.x, y: cy - startPos.current.y }));
}, [drag.dragging]);

const onPointerUp = useCallback(() => {
if (!drag.dragging) return;
const threshold = 100;
if (drag.x > threshold) triggerSwipe(“right”);
else if (drag.x < -threshold) triggerSwipe(“left”);
else setDrag({ x: 0, y: 0, dragging: false });
startPos.current = null;
}, [drag]);

const triggerSwipe = (direction) => {
setExiting(direction);
setTimeout(() => onSwipe(direction, card), 400);
};

useEffect(() => {
if (drag.dragging) {
window.addEventListener(“mousemove”, onPointerMove);
window.addEventListener(“mouseup”, onPointerUp);
window.addEventListener(“touchmove”, onPointerMove);
window.addEventListener(“touchend”, onPointerUp);
return () => {
window.removeEventListener(“mousemove”, onPointerMove);
window.removeEventListener(“mouseup”, onPointerUp);
window.removeEventListener(“touchmove”, onPointerMove);
window.removeEventListener(“touchend”, onPointerUp);
};
}
}, [drag.dragging, onPointerMove, onPointerUp]);

const tx = exiting === “right” ? 800 : exiting === “left” ? -800 : drag.x;
const ty = exiting ? -200 : drag.y * 0.4;
const rot = exiting === “right” ? 30 : exiting === “left” ? -30 : rotation;

return (
<div
ref={cardRef}
onMouseDown={onPointerDown}
onTouchStart={onPointerDown}
onClick={() => !drag.x && setExpanded(e => !e)}
style={{
position: “absolute”,
width: “min(380px, 92vw)”,
cursor: drag.dragging ? “grabbing” : “grab”,
userSelect: “none”,
touchAction: “none”,
zIndex: isTop ? 10 : 10 - stackIndex,
transform: `translate(${tx}px, ${ty}px) rotate(${rot}deg) scale(${isTop ? 1 : 1 - stackIndex * 0.04}) translateY(${stackIndex * 12}px)`,
transition: drag.dragging ? “none” : exiting ? “transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94)” : “transform 0.35s cubic-bezier(0.34,1.56,0.64,1)”,
borderRadius: 20,
overflow: “hidden”,
boxShadow: isTop
? `0 24px 80px rgba(0,0,0,0.6), 0 0 40px ${theme.glow}44`
: `0 8px 30px rgba(0,0,0,0.4)`,
}}
>
