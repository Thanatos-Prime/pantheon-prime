const computeMI = (scores) => {
const bad  = [“proxy”, “extern”, “lockin”, “info”].reduce((s, k) => s + (scores[k] || 0), 0);
const good = [“exit”, “timescale”].reduce((s, k) => s + (scores[k] || 0), 0);
return Math.max(0, Math.min(20, bad - good));
};

