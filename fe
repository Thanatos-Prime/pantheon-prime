🧪 Example usage

from field_engine.core.ontology import *

graph = FieldGraph()

# Create nodes
store = Node(
    node_id="store_1",
    node_type=NodeType.PLACE,
    attributes={"category": "coffee", "sqft": 2000},
    position=Position(lat=36.85, lon=-76.29)
)

gym = Node(
    node_id="gym_1",
    node_type=NodeType.PLACE,
    attributes={"category": "fitness"}
)

graph.add_node(store)
graph.add_node(gym)

# Connect them
edge = Edge(
    edge_id="e1",
    source_id="store_1",
    target_id="gym_1",
    edge_type=EdgeType.COMPLEMENTS,
    weight=0.8
)

graph.add_edge(edge)

# Add flow
flow = Flow(
    flow_id="f1",
    flow_type=FlowType.PEOPLE,
    source="gym_1",
    target="store_1",
    magnitude=120
)

graph.add_flow(flow)

# Validate
valid, errors = validate_graph(graph)
print(valid, errors)


