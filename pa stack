6. Database Schema

A minimal SQL version.

users

CREATE TABLE users (
  id TEXT PRIMARY KEY,
  display_name TEXT NOT NULL,
  trust_score REAL NOT NULL DEFAULT 0.5,
  credit_balance REAL NOT NULL DEFAULT 0,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

entities

CREATE TABLE entities (
  id TEXT PRIMARY KEY,
  type TEXT NOT NULL,
  name TEXT NOT NULL,
  tags TEXT,
  active BOOLEAN NOT NULL DEFAULT 1
);

comparison_events

CREATE TABLE comparison_events (
  id TEXT PRIMARY KEY,
  user_id TEXT NOT NULL,
  left_entity_id TEXT NOT NULL,
  right_entity_id TEXT NOT NULL,
  chosen_entity_id TEXT NOT NULL,
  confidence REAL,
  decision_time_ms INTEGER,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY(user_id) REFERENCES users(id)
);

binding_records

CREATE TABLE binding_records (
  id TEXT PRIMARY KEY,
  source_event_id TEXT NOT NULL,
  subject_id TEXT NOT NULL,
  object_a_id TEXT NOT NULL,
  object_b_id TEXT NOT NULL,
  relation TEXT NOT NULL,
  winner_id TEXT NOT NULL,
  traceable BOOLEAN NOT NULL DEFAULT 1
);

preference_ratings

CREATE TABLE preference_ratings (
  user_id TEXT NOT NULL,
  entity_id TEXT NOT NULL,
  rating REAL NOT NULL DEFAULT 1500,
  uncertainty REAL NOT NULL DEFAULT 0.25,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (user_id, entity_id)
);

output_artifacts

CREATE TABLE output_artifacts (
  id TEXT PRIMARY KEY,
  user_id TEXT NOT NULL,
  type TEXT NOT NULL,
  summary_json TEXT NOT NULL,
  derived_from_json TEXT NOT NULL,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

credit_events

CREATE TABLE credit_events (
  id TEXT PRIMARY KEY,
  user_id TEXT NOT NULL,
  source_artifact_id TEXT NOT NULL,
  impact_score REAL NOT NULL,
  trust_weight REAL NOT NULL,
  credit_delta REAL NOT NULL,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

