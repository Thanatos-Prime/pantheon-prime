export default async function handler(req, res) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Method not allowed" });
  }

  const {
    systemDesc = "",
    actors = [],
    constraints = [],
    edges = [],
    simResult = null,
  } = req.body || {};

  const actorLines = actors
    .map(
      (a) =>
        `${a.name || "Unnamed"}: horizon=${a.horizon}, lockin=${a.lockin}/5, infoAdvantage=${a.infoAdvantage}/5, externalities=${a.externalities}/5, rewardWeight=${a.rewardWeight}`
    )
    .join("\n");

  const constraintLines = constraints
    .map((c) => `[${c.type}] ${c.label} (impact ${c.impact}/5)`)
    .join("\n");

  const eqSummary = simResult?.equilibrium
    ? `Stable ${simResult.equilibrium.type} equilibrium. Avg payoff ${simResult.equilibrium.avgPayoff}. Trapped: ${simResult.equilibrium.trapped.join(", ") || "none"}.`
    : simResult?.collapseDetected
    ? "No convergence detected. System cycling or collapsing."
    : simResult?.attractors?.length > 0
    ? `Bistable: ${simResult.attractors
        .map((a) => `${a.label} (${a.actors.join(", ")})`)
        .join(" | ")}`
    : "Simulation inconclusive.";

  const prompt = `You are the Incentive Field Engine (IFE v1.0) of PantheonOS.

Core doctrine: Systems are not controlled by rules alone. They are controlled by what gets rewarded, punished, delayed, hidden, subsidized, or made legible. Incentives are field geometry. Actors move along gradients. System design is terrain-shaping.

SYSTEM:
${systemDesc}

ACTORS:
${actorLines}

CONSTRAINTS:
${constraintLines || "(none defined)"}

SIMULATION RESULT:
${eqSummary}

Respond ONLY with valid JSON. No markdown fences. No text outside the JSON object.
{
  "fieldDiagnosis": "2-3 sentence description of the incentive field geometry — what terrain has been shaped, who flows downhill, who is trapped uphill",
  "equilibriumInterpretation": "what the simulation convergence (or lack of it) reveals about the system’s attractor state",
  "misalignments": [
    { "pattern": "one of: Reward-Cost Separation, Time Horizon Mismatch, Proxy Capture, Lock-in Trap, Information Asymmetry", "actors": "specific actors", "mechanism": "how it operates" }
  ],
  "collapseVectors": ["specific path by which this system could destabilize or collapse"],
  "steeringOptions": [
    { "operator": "one of: Reward Rewrite, Cost Reinternalization, Delay Injection, Visibility Correction, Exit Restoration, Positive-Sum Reframe", "intervention": "specific action", "expectedEffect": "what changes in the field geometry", "risk": "unintended consequence" }
  ],
  "positiveSum": "one concrete redesign that makes cooperation pay more than extraction in this system",
  "pantheonVerdict": "one sentence: what Pantheon says about this system"
}`;

  try {
    const apiRes = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": process.env.ANTHROPIC_API_KEY,
        "anthropic-version": "2023-06-01",
      },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1200,
        messages: [{ role: "user", content: prompt }],
      }),
    });

    if (!apiRes.ok) {
      const errText = await apiRes.text().catch(() => "");
      return res
        .status(apiRes.status)
        .json({ error: `Anthropic error: ${errText || apiRes.statusText}` });
    }

    const data = await apiRes.json();
    const raw = (data.content || []).map((b) => b.text || "").join("").trim();

    const clean = raw
      .replace(/^```json\s*/i, "")
      .replace(/^```\s*/i, "")
      .replace(/\s*```$/i, "")
      .trim();

    let parsed;
    try {
      parsed = JSON.parse(clean);
    } catch {
      const m = clean.match(/\{[\s\S]*\}/);
      if (!m) {
        return res.status(500).json({ error: "Model returned invalid JSON." });
      }
      parsed = JSON.parse(m[0]);
    }

    return res.status(200).json({
      fieldDiagnosis:
        typeof parsed.fieldDiagnosis === "string" ? parsed.fieldDiagnosis : "",
      equilibriumInterpretation:
        typeof parsed.equilibriumInterpretation === "string"
          ? parsed.equilibriumInterpretation
          : "",
      misalignments: Array.isArray(parsed.misalignments)
        ? parsed.misalignments
        : [],
      collapseVectors: Array.isArray(parsed.collapseVectors)
        ? parsed.collapseVectors
        : [],
      steeringOptions: Array.isArray(parsed.steeringOptions)
        ? parsed.steeringOptions
        : [],
      positiveSum:
        typeof parsed.positiveSum === "string" ? parsed.positiveSum : "",
      pantheonVerdict:
        typeof parsed.pantheonVerdict === "string"
          ? parsed.pantheonVerdict
          : "",
    });
  } catch (err) {
    return res.status(500).json({
      error: err instanceof Error ? err.message : "Unknown server error",
    });
  }
}

