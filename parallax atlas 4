<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PARALLAX ATLAS v0.3 — Tier-1 Sky Engine</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap');

:root {
–bg: #05070e;
–bg2: #080b14;
–bg3: #0b0f1c;
–panel: #0d1222;
–amber: #d4961a;
–amber-d: rgba(212,150,26,0.25);
–amber-dd: rgba(212,150,26,0.07);
–amber-glow: rgba(212,150,26,0.45);
–green: #3dba6e;
–green-d: rgba(61,186,110,0.2);
–green-dd: rgba(61,186,110,0.06);
–phosphor: #c8e870;
–phosphor-d: rgba(200,232,112,0.15);
–red: #e85030;
–red-d: rgba(232,80,48,0.2);
–ice: #7ab4e0;
–ice-d: rgba(122,180,224,0.15);
–text: #9eacc8;
–text-b: #ccd8ec;
–text-d: rgba(158,172,200,0.4);
–rule: rgba(100,120,180,0.12);
–rule-hi: rgba(160,180,220,0.2);
–myth: #c080ff;
–tab-h: 38px;
–hdr-h: 52px;
–ft-h: 46px;
}

*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;background:var(–bg);}
body{color:var(–text);font-family:‘IBM Plex Mono’,monospace;font-size:11px;position:relative;}

/* ── SCAN-LINE OVERLAY ── */
body::after{
content:’’;position:fixed;inset:0;pointer-events:none;z-index:9999;
background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.06) 2px,rgba(0,0,0,.06) 4px);
}

/* ── STARFIELD ── */
#sf{position:fixed;inset:0;z-index:0;pointer-events:none;}

.root{position:relative;z-index:1;height:100vh;display:grid;grid-template-rows:var(–hdr-h) var(–tab-h) 1fr var(–ft-h);}

/* ══ HEADER ══ */
.hdr{
display:flex;align-items:center;padding:0 24px;gap:28px;
border-bottom:1px solid var(–rule-hi);
background:linear-gradient(90deg,rgba(13,18,34,.98),rgba(8,11,20,.98));
}
.logo{
font-family:‘Playfair Display’,serif;font-size:16px;font-weight:400;
color:var(–text-b);letter-spacing:.18em;white-space:nowrap;
display:flex;flex-direction:column;gap:2px;
}
.logo-sub{font-family:‘IBM Plex Mono’,monospace;font-size:7px;letter-spacing:.4em;color:var(–amber);text-transform:uppercase;}
.vr{width:1px;height:30px;background:var(–rule-hi);}
.ctl{display:flex;flex-direction:column;gap:3px;}
.ctl-lbl{font-size:7px;letter-spacing:.35em;color:var(–text-d);text-transform:uppercase;}
select{
background:rgba(8,11,20,.9);border:1px solid var(–rule-hi);
color:var(–text-b);font-family:‘IBM Plex Mono’,monospace;font-size:10px;
padding:3px 8px;cursor:pointer;outline:none;-webkit-appearance:none;
transition:border-color .15s;
}
select:hover,select:focus{border-color:var(–amber);}
option{background:#080b14;}

.hdr-right{margin-left:auto;display:flex;gap:20px;align-items:center;}
.stat{display:flex;flex-direction:column;align-items:flex-end;gap:1px;}
.stat-v{font-size:14px;color:var(–amber);letter-spacing:.04em;font-variant-numeric:tabular-nums;}
.stat-k{font-size:7px;letter-spacing:.3em;color:var(–text-d);text-transform:uppercase;}

.tier-badge{
font-size:7px;letter-spacing:.3em;color:var(–green);
border:1px solid var(–green-d);padding:3px 8px;background:var(–green-dd);
text-transform:uppercase;white-space:nowrap;
}

/* ══ TABS ══ */
.tabs{
display:flex;align-items:flex-end;padding:0 18px;gap:0;
border-bottom:1px solid var(–rule-hi);background:var(–bg2);
}
.tab{
font-family:‘IBM Plex Mono’,monospace;font-size:8px;letter-spacing:.3em;
text-transform:uppercase;color:var(–text-d);
padding:0 18px;height:36px;display:flex;align-items:center;
cursor:pointer;border-bottom:2px solid transparent;
transition:all .15s;white-space:nowrap;user-select:none;
}
.tab:hover{color:var(–text-b);}
.tab.active{color:var(–amber);border-bottom-color:var(–amber);}

/* ══ CONTENT ══ */
.content{overflow:hidden;}
.pane{display:none;height:100%;overflow:hidden;}
.pane.active{display:block;}

/* ── shared sidebar layout ── */
.tri-grid{display:grid;height:100%;grid-template-columns:290px 1fr 290px;overflow:hidden;}
.duo-grid{display:grid;height:100%;grid-template-columns:1fr 380px;overflow:hidden;}

.col{
overflow-y:auto;padding:14px;
display:flex;flex-direction:column;gap:10px;
}
.col-border-r{border-right:1px solid var(–rule);}
.col-border-l{border-left:1px solid var(–rule);}

.col-hd{
font-size:7px;letter-spacing:.4em;color:var(–text-d);text-transform:uppercase;
padding-bottom:8px;border-bottom:1px solid var(–rule);margin-bottom:2px;
}

/* ── planet cards ── */
.pc{
border:1px solid var(–rule);padding:10px;cursor:pointer;
transition:all .15s;position:relative;
}
.pc:hover{border-color:var(–rule-hi);}
.pc.sel{border-color:var(–amber-d);background:var(–amber-dd);}
.pc-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.pc-name{font-family:‘Playfair Display’,serif;font-size:14px;color:var(–text-b);}
.pdot{width:7px;height:7px;border-radius:50%;}
.mr{display:flex;justify-content:space-between;align-items:center;padding:1.5px 0;border-top:1px solid rgba(100,120,180,.05);}
.mk{font-size:7px;letter-spacing:.12em;color:var(–text-d);}
.mv{font-size:9px;color:var(–text-b);font-variant-numeric:tabular-nums;}
.vbar{height:1.5px;background:rgba(100,120,180,.1);margin-top:5px;position:relative;}
.vfill{position:absolute;left:0;top:0;height:100%;transition:width .4s;}
.badge{
display:inline-block;font-size:6px;letter-spacing:.2em;
padding:1px 5px;border:1px solid;margin-top:4px;text-transform:uppercase;
}
.badge.int{color:var(–red);border-color:var(–red-d);background:rgba(232,80,48,.05);}
.badge.ext{color:var(–green);border-color:var(–green-d);background:var(–green-dd);}
.badge.mid{color:var(–phosphor);border-color:var(–phosphor-d);background:rgba(200,232,112,.05);}

/* ── central canvas area ── */
.canvas-center{
display:flex;flex-direction:column;align-items:center;justify-content:center;
position:relative;overflow:hidden;
}
canvas.main{display:block;}
.c-label{
position:absolute;font-size:7px;letter-spacing:.35em;color:var(–text-d);
text-transform:uppercase;pointer-events:none;
}
.c-label.top{top:10px;left:50%;transform:translateX(-50%);}
.c-label.bot{bottom:10px;left:50%;transform:translateX(-50%);}

/* ══ DELTA TAB ══ */
#pane-delta{overflow-y:auto;}
.delta-layout{
display:grid;grid-template-columns:1fr 420px;
height:100%;overflow:hidden;
}
.delta-chart-col{
display:flex;flex-direction:column;align-items:center;justify-content:center;
padding:20px;border-right:1px solid var(–rule);
gap:16px;
}
.delta-info-col{overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;}

.sim-bar-row{display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid var(–rule);}
.sim-name{font-family:‘Playfair Display’,serif;font-size:13px;color:var(–text-b);width:80px;flex-shrink:0;}
.sim-track{flex:1;height:2px;background:rgba(100,120,180,.12);position:relative;}
.sim-fill{position:absolute;left:0;top:0;height:100%;transition:width .5s;}
.sim-val{font-size:9px;color:var(–amber);width:42px;text-align:right;font-variant-numeric:tabular-nums;}
.sim-note{font-size:8px;color:var(–text-d);font-style:italic;}

/* ══ CULTURE TAB ══ */
#pane-culture{overflow-y:auto;}
.culture-doc{max-width:860px;margin:0 auto;padding:28px 32px;}
.doc-title{
font-family:‘Playfair Display’,serif;font-size:26px;font-weight:400;
color:var(–text-b);letter-spacing:.06em;
border-bottom:1px solid var(–rule-hi);padding-bottom:14px;margin-bottom:20px;
}
.doc-section{margin-bottom:36px;}
.doc-h2{
font-family:‘Playfair Display’,serif;font-size:14px;font-weight:400;
color:var(–amber);letter-spacing:.08em;margin-bottom:8px;margin-top:18px;
font-style:italic;
}
.doc-body{
font-family:‘IBM Plex Mono’,monospace;font-size:11px;line-height:1.9;
color:var(–text);max-width:740px;
}
.doc-body em{color:var(–myth);font-style:italic;}
.doc-body strong{color:var(–text-b);}
.doc-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px;}
.doc-card{
border:1px solid var(–rule);padding:12px;
background:rgba(13,18,34,.5);
}
.doc-card-title{font-family:‘Playfair Display’,serif;font-size:11px;color:var(–amber);margin-bottom:6px;font-style:italic;}
.doc-card-body{font-size:10px;line-height:1.75;color:var(–text-d);}

.field-report{
border:1px solid var(–amber-d);padding:14px 16px;
background:var(–amber-dd);margin:14px 0;
}
.field-report-lbl{font-size:7px;letter-spacing:.35em;color:var(–amber);text-transform:uppercase;margin-bottom:6px;}
.field-report-body{font-size:10px;line-height:1.8;color:var(–text);font-style:italic;}

.data-table{width:100%;border-collapse:collapse;margin-top:10px;font-size:9px;}
.data-table th{text-align:left;padding:4px 8px;font-size:7px;letter-spacing:.25em;color:var(–text-d);border-bottom:1px solid var(–rule-hi);}
.data-table td{padding:4px 8px;border-bottom:1px solid var(–rule);color:var(–text-b);font-variant-numeric:tabular-nums;}
.data-table tr:last-child td{border-bottom:none;}

/* ══ PANTHEON TAB ══ */
#pane-pantheon{overflow-y:auto;}
.pantheon-grid{
display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
gap:14px;padding:16px;
}
.deity{
border:1px solid var(–rule);padding:16px;
background:var(–bg3);transition:all .2s;
position:relative;overflow:hidden;
}
.deity::before{
content:’’;position:absolute;top:0;left:0;right:0;height:1px;
transition:opacity .2s;opacity:0;
}
.deity:hover{border-color:var(–rule-hi);}
.deity:hover::before{opacity:1;}
.deity-sym{font-size:28px;line-height:1;margin-bottom:8px;display:block;}
.deity-name{font-family:‘Playfair Display’,serif;font-size:17px;font-weight:400;color:var(–text-b);margin-bottom:2px;}
.deity-pl{font-size:7px;letter-spacing:.35em;color:var(–myth);text-transform:uppercase;margin-bottom:8px;opacity:.7;}
.deity-title{font-family:‘Playfair Display’,serif;font-style:italic;font-size:11px;color:var(–amber);margin-bottom:8px;}
.deity-lore{font-size:10px;line-height:1.75;color:var(–text-d);border-top:1px solid var(–rule);padding-top:8px;margin-top:6px;}
.deity-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:8px;}
.dtag{font-size:7px;letter-spacing:.18em;border:1px solid var(–amber-d);color:var(–amber);padding:1px 5px;background:var(–amber-dd);}
.deity-fests{margin-top:8px;border-top:1px solid var(–rule);padding-top:6px;}
.feast-item{font-size:9px;color:var(–text-d);padding:1px 0;}

/* ══ TIMELINE TAB ══ */
#pane-timeline{overflow:hidden;display:none;flex-direction:column;}
#pane-timeline.active{display:flex;}
.tl-wrap{flex:1;overflow:auto;}
#tlCanvas{display:block;}
.tl-legend{
display:flex;flex-wrap:wrap;gap:14px;padding:8px 16px;
border-top:1px solid var(–rule);flex-shrink:0;
}
.tll{display:flex;align-items:center;gap:5px;font-size:8px;letter-spacing:.12em;}
.tld{width:8px;height:8px;border-radius:50%;}

/* ══ FOOTER ══ */
.ft{
border-top:1px solid var(–rule-hi);display:flex;align-items:center;
gap:14px;padding:0 18px;background:var(–panel);
}
.ft-lbl{font-size:7px;letter-spacing:.3em;color:var(–text-d);text-transform:uppercase;white-space:nowrap;}
input[type=range]{
flex:1;height:2px;cursor:pointer;accent-color:var(–amber);
background:rgba(100,120,180,.15);border:none;outline:none;-webkit-appearance:none;padding:0;
}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:10px;height:10px;border-radius:0;background:var(–amber);cursor:pointer;}
.ft-t{font-size:11px;color:var(–amber);letter-spacing:.06em;min-width:260px;font-variant-numeric:tabular-nums;}
.spd-grp{display:flex;gap:3px;}
.spd{
background:none;border:1px solid var(–rule);color:var(–text-d);
font-family:‘IBM Plex Mono’,monospace;font-size:8px;padding:4px 8px;
cursor:pointer;transition:all .15s;letter-spacing:.15em;
}
.spd:hover{border-color:var(–rule-hi);color:var(–text-b);}
.spd.on{border-color:var(–amber-d);color:var(–amber);background:var(–amber-dd);}
.ft-btn{
background:none;border:1px solid var(–rule-hi);color:var(–text-b);
font-family:‘IBM Plex Mono’,monospace;font-size:8px;letter-spacing:.2em;
padding:6px 14px;cursor:pointer;transition:all .15s;white-space:nowrap;text-transform:uppercase;
}
.ft-btn:hover{border-color:var(–amber);color:var(–amber);}

/* scrollbar */
::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-track{background:var(–bg);}
::-webkit-scrollbar-thumb{background:var(–rule-hi);}
</style>

