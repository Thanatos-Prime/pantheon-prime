# Graph-level ranking

# —————————————————————————

def rank_by_similarity(
query_node: NodeRecord,
candidates: list[NodeRecord],
weights: Optional[dict[str, float]] = None,
min_score: float = 0.0,
) -> list[SimilarityResult]:
“””
Rank a list of candidate nodes by similarity to a query node.

```
Returns results sorted descending by score, filtered by min_score.
Excludes self-match.
"""
results = []
for candidate in candidates:
    if candidate.id == query_node.id:
        continue
    result = similarity(query_node, candidate, weights)
    if result.score >= min_score:
        results.append(result)

results.sort(key=lambda r: r.score, reverse=True)
return results
```

