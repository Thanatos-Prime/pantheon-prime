// STATS UPDATE
// ═══════════════════════════════════════════════════════════
function updateStats(){
  const op=helioXYZ(S.obs,S.t);
  const sLen=Math.hypot(op[0],op[1],op[2]);
  let vis=0,mid=0;
  BODIES.forEach(n=>{
    if(n===S.obs)return;
    const tp=helioXYZ(n,S.t);
    const rel=[tp[0]-op[0],tp[1]-op[1],tp[2]-op[2]];
    const dist=Math.hypot(rel[0],rel[1],rel[2]);
    const cosE=(rel[0]*(-op[0]/sLen)+rel[1]*(-op[1]/sLen)+rel[2]*(-op[2]/sLen))/dist;
    const elong=Math.acos(Math.max(-1,Math.min(1,cosE)))*180/Math.PI;
    if(elong>=S.elongVis)vis++;if(elong>=S.elongMid)mid++;
  });
  document.getElementById('stObs').textContent=S.obs;
  document.getElementById('stVis').textContent=`${vis}/${BODIES.length-1}`;
  document.getElementById('stMid').textContent=`${mid}/${BODIES.length-1}`;
  const yr=(S.t/365.256).toFixed(2);
  document.getElementById('stT').textContent=`${Math.round(S.t).toLocaleString()} d`;
  document.getElementById('ftT').textContent=`T+${Math.round(S.t).toLocaleString()} d  ·  Year ${yr}  ·  ${S.obs}`;
}

