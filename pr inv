Context assembler

# runtime/context.py
import hashlib
import json

def assemble_context(store, session_id: str, user_input: str) -> dict:
    recent = store.recent_for_session(session_id, limit=8)

    packet = {
        "user_input": user_input,
        "recent_thoughts": recent,
        "doctrine": {
            "identity": "Pantheon Runtime",
            "rules": [
                "Continuity is externalized",
                "Outputs must be inspectable",
                "Prefer invariant-based reasoning"
            ]
        }
    }

    raw = json.dumps(packet, sort_keys=True)
    packet["context_hash"] = hashlib.sha256(raw.encode()).hexdigest()
    return packet


