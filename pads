from dataclasses import dataclass
from typing import Dict, Any, List


@dataclass
class UncertaintyProfile:
    uncertainty: float          # 0.0 - 1.0
    impact: float               # 0.0 - 1.0
    conflict: float             # 0.0 - 1.0
    evidence_quality: float     # 0.0 - 1.0
    novelty: float              # 0.0 - 1.0
    recommended_depth: int
    reasons: List[str]


class UncertaintyEstimator:
    """
    Estimates how much reasoning depth a task deserves.
    """

    def estimate(self, context: Dict[str, Any]) -> UncertaintyProfile:
        uncertainty = self._clamp(context.get("uncertainty", 0.5))
        impact = self._clamp(context.get("impact", 0.5))
        conflict = self._clamp(context.get("conflict", 0.0))
        evidence_quality = self._clamp(context.get("evidence_quality", 0.5))
        novelty = self._clamp(context.get("novelty", 0.5))

        reasons = []

        if uncertainty > 0.7:
            reasons.append("High uncertainty detected")
        if impact > 0.7:
            reasons.append("High-impact decision")
        if conflict > 0.5:
            reasons.append("Internal or external conflict in inputs")
        if evidence_quality < 0.4:
            reasons.append("Weak evidence quality")
        if novelty > 0.7:
            reasons.append("Novel problem structure")

        # Depth goes up with uncertainty, impact, conflict, novelty.
        # Depth goes down with strong evidence quality.
        raw_depth_score = (
            (0.30 * uncertainty) +
            (0.25 * impact) +
            (0.20 * conflict) +
            (0.15 * novelty) +
            (0.10 * (1.0 - evidence_quality))
        )

        if raw_depth_score < 0.30:
            recommended_depth = 1
        elif raw_depth_score < 0.50:
            recommended_depth = 2
        elif raw_depth_score < 0.70:
            recommended_depth = 3
        elif raw_depth_score < 0.85:
            recommended_depth = 4
        else:
            recommended_depth = 5

        return UncertaintyProfile(
            uncertainty=uncertainty,
            impact=impact,
            conflict=conflict,
            evidence_quality=evidence_quality,
            novelty=novelty,
            recommended_depth=recommended_depth,
            reasons=reasons
        )

    @staticmethod
    def _clamp(value: float) -> float:
        return max(0.0, min(1.0, float(value)))


