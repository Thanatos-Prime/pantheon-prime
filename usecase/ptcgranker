function PersonaRadar({ metadata }) {
const eraVotes = metadata.era_votes || {};
const styleVotes = metadata.style_votes || {};
const totalDecisions = metadata.total_decisions || 0;

const topEras = Object.entries(eraVotes)
.sort((a, b) => b[1] - a[1])
.slice(0, 3);

const topStyles = Object.entries(styleVotes)
.sort((a, b) => b[1] - a[1])
.slice(0, 4);

