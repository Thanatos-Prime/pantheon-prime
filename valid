args = parser.parse_args()

if args.path:
    with open(args.path) as f:
        data = yaml.safe_load(f)
    validator = NodeValidator()
    result = validator.validate(data, args.path)
    print(result.explain())
    sys.exit(0 if result.passed else 2)

elif args.corpus:
    records = load_yaml_corpus(args.corpus)
    if not records:
        print(f"No YAML files found in {args.corpus}")
        sys.exit(1)

    known_ids = {r.get("id") for r, _ in records if "id" in r}
    validator = NodeValidator(known_ids=known_ids)

    all_results = []
    for data, path in records:
        result = validator.validate(data, path)
        all_results.append(result)

    total = len(all_results)
    errors = sum(1 for r in all_results if not r.passed)
    canon_ready = sum(1 for r in all_results if r.canon_ready)

    for result in all_results:
        if args.errors_only and result.passed:
            continue
        print(result.explain())
        print()

    print(f"{'='*60}")
    print(f"Total nodes:    {total}")
    print(f"Valid:          {total - errors}")
    print(f"With errors:    {errors}")
    if args.canon_check:
        print(f"Canon-ready:    {canon_ready}")

    sys.exit(0 if errors == 0 else 2)

else:
    parser.print_help()
    sys.exit(1)
