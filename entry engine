10. Minimal scoring rule

For now, keep scoring dead simple.

export interface EntryScore {
  clarity: number;     // 0-1
  reusePotential: number; // 0-1
  specificity: number; // 0-1
  actionability: number; // 0-1
}

export function computeConfidence(score: EntryScore): number {
  const avg =
    (score.clarity +
      score.reusePotential +
      score.specificity +
      score.actionability) / 4;
  return Number(avg.toFixed(2));
}

