class GateDecision(Enum):
    ALLOW = "allow"
    DENY = "deny"
    MODIFY = "modify"
    ESCALATE = "escalate"
    ABSTAIN = "abstain"


class FailureMode(Enum):
    SILENT = "fail-silent"
    SOFT = "fail-soft"
    OPEN = "fail-open"
    LOOP_PROTECTED = "fail-loop-protected"


