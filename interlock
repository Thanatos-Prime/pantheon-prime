def emit_artifact(state: WorkState) -> str:
lines = [
f”# Pantheon Engine Output”,
f”**Session:** {state.session_id}”,
f”**Goal:** {state.goal}”,
f”**Confidence:** {round(state.confidence, 3)}”,
f”**Status:** {state.termination_status}”,
f””,
“## Artifact Plan”,
]
for item in state.artifact_plan or [”(none generated)”]:
lines.append(f”- {item}”)

```
lines += ["", "## Risks Identified"]
for r in state.risks or ["(none)"]:
    lines.append(f"- ⚠️ {r}")

lines += ["", "## Opportunities"]
for o in state.opportunities or ["(none)"]:
    lines.append(f"- ✓ {o}")

lines += ["", "## Open Questions"]
for q in state.open_questions or ["(none)"]:
    lines.append(f"- ? {q}")

lines += ["", "## Assumptions"]
for a in state.assumptions or ["(none)"]:
    lines.append(f"- {a}")

lines += ["", "## Provenance Chain"]
for i, p in enumerate(state.provenance):
    lines.append(f"{i+1}. **{p['role']}** → {p['handoff']} *(confidence: {p['confidence_after']})*")

return "\n".join(lines)
```

