      <div class="mr"><span class="mk">TOP 3 DOMINANTS</span><span class="mv">${myTop3.join(' · ')}</span></div>
      <div class="mr"><span class="mk">INTERIOR BODIES</span><span class="mv" style="color:var(--red)">${interior.join(', ')||'none'}</span></div>
      <div class="mr"><span class="mk">MIDNIGHT WANDERERS</span><span class="mv" style="color:var(--phosphor)">${exterior.join(', ')||'none'}</span></div>
    </div>

    <div style="font-size:7px;letter-spacing:.3em;color:var(--text-d);text-transform:uppercase;margin-bottom:8px;border-bottom:1px solid var(--rule);padding-bottom:6px">Sky Character Analysis</div>

    <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;line-height:1.85;color:var(--text)">
      ${getDeltaNarrative(obs,myMetrics,obsSim)}
