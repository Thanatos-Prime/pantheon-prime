🧪 Minimal pseudo-code

class Wasserpferd:
    def step(self, S, F, alpha, w):
        S_hat = self.predict(F)
        delta = (S_hat - S)
        return S + alpha * delta * w
    def update_confidence(self, w, error):
        return max(0, min(1, w * (1 - error)))

