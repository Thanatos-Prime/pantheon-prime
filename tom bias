from __future__ import annotations

from typing import Dict, Any, List, Tuple


def check_tom_invariants(packet: Dict[str, Any], output_text: str) -> Tuple[List[str], List[str]]:
    passed: List[str] = []
    failed: List[str] = []

    tom_bias = packet.get("tom_bias", {})
    observations = tom_bias.get("observations", [])
    alternatives = tom_bias.get("alternatives", [])
    biases = tom_bias.get("biases", [])

    lowered = output_text.lower()

    if observations:
        passed.append("tom_observation_layer_present")
    else:
        failed.append("missing_observation_layer")

    if alternatives:
        passed.append("alternative_models_present")
    else:
        failed.append("missing_alternative_model")

    if biases:
        if "might" in lowered or "may" in lowered or "likely" in lowered or "could" in lowered:
            passed.append("calibrated_language_present")
        else:
            failed.append("bias_present_without_calibration")
    else:
        passed.append("no_strong_bias_signal")

    if "observation" in lowered or "observed" in lowered or "evidence" in lowered:
        passed.append("observation_inference_distinction_surface")
    else:
        failed.append("missing_observation_inference_distinction")

    return passed, failed


