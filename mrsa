  .bill-summary {
    background: rgba(201,168,76,0.08);
    border-left: 4px solid var(--gold);
    padding: 1.2rem 1.5rem;
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
  }
  .bill-summary strong { color: var(--gold); font-family: 'IBM Plex Mono', monospace; }

  .targets-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  @media(max-width: 800px) { .targets-grid { grid-template-columns: 1fr; } }

  /* DOSSIER CARD */
  .dossier {
    border: 1px solid rgba(244,244,244,0.12);
    background: rgba(244,244,244,0.03);
    position: relative;
    overflow: hidden;
  }
  .dossier::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
  }
  .dossier-wicker::before { background: var(--red); }
  .dossier-johnson::before { background: var(--gold); }

  .dossier-header {
    padding: 1.5rem 1.5rem 1rem;
    border-bottom: 1px solid rgba(244,244,244,0.08);
  }
  .dossier-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--steel);
    margin-bottom: 0.4rem;
  }
  .dossier-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .dossier-wicker .dossier-name { color: var(--red); }
  .dossier-johnson .dossier-name { color: var(--gold); }
  .dossier-subtitle {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: var(--steel);
    margin-top: 0.3rem;
  }

  .dossier-body { padding: 1.5rem; }

  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--steel);
    margin-bottom: 0.6rem;
    margin-top: 1.4rem;
    text-transform: uppercase;
  }
  .section-label:first-child { margin-top: 0; }

  .objection-block {
    background: rgba(200,16,46,0.08);
    border-left: 3px solid var(--red);
    padding: 0.8rem 1rem;
    font-size: 0.88rem;
    font-style: italic;
    margin-bottom: 0.5rem;
