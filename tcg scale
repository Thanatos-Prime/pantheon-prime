from __future__ import annotations

import hashlib
from collections import defaultdict
from typing import Dict, Any, List

import numpy as np


VECTOR_SIZE = 24
LEARNING_RATE = 0.05
FEATURE_SCALE = 0.20


def sigmoid(x: float) -> float:
    return 1.0 / (1.0 + np.exp(-np.clip(x, -20, 20)))


def normalize_dwell(ms: int) -> float:
    return min(ms / 3000.0, 1.0)


def random_vector() -> np.ndarray:
    return np.random.normal(0, 0.1, VECTOR_SIZE)


def stable_hash(text: str) -> int:
    digest = hashlib.sha256(text.encode("utf-8")).hexdigest()
    return int(digest[:16], 16)


def feature_vector(features: Dict[str, Any]) -> np.ndarray:
    vec = np.zeros(VECTOR_SIZE, dtype=float)

    for key, value in sorted(features.items()):
        token = f"{key}={value}"
        idx = stable_hash(token) % VECTOR_SIZE
        sign = 1.0 if stable_hash("sign:" + token) % 2 == 0 else -1.0
        vec[idx] += sign

    norm = np.linalg.norm(vec)
    if norm > 0:
        vec = vec / norm

    return vec


class PreferenceEngine:
    def __init__(self) -> None:
        self.user_vectors: Dict[str, np.ndarray] = defaultdict(random_vector)
        self.item_vectors: Dict[str, np.ndarray] = defaultdict(random_vector)
        self.user_event_counts: Dict[str, int] = defaultdict(int)
        self.user_domain_counts: Dict[str, Dict[str, int]] = defaultdict(lambda: defaultdict(int))

    def item_representation(self, item_id: str, features: Dict[str, Any]) -> np.ndarray:
        base = self.item_vectors[item_id]
        feat = feature_vector(features)
        return base + FEATURE_SCALE * feat

    def score(self, user_id: str, item_id: str, item_features: Dict[str, Any] | None = None) -> float:
        if item_features is None:
            item_features = {}
        u = self.user_vectors[user_id]
        i = self.item_representation(item_id, item_features)
        return float(np.dot(u, i))

    def preference_prob(
        self,
        user_id: str,
        item_a: str,
        item_b: str,
        item_a_features: Dict[str, Any] | None = None,
        item_b_features: Dict[str, Any] | None = None,
    ) -> float:
        sa = self.score(user_id, item_a, item_a_features or {})
        sb = self.score(user_id, item_b, item_b_features or {})
        return sigmoid(sa - sb)

    def event_weight(self, confidence: float, dwell_ms: int) -> float:
        return 0.5 * confidence + 0.5 * normalize_dwell(dwell_ms)

    def update(
        self,
        user_id: str,
        item_a: str,
        item_b: str,
        selected: str,
        confidence: float = 0.5,
        dwell_ms: int = 1000,
        domain: str = "default",
        item_a_features: Dict[str, Any] | None = None,
        item_b_features: Dict[str, Any] | None = None,
    ) -> Dict[str, float]:
        item_a_features = item_a_features or {}
        item_b_features = item_b_features or {}

        if selected not in {item_a, item_b}:
            raise ValueError("selected must equal item_a or item_b")

        weight = self.event_weight(confidence, dwell_ms)

        u_vec = self.user_vectors[user_id]
        a_vec = self.item_representation(item_a, item_a_features)
        b_vec = self.item_representation(item_b, item_b_features)

        prob = sigmoid(float(np.dot(u_vec, a_vec - b_vec)))
        target = 1.0 if selected == item_a else 0.0
        error = (target - prob) * weight

        self.user_vectors[user_id] = u_vec + LEARNING_RATE * error * (a_vec - b_vec)
        self.item_vectors[item_a] = self.item_vectors[item_a] + LEARNING_RATE * error * u_vec
        self.item_vectors[item_b] = self.item_vectors[item_b] - LEARNING_RATE * error * u_vec

        self.user_event_counts[user_id] += 1
        self.user_domain_counts[user_id][domain] += 1

        return {
            "prob_item_a": prob,
            "target": target,
            "weight": weight,
            "error": error,
        }

    def user_profile(self, user_id: str) -> Dict[str, Any]:
        return {
            "user_id": user_id,
            "vector": self.user_vectors[user_id].round(6).tolist(),
            "events_seen": self.user_event_counts[user_id],
            "domain_counts": dict(self.user_domain_counts[user_id]),
        }

    def all_user_vectors(self) -> Dict[str, List[float]]:
        return {
            user_id: vec.tolist()
            for user_id, vec in self.user_vectors.items()
        }

    def similarity(self, item_x: str, item_y: str) -> float:
        a = self.item_vectors[item_x]
        b = self.item_vectors[item_y]
        denom = float(np.linalg.norm(a) * np.linalg.norm(b)) + 1e-8
        return float(np.dot(a, b) / denom)

