14. Decision Matrix

def post_capture_route(pattern):
    if pattern.hazard_level > 0.8 and pattern.antidote_potential > 0.6:
        return "FORGE_ANTIDOTE"
    elif pattern.salvage_value > 0.7:
        return "REPURPOSE"
    elif pattern.meta_pattern_density > 0.7:
        return "ABSTRACT_TO_META_PATTERN"
    elif pattern.hazard_level > 0.8:
        return "WARNING_ARCHIVE"
    else:
        return "COMPOST"


