Make governance use live reputation

In app/main.py, replace the current /governance/aggregate endpoint with this version so it can pull from the ledger when a source already exists there:

:::writing{variant=“standard” id=“31851”}

@app.post("/governance/aggregate")
def governance_aggregate(request: GovernanceRequest):
    engine = SignalGovernanceEngine()

    exported = _reputation_ledger.export_sources_for_governance()

    for source in request.sources:
        ledger_data = exported.get(source.source_id, {})
        engine.register_source(
            SignalSource(
                source_id=source.source_id,
                source_type=source.source_type,
                predictive_accuracy=ledger_data.get("predictive_accuracy", source.predictive_accuracy),
                consistency=ledger_data.get("consistency", source.consistency),
                stake=ledger_data.get("stake", source.stake),
                expertise=ledger_data.get("expertise", source.expertise),
                manipulation_risk=ledger_data.get("manipulation_risk", source.manipulation_risk),
                volume=ledger_data.get("volume", source.volume),
            )
        )

    votes = [
        SignalVote(
            source_id=v.source_id,
            score=v.score,
            confidence=v.confidence,
            personalization_alignment=v.personalization_alignment,
        )
        for v in request.votes
    ]

    invariants = InvariantReport(
        reversibility_ok=request.invariants.get("reversibility_ok", True),
        transparency_ok=request.invariants.get("transparency_ok", True),
        anti_gaming_ok=request.invariants.get("anti_gaming_ok", True),
        consent_ok=request.invariants.get("consent_ok", True),
        coherence_ok=request.invariants.get("coherence_ok", True),
    )

    return engine.aggregate(votes, invariants=invariants)

