from dataclasses import dataclass
def clamp(x: float, lo: float = 0.0, hi: float = 1.0) -> float:
    return max(lo, min(hi, x))
@dataclass
class TrustState:
    alpha: float = 0.25      # commitment / action force
    w: float = 0.50          # validated trust
    reversibility: float = 0.75
    last_error: float = 0.0
class SpeedOfTrustEngine:
    """
    PantheonOS Speed of Trust Engine v1.0
    Principle:
    Move at the speed of validated confidence.
    velocity = alpha * w
    """
    def __init__(self, state: TrustState | None = None):
        self.state = state or TrustState()
    def velocity(self) -> float:
        return self.state.alpha * self.state.w
    def update_from_feedback(
        self,
        predicted: float,
        actual: float,
        tolerance: float = 1.0,
    ) -> TrustState:
        error = abs(predicted - actual) / max(tolerance, 1e-9)
        error = clamp(error)
        success = 1.0 - error
        # Trust rises slowly, falls faster.
        if success >= 0.75:
            self.state.w = clamp(self.state.w + 0.08 * success)
        else:
            self.state.w = clamp(self.state.w - 0.18 * error)
        self.state.last_error = error
        return self.state
    def apply_key(self, key: str) -> TrustState:
        key = key.upper()
        if key == "W":
            # Advance, but capped by trust and reversibility.
            self.state.alpha = clamp(
                self.state.alpha + 0.10 * self.state.w * self.state.reversibility
            )
        elif key == "S":
            # Brake / preserve optionality.
            self.state.alpha = clamp(self.state.alpha * 0.55)
        elif key == "A":
            # Explore alternate attractor.
            self.state.w = clamp(self.state.w * 0.85)
            self.state.alpha = clamp(self.state.alpha * 0.80)
        elif key == "D":
            # Refine current attractor, modest confidence increase only.
            self.state.w = clamp(self.state.w + 0.03)
            self.state.alpha = clamp(self.state.alpha + 0.03 * self.state.w)
        return self.state
    def set_reversibility(self, score: float) -> TrustState:
        self.state.reversibility = clamp(score)
        return self.state
    def status(self) -> dict:
        return {
            "alpha": round(self.state.alpha, 3),
            "w": round(self.state.w, 3),
            "velocity": round(self.velocity(), 3),
            "reversibility": round(self.state.reversibility, 3),
            "last_error": round(self.state.last_error, 3),
        }

