        source_id=request.source_id,
        stake=request.stake,
        expertise=request.expertise,
        manipulation_risk=request.manipulation_risk,
    )
    upsert_reputation(record.to_dict())

    return {
        "status": "adjusted",
        "record": record.to_dict(),
    }


@app.get("/reputation/{source_id}")
