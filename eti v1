Minimal React scaffold

import { useMemo, useState } from "react";

type Marker = {
  zone: string;
  type: "pain" | "stress" | "energy" | "injury" | "note";
  intensity: number;
  note?: string;
};

type Snapshot = {
  id: string;
  timestamp: string;
  markers: Marker[];
  globals: {
    energy: number;
    mood: string;
    sleep_quality: number;
  };
};

const BODY_ZONES = [
  "head",
  "neck",
  "chest",
  "abdomen",
  "left_shoulder",
  "right_shoulder",
  "left_arm",
  "right_arm",
  "left_leg",
  "right_leg"
];

export default function ETIDashboard() {
  const [snapshots, setSnapshots] = useState<Snapshot[]>([]);
  const [selectedZone, setSelectedZone] = useState<string | null>(null);
  const [currentType, setCurrentType] = useState<Marker["type"]>("pain");
  const [currentIntensity, setCurrentIntensity] = useState(5);
  const [note, setNote] = useState("");

  const currentSnapshot = useMemo<Snapshot>(() => {
    return {
      id: crypto.randomUUID(),
      timestamp: new Date().toISOString(),
      markers: [],
      globals: {
        energy: 5,
        mood: "neutral",
        sleep_quality: 5
      }
    };
  }, []);

  function saveMarker() {
    if (!selectedZone) return;

    const next: Snapshot = {
      ...currentSnapshot,
      markers: [
        ...currentSnapshot.markers,
        {
          zone: selectedZone,
          type: currentType,
          intensity: currentIntensity,
          note
        }
      ]
    };

    setSnapshots(prev => [next, ...prev]);
    setNote("");
  }

  return (
    <div style={{ display: "grid", gridTemplateColumns: "2fr 1fr", gap: 16 }}>
      <section>
        <h2>ETI Body Twin</h2>
        <div style={{ display: "grid", gridTemplateColumns: "repeat(2, 120px)", gap: 8 }}>
          {BODY_ZONES.map(zone => (
            <button key={zone} onClick={() => setSelectedZone(zone)}>
              {zone}
            </button>
          ))}
        </div>
      </section>

      <aside>
        <h3>Inspector</h3>
        <p>Selected zone: {selectedZone ?? "none"}</p>

        <label>Type</label>
        <select value={currentType} onChange={e => setCurrentType(e.target.value as Marker["type"])}>
          <option value="pain">pain</option>
          <option value="stress">stress</option>
          <option value="energy">energy</option>
          <option value="injury">injury</option>
          <option value="note">note</option>
        </select>

        <label>Intensity</label>
        <input
          type="range"
          min={1}
          max={10}
          value={currentIntensity}
          onChange={e => setCurrentIntensity(Number(e.target.value))}
        />

        <label>Note</label>
        <textarea value={note} onChange={e => setNote(e.target.value)} />

        <button onClick={saveMarker}>Save marker</button>
      </aside>
    </div>
  );
}


