function buildVisPanel(){
  const el=document.getElementById('visPanel');
  el.innerHTML='';

  // Current positions
  const div=document.createElement('div');
  div.innerHTML='<div class="s-title" style="margin-bottom:8px">Current Positions</div>';
  PNAMES.forEach(n=>{
    if(n===STATE.observer) return;
    const deg=getPlanetLongitude(n,STATE.t);
    const h=getZodiacHouse(deg);
    const obsP=xy(STATE.observer,STATE.t),tgP=xy(n,STATE.t);
    const rel=[tgP[0]-obsP[0],tgP[1]-obsP[1]];
    const dist=Math.hypot(rel[0],rel[1]);
    const sunV=[-obsP[0],-obsP[1]];
    const cosE=(rel[0]*sunV[0]+rel[1]*sunV[1])/(dist*Math.hypot(sunV[0],sunV[1]));
    const elong=Math.acos(Math.max(-1,Math.min(1,cosE)))*180/Math.PI;
    const vis=elong>=STATE.elongThresh;
    const p=PLANETS[n];
    const row=document.createElement('div');
    row.className='mrow';
    row.style.padding='3px 0';
    row.innerHTML=`
      <span style="color:${p.col};font-size:9px">${p.sym} ${n}</span>
      <span style="font-size:8px;color:${vis?'var(--teal)':'var(--ember)'}">${h.sym}${h.name.substring(0,3)} ${elong.toFixed(0)}° ${vis?'VIS':'—'}</span>
    `;
    div.appendChild(row);
  });
  el.appendChild(div);

  // Notable conjunctions
  const conj=document.createElement('div');
  conj.innerHTML='<div class="s-title" style="margin-top:14px;margin-bottom:8px">Near Conjunctions</div>';
  const positions=PNAMES.filter(n=>n!==STATE.observer).map(n=>({name:n,deg:getPlanetLongitude(n,STATE.t)}));
  const pairs=[];
  for(let i=0;i<positions.length;i++)for(let j=i+1;j<positions.length;j++){
    const diff=Math.abs(positions[i].deg-positions[j].deg);
    const ang=Math.min(diff,360-diff);
    if(ang<15) pairs.push({a:positions[i].name,b:positions[j].name,ang:ang.toFixed(1)});
  }
  if(pairs.length){
    pairs.sort((a,b)=>a.ang-b.ang).slice(0,3).forEach(pair=>{
      const r=document.createElement('div');r.className='mrow';r.style.padding='3px 0';
      r.innerHTML=`<span style="font-size:8px">${PLANETS[pair.a].sym}${pair.a.substring(0,3)} — ${PLANETS[pair.b].sym}${pair.b.substring(0,3)}</span><span style="font-size:8px;color:var(--gold)">${pair.ang}°</span>`;
      conj.appendChild(r);
    });
  } else {
    conj.innerHTML+='<div style="font-size:9px;color:var(--text-d);font-family:\'EB Garamond\',serif;font-style:italic">No close conjunctions at this time</div>';
  }
  el.appendChild(conj);
}

