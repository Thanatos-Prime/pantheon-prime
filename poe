Execution loop

Outcome loop

while not goal.completed:
    action = select_best_action(goal, context, memory, constraints)

    result = execute(action)

    if result.success:
        update_state(result)
    else:
        record_failure(result)
        alternative = generate_fallback(action, result, memory, constraints)

        if boundary_hit(alternative, constraints):
            escalate_or_stop()
            break

        queue(alternative)


