              <FieldCanvas actors={actors} edges={edges} frames={simResult.frames} currentStep={currentStep} />
              <input type="range" min={0} max={simResult.frames.length - 1} value={currentStep}
                onChange={(e) => { setStep(Number(e.target.value)); setPlaying(false); }}
                style={{ width: "100%", marginTop: 8, accentColor: C.accent }} />
            </Panel>

            <Panel style={{ padding: "12px" }}>
              <div style={{ fontSize: 10, color: C.dim, letterSpacing: "0.1em", marginBottom: 8 }}>
                WELFARE OVER TIME
                <span style={{ marginLeft: 12 }}>
                  {actors.map((a, i) => (
                    <span key={i} style={{ color: ACTOR_COLORS[i % ACTOR_COLORS.length], marginRight: 10, fontSize: 10 }}>
                      * {a.name}
                    </span>
                  ))}
                </span>
              </div>
              <PayoffChart actors={actors} frames={simResult.frames} currentStep={currentStep} />
            </Panel>
          </>
        )}
      </div>
    )}

    {/* ANALYSIS */}
    {tab === "analysis" && (
      <div>
        <h2 style={{ margin: "0 0 14px", fontSize: 13, fontWeight: 700, color: C.accent, letterSpacing: "0.12em", textTransform: "uppercase" }}>
          IFE Analysis — Spider to Hound to Dragonfly to Mirror
        </h2>

        {!simResult && (
          <Panel style={{ textAlign: "center", padding: 32, border: `1px dashed ${C.border}` }}>
            <div style={{ color: C.dim, fontSize: 13 }}>Run the simulation first. IFE analysis requires a simulation result.</div>
          </Panel>
        )}

        {simResult && !aiResult && !aiLoading && !aiError && (
          <Panel style={{ textAlign: "center", padding: 32, border: `1px dashed ${C.border}` }}>
            <div style={{ fontSize: 22, marginBottom: 10 }}>⚡</div>
            <div style={{ color: C.dim, fontSize: 13, marginBottom: 12 }}>Simulation complete. Ready for field analysis.</div>
            <Btn onClick={runAI} color={C.accent}>⚡ Run IFE Analysis</Btn>
          </Panel>
        )}

        {aiLoading && (
          <Panel style={{ textAlign: "center", padding: 40 }}>
            <div style={{ fontSize: 24, marginBottom: 12 }}>⟳</div>
            <div style={{ color: C.dim, fontSize: 13 }}>Running field analysis...</div>
            <div style={{ color: C.accentD, fontSize: 11, marginTop: 6 }}>Mapping gradients · Detecting attractors · Forging redesigns</div>
          </Panel>
        )}

        {aiError && (
          <Panel style={{ borderLeft: `3px solid ${C.red}` }}>
            <div style={{ color: C.red, fontSize: 12, marginBottom: 4 }}>Analysis Error</div>
            <div style={{ color: C.dim, fontSize: 11 }}>{aiError}</div>
          </Panel>
        )}

        {aiResult && (
          <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
            {aiResult.fieldDiagnosis && (
              <Panel style={{ borderLeft: `3px solid ${C.accent}` }}>
                <div style={{ fontSize: 10, color: C.accent, letterSpacing: "0.1em", marginBottom: 8 }}>FIELD DIAGNOSIS</div>
                <p style={{ margin: 0, fontSize: 13, color: C.text, lineHeight: 1.7 }}>{aiResult.fieldDiagnosis}</p>
              </Panel>
            )}
            {aiResult.equilibriumInterpretation && (
              <Panel style={{ borderLeft: `3px solid ${eqColor}` }}>
                <div style={{ fontSize: 10, color: eqColor, letterSpacing: "0.1em", marginBottom: 8 }}>EQUILIBRIUM INTERPRETATION</div>
                <p style={{ margin: 0, fontSize: 13, color: C.text, lineHeight: 1.7 }}>{aiResult.equilibriumInterpretation}</p>
              </Panel>
            )}
            {aiResult.misalignments.length > 0 && (
              <Panel>
                <div style={{ fontSize: 10, color: C.accent, letterSpacing: "0.1em", marginBottom: 10 }}>MISALIGNMENT PATTERNS</div>
                {aiResult.misalignments.map((m, i) => {
                  const pat = MISALIGNMENT_PATTERNS.find((p) => p.label === m.pattern) || MISALIGNMENT_PATTERNS[0];
                  return (
                    <div key={i} style={{ marginBottom: 10, padding: "10px 12px", borderRadius: 4, background: `${pat.color}11`, border: `1px solid ${pat.color}33` }}>
                      <div style={{ display: "flex", gap: 8, alignItems: "center", marginBottom: 4, flexWrap: "wrap" }}>
                        <span>{pat.icon}</span>
                        <span style={{ fontWeight: 700, color: pat.color, fontSize: 12 }}>{m.pattern}</span>
                        {m.actors && <Tag label={m.actors} color={pat.color} small />}
                      </div>
                      <p style={{ margin: 0, fontSize: 11, color: C.dim, lineHeight: 1.5 }}>{m.mechanism}</p>
                    </div>
                  );
                })}
              </Panel>
            )}
            {aiResult.collapseVectors.length > 0 && (
              <Panel style={{ borderLeft: `3px solid ${C.red}` }}>
                <div style={{ fontSize: 10, color: C.red, letterSpacing: "0.1em", marginBottom: 10 }}>COLLAPSE VECTORS</div>
                {aiResult.collapseVectors.map((v, i) => (
                  <div key={i} style={{ display: "flex", gap: 8, marginBottom: 6, alignItems: "flex-start" }}>
                    <span style={{ color: C.red, fontSize: 10, marginTop: 3, flexShrink: 0 }}>◆</span>
                    <span style={{ fontSize: 12, color: C.text, lineHeight: 1.5 }}>{v}</span>
                  </div>
                ))}
              </Panel>
            )}
            {aiResult.steeringOptions.length > 0 && (
              <Panel>
                <div style={{ fontSize: 10, color: C.accent, letterSpacing: "0.1em", marginBottom: 12 }}>STEERING OPTIONS</div>
                {aiResult.steeringOptions.map((s, i) => {
                  const cols = [C.green, C.blue, C.purple];
                  const col  = cols[i % cols.length];
                  return (
                    <div key={i} style={{ marginBottom: 10, padding: "10px 12px", borderRadius: 4, background: `${col}0d`, border: `1px solid ${col}33` }}>
                      <div style={{ fontWeight: 700, color: col, fontSize: 12, marginBottom: 4 }}>{s.operator}</div>
                      <p style={{ margin: "0 0 4px", fontSize: 12, color: C.text, lineHeight: 1.5 }}>{s.intervention}</p>
                      <p style={{ margin: "0 0 2px", fontSize: 11, color: C.dim }}>Expected: {s.expectedEffect}</p>
                      <p style={{ margin: 0, fontSize: 10, color: C.dim }}>Risk: {s.risk}</p>
                    </div>
                  );
                })}
              </Panel>
            )}
            {aiResult.positiveSum && (
              <Panel style={{ borderLeft: `3px solid ${C.teal}` }}>
                <div style={{ fontSize: 10, color: C.teal, letterSpacing: "0.1em", marginBottom: 8 }}>POSITIVE-SUM REDESIGN</div>
                <p style={{ margin: 0, fontSize: 12, color: C.text, lineHeight: 1.6 }}>{aiResult.positiveSum}</p>
              </Panel>
            )}
            {aiResult.pantheonVerdict && (
              <Panel style={{ background: `${C.accent}0d`, borderColor: C.accent }}>
                <div style={{ fontSize: 10, color: C.accent, letterSpacing: "0.1em", marginBottom: 8 }}>PANTHEON VERDICT</div>
                <p style={{ margin: 0, fontSize: 14, color: C.accentL, lineHeight: 1.6, fontStyle: "italic" }}>{aiResult.pantheonVerdict}</p>
              </Panel>
            )}
          </div>
        )}
      </div>
    )}
  </div>

  <style>{`
    input[type=range] { height: 4px; }
    select option { background: #0d1118; }
    textarea::placeholder, input::placeholder { color: #3a4555; }
    * { box-sizing: border-box; }
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: #080b0f; }
    ::-webkit-scrollbar-thumb { background: #1a2230; border-radius: 3px; }
  `}</style>
</div>
