Cleaned core utilities

Here’s a cleaned version of your helpers:

function uid() {
  return Math.random().toString(36).slice(2, 10);
}

function fmtTime(ts: number) {
  return new Date(ts).toLocaleTimeString([], {
    hour: "2-digit",
    minute: "2-digit",
  });
}

function fmtDate(ts: number) {
  return new Date(ts).toLocaleDateString([], {
    month: "short",
    day: "numeric",
  });
}

function computeDelta(curr: any, prev: any) {
  if (!curr || !prev) return [];

  const keyOf = (m: any) => `${m.zone}__${m.type}`;
  const currMap = new Map(curr.markers.map((m: any) => [keyOf(m), m]));
  const prevMap = new Map(prev.markers.map((m: any) => [keyOf(m), m]));
  const allKeys = new Set([...currMap.keys(), ...prevMap.keys()]);

  return [...allKeys]
    .map((key) => {
      const c = currMap.get(key);
      const p = prevMap.get(key);
      const [zone, type] = key.split("__");
      return {
        zone,
        type,
        delta: (c?.intensity ?? 0) - (p?.intensity ?? 0),
      };
    })
    .filter((d) => d.delta !== 0);
}

function findClusters(snapshots: any[]) {
  const counts: Record<string, number> = {};

  snapshots.forEach((s) =>
    s.markers.forEach((m: any) => {
      const key = `${m.zone}__${m.type}`;
      counts[key] = (counts[key] || 0) + 1;
    })
  );

  return Object.entries(counts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 5)
    .map(([key, count]) => {
      const [zone, type] = key.split("__");
      return { zone, type, count };
    });
}


