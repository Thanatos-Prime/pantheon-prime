const [snapshots, setSnapshots] = useState<Snapshot[]>(() => {
  const saved = localStorage.getItem("eti_snapshots");
  return saved ? JSON.parse(saved) : [];
});

useEffect(() => {
  localStorage.setItem("eti_snapshots", JSON.stringify(snapshots));
}, [snapshots]);

const [selectedIndex, setSelectedIndex] = useState(0);

const current = snapshots[selectedIndex];
const previous = snapshots[selectedIndex + 1];

function computeDelta(curr?: Snapshot, prev?: Snapshot) {
  if (!curr || !prev) return [];

  return curr.markers.map(m => {
    const prevMatch = prev.markers.find(p => p.zone === m.zone && p.type === m.type);
    return {
      zone: m.zone,
      type: m.type,
      delta: m.intensity - (prevMatch?.intensity ?? 0)
    };
  });
}


