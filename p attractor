// ── PARTICLE FIELD ──────────────────────────────────────────────────────────
function ParticleField({ stage, width = 400, height = 300 }) {
const canvasRef = useRef(null);
const rafRef = useRef(null);
const timeRef = useRef(0);

useEffect(() => {
const canvas = canvasRef.current;
if (!canvas) return;
const ctx = canvas.getContext(“2d”);
const N = 80;

```
const particles = Array.from({ length: N }, (_, i) => ({
  x: Math.random() * width,
  y: Math.random() * height,
  vx: (Math.random() - 0.5) * 0.8,
  vy: (Math.random() - 0.5) * 0.8,
  phase: Math.random() * Math.PI * 2,
  size: 1 + Math.random() * 2,
  color: DAEMONS[i % DAEMONS.length].color,
}));

const cx = width / 2;
const cy = height / 2;

function draw() {
  timeRef.current += 0.012;
  const t = timeRef.current;
  const coherence = stage / 7;

  ctx.fillStyle = "rgba(4,6,13,0.18)";
  ctx.fillRect(0, 0, width, height);

  // Attractor basin — grows with stage
  if (stage > 2) {
    const r = 60 + coherence * 80;
    const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
    grad.addColorStop(0, `rgba(0,229,255,${0.04 * coherence})`);
    grad.addColorStop(1, "transparent");
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fill();
  }

  particles.forEach((p, i) => {
    // Pull toward center increases with stage
    const dx = cx - p.x;
    const dy = cy - p.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const pull = coherence * 0.015;

    p.vx += dx / Math.max(dist, 1) * pull + noise(t + p.phase, i) * (1 - coherence) * 0.3;
    p.vy += dy / Math.max(dist, 1) * pull + noise(t + p.phase, i * 1.5) * (1 - coherence) * 0.3;

    // Damping increases with governance
    const damp = 0.97 + coherence * 0.01;
    p.vx *= damp;
    p.vy *= damp;

    p.x += p.vx;
    p.y += p.vy;

    // Boundary wrap
    if (p.x < 0) p.x = width;
    if (p.x > width) p.x = 0;
    if (p.y < 0) p.y = height;
    if (p.y > height) p.y = 0;

    // Draw particle
    const alpha = 0.4 + Math.sin(t * 2 + p.phase) * 0.2;
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
    ctx.fillStyle = p.color + Math.floor(alpha * 255).toString(16).padStart(2, "0");
    ctx.fill();

    // Connection lines at high coherence
    if (stage >= 5) {
      particles.forEach((q, j) => {
        if (j <= i) return;
        const d = Math.hypot(p.x - q.x, p.y - q.y);
        const maxD = 60 + coherence * 40;
        if (d < maxD) {
          const a = (1 - d / maxD) * 0.15 * coherence;
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = `rgba(0,229,255,${a})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      });
    }
  });

  // Stage label
  ctx.font = "bold 11px 'Share Tech Mono', monospace";
  ctx.fillStyle = `rgba(0,229,255,${0.5 + coherence * 0.5})`;
  ctx.textAlign = "center";
  ctx.fillText(`STAGE ${stage} — ${ATTRACTOR_STAGES[stage - 1].label.toUpperCase()}`, cx, height - 12);

  rafRef.current = requestAnimationFrame(draw);
}

draw();
return () => cancelAnimationFrame(rafRef.current);
