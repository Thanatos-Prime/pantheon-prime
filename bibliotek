10. Imp API contract

Each Imp should follow this abstract interface:

interface LibraryImp {
  name: string
  purpose: string
  inputs: string[]
  outputs: string[]
  run(payload: any): ImpResult
}

interface ImpResult {
  summary: string
  structured_output: any
  confidence: number
  escalation_required: boolean
  recommended_action?: "store" | "review" | "archive" | "merge"
}


