const skyC=document.getElementById('skyCanvas');
const skyX=skyC.getContext('2d');
const MAX_ORBITAL_RADIUS=39.48; // Pluto

function resizeSky(){
  const cont=skyC.parentElement;
  const sz=Math.min(cont.clientWidth,cont.clientHeight)-20;
  skyC.width=sz; skyC.height=sz;
