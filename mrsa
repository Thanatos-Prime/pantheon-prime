  }
  .rebuttal-block {
    background: rgba(201,168,76,0.06);
    border-left: 3px solid var(--gold);
    padding: 0.8rem 1rem;
    font-size: 0.88rem;
    margin-bottom: 1rem;
    color: rgba(244,244,244,0.9);
