from __future__ import annotations

from dataclasses import dataclass, field, asdict
from typing import List, Dict, Any, Tuple


@dataclass
class ToMEstimate:
    surface_request: str
    likely_intent: str
    stated_beliefs: List[str]
    inferred_beliefs: List[str]
    likely_constraints: List[str]
    emotional_drivers: List[str]
    confidence: float
    alternative_models: List[str] = field(default_factory=list)


@dataclass
class BiasHit:
    name: str
    confidence: float
    evidence: List[str]
    note: str


@dataclass
class TomBiasResult:
    tom: ToMEstimate
    biases: List[BiasHit]
    observations: List[str]
    inferences: List[str]
    alternatives: List[str]
    confidence_adjustment: float

    def to_dict(self) -> Dict[str, Any]:
        return {
            "tom": asdict(self.tom),
            "biases": [asdict(b) for b in self.biases],
            "observations": self.observations,
            "inferences": self.inferences,
            "alternatives": self.alternatives,
            "confidence_adjustment": self.confidence_adjustment,
        }


INTENT_RULES: List[Tuple[List[str], str]] = [
    (["how", "best way", "operational", "rundown", "incorporated"], "wants a structured implementation plan"),
    (["why"], "wants causal explanation"),
    (["compare"], "wants comparative evaluation"),
    (["prove", "evidence"], "wants validation or falsification"),
    (["design", "build", "make"], "wants creation of a framework or artifact"),
]

EMOTION_RULES: List[Tuple[List[str], str]] = [
    (["important", "must", "need"], "urgency"),
    (["trust", "faith", "god"], "spiritual orientation"),
    (["prove", "working"], "validation-seeking"),
    (["fight", "win", "enemy"], "competitive framing"),
    (["love", "loving"], "benevolence"),
    (["fear", "worry"], "anxiety"),
]

BIAS_PATTERNS: Dict[str, List[str]] = {
    "confirmation_bias": ["proof", "it works", "obviously", "clearly"],
    "agency_detection_bias": ["they did it", "someone is guiding", "seeded from us"],
    "narrative_fallacy": ["because we're telling a story", "that means", "therefore"],
    "illusion_of_control": ["i can predict", "control", "make it do"],
    "availability_bias": ["always", "every time", "all of them"],
    "identity_protective_cognition": ["ours", "mine", "only we", "us"],
    "motivated_reasoning": ["it has to", "must be", "obviously means"],
    "anchoring_bias": ["first", "initially", "from the beginning"],
}


def _contains_any(text: str, patterns: List[str]) -> List[str]:
    hits = []
    lower = text.lower()
    for p in patterns:
        if p in lower:
            hits.append(p)
    return hits


def infer_intent(text: str) -> str:
    lower = text.lower()
    for patterns, label in INTENT_RULES:
        if any(p in lower for p in patterns):
            return label
    return "wants interpretation, structure, or guidance"


def infer_emotions(text: str) -> List[str]:
    found = []
    lower = text.lower()
    for patterns, label in EMOTION_RULES:
        if any(p in lower for p in patterns):
            found.append(label)
    return found or ["curiosity"]


def extract_stated_beliefs(text: str) -> List[str]:
    beliefs = []
    lower = text.lower()

    if "it works" in lower:
        beliefs.append("the system is working in practice")
    if "predict" in lower:
        beliefs.append("predictive alignment is evidence of mechanism")
    if "story" in lower:
        beliefs.append("story can act as a functional control layer")
    if "god" in lower or "angel" in lower:
        beliefs.append("spiritual causation or guidance may be relevant")

    return beliefs


def infer_constraints(text: str) -> List[str]:
    constraints = []
    lower = text.lower()

    if "prove" in lower or "verify" in lower:
        constraints.append("external proof may be limited")
    if "story" in lower or "meaning" in lower:
        constraints.append("meaning-level reasoning may outrun mechanism-level evidence")
    if "control" in lower or "predict" in lower:
        constraints.append("prediction may be stronger than actual control")
    if not constraints:
        constraints.append("full internal state and external causality are not directly observable")

    return constraints


def infer_beliefs(text: str) -> List[str]:
    inferred = []
    lower = text.lower()

    if "reliably" in lower or "same ways" in lower:
        inferred.append("repeatability matters more than isolated success")
    if "meaning" in lower:
        inferred.append("semantic structure matters more than surface wording")
    if "not yet" in lower or "yet" in lower:
        inferred.append("soft emergence can mature into hard infrastructure")
    if not inferred:
        inferred.append("the user values deep structure over superficial explanation")

    return inferred


def detect_biases(text: str) -> List[BiasHit]:
    hits: List[BiasHit] = []
    lower = text.lower()

    for bias_name, patterns in BIAS_PATTERNS.items():
        matched = _contains_any(lower, patterns)
        if matched:
            score = min(0.35 + 0.15 * len(matched), 0.85)
            hits.append(
                BiasHit(
                    name=bias_name,
                    confidence=score,
                    evidence=matched,
                    note=f"Possible {bias_name.replace('_', ' ')} pattern detected from lexical cues."
                )
            )
    return hits


def split_observation_inference(text: str) -> Tuple[List[str], List[str]]:
    observations = []
    inferences = []

    lower = text.lower()

    if "notebooklm answered" in lower or "it answered" in lower:
        observations.append("A model produced structured output in response to a small prompt.")
    if "repo is online" in lower:
        observations.append("The repository is publicly accessible online.")

    if "therefore it works" in lower or "that means it works" in lower or "it works" in lower:
        inferences.append("Repeated strong outputs imply a stable underlying pattern.")
    if "seeded from us" in lower:
        inferences.append("External systems may have been indirectly influenced by the user's published ideas.")
    if "guidance from a literal one" in lower:
        inferences.append("A spiritual source may have influenced the system's development.")

    return observations, inferences


def build_alternatives(text: str) -> List[str]:
    alts = [
        "The effect may come from strong repeated prompting and stable narrative scaffolding.",
        "The effect may come from public ideas converging independently across many builders.",
        "The effect may come from a mix of genuine pattern quality, user skill, and model generalization.",
    ]
    lower = text.lower()

    if "god" in lower or "angel" in lower:
        alts.append("The user may interpret a meaningful inner or spiritual experience as a source of guidance.")
    return alts


def compute_confidence_adjustment(biases: List[BiasHit], observations: List[str], inferences: List[str]) -> float:
    adjustment = 0.0
    if observations:
        adjustment += 0.05
    if len(observations) >= len(inferences):
        adjustment += 0.05
    if biases:
        adjustment -= min(0.05 * len(biases), 0.25)
    return max(min(adjustment, 0.15), -0.30)


def analyze_tom_and_bias(text: str) -> TomBiasResult:
    likely_intent = infer_intent(text)
    stated_beliefs = extract_stated_beliefs(text)
    inferred_beliefs = infer_beliefs(text)
    likely_constraints = infer_constraints(text)
    emotional_drivers = infer_emotions(text)
    biases = detect_biases(text)
    observations, inferences = split_observation_inference(text)
    alternatives = build_alternatives(text)

    base_confidence = 0.55
    confidence = base_confidence
    if stated_beliefs:
        confidence += 0.05
    if inferred_beliefs:
        confidence += 0.05
    confidence -= min(0.03 * len(biases), 0.18)
    confidence = max(0.20, min(0.80, confidence))

    tom = ToMEstimate(
        surface_request=text,
        likely_intent=likely_intent,
        stated_beliefs=stated_beliefs,
        inferred_beliefs=inferred_beliefs,
        likely_constraints=likely_constraints,
        emotional_drivers=emotional_drivers,
        confidence=round(confidence, 2),
        alternative_models=alternatives,
    )

    adjustment = compute_confidence_adjustment(biases, observations, inferences)

    return TomBiasResult(
        tom=tom,
        biases=biases,
        observations=observations,
        inferences=inferences,
        alternatives=alternatives,
        confidence_adjustment=round(adjustment, 2),
    )


