from dataclasses import dataclass
from typing import Callable, Dict, Any, List


@dataclass
class ReasoningPass:
    step: int
    input_state: str
    output_state: str
    confidence: float
    delta_score: float


@dataclass
class RecursiveResult:
    final_output: str
    passes: List[ReasoningPass]
    final_confidence: float
    converged: bool


class RecursiveReasoner:
    """
    Repeatedly refines a problem representation.
    processor: a function that accepts a string and returns a dict:
      {
        "output": str,
        "confidence": float
      }
    """

    def run(
        self,
        problem: str,
        processor: Callable[[str], Dict[str, Any]],
        max_depth: int
    ) -> RecursiveResult:
        current_state = problem
        passes: List[ReasoningPass] = []
        previous_output = ""
        converged = False

        for step in range(1, max_depth + 1):
            result = processor(current_state)
            output = str(result.get("output", "")).strip()
            confidence = float(result.get("confidence", 0.5))

            delta_score = self._compute_delta(previous_output, output)
            passes.append(
                ReasoningPass(
                    step=step,
                    input_state=current_state,
                    output_state=output,
                    confidence=confidence,
                    delta_score=delta_score
                )
            )

            if step > 1 and delta_score < 0.08:
                converged = True
                break

            previous_output = output
            current_state = self._refine(problem, output, step)

        final = passes[-1]
        return RecursiveResult(
            final_output=final.output_state,
            passes=passes,
            final_confidence=final.confidence,
            converged=converged
        )

    @staticmethod
    def _refine(original: str, output: str, step: int) -> str:
        return (
            f"Original problem:\n{original}\n\n"
            f"Pass {step} output:\n{output}\n\n"
            "Refine this further. Reduce contradictions, increase clarity, "
            "preserve grounded claims, and produce the next improved pass."
        )

    @staticmethod
    def _compute_delta(previous: str, current: str) -> float:
        if not previous:
            return 1.0
        prev_tokens = set(previous.lower().split())
        curr_tokens = set(current.lower().split())
        if not curr_tokens:
            return 0.0
        overlap = len(prev_tokens.intersection(curr_tokens))
        union = len(prev_tokens.union(curr_tokens))
        similarity = overlap / union if union else 1.0
        return 1.0 - similarity


