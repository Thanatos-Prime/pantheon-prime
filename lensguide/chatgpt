const mainImage = document.getElementById("mainImage");
const overlaySvg = document.getElementById("overlaySvg");
const stepTabs = document.getElementById("stepTabs");
const stepTitle = document.getElementById("stepTitle");
const stepDescription = document.getElementById("stepDescription");
const stepChecklist = document.getElementById("stepChecklist");
const decisionBox = document.getElementById("decisionBox");
const stateTitle = document.getElementById("stateTitle");
const stateSummary = document.getElementById("stateSummary");
const lightPatternOptions = document.getElementById("lightPatternOptions");
const countdownTag = document.getElementById("countdownTag");
const countdownValue = document.getElementById("countdownValue");

let currentStep = 0;
let currentState = "orange_blinking";
let countdownInterval = null;

function renderStepTabs() {
  stepTabs.innerHTML = "";

  graph.steps.forEach((step, index) => {
    const btn = document.createElement("button");
    btn.className = `chip ${index === currentStep ? "active" : ""}`;
    btn.textContent = step.chip;
    btn.onclick = () => {
      currentStep = index;
      render();
    };
    stepTabs.appendChild(btn);
  });
}

function renderLightOptions() {
  const options = [
    { value: "orange_blinking", label: "Orange blinking" },
    { value: "green_solid", label: "Solid green" },
    { value: "unknown", label: "Not sure" },
  ];

  lightPatternOptions.innerHTML = "";

  options.forEach((opt) => {
    const btn = document.createElement("button");
    btn.className = `option ${opt.value === currentState ? "active" : ""}`;
    btn.textContent = opt.label;
    btn.onclick = () => {
      currentState = opt.value;
      currentStep = graph.states[currentState].defaultStep;
      render();
    };
    lightPatternOptions.appendChild(btn);
  });
}

function clearOverlay() {
  overlaySvg.innerHTML = "";
}

function addLabel(x, y, textValue) {
  const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
  text.setAttribute("x", x);
  text.setAttribute("y", y);
  text.textContent = textValue;
  overlaySvg.appendChild(text);
}

function drawOverlay(items) {
  clearOverlay();

  items.forEach((item) => {
    if (item.type === "target" && item.shape === "circle") {
      const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      circle.setAttribute("cx", item.x);
      circle.setAttribute("cy", item.y);
      circle.setAttribute("r", item.r);
      circle.setAttribute("fill", "rgba(124,196,255,0.18)");
      circle.setAttribute("stroke", "#7cc4ff");
      circle.setAttribute("stroke-width", "0.7");
      overlaySvg.appendChild(circle);
      addLabel(item.x + 1.2, item.y - 5.5, item.label);
    }

    if (item.type === "target" && item.shape === "rect") {
      const rect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
      rect.setAttribute("x", item.x);
      rect.setAttribute("y", item.y);
      rect.setAttribute("width", item.w);
      rect.setAttribute("height", item.h);
      rect.setAttribute("rx", "1.5");
      rect.setAttribute("fill", "rgba(124,196,255,0.12)");
      rect.setAttribute("stroke", "#7cc4ff");
      rect.setAttribute("stroke-width", "0.7");
      overlaySvg.appendChild(rect);
      addLabel(item.x, Math.max(item.y - 1.2, 3), item.label);
    }

    if (item.type === "arrow") {
      const [x1, y1, x2, y2, x3, y3] = item.points;
      const path = document.createElementNS("http://www.w3.org/2000/svg", "path");

      let d = `M ${x1} ${y1} L ${x2} ${y2}`;
      if (typeof x3 === "number") d += ` L ${x3} ${y3}`;

      path.setAttribute("d", d);
      path.setAttribute("fill", "none");
      path.setAttribute("stroke", "#9df5c2");
      path.setAttribute("stroke-width", "1");
      path.setAttribute("stroke-linecap", "round");
      path.setAttribute("stroke-linejoin", "round");
      overlaySvg.appendChild(path);

      const head = document.createElementNS("http://www.w3.org/2000/svg", "polygon");
      const endX = typeof x3 === "number" ? x3 : x2;
      const endY = typeof y3 === "number" ? y3 : y2;
      head.setAttribute(
        "points",
        `${endX},${endY} ${endX - 1.4},${endY - 0.6} ${endX - 0.4},${endY - 1.6}`
      );
      head.setAttribute("fill", "#9df5c2");
      overlaySvg.appendChild(head);
    }
  });
}

function renderInfo() {
  const state = graph.states[currentState];
  const step = graph.steps[currentStep];

  stateTitle.textContent = state.title;
  stateSummary.textContent = state.summary;
  stepTitle.textContent = step.title;
  stepDescription.textContent = step.description;

  stepChecklist.innerHTML = "";
  step.checklist.forEach((item) => {
    const li = document.createElement("li");
    li.textContent = item;
    stepChecklist.appendChild(li);
  });

  decisionBox.innerHTML = "";
  step.decision.forEach((item) => {
    const div = document.createElement("div");
    div.className = `decision-item ${item.kind === "warn" ? "warn" : ""}`;
    div.textContent = item.text;
    decisionBox.appendChild(div);
  });
}

function render() {
  renderStepTabs();
  renderLightOptions();
  renderInfo();
  drawOverlay(graph.steps[currentStep].overlay);
}

function beginCountdown() {
  if (countdownInterval) clearInterval(countdownInterval);

  let remaining = 7;
  countdownTag.classList.remove("hidden");
  countdownValue.textContent = remaining;

  countdownInterval = setInterval(() => {
    remaining -= 1;
    countdownValue.textContent = Math.max(remaining, 0);

    if (remaining <= 0) {
      clearInterval(countdownInterval);
      countdownInterval = null;
      countdownTag.classList.add("hidden");
      currentState = "green_solid";
      currentStep = 2;
      render();
    }
  }, 1000);
}

document.getElementById("prevBtn").onclick = () => {
  currentStep = Math.max(currentStep - 1, 0);
  render();
};

document.getElementById("nextBtn").onclick = () => {
  currentStep = Math.min(currentStep + 1, graph.steps.length - 1);
  render();
};

document.getElementById("holdBtn").onclick = beginCountdown;

document.getElementById("imageUpload").addEventListener("change", (event) => {
  const file = event.target.files?.[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = () => {
    mainImage.src = reader.result;
  };
  reader.readAsDataURL(file);
});

document.getElementById("resetImageBtn").onclick = () => {
  mainImage.src = "demo-nespresso.jpeg";
};

render();


