<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PANTHEON — FEDERATION COMMAND</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;700;900&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap');

:root {
–void: #04060a;
–deep: #080c12;
–surface: #0e1520;
–panel: #121b28;
–border: #1a2535;
–border-bright: #2a3f58;
–gold: #d4a843;
–gold-dim: #6b4f18;
–gold-glow: rgba(212,168,67,0.15);
–red: #c0392b;
–red-dim: #5a1510;
–red-glow: rgba(192,57,43,0.2);
–ice: #3ab5d4;
–ice-dim: #0e3a4a;
–green: #27ae60;
–green-dim: #0a2e18;
–amber: #e67e22;
–text: #8a9bb0;
–text-bright: #c8d8e8;
–text-dim: #2a3a4a;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–void);
color: var(–text);
font-family: ‘DM Mono’, monospace;
min-height: 100vh;
overflow-x: hidden;
}

/* Grid background */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image:
linear-gradient(rgba(26,37,53,0.4) 1px, transparent 1px),
linear-gradient(90deg, rgba(26,37,53,0.4) 1px, transparent 1px);
background-size: 40px 40px;
pointer-events: none;
z-index: 0;
}

.app {
position: relative;
z-index: 1;
max-width: 1100px;
margin: 0 auto;
padding: 32px 20px;
}

/* Header */
.header {
display: flex;
align-items: flex-start;
justify-content: space-between;
margin-bottom: 40px;
padding-bottom: 24px;
border-bottom: 1px solid var(–border);
}

.header-left h1 {
font-family: ‘Unbounded’, sans-serif;
font-size: clamp(20px, 3.5vw, 32px);
font-weight: 900;
color: var(–gold);
letter-spacing: -0.02em;
text-shadow: 0 0 40px var(–gold-glow);
line-height: 1;
}

.header-left .sub {
font-size: 10px;
letter-spacing: 0.3em;
color: var(–text-dim);
margin-top: 6px;
text-transform: uppercase;
}

.header-right {
text-align: right;
font-size: 10px;
letter-spacing: 0.2em;
color: var(–text-dim);
line-height: 2;
}

.header-right .live {
color: var(–green);
display: flex;
align-items: center;
gap: 6px;
justify-content: flex-end;
}

.pulse {
width: 6px;
height: 6px;
background: var(–green);
border-radius: 50%;
animation: pulse 2s ease-in-out infinite;
box-shadow: 0 0 8px var(–green);
}

@keyframes pulse {
0%, 100% { opacity: 1; transform: scale(1); }
50% { opacity: 0.3; transform: scale(0.8); }
}

/* Three column layout */
.main-grid {
display: grid;
grid-template-columns: 1fr 1.4fr 1fr;
gap: 16px;
margin-bottom: 16px;
}

/* Panels */
.panel {
background: var(–panel);
border: 1px solid var(–border);
padding: 20px;
position: relative;
animation: fadeIn 0.6s ease both;
}

.panel::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 1px;
background: linear-gradient(to right, transparent, var(–border-bright), transparent);
}

@keyframes fadeIn {
from { opacity: 0; transform: translateY(8px); }
to { opacity: 1; transform: translateY(0); }
}

.panel-title {
font-family: ‘Unbounded’, sans-serif;
font-size: 9px;
font-weight: 700;
letter-spacing: 0.3em;
color: var(–text-dim);
text-transform: uppercase;
margin-bottom: 16px;
padding-bottom: 10px;
border-bottom: 1px solid var(–border);
}

/* FEDERATION NODES */
.node {
display: flex;
align-items: flex-start;
gap: 12px;
padding: 10px 0;
border-bottom: 1px solid var(–border);
cursor: default;
transition: background 0.2s;
}

.node:last-child { border-bottom: none; }

.node:hover { background: rgba(212,168,67,0.03); margin: 0 -20px; padding: 10px 20px; }

.node-icon {
width: 32px;
height: 32px;
border: 1px solid var(–border-bright);
display: flex;
align-items: center;
justify-content: center;
font-size: 14px;
flex-shrink: 0;
position: relative;
}

.node-icon::after {
content: ‘’;
position: absolute;
inset: -3px;
border: 1px solid transparent;
transition: border-color 0.3s;
}

.node:hover .node-icon::after { border-color: var(–gold-dim); }

.node-body { flex: 1; min-width: 0; }

.node-name {
font-family: ‘Unbounded’, sans-serif;
font-size: 9px;
font-weight: 700;
color: var(–text-bright);
letter-spacing: 0.1em;
}

.node-role {
font-size: 9px;
color: var(–text-dim);
margin-top: 2px;
letter-spacing: 0.1em;
}

.node-status {
font-size: 8px;
padding: 2px 6px;
border: 1px solid;
letter-spacing: 0.1em;
margin-top: 4px;
display: inline-block;
}

.status-active { border-color: var(–green); color: var(–green); background: var(–green-dim); }
.status-standby { border-color: var(–gold-dim); color: var(–gold); background: rgba(212,168,67,0.05); }
.status-shadow { border-color: var(–text-dim); color: var(–text-dim); }

/* CENTER - Command map */
.command-center {
position: relative;
display: flex;
flex-direction: column;
align-items: center;
}

.orbital-map {
position: relative;
width: 100%;
aspect-ratio: 1;
max-width: 340px;
margin: 0 auto 16px;
}

.orbital-map svg {
width: 100%;
height: 100%;
}

/* Propagation nodes */
.prop-node {
padding: 8px 12px;
border: 1px solid var(–border);
margin-bottom: 6px;
display: flex;
align-items: center;
gap: 10px;
transition: border-color 0.3s;
cursor: default;
}

.prop-node:hover { border-color: var(–border-bright); }

.prop-dot {
width: 6px;
height: 6px;
border-radius: 50%;
flex-shrink: 0;
}

.prop-label {
font-size: 9px;
color: var(–text);
letter-spacing: 0.15em;
flex: 1;
}

.prop-count {
font-family: ‘Unbounded’, sans-serif;
font-size: 9px;
color: var(–text-dim);
}

/* Bottom strip */
.bottom-strip {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 16px;
}

.stat-block {
background: var(–panel);
border: 1px solid var(–border);
padding: 16px;
text-align: center;
}

.stat-value {
font-family: ‘Unbounded’, sans-serif;
font-size: clamp(18px, 2.5vw, 26px);
font-weight: 900;
color: var(–gold);
line-height: 1;
text-shadow: 0 0 20px var(–gold-glow);
}

.stat-label {
font-size: 8px;
letter-spacing: 0.25em;
color: var(–text-dim);
margin-top: 6px;
text-transform: uppercase;
}

/* Doctrine strip */
.doctrine {
margin-top: 16px;
background: var(–panel);
border: 1px solid var(–border);
border-left: 2px solid var(–gold);
padding: 14px 20px;
display: flex;
align-items: center;
gap: 16px;
}

.doctrine-label {
font-size: 8px;
letter-spacing: 0.3em;
color: var(–gold-dim);
text-transform: uppercase;
flex-shrink: 0;
}

.doctrine-text {
font-family: ‘Unbounded’, sans-serif;
font-size: clamp(10px, 1.5vw, 13px);
font-weight: 300;
color: var(–text-bright);
letter-spacing: 0.05em;
font-style: italic;
}

/* Scanline */
.scanline {
position: fixed;
top: 0; left: 0;
width: 100%;
height: 3px;
background: linear-gradient(to right, transparent, rgba(212,168,67,0.08), transparent);
animation: scan 8s linear infinite;
pointer-events: none;
z-index: 999;
}

@keyframes scan {
0% { top: -3px; }
100% { top: 100vh; }
}

@media (max-width: 700px) {
.main-grid { grid-template-columns: 1fr; }
.bottom-strip { grid-template-columns: repeat(2, 1fr); }
}
</style>

</head>
