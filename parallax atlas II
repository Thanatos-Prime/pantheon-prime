function drawSky(){
  const W=skyC.width,H=skyC.height,cx=W/2,cy=H/2;
  skyX.clearRect(0,0,W,H);

  // background
  const bg=skyX.createRadialGradient(cx,cy,0,cx,cy,cx);
  bg.addColorStop(0,'rgba(12,16,40,.95)');
  bg.addColorStop(1,'rgba(2,3,10,.98)');
  skyX.fillStyle=bg;skyX.fillRect(0,0,W,H);

  // scale: Pluto fits at 0.92*cx
  const SCALE=cx*.92/MAX_ORBITAL_RADIUS;

  // Zodiac band (outermost ring)
  const zodR=cx*.92;
  ZODIAC_12.forEach((z,i)=>{
    const a1=(z.start-90)*Math.PI/180;
    const a2=(z.end-90)*Math.PI/180;
    skyX.beginPath();
    skyX.moveTo(cx,cy);
    skyX.arc(cx,cy,zodR,a1,a2);
    skyX.closePath();
    const elCols={Fire:'rgba(200,80,40,.07)',Earth:'rgba(80,160,80,.07)',Air:'rgba(80,160,220,.07)',Water:'rgba(60,80,200,.07)'};
    skyX.fillStyle=elCols[z.element];
    skyX.fill();
    skyX.strokeStyle='rgba(100,130,200,.08)';
    skyX.lineWidth=.5;
    skyX.stroke();
    // sign symbol
    const mid=(z.start+z.end)/2;
    const mx=cx+(zodR-.015*cx)*Math.cos((mid-90)*Math.PI/180);
    const my=cy+(zodR-.015*cx)*Math.sin((mid-90)*Math.PI/180);
    skyX.fillStyle='rgba(100,130,200,.4)';
    skyX.font=`${Math.max(8,W*.018)}px serif`;
    skyX.textAlign='center';skyX.textBaseline='middle';
    skyX.fillText(z.sym,mx,my);
  });

  // Orbit circles
  PNAMES.forEach(n=>{
    const a=PLANETS[n].a,hi=(n===STATE.observer);
    skyX.beginPath();
    skyX.arc(cx,cy,a*SCALE,0,Math.PI*2);
    skyX.strokeStyle=hi?'rgba(80,128,255,.3)':'rgba(100,130,200,.07)';
    skyX.lineWidth=hi?1.2:.5;
    if(!hi) skyX.setLineDash([2,5]);
    else skyX.setLineDash([]);
    skyX.stroke();skyX.setLineDash([]);
  });

  // Sun
  const sg=skyX.createRadialGradient(cx,cy,0,cx,cy,18);
  sg.addColorStop(0,'rgba(255,248,200,1)');
  sg.addColorStop(.5,'rgba(255,200,80,.7)');
  sg.addColorStop(1,'rgba(255,140,20,0)');
  skyX.beginPath();skyX.arc(cx,cy,11,0,Math.PI*2);skyX.fillStyle=sg;skyX.fill();
  skyX.fillStyle='rgba(255,248,200,.9)';skyX.font='10px serif';
  skyX.textAlign='center';skyX.textBaseline='middle';
  skyX.fillText('☉',cx,cy);

  const obsPos=xy(STATE.observer,STATE.t);
  const ox=cx+obsPos[0]*SCALE, oy=cy-obsPos[1]*SCALE;

  // Visibility cone
  const sunAngle=Math.atan2(obsPos[1],obsPos[0])+Math.PI;
  const elongRadians=STATE.elongThresh*Math.PI/180;
  skyX.save();
  skyX.globalAlpha=.05;
  skyX.beginPath();
  skyX.moveTo(ox,oy);
  skyX.arc(ox,oy,cx*.15,-sunAngle-elongRadians,-sunAngle+elongRadians);
  skyX.closePath();
  skyX.fillStyle='#ff6030';skyX.fill();
  skyX.globalAlpha=1;
  skyX.restore();

  // Planets
  PNAMES.forEach(n=>{
    const pos=xy(n,STATE.t);
    const px=cx+pos[0]*SCALE,py=cy-pos[1]*SCALE;
    const isObs=(n===STATE.observer);
    const p=PLANETS[n];
    const pr=isObs?8:Math.max(2,Math.log(p.R+1)*2.8);

    if(isObs){
      const g=skyX.createRadialGradient(px,py,0,px,py,22);
      g.addColorStop(0,p.col+'66');g.addColorStop(1,'transparent');
      skyX.beginPath();skyX.arc(px,py,22,0,Math.PI*2);
      skyX.fillStyle=g;skyX.fill();
    }
    skyX.beginPath();skyX.arc(px,py,pr,0,Math.PI*2);
    skyX.fillStyle=p.col;skyX.fill();

    // elong line
    if(!isObs){
      const rel=[pos[0]-obsPos[0],pos[1]-obsPos[1]];
      const dist=Math.hypot(rel[0],rel[1]);
      const sunV=[-obsPos[0],-obsPos[1]],sL=Math.hypot(sunV[0],sunV[1]);
      const cosE=(rel[0]*sunV[0]+rel[1]*sunV[1])/(dist*sL);
      const elong=Math.acos(Math.max(-1,Math.min(1,cosE)))*180/Math.PI;
      const vis=elong>=STATE.elongThresh;
      skyX.beginPath();skyX.moveTo(ox,oy);skyX.lineTo(px,py);
      skyX.strokeStyle=vis?'rgba(80,128,255,.15)':'rgba(255,80,30,.08)';
      skyX.lineWidth=.5;skyX.stroke();
    }

    // label
    skyX.fillStyle=isObs?'#e8f0ff':'rgba(160,180,220,.55)';
    skyX.font=isObs?`bold ${W*.018}px "Share Tech Mono"`:` ${W*.015}px "Share Tech Mono"`;
    skyX.textAlign='center';skyX.textBaseline='bottom';
    skyX.fillText(n.substring(0,3).toUpperCase(),px,py-pr-3);

    // observer ring
    if(isObs){
      skyX.beginPath();skyX.arc(ox,oy,12,0,Math.PI*2);
      skyX.strokeStyle='rgba(80,128,255,.7)';skyX.lineWidth=1.5;skyX.stroke();
    }
  });
}

