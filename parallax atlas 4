  // Observer label
  zdX.font=`bold ${W*.012}px "IBM Plex Mono"`;zdX.fillStyle='rgba(212,150,26,.7)';
  zdX.textAlign='center';zdX.fillText(S.obs.toUpperCase(),cx,cy+innerR*.25);

  // Planets
  BODIES.forEach(n=>{
    if(n===S.obs)return;
    const deg=eclipticLon(n,S.t);
    const a=(deg-90)*D2R;
    const ph=PHYS[n];
    const r=Math.max(4,Math.log(ph.R+1)*2.4);
    const pR=innerR*.78;
    const px=cx+pR*Math.cos(a),py=cy+pR*Math.sin(a);
