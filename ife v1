// ── SIMULATION ENGINE ────────────────────────────────────────────────────────
function computePayoff(actor) {
const baseReward  = actor.rewardWeight * 5;
const costPenalty = (actor.externalities / 5) * (1 - actor.rewardWeight) * 3;
const lockBonus   = actor.rewardWeight > 0.6 ? actor.lockin * 0.4 : 0;
const infoBonus   = actor.infoAdvantage * actor.rewardWeight * 0.3;
const timeFactor  = { Immediate:1.2, Quarterly:1.1, Annual:1.0, Career:0.85, Lifetime:0.7, Intergenerational:0.5 }[actor.horizon] || 1.0;
const noise       = (Math.random() - 0.5) * 0.3;
return (baseReward + lockBonus + infoBonus - costPenalty) * timeFactor + noise;
}

function runSimulation(actors, constraints, edges, steps = 40) {
if (actors.length === 0) return { frames: [], equilibrium: null, collapseDetected: false, attractors: [] };

const hardPenalty   = constraints.filter((c) => c.type === “Hard”).reduce((s, c) => s + c.impact, 0) / 10;
const invisibleLoad = constraints.filter((c) => c.type === “Invisible”).reduce((s, c) => s + c.impact, 0) / 10;

const frames = [];
let state = actors.map(() => ({ payoff: 3, welfare: 3, position: Math.random() * 4 + 1 }));

for (let step = 0; step < steps; step++) {
const next = state.map((s, i) => {
const actor     = actors[i];
const raw       = computePayoff(actor);
const edgeBonus = edges.filter((e) => e.from === i).reduce((sum, e) => sum + e.weight * 0.15, 0);
const edgeCost  = edges.filter((e) => e.to === i && [“extracts from”,“locks in”,“punishes”].includes(e.type)).reduce((sum, e) => sum + e.weight * 0.2, 0);
const payoff    = Math.max(0, Math.min(10, raw + edgeBonus - edgeCost - hardPenalty * 0.5));
const welfare   = Math.max(0, Math.min(10, payoff - (invisibleLoad * actor.externalities) / 5));
const drift     = (payoff - s.payoff) * 0.3;
const position  = Math.max(0, Math.min(10, s.position + drift * 0.5 + (Math.random() - 0.5) * 0.2));
return { payoff, welfare, position };
});
frames.push(next.map((s) => ({ …s })));
state = next;
}

const lastN     = frames.slice(-8);
const variances = actors.map((_, i) => {
const vals = lastN.map((f) => f[i].payoff);
const mean = vals.reduce((s, v) => s + v, 0) / vals.length;
return vals.reduce((s, v) => s + Math.pow(v - mean, 2), 0) / vals.length;
});
const maxVar = Math.max(…variances);

let equilibrium = null, collapseDetected = false, attractors = [];

if (maxVar < 0.15) {
const finalPayoffs = actors.map((*, i) => frames[frames.length - 1][i].payoff);
const avgPayoff    = finalPayoffs.reduce((s, v) => s + v, 0) / finalPayoffs.length;
const lowActors    = actors.filter((*, i) => frames[frames.length - 1][i].welfare < 2.5);
equilibrium = {
stable: true,
avgPayoff: avgPayoff.toFixed(2),
type: avgPayoff > 6 ? “cooperative” : avgPayoff > 4 ? “neutral” : “extractive”,
trapped: lowActors.map((a) => a.name),
};
} else if (maxVar > 1.5) {
collapseDetected = true;
} else {
const finalPos = actors.map((*, i) => frames[frames.length - 1][i].position);
const high     = actors.filter((*, i) => finalPos[i] > 6).map((a) => a.name);
const low      = actors.filter((_, i) => finalPos[i] < 4).map((a) => a.name);
if (high.length > 0 && low.length > 0) {
attractors = [
{ label: “High-payoff basin”, actors: high },
{ label: “Low-payoff basin”,  actors: low  },
];
}
}

return { frames, equilibrium, collapseDetected, attractors };
}

// ── AI ANALYSIS ───────────────────────────────────────────────────────────────
async function callIFE(systemDesc, actors, constraints, edges, simResult) {
const actorLines = actors.map((a) =>
`${a.name || "Unnamed"}: horizon=${a.horizon}, lockin=${a.lockin}/5, infoAdvantage=${a.infoAdvantage}/5, externalities=${a.externalities}/5, rewardWeight=${a.rewardWeight}`
).join(”\n”);

const constraintLines = constraints.map((c) => `[${c.type}] ${c.label} (impact ${c.impact}/5)`).join(”\n”);

const eqSummary = simResult?.equilibrium
? `Stable ${simResult.equilibrium.type} equilibrium. Avg payoff ${simResult.equilibrium.avgPayoff}. Trapped: ${simResult.equilibrium.trapped.join(", ") || "none"}.`
: simResult?.collapseDetected ? “No convergence detected. System cycling or collapsing.”
: simResult?.attractors?.length > 0
? `Bistable: ${simResult.attractors.map((a) => `${a.label} (${a.actors.join(”, “)})`).join(" | ")}`
: “Simulation inconclusive.”;

const prompt = `You are the Incentive Field Engine (IFE v1.0) of PantheonOS.

Core doctrine: Systems are not controlled by rules alone. They are controlled by what gets rewarded, punished, delayed, hidden, subsidized, or made legible. Incentives are field geometry. Actors move along gradients. System design is terrain-shaping.

SYSTEM:
${systemDesc}

ACTORS:
${actorLines}

CONSTRAINTS:
${constraintLines || “(none defined)”}

SIMULATION RESULT:
${eqSummary}

Respond ONLY with valid JSON. No markdown fences. No text outside the JSON object.
{
“fieldDiagnosis”: “2-3 sentence description of the incentive field geometry”,
“equilibriumInterpretation”: “what the simulation convergence reveals about the system attractor state”,
“misalignments”: [
{ “pattern”: “one of: Reward-Cost Separation, Time Horizon Mismatch, Proxy Capture, Lock-in Trap, Information Asymmetry”, “actors”: “specific actors”, “mechanism”: “how it operates” }
],
“collapseVectors”: [“specific destabilization path 1”, “specific destabilization path 2”],
“steeringOptions”: [
{ “operator”: “one of: Reward Rewrite, Cost Reinternalization, Delay Injection, Visibility Correction, Exit Restoration, Positive-Sum Reframe”, “intervention”: “specific action”, “expectedEffect”: “field geometry change”, “risk”: “unintended consequence” }
],
“positiveSum”: “one concrete redesign that makes cooperation pay more than extraction”,
“pantheonVerdict”: “one sentence Pantheon assessment”
}`;

const res = await fetch(“https://api.anthropic.com/v1/messages”, {
method: “POST”,
headers: { “Content-Type”: “application/json” },
body: JSON.stringify({
model: “claude-sonnet-4-20250514”,
max_tokens: 1200,
messages: [{ role: “user”, content: prompt }],
}),
});

if (!res.ok) throw new Error(`API error ${res.status}`);
const data  = await res.json();
const raw   = (data.content || []).map((b) => b.text || “”).join(””).trim();
const clean = raw.replace(/^`(?:json)?\s*/i, "").replace(/\s*`\s*$/i, “”).trim();

let parsed;
try { parsed = JSON.parse(clean); }
catch {
const m = clean.match(/{[\s\S]*}/);
if (m) parsed = JSON.parse(m[0]);
else throw new Error(“Model returned invalid JSON.”);
}

return {
fieldDiagnosis:            typeof parsed.fieldDiagnosis === “string”            ? parsed.fieldDiagnosis : “”,
equilibriumInterpretation: typeof parsed.equilibriumInterpretation === “string” ? parsed.equilibriumInterpretation : “”,
misalignments:             Array.isArray(parsed.misalignments)                  ? parsed.misalignments : [],
collapseVectors:           Array.isArray(parsed.collapseVectors)                ? parsed.collapseVectors : [],
steeringOptions:           Array.isArray(parsed.steeringOptions)                ? parsed.steeringOptions : [],
positiveSum:               typeof parsed.positiveSum === “string”               ? parsed.positiveSum : “”,
pantheonVerdict:           typeof parsed.pantheonVerdict === “string”           ? parsed.pantheonVerdict : “”,
};
}

