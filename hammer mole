## 11. Pseudocode

```text
CLASS HammerMoleGame:

    INIT(word_source, validator, lexicon, scoreboard, settings):
        self.word_source = word_source
        self.validator = validator
        self.lexicon = lexicon
        self.scoreboard = scoreboard
        self.settings = settings
        self.current_round = null
        self.combo = 0

    FUNCTION start_session(player):
        session = create_session(player, settings)
        WHILE session.is_active:
            word = word_source.next_word(
                difficulty=session.difficulty,
                avoid=session.recent_words
            )

            result = play_round(player, word, session)
            session.record(result)

            IF result.accepted:
                combo += 1
                maybe_archive(result)
            ELSE:
                combo = 0

            update_difficulty(session, result)
            move_conveyor(session)

        RETURN session.summary()


    FUNCTION play_round(player, word, session):
        round = create_round(word)

        # MIRROR
        round.mirror = prompt_player(
            "What does this word ordinarily mean or feel like?"
        )

        # WALKING SPIDER FIRST STEP
        first_split = prompt_player(
            "Name two importantly different things hidden inside this word."
        )
        round.fragments.add(first_split)

        # HAMMER LOOP
        WHILE should_continue_hammering(round, session):
            suggestion = detect_missing_axis(round)

            next_fragment = prompt_player(
                build_progressive_prompt(round, suggestion)
            )

            IF next_fragment is empty:
                BREAK

            IF is_probably_redundant(next_fragment, round.fragments):
                show_feedback("That may overlap an existing fragment.")
                next_fragment = request_differentiation(next_fragment)

            round.fragments.add(next_fragment)

        # DIFFERENTIATION
        FOR fragment IN round.fragments:
            fragment.definition = prompt_player(
                "What makes " + fragment.label + " distinct?"
            )
            fragment.mechanism = prompt_player(
                "What causes or governs it?"
            )
            fragment.examples = collect_examples(fragment)

        # KINTSUGI
        candidate_pairs = identify_related_fragments(round.fragments)

        FOR pair IN candidate_pairs:
            seam = prompt_player(
                "How are " + pair.a.label +
                " and " + pair.b.label +
                " related without being identical?"
            )
            round.seams.add(seam)

        # ZPC
        round.zpc.compact_representation = prompt_player(
            "Compress this repaired structure into its smallest reusable form."
        )

        round.zpc.reconstruction_instructions = prompt_player(
            "How should another player expand this compression correctly?"
        )

        # TRANSFER TEST
        transfer_domain = choose_transfer_domain(word, round.fragments)

        round.transfer_test = prompt_player(
            "Apply the repaired word to: " + transfer_domain
        )

        # VALIDATION
        validation = validator.evaluate(round)

        # SCORE
        score = calculate_score(validation, session, combo)
        round.score = score

        # ACCEPTANCE
        round.accepted = acceptance_gate(
            score=score,
            coherence=validation.coherence,
            reconstructability=validation.reconstructability,
            safety=validation.safety
        )

        scoreboard.submit(player, word, score)

        RETURN round


    FUNCTION calculate_score(validation, session, combo):
        positive =
            validation.intuitive_resonance * 10 +
            validation.distinctness * 15 +
            validation.coverage * 15 +
            validation.coherence * 15 +
            validation.usefulness * 15 +
            validation.compression_quality * 10 +
            validation.reconstructability * 10 +
            validation.novelty * 5 +
            validation.cross_domain_transfer * 5

        penalty_total = SUM(validation.penalties)

        combo_bonus = MIN(combo * settings.combo_multiplier,
                          settings.max_combo_bonus)

        speed_bonus = calculate_speed_bonus(
            elapsed=session.round_elapsed,
            quality=positive
        )

        # Speed cannot rescue weak semantics.
        IF positive < settings.minimum_quality_for_speed_bonus:
            speed_bonus = 0

        RETURN CLAMP(
            positive - penalty_total + combo_bonus + speed_bonus,
            0,
            100
        )


    FUNCTION maybe_archive(round):
        IF round.score < settings.archive_threshold:
            RETURN

        duplicate = lexicon.find_semantic_duplicate(round)

        IF duplicate is null:
            lexicon.add(round)
            spawn_hydra_words(round.fragments)
        ELSE:
            merged = kintsugi_merge(duplicate, round)
            lexicon.propose_revision(merged)


    FUNCTION spawn_hydra_words(fragments):
        FOR fragment IN fragments:
            IF fragment.depth_potential >= settings.hydra_threshold:
                word_source.enqueue(fragment.label)


    FUNCTION update_difficulty(session, result):
        IF result.score >= 85:
            session.difficulty += 1
            session.belt_speed *= 1.05
        ELSE IF result.score < 50:
            session.difficulty = MAX(1, session.difficulty - 1)
            session.belt_speed *= 0.95

        session.difficulty = adapt_to_player_delta(
            current=session.difficulty,
            skill_history=session.score_history,
            fatigue=session.estimated_fatigue
        )
```

