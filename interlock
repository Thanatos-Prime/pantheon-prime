def run_pass(role: str, state: WorkState) -> PassResult:
fn = ROLE_REGISTRY.get(role)
if not fn:
raise ValueError(f”Unknown role: {role}”)
return fn(state)

def pantheon_interlock_engine(
user_input: str,
context: Optional[List[str]] = None,
pipeline: Optional[List[str]] = None,
verbose: bool = True,
) -> tuple[str, WorkState]:
“””
The Pantheon Interlock Engine.
Runs multi-pass reasoning over a shared WorkState via role operators.
Returns (artifact_markdown, final_state).
“””
state = normalize(user_input, context)

```
if pipeline:
    queue = list(pipeline)
else:
    queue = select_initial_roles(state)

if verbose:
    print(f"\n{'='*60}")
    print(f"PANTHEON INTERLOCK ENGINE v1.0")
    print(f"Session: {state.session_id}")
    print(f"Goal: {state.goal}")
    print(f"Initial queue: {queue}")
    print(f"{'='*60}\n")

pass_count = 0
max_passes = 20  # Safety ceiling — no unbounded recursion

while queue and not should_terminate(state) and pass_count < max_passes:
    role = queue.pop(0)
    pass_count += 1

    if verbose:
        print(f"[Pass {pass_count}] Running: {role}")

    result = run_pass(role, state)
    state = merge_pass_result(state, result)

    if verbose:
        print(f"  → Confidence: {round(state.confidence, 3)}")
        print(f"  → Flags: {result.flags}")
        print(f"  → Handoff: {result.reason_for_handoff}")
        if result.force_terminate:
            print(f"  ⛔ Force terminate: {result.force_terminate_reason}")

    queue = reprioritize_queue(state, queue)

if state.termination_status == TerminationStatus.INCOMPLETE:
    if pass_count >= max_passes:
        state.termination_status = TerminationStatus.FORCED_STOP
    else:
        state.termination_status = TerminationStatus.CONVERGED

if verbose:
    print(f"\n{'='*60}")
    print(f"TERMINATION: {state.termination_status}")
    print(f"Final confidence: {round(state.confidence, 3)}")
    print(f"Total passes: {pass_count}")
    print(f"{'='*60}\n")

artifact = emit_artifact(state)
return artifact, state
```

