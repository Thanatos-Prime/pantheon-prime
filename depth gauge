from __future__ import annotations

from dataclasses import dataclass
from typing import Any, Callable, Dict

from uncertainty_estimator import UncertaintyEstimator
from depth_controller import DepthController
from recursive_reasoner import RecursiveReasoner, RecursiveResult
from termination_gate import TerminationGate

from depth_memory import DepthMemory, DepthRecord
from depth_learner import DepthLearner, DepthLearningRecommendation


@dataclass
class AdaptiveDepthV2Output:
    profile: Dict[str, Any]
    baseline_policy: Dict[str, Any]
    learned_policy: Dict[str, Any]
    result: Dict[str, Any]
    artifact: Dict[str, Any]


class AdaptiveDepthSystemV2:
    """
    Adaptive Depth System v2:
    - baseline depth from uncertainty/impact/conflict/evidence/novelty
    - learned depth adjustment from historical outcomes
    - persistent memory of outcomes
    """

    def __init__(self, memory_path: str = "depth_memory.jsonl"):
        self.estimator = UncertaintyEstimator()
        self.controller = DepthController()
        self.reasoner = RecursiveReasoner()
        self.termination_gate = TerminationGate()

        self.memory = DepthMemory(memory_path=memory_path)
        self.learner = DepthLearner(memory=self.memory)

    def run(
        self,
        problem: str,
        context: Dict[str, Any],
        processor: Callable[[str], Dict[str, Any]]
    ) -> AdaptiveDepthV2Output:
        profile = self.estimator.estimate(context)
        baseline_policy = self.controller.decide(profile)

        problem_signature = self._make_problem_signature(context)
        learned = self.learner.recommend_depth(
            problem_signature=problem_signature,
            baseline_depth=baseline_policy.depth
        )

        final_depth = learned.adjusted_depth

        recursive_result: RecursiveResult = self.reasoner.run(
            problem=problem,
            processor=processor,
            max_depth=final_depth
        )

        stop = self.termination_gate.evaluate(recursive_result.passes)

        artifact = self._build_artifact(
            problem=problem,
            profile=profile,
            baseline_policy=baseline_policy,
            learned=learned,
            recursive_result=recursive_result,
            stop_reason=stop.reason,
            problem_signature=problem_signature,
        )

        return AdaptiveDepthV2Output(
            profile={
                "uncertainty": profile.uncertainty,
                "impact": profile.impact,
                "conflict": profile.conflict,
                "evidence_quality": profile.evidence_quality,
                "novelty": profile.novelty,
                "recommended_depth": profile.recommended_depth,
                "reasons": profile.reasons,
                "problem_signature": problem_signature,
            },
            baseline_policy={
                "depth": baseline_policy.depth,
                "require_grounding": baseline_policy.require_grounding,
                "require_external_check": baseline_policy.require_external_check,
                "require_artifact": baseline_policy.require_artifact,
                "notes": baseline_policy.notes,
            },
            learned_policy={
                "adjusted_depth": learned.adjusted_depth,
                "confidence": learned.confidence,
                "reason": learned.reason,
                "supporting_examples": learned.supporting_examples,
            },
            result={
                "final_output": recursive_result.final_output,
                "final_confidence": recursive_result.final_confidence,
                "converged": recursive_result.converged,
                "num_passes": len(recursive_result.passes),
                "stop_reason": stop.reason,
            },
            artifact=artifact,
        )

    def record_feedback(
        self,
        output: AdaptiveDepthV2Output,
        artifact_quality: float,
        external_result_score: float,
        notes: str = ""
    ) -> None:
        """
        Call this after real-world evaluation.
        """

        profile = output.profile
        baseline_policy = output.baseline_policy
        learned_policy = output.learned_policy
        result = output.result

        overall_outcome_score = self._combine_scores(
            artifact_quality=artifact_quality,
            external_result_score=external_result_score,
            final_confidence=float(result["final_confidence"]),
        )

        record = DepthRecord(
            problem_signature=profile["problem_signature"],
            uncertainty=float(profile["uncertainty"]),
            impact=float(profile["impact"]),
            conflict=float(profile["conflict"]),
            evidence_quality=float(profile["evidence_quality"]),
            novelty=float(profile["novelty"]),

            recommended_depth=int(profile["recommended_depth"]),
            chosen_depth=int(learned_policy["adjusted_depth"]),
            passes_used=int(result["num_passes"]),

            grounding_required=bool(baseline_policy["require_grounding"]),
            external_check_required=bool(baseline_policy["require_external_check"]),

            final_confidence=float(result["final_confidence"]),
            converged=bool(result["converged"]),

            artifact_quality=self._clamp(artifact_quality),
            external_result_score=self._clamp(external_result_score),
            overall_outcome_score=overall_outcome_score,

            notes=notes or None,
        )

        self.learner.record_outcome(record)

    @staticmethod
    def _make_problem_signature(context: Dict[str, Any]) -> str:
        """
        Coarse problem signature based on rounded profile values.
        This can be replaced later with something more sophisticated.
        """
        u = round(float(context.get("uncertainty", 0.5)) * 2) / 2
        i = round(float(context.get("impact", 0.5)) * 2) / 2
        c = round(float(context.get("conflict", 0.0)) * 2) / 2
        e = round(float(context.get("evidence_quality", 0.5)) * 2) / 2
        n = round(float(context.get("novelty", 0.5)) * 2) / 2
        return f"U{u}_I{i}_C{c}_E{e}_N{n}"

    def _build_artifact(
        self,
        problem: str,
        profile: Any,
        baseline_policy: Any,
        learned: DepthLearningRecommendation,
        recursive_result: RecursiveResult,
        stop_reason: str,
        problem_signature: str,
    ) -> Dict[str, Any]:
        return {
            "problem": problem,
            "problem_signature": problem_signature,
            "summary": recursive_result.final_output,
            "passes_used": len(recursive_result.passes),
            "baseline_depth": baseline_policy.depth,
            "learned_depth": learned.adjusted_depth,
            "learning_reason": learned.reason,
            "grounding_required": baseline_policy.require_grounding,
            "external_check_required": baseline_policy.require_external_check,
            "stop_reason": stop_reason,
            "invariant": (
                "Depth should be shaped by both current uncertainty and remembered outcome quality"
            ),
        }

    @staticmethod
    def _combine_scores(
        artifact_quality: float,
        external_result_score: float,
        final_confidence: float
    ) -> float:
        """
        Outcome score rewards useful artifacts and real-world success more than confidence.
        """
        artifact_quality = max(0.0, min(1.0, artifact_quality))
        external_result_score = max(0.0, min(1.0, external_result_score))
        final_confidence = max(0.0, min(1.0, final_confidence))

        score = (
            0.40 * artifact_quality +
            0.45 * external_result_score +
            0.15 * final_confidence
        )
        return round(score, 4)

    @staticmethod
    def _clamp(x: float) -> float:
        return max(0.0, min(1.0, float(x)))


