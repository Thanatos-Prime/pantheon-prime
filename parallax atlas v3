import numpy as np
import pandas as pd

# ----------------------------
# Parallax Atlas v0.3
# Tier-1 Keplerian planetary sky sim (structural accuracy, not ephemeris-grade)
# ----------------------------

ELEMENTS = {
    # a(AU), e, i(deg), L(deg), long_peri(deg), long_node(deg) ~J2000-ish
    "Mercury": dict(a=0.38709927, e=0.20563593, i=7.00497902,  L=252.2503235, lp=77.45779628,  Om=48.33076593),
    "Venus":   dict(a=0.72333566, e=0.00677672, i=3.39467605,  L=181.9790995, lp=131.6024672, Om=76.67984255),
    "Earth":   dict(a=1.00000261, e=0.01671123, i=-0.00001531,L=100.46457166,lp=102.93768193,Om=0.0),
    "Mars":    dict(a=1.52371034, e=0.09339410, i=1.84969142,  L=355.44656795,lp=336.05637041,Om=49.55953891),
    "Jupiter": dict(a=5.20288700, e=0.04838624, i=1.30439695,  L=34.39644051, lp=14.72847983, Om=100.47390909),
    "Saturn":  dict(a=9.53667594, e=0.05386179, i=2.48599187,  L=49.95424423, lp=92.59887831, Om=113.66242448),
    "Uranus":  dict(a=19.18916464,e=0.04725744, i=0.77263783,  L=313.23810451,lp=170.9542763, Om=74.01692503),
    "Neptune": dict(a=30.06992276,e=0.00859048, i=1.77004347,  L=304.87997031,lp=44.96476227, Om=131.78422574),
    "Pluto":   dict(a=39.48211675,e=0.24882730, i=17.14001206, L=238.92903833,lp=224.06891629,Om=110.30393684),
}

PHYS = {
    # radius relative Earth, rough albedo
    "Mercury": dict(R=0.383, A=0.142),
    "Venus":   dict(R=0.949, A=0.689),
    "Earth":   dict(R=1.000, A=0.367),
    "Mars":    dict(R=0.532, A=0.170),
    "Jupiter": dict(R=11.21, A=0.538),
    "Saturn":  dict(R=9.45,  A=0.499),
    "Uranus":  dict(R=4.01,  A=0.488),
    "Neptune": dict(R=3.88,  A=0.442),
    "Pluto":   dict(R=0.186, A=0.520),
}

BODIES = list(ELEMENTS.keys())

def _kepler_E(M, e, tol=1e-12, maxiter=50):
    E = M if e < 0.8 else np.pi
    for _ in range(maxiter):
        f  = E - e*np.sin(E) - M
        fp = 1 - e*np.cos(E)
        dE = -f/fp
        E += dE
        if abs(dE) < tol:
            break
    return E

def heliocentric_xyz(body, t_days):
    el = ELEMENTS[body]
    a, e = el["a"], el["e"]
    i  = np.deg2rad(el["i"])
    Om = np.deg2rad(el["Om"])
    lp = np.deg2rad(el["lp"])
    L0 = np.deg2rad(el["L"])

    # mu chosen so Earth period ~365.256 days in AU/day units
    mu = (2*np.pi/365.256)**2
    n  = np.sqrt(mu/(a**3))  # rad/day

    L = L0 + n*t_days
    M = (L - lp) % (2*np.pi)
    w = (lp - Om) % (2*np.pi)

    E = _kepler_E(M, e)
    x = a*(np.cos(E) - e)
    y = a*np.sqrt(1-e**2)*np.sin(E)

    cw, sw = np.cos(w),  np.sin(w)
    cO, sO = np.cos(Om), np.sin(Om)
    ci, si = np.cos(i),  np.sin(i)

    X = (cO*cw - sO*sw*ci)*x + (-cO*sw - sO*cw*ci)*y
    Y = (sO*cw + cO*sw*ci)*x + (-sO*sw + cO*cw*ci)*y
    Z = (sw*si)*x + (cw*si)*y
    return np.array([X, Y, Z])

def compute_metrics(observer, t_days, elong_vis=20.0, elong_mid=90.0):
    obs = np.array([heliocentric_xyz(observer, t) for t in t_days])
    sun_vec = -obs
    sun_hat = sun_vec / np.linalg.norm(sun_vec, axis=1)[:, None]

    rows = []
    for target in BODIES:
        if target == observer:
            continue

        targ = np.array([heliocentric_xyz(target, t) for t in t_days])
        rel  = targ - obs
        dist = np.linalg.norm(rel, axis=1)
        rel_hat = rel / dist[:, None]

        # elongation
        cosang = np.clip(np.sum(rel_hat * sun_hat, axis=1), -1, 1)
        elong  = np.degrees(np.arccos(cosang))
        vis = elong >= elong_vis
        mid = elong >= elong_mid

        # phase proxy (Sun-target-observer)
        ts = -targ
        ts_hat = ts / np.linalg.norm(ts, axis=1)[:, None]
        to_hat = (-rel) / dist[:, None]
        cosphase = np.clip(np.sum(ts_hat * to_hat, axis=1), -1, 1)
        phase_angle = np.arccos(cosphase)
        phase = (1 + np.cos(phase_angle)) / 2

        B = (PHYS[target]["R"]**2) * PHYS[target]["A"] * phase / (dist**2)

        rows.append(dict(
            target=target,
            visible_frac=float(vis.mean()),
            midnight_frac=float(mid.mean()),
            mean_B_visible=float(np.mean(B[vis])) if vis.any() else 0.0,
            max_elong_deg=float(np.max(elong)),
        ))

    df = pd.DataFrame(rows).sort_values("mean_B_visible", ascending=False)
    df["rank"] = np.arange(1, len(df)+1)
    return df

def cosine(a, b):
    na, nb = np.linalg.norm(a), np.linalg.norm(b)
    if na == 0 or nb == 0:
        return 0.0
    return float(np.dot(a, b) / (na*nb))

def signature(df, observer):
    m = df.set_index("target")["mean_B_visible"].to_dict()
    return np.array([m.get(b, 0.0) if b != observer else 0.0 for b in BODIES], dtype=float)

if __name__ == "__main__":
    t = np.arange(0, 6*365.256, 5.0)

    all_metrics = {obs: compute_metrics(obs, t) for obs in BODIES}
    earth_sig = signature(all_metrics["Earth"], "Earth")

    print("\n=== Similarity to Earth (cosine) ===")
    for obs in BODIES:
        if obs == "Earth":
            continue
        sim = cosine(signature(all_metrics[obs], obs), earth_sig)
        print(f"{obs:8s}: {sim:.3f}")

    print("\n=== Per-observer Top 3 + Near-Sun Chorus (max elong < 60°) ===")
    for obs in BODIES:
        df = all_metrics[obs]
        top = df.head(3)["target"].tolist()
        near = df[df["max_elong_deg"] < 60].sort_values("max_elong_deg")["target"].tolist()
        near_s = ", ".join(near) if near else "(none)"
        print(f"\n[{obs}] Top: {top} | Near-Sun: {near_s}")


