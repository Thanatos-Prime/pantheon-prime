from __future__ import annotations

import sqlite3
from pathlib import Path
from typing import Dict, Any, List

DB_PATH = Path("psr.db")


def get_conn() -> sqlite3.Connection:
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def init_reputation_db() -> None:
    conn = get_conn()
    cur = conn.cursor()

    cur.execute(
        """
        CREATE TABLE IF NOT EXISTS reputation (
            source_id TEXT PRIMARY KEY,
            total_predictions INTEGER NOT NULL,
            correct_predictions INTEGER NOT NULL,
            predictive_accuracy REAL NOT NULL,
            consistency REAL NOT NULL,
            stake REAL NOT NULL,
            expertise REAL NOT NULL,
            manipulation_risk REAL NOT NULL,
            volume INTEGER NOT NULL,
            mean_score REAL NOT NULL,
            score_variance_proxy REAL NOT NULL,
            last_outcome_error REAL NOT NULL
        )
        """
    )

    conn.commit()
    conn.close()


def upsert_reputation(record: Dict[str, Any]) -> None:
    conn = get_conn()
    cur = conn.cursor()

    cur.execute(
        """
        INSERT INTO reputation (
            source_id, total_predictions, correct_predictions, predictive_accuracy,
            consistency, stake, expertise, manipulation_risk, volume,
            mean_score, score_variance_proxy, last_outcome_error
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(source_id) DO UPDATE SET
            total_predictions=excluded.total_predictions,
            correct_predictions=excluded.correct_predictions,
            predictive_accuracy=excluded.predictive_accuracy,
            consistency=excluded.consistency,
            stake=excluded.stake,
            expertise=excluded.expertise,
            manipulation_risk=excluded.manipulation_risk,
            volume=excluded.volume,
            mean_score=excluded.mean_score,
            score_variance_proxy=excluded.score_variance_proxy,
            last_outcome_error=excluded.last_outcome_error
        """,
        (
            record["source_id"],
            record["total_predictions"],
            record["correct_predictions"],
            record["predictive_accuracy"],
            record["consistency"],
            record["stake"],
            record["expertise"],
            record["manipulation_risk"],
            record["volume"],
            record["mean_score"],
            record["score_variance_proxy"],
            record["last_outcome_error"],
        ),
    )

    conn.commit()
    conn.close()


def fetch_all_reputation() -> List[Dict[str, Any]]:
    conn = get_conn()
    cur = conn.cursor()
    rows = cur.execute("SELECT * FROM reputation").fetchall()
    conn.close()

    return [dict(row) for row in rows]

