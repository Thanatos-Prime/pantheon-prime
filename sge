from __future__ import annotations

from dataclasses import dataclass, field
from typing import Dict, Any, List, Optional
import math


def clamp(value: float, lo: float = 0.0, hi: float = 1.0) -> float:
    return max(lo, min(hi, value))


@dataclass
class SignalSource:
    source_id: str
    source_type: str = "user"
    predictive_accuracy: float = 0.5
    consistency: float = 0.5
    stake: float = 0.0
    expertise: float = 0.0
    manipulation_risk: float = 0.0
    volume: int = 0

    def credibility_score(self) -> float:
        """
        Composite source quality score.
        Higher is better.
        """
        score = (
            0.35 * clamp(self.predictive_accuracy)
            + 0.25 * clamp(self.consistency)
            + 0.20 * clamp(self.expertise)
            + 0.10 * clamp(self.stake)
            + 0.10 * clamp(math.log1p(self.volume) / 10.0)
            - 0.30 * clamp(self.manipulation_risk)
        )
        return clamp(score)


@dataclass
class InvariantReport:
    reversibility_ok: bool = True
    transparency_ok: bool = True
    anti_gaming_ok: bool = True
    consent_ok: bool = True
    coherence_ok: bool = True

    def penalty(self) -> float:
        """
        Returns penalty in [0,1], where 0 = no penalty and 1 = total block.
        """
        failures = [
            not self.reversibility_ok,
            not self.transparency_ok,
            not self.anti_gaming_ok,
            not self.consent_ok,
            not self.coherence_ok,
        ]
        penalty = sum(failures) / len(failures)
        return clamp(penalty)


@dataclass
class GovernanceWeights:
    democracy_weight: float = 0.25
    merit_weight: float = 0.30
    stake_weight: float = 0.15
    expert_weight: float = 0.20
    personalization_weight: float = 0.10

    def normalized(self) -> "GovernanceWeights":
        total = (
            self.democracy_weight
            + self.merit_weight
            + self.stake_weight
            + self.expert_weight
            + self.personalization_weight
        )
        if total <= 0:
            return GovernanceWeights()
        return GovernanceWeights(
            democracy_weight=self.democracy_weight / total,
            merit_weight=self.merit_weight / total,
            stake_weight=self.stake_weight / total,
            expert_weight=self.expert_weight / total,
            personalization_weight=self.personalization_weight / total,
        )


@dataclass
class SignalVote:
    source_id: str
    score: float
    confidence: float = 0.5
    personalization_alignment: float = 0.5
    metadata: Dict[str, Any] = field(default_factory=dict)


class SignalGovernanceEngine:
    """
    Hybrid aggregation engine:
    - Democracy: equal participation
    - Merit: source credibility
    - Stake: skin in the game
    - Expert: declared expertise
    - Personalization: fit to local/user lens
    """

    def __init__(
        self,
        weights: Optional[GovernanceWeights] = None,
        source_registry: Optional[Dict[str, SignalSource]] = None,
    ) -> None:
        self.weights = (weights or GovernanceWeights()).normalized()
        self.source_registry: Dict[str, SignalSource] = source_registry or {}

    def register_source(self, source: SignalSource) -> None:
        self.source_registry[source.source_id] = source

    def get_source(self, source_id: str) -> SignalSource:
        return self.source_registry.get(source_id, SignalSource(source_id=source_id))

    def democratic_component(self, votes: List[SignalVote]) -> float:
        if not votes:
            return 0.0
        return sum(clamp(v.score) for v in votes) / len(votes)

    def merit_component(self, votes: List[SignalVote]) -> float:
        if not votes:
            return 0.0

        numer = 0.0
        denom = 0.0
        for vote in votes:
            source = self.get_source(vote.source_id)
            w = source.credibility_score() * clamp(vote.confidence)
            numer += clamp(vote.score) * w
            denom += w

        return numer / denom if denom > 0 else 0.0

    def stake_component(self, votes: List[SignalVote]) -> float:
        if not votes:
            return 0.0

        numer = 0.0
        denom = 0.0
        for vote in votes:
            source = self.get_source(vote.source_id)
            w = clamp(source.stake)
            numer += clamp(vote.score) * w
            denom += w

        return numer / denom if denom > 0 else 0.0

    def expert_component(self, votes: List[SignalVote]) -> float:
        if not votes:
            return 0.0

        numer = 0.0
        denom = 0.0
        for vote in votes:
            source = self.get_source(vote.source_id)
            w = clamp(source.expertise)
            numer += clamp(vote.score) * w
            denom += w

        return numer / denom if denom > 0 else 0.0

    def personalization_component(self, votes: List[SignalVote]) -> float:
        if not votes:
            return 0.0

        numer = 0.0
        denom = 0.0
        for vote in votes:
            w = clamp(vote.personalization_alignment)
            numer += clamp(vote.score) * w
            denom += w

        return numer / denom if denom > 0 else 0.0

    def aggregate(
        self,
        votes: List[SignalVote],
        invariants: Optional[InvariantReport] = None,
    ) -> Dict[str, Any]:
        invariants = invariants or InvariantReport()

        democracy = self.democratic_component(votes)
        merit = self.merit_component(votes)
        stake = self.stake_component(votes)
        expert = self.expert_component(votes)
        personalization = self.personalization_component(votes)

        raw_score = (
            self.weights.democracy_weight * democracy
            + self.weights.merit_weight * merit
            + self.weights.stake_weight * stake
            + self.weights.expert_weight * expert
            + self.weights.personalization_weight * personalization
        )

        penalty = invariants.penalty()
        final_score = clamp(raw_score * (1.0 - penalty))

        return {
            "final_score": final_score,
            "raw_score": raw_score,
            "penalty": penalty,
            "components": {
                "democracy": democracy,
                "merit": merit,
                "stake": stake,
                "expert": expert,
                "personalization": personalization,
            },
            "weights": {
                "democracy_weight": self.weights.democracy_weight,
                "merit_weight": self.weights.merit_weight,
                "stake_weight": self.weights.stake_weight,
                "expert_weight": self.weights.expert_weight,
                "personalization_weight": self.weights.personalization_weight,
            },
            "votes_count": len(votes),
        }

