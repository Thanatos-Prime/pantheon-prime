# SECTION 8 — DISTILLATION PIPELINE
# =============================================================================

class DistillationPipeline:
    """
    Experience -> Patterns -> Heuristics -> Doctrine -> Identity
    """

    def distill(self, ledger: Ledger, sv: StateVector) -> List[str]:
        """
        Compress recent Ledger entries into doctrine fragments.
        Returns list of doctrine strings to merge into SV.doctrine_digest.
        """
        recent = ledger.tail(20)
        if not recent:
            return []

        # Stage 2 — Patterns: tag frequency analysis
        tag_freq: Dict[str, int] = {}
        sc_values: List[float] = []
        for to in recent:
            for tag in to.tags:
                tag_freq[tag] = tag_freq.get(tag, 0) + 1
            sc_values.append(to.sc())

        # Stage 3 — Heuristics: high-frequency tags + SC trend
        top_tags = sorted(tag_freq, key=tag_freq.get, reverse=True)[:3]
        mean_sc = statistics.mean(sc_values) if sc_values else 0.0
        trend = "stable" if len(sc_values) < 2 or statistics.stdev(sc_values) < 0.1 else "volatile"

        # Stage 4 — Doctrine: compressed principle
        doctrine: List[str] = []
        if top_tags:
            doctrine.append(f"Recurring themes: {', '.join(top_tags)}")
        doctrine.append(f"Mean coherence over last {len(recent)} cycles: {mean_sc:.2f} ({trend})")
        if mean_sc < 0.70:
            doctrine.append("Warning: coherence below threshold — review active invariants.")
        return doctrine


