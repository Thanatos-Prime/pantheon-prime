// ── MAIN APP ─────────────────────────────────────────────────────────────────
export default function IFE() {
  const [tab, setTab] = useState("actors");
  const [desc, setDesc] = useState("");
  const [actors, setActors] = useState([]);
  const [constraints, setConsts] = useState([]);
  const [edges, setEdges] = useState([]);
  const [simResult, setSimResult] = useState(null);
  const [simRunning, setSimRunning] = useState(false);
  const [currentStep, setStep] = useState(0);
  const [playing, setPlaying] = useState(false);
  const [aiResult, setAiResult] = useState(null);
  const [aiLoading, setAiLoading] = useState(false);
  const [aiError, setAiError] = useState("");
  const [showTemplates, setShowTemplates] = useState(false);
  const simSteps = 40;
  const playRef = useRef(null);

  useEffect(() => {
    if (playing && simResult) {
      playRef.current = setInterval(() => {
        setStep((s) => {
          if (s >= simResult.frames.length - 1) {
            setPlaying(false);
            return s;
          }
          return s + 1;
        });
      }, 80);
    } else if (playRef.current) {
      clearInterval(playRef.current);
    }

    return () => {
      if (playRef.current) clearInterval(playRef.current);
    };
  }, [playing, simResult]);

  const loadTemplate = (name) => {
    const t = TEMPLATES[name];
    if (!t) return;

    setDesc(t.desc);
    setActors(t.actors.map((a) => ({ ...DEFAULT_ACTOR(), ...a, id: uid() })));
    setConsts(
      t.constraints.map((c) => ({ ...DEFAULT_CONSTRAINT(), ...c, id: uid() }))
    );
    setEdges(
      t.edges.map((e) => ({
        ...DEFAULT_EDGE(t.actors.length),
        ...e,
        id: uid(),
      }))
    );
    setSimResult(null);
    setAiResult(null);
    setAiError("");
    setStep(0);
    setPlaying(false);
    setShowTemplates(false);
    setTab("actors");
  };

  const runSim = useCallback(() => {
    if (actors.length === 0) return;
    setSimRunning(true);

    setTimeout(() => {
      const result = runSimulation(actors, constraints, edges, simSteps);
      setSimResult(result);
      setStep(0);
      setPlaying(false);
      setSimRunning(false);
      setTab("field");
    }, 200);
  }, [actors, constraints, edges]);

  const runAI = async () => {
    if (!simResult) return;
    setAiLoading(true);
    setAiResult(null);
    setAiError("");
    setTab("analysis");

    try {
      const r = await callIFE(desc, actors, constraints, edges, simResult);
      setAiResult(r);
    } catch (e) {
      setAiError(e.message || "Analysis failed.");
    } finally {
      setAiLoading(false);
