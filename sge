@app.post("/governance/aggregate")
def governance_aggregate(request: GovernanceRequest):
    engine = SignalGovernanceEngine()

    for source in request.sources:
        engine.register_source(
            SignalSource(
                source_id=source.source_id,
                source_type=source.source_type,
                predictive_accuracy=source.predictive_accuracy,
                consistency=source.consistency,
                stake=source.stake,
                expertise=source.expertise,
                manipulation_risk=source.manipulation_risk,
                volume=source.volume,
            )
        )

    votes = [
        SignalVote(
            source_id=v.source_id,
            score=v.score,
            confidence=v.confidence,
            personalization_alignment=v.personalization_alignment,
        )
        for v in request.votes
    ]

    invariants = InvariantReport(
        reversibility_ok=request.invariants.get("reversibility_ok", True),
        transparency_ok=request.invariants.get("transparency_ok", True),
        anti_gaming_ok=request.invariants.get("anti_gaming_ok", True),
        consent_ok=request.invariants.get("consent_ok", True),
        coherence_ok=request.invariants.get("coherence_ok", True),
    )

    return engine.aggregate(votes, invariants=invariants)

