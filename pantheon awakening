}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

function spawnParticle() {
  particles.push({
    x: Math.random()*canvas.width,
    y: canvas.height + 10,
    vx: (Math.random()-0.5)*0.5,
    vy: -(0.3+Math.random()*0.8),
    life: 1,
    decay: 0.003+Math.random()*0.004,
    size: Math.random()*2,
    type: Math.random() > 0.7 ? 'gold' : 'rune',
    char: runeChars[Math.floor(Math.random()*runeChars.length)]
  });
}

function animParticles() {
  ctx.clearRect(0,0,canvas.width,canvas.height);
  if (Math.random()<0.3) spawnParticle();
  particles = particles.filter(p=>{
    p.x+=p.vx; p.y+=p.vy; p.life-=p.decay;
    if(p.life<=0) return false;
    if(p.type==='gold'){
      ctx.beginPath();
      ctx.arc(p.x,p.y,p.size,0,Math.PI*2);
      ctx.fillStyle=`rgba(200,144,10,${p.life*0.4})`;
      ctx.fill();
    } else {
      ctx.font=`${10+p.size*4}px 'UnifrakturMaguntia', serif`;
      ctx.fillStyle=`rgba(112,64,192,${p.life*0.3})`;
      ctx.fillText(p.char,p.x,p.y);
    }
    return true;
  });
  requestAnimationFrame(animParticles);
}
