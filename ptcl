class ProblemClassifier:
    """
    Classifies problems into semantic types
    """

    def classify(self, problem: str, context: dict):
        text = problem.lower()

        if any(k in text for k in ["build", "system", "architecture", "module"]):
            return "ARCHITECTURE"

        elif any(k in text for k in ["decide", "should i", "option", "choose"]):
            return "DECISION"

        elif any(k in text for k in ["make money", "invest", "business", "profit"]):
            return "MONETIZATION"

        elif any(k in text for k in ["why", "meaning", "understand", "insight"]):
            return "ANALYSIS"

        elif any(k in text for k in ["write", "content", "story"]):
            return "CREATION"

        else:
            return "GENERAL"


