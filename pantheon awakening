    for(let j=0;j<seg.s.length;j++){
      if(count>=total) break;
      if(seg.t==='system' && j===0) html+='<span class="system-inject">';
      if(seg.t==='bold' && j===0) html+='<strong>';
      html+=seg.s[j]==='\n'?'<br>':seg.s[j];
