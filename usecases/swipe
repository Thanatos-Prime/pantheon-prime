function SwipeCard({ card, onSwipe, isTop, stackIndex }) {
const theme = getTheme(card);
const [drag, setDrag] = useState({ x: 0, y: 0, active: false });
const [expanded, setExpanded] = useState(false);
const [exiting, setExiting] = useState(null);
const startRef = useRef(null);

const rotate = drag.x * 0.07;
const keepOpacity = clamp(drag.x / 90, 0, 1);
const passOpacity = clamp(-drag.x / 90, 0, 1);

const onPointerDown = (e) => {
if (expanded || !isTop) return;
const x = e.clientX ?? e.touches?.[0]?.clientX;
const y = e.clientY ?? e.touches?.[0]?.clientY;
startRef.current = { x, y };
setDrag(d => ({ …d, active: true }));
};

const onPointerMove = useCallback((e) => {
if (!drag.active || !startRef.current) return;
const x = e.clientX ?? e.touches?.[0]?.clientX;
const y = e.clientY ?? e.touches?.[0]?.clientY;
setDrag(d => ({ …d, x: x - startRef.current.x, y: y - startRef.current.y }));
}, [drag.active]);

const onPointerUp = useCallback(() => {
if (!drag.active) return;
if (Math.abs(drag.x) > 90) fire(drag.x > 0 ? “right” : “left”);
else setDrag({ x: 0, y: 0, active: false });
startRef.current = null;
}, [drag]);

const fire = (dir) => {
setExiting(dir);
setTimeout(() => onSwipe(dir, card), 380);
};

useEffect(() => {
if (!drag.active) return;
window.addEventListener(“mousemove”, onPointerMove);
window.addEventListener(“mouseup”, onPointerUp);
window.addEventListener(“touchmove”, onPointerMove, { passive: true });
window.addEventListener(“touchend”, onPointerUp);
return () => {
window.removeEventListener(“mousemove”, onPointerMove);
window.removeEventListener(“mouseup”, onPointerUp);
window.removeEventListener(“touchmove”, onPointerMove);
window.removeEventListener(“touchend”, onPointerUp);
};
}, [drag.active, onPointerMove, onPointerUp]);

const tx = exiting === “right” ? 900 : exiting === “left” ? -900 : drag.x;
const ty = exiting ? -150 : drag.y * 0.35;
const rot = exiting === “right” ? 28 : exiting === “left” ? -28 : rotate;

const rarity = card.rarity || “”;
const rarityColor = rarity.includes(“Illustration”) || rarity.includes(“Special”) ? “#FFD700”
: rarity.includes(“Hyper”) || rarity.includes(“Rainbow”) ? “#FF8A65”
: rarity.includes(“Ultra”) || rarity.includes(“Full Art”) ? “#CE93D8”
: rarity.includes(“Holo”) ? theme.accent
: rarity.includes(“Rare”) ? “#64B5F6”
: “#666”;

return (
<div
onMouseDown={onPointerDown}
onTouchStart={onPointerDown}
onClick={() => { if (!drag.x && isTop) setExpanded(e => !e); }}
style={{
position: “absolute”,
width: “min(360px, 90vw)”,
cursor: drag.active ? “grabbing” : “grab”,
userSelect: “none”,
touchAction: “none”,
zIndex: isTop ? 10 : 10 - stackIndex,
transform: `translate(${tx}px, ${ty}px) rotate(${rot}deg) scale(${isTop ? 1 : 1 - stackIndex * 0.035}) translateY(${stackIndex * 14}px)`,
transition: drag.active ? “none” : exiting
? “transform 0.38s cubic-bezier(0.25,0.46,0.45,0.94)”
: “transform 0.3s cubic-bezier(0.34,1.4,0.64,1)”,
borderRadius: 22,
overflow: “hidden”,
boxShadow: isTop
? `0 28px 70px rgba(0,0,0,0.7), 0 0 50px ${theme.glow}33`
: `0 10px 35px rgba(0,0,0,0.5)`,
filter: isTop ? “none” : `brightness(${1 - stackIndex * 0.12})`,
}}
>
<div style={{
background: `linear-gradient(165deg, ${theme.bg} 0%, #020008 100%)`,
border: `1px solid ${theme.accent}28`,
borderRadius: 22,
overflow: “hidden”,
}}>

