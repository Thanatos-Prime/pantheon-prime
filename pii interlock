Minimal implementation

Here is the smallest usable version.

State model

from dataclasses import dataclass, field
from typing import List, Dict, Any

@dataclass
class WorkState:
    goal: str
    context: List[str] = field(default_factory=list)
    assumptions: List[str] = field(default_factory=list)
    constraints: List[str] = field(default_factory=list)
    candidate_models: List[str] = field(default_factory=list)
    evidence: List[str] = field(default_factory=list)
    risks: List[str] = field(default_factory=list)
    opportunities: List[str] = field(default_factory=list)
    language_notes: List[str] = field(default_factory=list)
    artifact_plan: List[str] = field(default_factory=list)
    open_questions: List[str] = field(default_factory=list)
    confidence: float = 0.25
    termination_status: str = "incomplete"
    provenance: List[Dict[str, Any]] = field(default_factory=list)

Pass result

@dataclass
class PassResult:
    role: str
    adds: Dict[str, List[str]]
    removes: Dict[str, List[str]]
    flags: List[str]
    confidence_delta: float
    reason_for_handoff: str

Merge

def merge_pass_result(state: WorkState, result: PassResult) -> WorkState:
    for key, values in result.adds.items():
        current = getattr(state, key)
        for v in values:
            if v not in current:
                current.append(v)

    for key, values in result.removes.items():
        current = getattr(state, key)
        setattr(state, key, [x for x in current if x not in values])

    state.confidence = max(0.0, min(1.0, state.confidence + result.confidence_delta))
    state.provenance.append({
        "role": result.role,
        "flags": result.flags,
        "handoff": result.reason_for_handoff
    })
    return state


