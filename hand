class PantheonMusicEngine:

def generate(self, prompt: str, style: str):
    meaning = extract_meaning(prompt)
    music_core = map_to_music(meaning)
    styled = apply_style(music_core, style)

    return styled---

📁 4. runtime/models.pydef extract_meaning(prompt: str):

prompt_lower = prompt.lower()

emotions = []
if "guardian" in prompt_lower or "protect" in prompt_lower:
    emotions.append("duty")
if "collapse" in prompt_lower or "fall" in prompt_lower:
    emotions.append("loss")
if "fight" in prompt_lower or "war" in prompt_lower:
    emotions.append("intensity")

if not emotions:
    emotions = ["reflection"]

arc = "rise → tension → peak → resolve"

return {
    "prompt": prompt,
    "emotions": emotions,
    "arc": arc
}

def map_to_music(meaning):
emotions = meaning[“emotions”]

if "intensity" in emotions:
    tempo = 110
    key = "D minor"
else:
    tempo = 85
    key = "A minor"

structure = [
    "intro",
    "build",
    "drop",
    "resolve"
]

palette = [
    "bass pulse",
    "pads",
    "percussion",
    "lead melody"
]

return {
    "title": meaning["prompt"][:30],
    "tempo": tempo,
    "key": key,
    "structure": structure,
    "palette": palette,
    "emotions": emotions
}

def apply_style(core, style):
core[“style”] = style

if "rock" in style:
    core["palette"].append("distorted guitar")
if "cinematic" in style:
    core["palette"].append("strings")
if "trap" in style:
    core["palette"].append("808 drums")

core["hook"] = f"A central phrase reflecting {', '.join(core['emotions'])}"

return core---

