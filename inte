            "justification": "prior convergence session",
            "references": [],
            "asserts_trust_without_evidence": True,
        },
        tags=["convergence", "claim"],
    )

    result = sigma_c_gate(untested_claim, sv)
    append_to_ledger(untested_claim, result)
    print(result)
