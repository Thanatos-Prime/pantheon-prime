9. Artifact Generation Logic

After enough comparisons, create a taste profile.

Minimal rule-based version

def generate_taste_profile(top_entities: list[dict]) -> dict:
    tags = []
    for entity in top_entities:
        tags.extend(entity.get("tags", []))
    tag_counts = {}
    for tag in tags:
        tag_counts[tag] = tag_counts.get(tag, 0) + 1
    sorted_tags = sorted(tag_counts.items(), key=lambda x: x[1], reverse=True)
    primary_style = "-".join([tag for tag, _ in sorted_tags[:2]]) if sorted_tags else "unclear"
    return {
        "primary_style": primary_style,
        "top_entities": [e["name"] for e in top_entities[:3]]
    }

