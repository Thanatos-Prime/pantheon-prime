let loopAutoStep = 0;
function autoAdvanceLoop() {
  loopAutoStep = (loopAutoStep + 1) % LOOP_STEPS.length;
  LOOP_STEPS.forEach((_,i) => {
    const el = document.getElementById('ls_' + i);
    if (!el) return;
    el.className = 'step-node' + (i < loopAutoStep ? ' done' : i === loopAutoStep ? ' current' : '');
  });
  document.getElementById('loopStatus').textContent = 'RUNNING: ' + LOOP_STEPS[loopAutoStep];
  if (loopAutoStep === 0) {
    LOOP_STEPS.forEach((_,i) => {
      const el = document.getElementById('ls_' + i);
      if (el) el.className = 'step-node';
    });
  }
}

let oasaStep = 0;
function advanceOASA() {
  for (let i=0;i<4;i++) document.getElementById('oasa'+i).classList.remove('active');
