Minimal repo-ready spec

class TransitionEvent:
    def __init__(self, prior, actor, context, claim, mechanism, result):
        self.prior = prior
        self.actor = actor
        self.context = context
        self.claim = claim          # "what it says it's doing"
        self.mechanism = mechanism  # "what actually happened"
        self.result = result

class Anubis:
    def score(self, e):
        checks = {
            "continuity": self.context_ok(e),
            "coherence": self.coherence_ok(e),
            "proportionality": self.proportional(e),
            "mechanism_vs_claim": self.matches(e),
            "reversible": self.reversible(e),
        }
        failures = [k for k,v in checks.items() if not v]
        if len(failures) >= 2:
            return {"action": "step_up_or_block", "failures": failures}
        return {"action": "allow_with_trace", "failures": failures}


