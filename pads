from dataclasses import dataclass
from typing import Dict, Any, Callable

from uncertainty_estimator import UncertaintyEstimator
from depth_controller import DepthController
from recursive_reasoner import RecursiveReasoner, RecursiveResult
from termination_gate import TerminationGate


@dataclass
class AdaptiveDepthOutput:
    profile: Dict[str, Any]
    policy: Dict[str, Any]
    result: Dict[str, Any]
    artifact: Dict[str, Any]


class AdaptiveDepthSystem:
    """
    Pantheon Adaptive Depth System v1.0

    Flow:
      estimate uncertainty -> choose depth policy -> recurse to needed depth
      -> stop on convergence / degradation -> emit artifact
    """

    def __init__(self):
        self.estimator = UncertaintyEstimator()
        self.controller = DepthController()
        self.reasoner = RecursiveReasoner()
        self.termination_gate = TerminationGate()

    def run(
        self,
        problem: str,
        context: Dict[str, Any],
        processor: Callable[[str], Dict[str, Any]]
    ) -> AdaptiveDepthOutput:
        profile = self.estimator.estimate(context)
        policy = self.controller.decide(profile)

        recursive_result: RecursiveResult = self.reasoner.run(
            problem=problem,
            processor=processor,
            max_depth=policy.depth
        )

        stop = self.termination_gate.evaluate(recursive_result.passes)

        artifact = self._build_artifact(problem, profile, policy, recursive_result, stop)

        return AdaptiveDepthOutput(
            profile={
                "uncertainty": profile.uncertainty,
                "impact": profile.impact,
                "conflict": profile.conflict,
                "evidence_quality": profile.evidence_quality,
                "novelty": profile.novelty,
                "recommended_depth": profile.recommended_depth,
                "reasons": profile.reasons,
            },
            policy={
                "depth": policy.depth,
                "require_grounding": policy.require_grounding,
                "require_external_check": policy.require_external_check,
                "require_artifact": policy.require_artifact,
                "notes": policy.notes,
            },
            result={
                "final_output": recursive_result.final_output,
                "final_confidence": recursive_result.final_confidence,
                "converged": recursive_result.converged,
                "num_passes": len(recursive_result.passes),
                "stop_reason": stop.reason,
            },
            artifact=artifact
        )

    def _build_artifact(self, problem, profile, policy, recursive_result, stop):
        return {
            "problem": problem,
            "summary": recursive_result.final_output,
            "actionability": "high" if policy.require_artifact else "low",
            "grounding_required": policy.require_grounding,
            "external_check_required": policy.require_external_check,
            "passes_used": len(recursive_result.passes),
            "stop_reason": stop.reason,
            "invariant": "Increase depth only when warranted by uncertainty, stakes, or conflict",
        }


