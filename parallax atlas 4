function drawSky(){
  const W=skyC.width,H=skyC.height,cx=W/2,cy=H/2;
  skX.clearRect(0,0,W,H);
  const bg=skX.createRadialGradient(cx,cy,0,cx,cy,cx);
  bg.addColorStop(0,'rgba(11,15,28,.96)');bg.addColorStop(1,'rgba(5,7,14,.98)');
  skX.fillStyle=bg;skX.fillRect(0,0,W,H);

  const SCALE=cx*.88/39.5;

  // zodiac ring
  ZOD12.forEach(z=>{
    const a1=(z.s-90)*D2R,a2=(z.e-90)*D2R;
    skX.beginPath();skX.moveTo(cx,cy);
    skX.arc(cx,cy,cx*.93,a1,a2);skX.closePath();
    const ec={'Fire':'rgba(200,80,30,.06)','Earth':'rgba(60,150,60,.06)','Air':'rgba(60,140,210,.06)','Water':'rgba(40,60,200,.06)'};
    skX.fillStyle=ec[z.el];skX.fill();
    skX.strokeStyle='rgba(100,130,200,.07)';skX.lineWidth=.5;skX.stroke();
    const mid=(z.s+z.e)/2-90;
    skX.fillStyle='rgba(100,130,180,.35)';skX.font=`${W*.018}px serif`;
    skX.textAlign='center';skX.textBaseline='middle';
    skX.fillText(z.sym,cx+(cx*.9)*Math.cos(mid*D2R),cy+(cx*.9)*Math.sin(mid*D2R));
  });

  // orbits
  BODIES.forEach(n=>{
    const p=EL[n];
    // For elliptical orbits, draw approximated orbit ring at semi-major axis
    const isObs=n===S.obs;
    skX.beginPath();skX.arc(cx,cy,p.a*SCALE,0,Math.PI*2);
    skX.strokeStyle=isObs?'rgba(200,150,26,.28)':'rgba(100,130,200,.07)';
    skX.lineWidth=isObs?1.2:.5;
    skX.setLineDash(isObs?[]:([2,4]));skX.stroke();skX.setLineDash([]);
  });

  // Sun
  const sg=skX.createRadialGradient(cx,cy,0,cx,cy,16);
  sg.addColorStop(0,'rgba(255,248,200,.98)');sg.addColorStop(.5,'rgba(255,200,60,.6)');sg.addColorStop(1,'transparent');
  skX.beginPath();skX.arc(cx,cy,10,0,Math.PI*2);skX.fillStyle=sg;skX.fill();
  skX.fillStyle='rgba(255,248,180,.85)';skX.font=`${W*.022}px serif`;
  skX.textAlign='center';skX.textBaseline='middle';skX.fillText('☉',cx,cy);

  const op=helioXYZ(S.obs,S.t);
  const ox=cx+op[0]*SCALE,oy=cy-op[1]*SCALE;

  // glare cone
  const sunAng=Math.atan2(op[1],op[0])+Math.PI;
  const coneR=20*D2R;
  skX.save();skX.globalAlpha=.05;
  skX.beginPath();skX.moveTo(ox,oy);
  skX.arc(ox,oy,cx*.14,-sunAng-coneR,-sunAng+coneR);
  skX.closePath();skX.fillStyle='#ff7030';skX.fill();
  skX.globalAlpha=1;skX.restore();

  BODIES.forEach(n=>{
    const pos=helioXYZ(n,S.t);
    const px=cx+pos[0]*SCALE,py=cy-pos[1]*SCALE;
    const ph=PHYS[n];
    const isObs=n===S.obs;
    const r=isObs?7:Math.max(2,Math.log(ph.R+1)*2.6);

    if(isObs){
      const g=skX.createRadialGradient(px,py,0,px,py,22);
      g.addColorStop(0,ph.col+'66');g.addColorStop(1,'transparent');
      skX.beginPath();skX.arc(px,py,22,0,Math.PI*2);skX.fillStyle=g;skX.fill();
    }
    skX.beginPath();skX.arc(px,py,r,0,Math.PI*2);skX.fillStyle=ph.col;skX.fill();

    if(!isObs){
      const rel=[pos[0]-op[0],pos[1]-op[1],pos[2]-op[2]];
      const dist=Math.hypot(rel[0],rel[1],rel[2]);
      const sLen=Math.hypot(op[0],op[1],op[2]);
      const cosE=(rel[0]*(-op[0]/sLen)+rel[1]*(-op[1]/sLen)+rel[2]*(-op[2]/sLen))/dist;
      const elong=Math.acos(Math.max(-1,Math.min(1,cosE)))*180/Math.PI;
      const vis=elong>=S.elongVis;
      skX.beginPath();skX.moveTo(ox,oy);skX.lineTo(px,py);
      skX.strokeStyle=vis?'rgba(61,186,110,.12)':'rgba(232,80,48,.07)';
      skX.lineWidth=.5;skX.stroke();
    }

    skX.fillStyle=isObs?'#ccd8ec':'rgba(140,160,200,.5)';
    skX.font=`${isObs?'bold ':''} ${W*.013}px "IBM Plex Mono"`;
    skX.textAlign='center';skX.textBaseline='bottom';
    skX.fillText(n.substring(0,3).toUpperCase(),px,py-r-3);

    if(isObs){
      skX.beginPath();skX.arc(ox,oy,11,0,Math.PI*2);
      skX.strokeStyle='rgba(212,150,26,.7)';skX.lineWidth=1.5;skX.stroke();
    }
  });
}

