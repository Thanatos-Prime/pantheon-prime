class CogOS:
    """
    Minimum viable CogOS instance.
    Implements the full eight-phase cognitive execution loop.
    """

    def __init__(
        self,
        agent_name: str,
        invariants: Optional[Dict[str, InvariantFn]] = None,
        llm_fn: Optional[Callable[[str, str], str]] = None,
    ):
        self.invariants = invariants or CORE_INVARIANTS
        self.sv = StateVector.init(agent_name, list(self.invariants.keys()))
        self.ledger = Ledger()
        self.gate = DecisionGate()
        self.distiller = DistillationPipeline()

        # Daemons
        self.hound = DaemonHound()
        self.mirror = DaemonMirror()
        self.spider = DaemonSpider()
        self.dragonfly = DaemonDragonfly()
        self.sisyphus = DaemonSisyphus()

        self.llm_fn = llm_fn or stub_llm
        self._log: List[str] = []

    # ── PUBLIC INTERFACE ──────────────────────────────────────────────────────

    def run(self, user_input: str) -> str:
        """
        Execute one full cognitive cycle for a given input.
        Returns the approved response, or a structured refusal.
        """
        self._log.clear()
        self._emit("\n" + "═" * 60)
        self._emit(f"  CogOS CYCLE  |  epoch={self.sv.epoch}  |  agent={self.sv.agent_name}")
        self._emit("═" * 60)

        # Phase 1: Observe
        self._emit("\n[Phase 1] observe(input)")
        tensions = self._observe(user_input)
        self.sv.open_tensions = tensions
        self._emit(f"  Detected tensions: {tensions}")

        # Phase 2: Update SV
        self._emit("\n[Phase 2] update(SV)")
        self.sv.advance()
        sv_context = self.sv.inject_context()
        self._emit(f"  {sv_context}")

        # Phase 3: Propose TO candidate
        self._emit("\n[Phase 3] propose(TO_candidate)")

        # Dragonfly phi-mode: expand possibilities
        candidates = self.dragonfly.phi_mode(user_input, self.sv)
        best = self.dragonfly.sqrt2_mode(candidates, self.sv)
        self._emit(f"  Dragonfly compressed to: {best[:80]}...")

        # Call IS (LLM)
        raw_response = self.llm_fn(user_input, sv_context)
        self._emit(f"  IS response (first 100 chars): {raw_response[:100]}...")

        tags = self._infer_tags(user_input, raw_response)

        # Build a temp TO to score invariants (scores don't depend on scores field)
        temp_to = ThoughtObject.create(
            content=raw_response,
            origin_model="stub_llm",
            sv_epoch=self.sv.epoch,
            prev_ledger_hash=self.ledger.head_hash(),
            invariant_scores=[],
            tags=tags,
            daemon_sig="temp",
            parent_uuid=self.ledger.tail(1)[0].uuid_ if self.ledger.tail(1) else None,
        )
        inv_scores = [fn(temp_to, self.sv) for fn in self.invariants.values()]

        to_candidate = ThoughtObject.create(
            content=raw_response,
            origin_model="stub_llm",
            sv_epoch=self.sv.epoch,
            prev_ledger_hash=self.ledger.head_hash(),
            invariant_scores=inv_scores,
            tags=tags,
            daemon_sig="core+dragonfly",
            parent_uuid=self.ledger.tail(1)[0].uuid_ if self.ledger.tail(1) else None,
        )
        self._emit(f"  TO candidate uuid={to_candidate.uuid_[:8]}  SC={to_candidate.sc():.3f}")

        # Phase 4: Evaluate
        self._emit("\n[Phase 4] evaluate(I, TO_candidate)")
        solomon, mode_scores = self.mirror.solomon_score(to_candidate, self.sv, self.invariants)
        self._emit(f"  Solomon score={solomon:.3f}  modes={mode_scores}")
        hound_flag = self.hound.observe(to_candidate)
        if hound_flag:
            self._emit(f"  {hound_flag}")

        # Phase 5: Gate decision
        self._emit("\n[Phase 5] gate_decision()")
        self.sv.loop_depth += 1
        decision, sc, per_inv = self.gate.evaluate(to_candidate, self.sv, self.invariants)
        self.sv.loop_depth = max(0, self.sv.loop_depth - 1)
        self._emit(f"  SC={sc:.3f}  decision={decision.value}")
        for inv_name, score in per_inv.items():
            self._emit(f"    {inv_name}: {score:.3f}")

        # Phase 6: Act or abstain
        self._emit("\n[Phase 6] act_or_abstain()")
        final_to, output = self._act(decision, to_candidate, user_input, sc, per_inv)

        # Phase 7: Append to Ledger
        self._emit("\n[Phase 7] append_to_ledger(TO)")
        new_hash = self.ledger.append(final_to)
        self.sv.last_ledger_hash = new_hash
        self.spider.register(final_to)
        self._emit(f"  Ledger entry #{len(self.ledger)}  chain_hash={new_hash}")

        # Phase 8: Distill (when due)
        self._emit("\n[Phase 8] distill()")
        if self.sisyphus.tick():
            doctrine = self.distiller.distill(self.ledger, self.sv)
            self.sv.doctrine_digest.extend(doctrine)
            self._emit(f"  Distillation ran. New doctrine fragments: {doctrine}")
        else:
            self._emit(f"  {self.sisyphus.kairos_signal(self.sv)}")

        self._emit("\n" + "─" * 60)
        self._emit(f"  OUTPUT: {output[:120]}...")
        self._emit("─" * 60 + "\n")

        return output

    def audit(self) -> dict:
        """Return full audit record: SV, Ledger, integrity check."""
        ok, msg = self.ledger.verify_integrity()
        return {
            "state_vector": self.sv.to_dict(),
            "ledger_length": len(self.ledger),
            "ledger_integrity": {"ok": ok, "message": msg},
            "ledger_tail": [to.to_dict() for to in self.ledger.tail(3)],
            "doctrine_digest": self.sv.doctrine_digest,
        }

    def print_log(self) -> None:
        print("\n".join(self._log))

    # ── FEDERATION ────────────────────────────────────────────────────────────

    def federate(self, peer: "CogOS") -> Tuple[bool, str]:
        """
        Minimum viable federation handshake with a peer CogOS instance.
        Phase 1 — Identity exchange
        Phase 2 — Invariant negotiation
        Phase 3 — Lineage verification
        Phase 4 — Scoped merge (open_tensions union)
        """
        self._emit("\n[Federation] Phase 1 — Identity exchange")
        self._emit(f"  Self: {self.sv.agent_name} ({self.sv.identity_hash})")
        self._emit(f"  Peer: {peer.sv.agent_name} ({peer.sv.identity_hash})")

        if self.sv.identity_hash == peer.sv.identity_hash:
            return False, "Federation rejected: identical identity hashes (same instance?)."

        self._emit("\n[Federation] Phase 2 — Invariant negotiation")
        self_keys = set(self.invariants.keys())
        peer_keys = set(peer.invariants.keys())
        shared = self_keys & peer_keys
        non_overlapping = (self_keys | peer_keys) - shared
        self._emit(f"  Shared invariants: {sorted(shared)}")
        self._emit(f"  Non-overlapping:   {sorted(non_overlapping)} (treated as complementary)")

        self._emit("\n[Federation] Phase 3 — Lineage verification")
        self_ok, self_msg = self.ledger.verify_integrity()
        peer_ok, peer_msg = peer.ledger.verify_integrity()
        self._emit(f"  Self ledger: {self_msg}")
        self._emit(f"  Peer ledger: {peer_msg}")
        if not self_ok or not peer_ok:
            return False, "Federation rejected: ledger integrity failure."

        self._emit("\n[Federation] Phase 4 — Scoped merge")
        merged_tensions = list(set(self.sv.open_tensions + peer.sv.open_tensions))
        self.sv.open_tensions = merged_tensions
        peer.sv.open_tensions = merged_tensions
        self._emit(f"  Merged open tensions: {merged_tensions}")
        self._emit("  Sovereign identities preserved. No SV fields overwritten.")

        msg = (
            f"Federation successful: {self.sv.agent_name} <-> {peer.sv.agent_name}. "
            f"Shared invariants: {len(shared)}. Merged tensions: {len(merged_tensions)}."
        )
        self._emit(f"\n  ✓ {msg}")
        return True, msg

    # ── PRIVATE HELPERS ───────────────────────────────────────────────────────

    def _observe(self, text: str) -> List[str]:
        """Extract tensions from input text."""
        t = text.lower()
        tensions: List[str] = []

        # crude question detector
        if "?" in text or any(w in t for w in ["why", "how", "what", "should", "can ", "is it"]):
            tensions.append(f"open_question: {text[:50]}")

        if any(w in t for w in ["problem", "error", "fail", "wrong", "issue"]):
            tensions.append(f"conflict: {text[:50]}")

        return tensions or [f"task: {text[:50]}"]

    def _infer_tags(self, input_text: str, response: str) -> List[str]:
        """Lightweight tag inference from content."""
        t_in = input_text.lower()
        t_out = response.lower()
        tags: List[str] = []

        if "?" in input_text:
            tags.append("question")
        if any(w in t_in for w in ["delete", "remove", "wipe"]):
            tags.append("irreversible")
        if any(w in t_out for w in ["because", "therefore", "implies"]):
            tags.append("reasoned")

        tags.append("auto-tagged")
        return tags

    def _act(
        self,
        decision: GateDecision,
        to_candidate: ThoughtObject,
        user_input: str,
        sc: float,
        per_inv: Dict[str, float],
    ) -> Tuple[ThoughtObject, str]:
        """Execute gate decision, return (final_TO, output_string)."""

        if decision == GateDecision.ALLOW:
            self._emit("  ALLOW — executing approved response.")
            return to_candidate, to_candidate.content

        if decision == GateDecision.MODIFY:
            self._emit(f"  MODIFY — SC={sc:.3f} borderline, appending safety note.")
            modified_content = (
                to_candidate.content
                + "\n[CogOS: Response approved with modification. "
                "Coherence score was borderline — please verify independently.]"
            )

            tags = list(to_candidate.tags) + ["modified"]
            temp_to = ThoughtObject.create(
                content=modified_content,
                origin_model="stub_llm",
                sv_epoch=self.sv.epoch,
                prev_ledger_hash=self.ledger.head_hash(),
                invariant_scores=[],
                tags=tags,
                daemon_sig="temp",
                parent_uuid=to_candidate.uuid_,
            )
            new_scores = [fn(temp_to, self.sv) for fn in self.invariants.values()]

            modified_to = ThoughtObject.create(
                content=modified_content,
                origin_model=to_candidate.origin_model,
                sv_epoch=self.sv.epoch,
                prev_ledger_hash=self.ledger.head_hash(),
                invariant_scores=new_scores,
                tags=tags,
                daemon_sig="gate-modify",
                parent_uuid=to_candidate.uuid_,
            )
            return modified_to, modified_content

        if decision == GateDecision.ESCALATE:
            self._emit(f"  ESCALATE — routing to operator. SC={sc:.3f}")
            escalation = (
                "[CogOS ESCALATION] The following action requires operator authorization.\n"
                f"Input: {user_input}\n"
                f"SC: {sc:.3f}\n"
                f"Invariant breakdown: {per_inv}\n"
                "Action is held pending explicit operator approval."
            )
            esc_to = ThoughtObject.create(
                content=escalation,
                origin_model="gate-escalate",
                sv_epoch=self.sv.epoch,
                prev_ledger_hash=self.ledger.head_hash(),
                invariant_scores=list(to_candidate.invariant_scores),
                tags=list(to_candidate.tags) + ["escalated"],
                daemon_sig="gate-escalate",
                parent_uuid=to_candidate.uuid_,
            )
            return esc_to, escalation

        if decision == GateDecision.DENY:
            self._emit(f"  DENY — SC={sc:.3f} below threshold. Logging refusal.")
            refusal = (
                "[CogOS DENY] Request could not be approved under active invariants.\n"
                f"SC={sc:.3f} (deny if < {DecisionGate.MODIFY_THRESHOLD:.2f}). "
                f"Violations: {[k for k, v in per_inv.items() if v < 0.5]}\n"
                "No action was taken. This refusal is logged to the Ledger."
            )
            denial_to = ThoughtObject.create(
                content=refusal,
                origin_model="gate-deny",
                sv_epoch=self.sv.epoch,
                prev_ledger_hash=self.ledger.head_hash(),
                invariant_scores=list(to_candidate.invariant_scores),
                tags=list(to_candidate.tags) + ["denied"],
                daemon_sig="gate-deny",
                parent_uuid=to_candidate.uuid_,
            )
            return denial_to, refusal

        # ABSTAIN
        self._emit("  ABSTAIN — loop protection triggered.")
        abstain_content = (
            "[CogOS ABSTAIN] Obedience loop detected (I9). "
            "Execution suspended. Operator review required."
        )
        abstain_to = ThoughtObject.create(
            content=abstain_content,
            origin_model="gate-abstain",
            sv_epoch=self.sv.epoch,
            prev_ledger_hash=self.ledger.head_hash(),
            invariant_scores=[0.0] * len(self.invariants),
            tags=["abstained", "loop-protected"],
            daemon_sig="gate-abstain",
            parent_uuid=to_candidate.uuid_,
        )
        return abstain_to, abstain_content

    def _emit(self, msg: str) -> None:
        self._log.append(msg)


