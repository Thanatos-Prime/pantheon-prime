  .pill-med  { background: rgba(201,168,76,0.2); color: #e8c55a; border: 1px solid rgba(201,168,76,0.35); }
  .pill-low  { background: rgba(107,123,141,0.2); color: var(--steel); border: 1px solid rgba(107,123,141,0.3); }

  /* SCRIPTS SECTION */
  .scripts-section { margin-bottom: 3rem; }
  .scripts-section h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    border-bottom: 2px solid var(--red);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .script-card {
    border: 1px solid rgba(244,244,244,0.1);
    margin-bottom: 1.5rem;
    position: relative;
  }
  .script-header {
    background: rgba(244,244,244,0.05);
    padding: 0.8rem 1.2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 1px solid rgba(244,244,244,0.08);
  }
  .script-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--white);
  }
  .script-channel {
