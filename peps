D. routing/

Signal detection and profile selection.

routing_rules.yaml

rules:
  - if:
      uncertainty: high
      stakes: high
    then:
      profile: Auditor

  - if:
      uncertainty: high
      stakes: low
    then:
      profile: Explorer

  - if:
      time_pressure: high
    then:
      profile: Operator

  - if:
      progress: stalled
    then:
      profile: Explorer

  - if:
      drift_detected: true
    then:
      profile: Strategist


