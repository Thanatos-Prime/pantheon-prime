def normalize(user_input: str, context: Optional[List[str]] = None) -> WorkState:
“”“Ingest raw input, normalize into WorkState.”””
return WorkState(
goal=user_input.strip(),
context=context or [],
)

def merge_pass_result(state: WorkState, result: PassResult) -> WorkState:
“”“Merge a role’s PassResult into the shared WorkState. Append-only on provenance.”””
for key, values in result.adds.items():
if hasattr(state, key):
current = getattr(state, key)
if isinstance(current, list):
for v in values:
if v not in current:
current.append(v)

```
for key, values in result.removes.items():
    if hasattr(state, key):
        current = getattr(state, key)
        if isinstance(current, list):
            setattr(state, key, [x for x in current if x not in values])

state.confidence = max(0.0, min(1.0, state.confidence + result.confidence_delta))

state.provenance.append({
    "role": result.role,
    "flags": result.flags,
    "handoff": result.reason_for_handoff,
    "confidence_after": round(state.confidence, 3),
    "timestamp": datetime.utcnow().isoformat(),
})

if result.force_terminate:
    state.termination_status = TerminationStatus.FORCED_STOP

return state
```

