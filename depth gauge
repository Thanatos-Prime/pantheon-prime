from __future__ import annotations

import json
from dataclasses import dataclass, asdict
from pathlib import Path
from typing import Any, Dict, List, Optional


@dataclass
class DepthRecord:
    problem_signature: str
    uncertainty: float
    impact: float
    conflict: float
    evidence_quality: float
    novelty: float

    recommended_depth: int
    chosen_depth: int
    passes_used: int

    grounding_required: bool
    external_check_required: bool

    final_confidence: float
    converged: bool

    artifact_quality: float        # 0.0 - 1.0
    external_result_score: float   # 0.0 - 1.0
    overall_outcome_score: float   # 0.0 - 1.0

    notes: Optional[str] = None


class DepthMemory:
    """
    Persistent storage for depth decision history.
    """

    def __init__(self, memory_path: str = "depth_memory.jsonl"):
        self.memory_path = Path(memory_path)
        self.memory_path.parent.mkdir(parents=True, exist_ok=True)

    def append(self, record: DepthRecord) -> None:
        with self.memory_path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(asdict(record), ensure_ascii=False) + "\n")

    def load_all(self) -> List[DepthRecord]:
        if not self.memory_path.exists():
            return []

        records: List[DepthRecord] = []
        with self.memory_path.open("r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                data = json.loads(line)
                records.append(DepthRecord(**data))
        return records

    def query_by_signature(self, problem_signature: str) -> List[DepthRecord]:
        return [
            r for r in self.load_all()
            if r.problem_signature == problem_signature
        ]


