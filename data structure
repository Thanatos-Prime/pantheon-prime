4. Raw data / stream layer

DataStream

A stream is a category pipe, not an individual event.

interface DataStream {
  id: string;
  userId: UserID;
  sourceId: string;

  streamType:
    | "sleep"
    | "heart_rate"
    | "steps"
    | "purchase"
    | "search"
    | "location_trace"
    | "nutrition"
    | "workout"
    | "media_preference"
    | "survey_response"
    | "clinical_outcome";

  unit?: string; // bpm, count, usd, hours, etc.
  frequency: "realtime" | "hourly" | "daily" | "weekly" | "event_based";
  sensitivity: "low" | "medium" | "high" | "regulated";

  qualityScore: number;
  freshnessScore: number;
  rarityScore: number;

  status: "active" | "paused" | "archived";
  createdAt: string;
  updatedAt: string;
}


⸻

RawDataEvent

This is the immutable ledger of incoming signal.

interface RawDataEvent {
  id: string;
  streamId: string;
  userId: UserID;
  sourceId: string;

  observedAt: string;
  ingestedAt: string;

  payloadRef: string; // pointer to encrypted blob/object storage
  checksum: string;

  schemaVersion: string;
  verificationLevel: "raw" | "validated" | "cross_checked";

  privacyClass: "standard" | "sensitive" | "restricted";
}

Use payloadRef instead of stuffing giant JSON blobs in your main table.

⸻

5. Processed signal layer

SignalUnit

This is the first major primitive.

A SignalUnit is a normalized, permissioned, quality-scored atom of usable signal.

interface SignalUnit {
  id: string;
  userId: UserID;
  streamId: string;
  rawEventId?: string;

  signalType:
    | "health_activity"
    | "recovery"
    | "purchase_intent"
    | "brand_affinity"
    | "location_pattern"
    | "sleep_regularity"
    | "expert_label"
    | "outcome_signal"
    | "preference_signal";

  valueType: "numeric" | "categorical" | "vector" | "boolean" | "embedding";
  valueRef: string; // encrypted or structured pointer

  normalizedScore?: number;
  qualityScore: number;
  rarityScore: number;
  freshnessScore: number;
  trustScore: number;

  consentProfileId: string;
  transformTraceId: string;

  validFrom: string;
  validTo?: string;
  createdAt: string;
}


⸻

TransformTrace

This is how you preserve provenance.

interface TransformTrace {
  id: string;

  inputType: "raw_event" | "signal_unit" | "aggregate";
  inputRefs: string[];

  transformKind:
    | "normalize"
    | "aggregate"
    | "anonymize"
    | "feature_extract"
    | "quality_score"
    | "rarity_score"
    | "embedding"
    | "cross_domain_map";

  algorithmVersion: string;
  executedAt: string;

  outputRefs: string[];
  checksum: string;
}

This links directly to your provenance / Merkle style doctrine.

