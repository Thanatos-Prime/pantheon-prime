⚙️ engine.js (logic layer)

export function normalizeGraph(data) {
  return data.nodes.map(n => ({
    ...n,
    size: 0.5 + n.weight,
    glow: n.activity,
    color: getColor(n.category)
  }));
}
function getColor(category) {
  const map = {
    core: 0x00ffff,
    finance: 0xffd700,
    strategy: 0xff00ff
  };
  return map[category] || 0xffffff;
}

⸻

🎨 renderer.js (visual layer)

export function applyVisuals(mesh, node) {
  mesh.scale.setScalar(node.size);
  mesh.material.emissive.setHex(node.color);
  mesh.material.emissiveIntensity = node.glow;
}

