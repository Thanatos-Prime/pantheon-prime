<script>
// ═══════════════════════════════════════════════════════════
// STAR FIELD
// ═══════════════════════════════════════════════════════════
(()=>{
  const c=document.getElementById('sf'),x=c.getContext('2d');
  function rng(s){let v=s;return()=>{v=(v^v<<13)>>>0;v=(v^v>>17)>>>0;v=(v^v<<5)>>>0;return v/4294967296;};}
  function draw(){
    c.width=innerWidth;c.height=innerHeight;
    const r=rng(9973);
    for(let i=0;i<500;i++){
      const px=r()*c.width,py=r()*c.height,rad=r()*1.4;
      const a=.1+r()*.55;
      const hue=210+r()*40;
      x.beginPath();x.arc(px,py,rad,0,Math.PI*2);
      x.fillStyle=`hsla(${hue},60%,90%,${a})`;x.fill();
    }
    // milky way smear
    for(let i=0;i<80;i++){
      const px=r()*c.width,py=r()*(c.height*.6)+c.height*.1,w=r()*40+10,h=r()*6+2;
      x.fillStyle=`rgba(180,200,255,${r()*.04})`;
      x.fillRect(px,py,w,h);
    }
  }
  draw();window.addEventListener('resize',draw);
})();

// ═══════════════════════════════════════════════════════════
// PLANET DATA
