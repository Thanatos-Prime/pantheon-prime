## 12. Validator Pseudocode

```text
FUNCTION evaluate_repair(round):

    validation.intuitive_resonance =
        compare_mirror_to_common_usage(round.word, round.mirror)

    validation.distinctness =
        1 - mean_pairwise_semantic_overlap(round.fragments)

    validation.coverage =
        estimate_major_meanings_covered(round.word, round.fragments)

    validation.coherence =
        graph_coherence(round.fragments, round.seams)

    validation.usefulness =
        estimate_decision_or_explanatory_gain(round)

    validation.compression_quality =
        score_compression(
            original_structure=round.semantic_graph,
            compressed=round.zpc.compact_representation
        )

    validation.reconstructability =
        blind_reconstruction_test(round.zpc)

    validation.novelty =
        compare_against_lexicon(round)

    validation.cross_domain_transfer =
        evaluate_transfer_test(round.transfer_test)

    validation.penalties = []

    IF has_redundant_fragments(round):
        validation.penalties.add("redundancy", severity)

    IF uses_jargon_without_gain(round):
        validation.penalties.add("unsupported_jargon", severity)

    IF mirror_is_missing(round):
        validation.penalties.add("missing_mirror", severity)

    IF false_precision_detected(round):
        validation.penalties.add("false_precision", severity)

    IF unexplained_overlap_exists(round):
        validation.penalties.add("unrepaired_overlap", severity)

    RETURN validation
```

