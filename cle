5. Rhythm Loop (Cymatic Loop)

This replaces a purely mechanical loop with a timed one.

def cymatic_tick(state):
    phase = state["rhythm_phase"]
    if phase == "observe":
        state = observe(state)
    elif phase == "interpret":
        state = interpret(state)
    elif phase == "execute":
        action = resolve_tension(state)
        state = execute(action, state)
    elif phase == "reflect":
        state = evaluate(state)
    elif phase == "rest":
        state = idle(state)
    state["rhythm_phase"] = next_phase(phase)
    return state

