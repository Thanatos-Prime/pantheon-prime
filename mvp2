"use client";

import { useRef, useState } from "react";

interface UploadVisionProps {
  imageSummaries: string[];
  onSummariesChange: (summaries: string[]) => void;
}

async function fileToDataUrl(file: File): Promise<string> {
  return await new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(String(reader.result));
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

export default function UploadVision({
  imageSummaries,
  onSummariesChange,
}: UploadVisionProps) {
  const inputRef = useRef<HTMLInputElement | null>(null);
  const [previewUrls, setPreviewUrls] = useState<string[]>([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  async function handleFiles(files: FileList | null) {
    if (!files || files.length === 0) return;

    setLoading(true);
    setError("");

    try {
      const selected = Array.from(files).slice(0, 5);

      const invalid = selected.find(
        (file) => !["image/png", "image/jpeg", "image/webp"].includes(file.type)
      );

      if (invalid) {
        throw new Error("Only PNG, JPEG, and WEBP images are supported.");
      }

      const dataUrls = await Promise.all(selected.map(fileToDataUrl));
      setPreviewUrls(dataUrls);

      const res = await fetch("/api/analyze-images", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ images: dataUrls }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || "Failed to analyze images");
      }

      onSummariesChange(data.summaries);
    } catch (err) {
      setError(err instanceof Error ? err.message : "Unknown upload error");
    } finally {
      setLoading(false);
    }
  }

  return (
    <section className="space-y-4 rounded-2xl border p-4">
      <div className="space-y-1">
        <h2 className="text-lg font-semibold">Vision Images</h2>
        <p className="text-sm text-neutral-400">
          Upload up to 5 inspiration images. The app will turn them into planning signals.
        </p>
      </div>

      <input
        ref={inputRef}
        type="file"
        accept="image/png,image/jpeg,image/webp"
        multiple
        className="block w-full rounded-xl border p-3"
        onChange={(e) => handleFiles(e.target.files)}
      />

      {loading && (
        <p className="text-sm text-neutral-400">Analyzing images...</p>
      )}

      {error && <p className="text-sm text-red-400">{error}</p>}

      {previewUrls.length > 0 && (
        <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
          {previewUrls.map((url, idx) => (
            <img
              key={idx}
              src={url}
              alt={`Vision preview ${idx + 1}`}
              className="h-32 w-full rounded-xl object-cover border"
            />
          ))}
        </div>
      )}

      {imageSummaries.length > 0 && (
        <div className="space-y-2">
          <h3 className="font-medium">Extracted signals</h3>
          <ul className="list-disc pl-5 text-sm text-neutral-300">
            {imageSummaries.map((summary, idx) => (
              <li key={idx}>{summary}</li>
            ))}
          </ul>
        </div>
      )}
    </section>
  );
}


