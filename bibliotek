11. Mother Duck governance interface

interface MotherDuckReview {
  review(artifact: Artifact): ReviewDecision
}

interface ReviewDecision {
  decision: "accept" | "revise" | "provisional" | "archive" | "reject"
  rationale: string
  changes_required?: string[]
  canon_location?: string
}


