            onDelete={()=>removeActor(a.id)}
          />
        ))}
        <Btn onClick={addActor} outline style={{width:"100%",padding:"10px"}}>
          + Add Actor
        </Btn>
        {actors.length===0 && (
          <div style={{textAlign:"center",color:C.textDim,fontSize:12,marginTop:24,padding:"24px",
            border:`1px dashed ${C.border}`,borderRadius:6
          }}>
            No actors yet. Add actors to begin mapping the incentive field.<br/>
            <span style={{color:C.accentD}}>Every actor has a true objective function — often different from their stated one.</span>
          </div>
        )}
      </div>
    )}

    {/* SCORING MATRIX TAB */}
    {tab==="score" && (
      <div>
        <SectionHead sub="Score the system across 10 alignment dimensions (0=worst, 5=best).">
          System Scoring Matrix
        </SectionHead>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
          <Panel>
            <div style={{fontSize:11,color:C.accent,marginBottom:12,letterSpacing:"0.08em"}}>HEALTH DIMENSIONS</div>
            {SCORE_DIMS.filter(d=>!d.inv).map(d=>(
              <ScoreSlider key={d.id} label={d.label} value={scores[d.id]||0}
                onChange={v=>setScores(s=>({...s,[d.id]:v}))} inverted={false}/>
            ))}
          </Panel>
          <Panel>
            <div style={{fontSize:11,color:C.red,marginBottom:12,letterSpacing:"0.08em"}}>DYSFUNCTION DIMENSIONS</div>
            {SCORE_DIMS.filter(d=>d.inv).map(d=>(
              <ScoreSlider key={d.id} label={d.label} value={scores[d.id]||0}
                onChange={v=>setScores(s=>({...s,[d.id]:v}))} inverted={true}/>
            ))}
          </Panel>
        </div>

        {/* MI visualization */}
        <Panel style={{marginTop:16,borderColor:miC}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
            <div>
              <div style={{fontSize:13,fontWeight:700,color:miC}}>MISALIGNMENT INDEX</div>
              <div style={{fontSize:11,color:C.textDim}}>Proxy + Extern + Lock-in + Info Asymmetry − Exit − Timescale</div>
            </div>
            <div style={{textAlign:"right"}}>
              <div style={{fontSize:36,fontWeight:800,color:miC,lineHeight:1}}>{mi}</div>
              <div style={{fontSize:11,color:miC}}>/ 20 · {miL}</div>
            </div>
          </div>
          <div style={{height:8,background:C.border,borderRadius:4,overflow:"hidden"}}>
            <div style={{height:"100%",width:`${(mi/20)*100}%`,background:miC,transition:"width 0.4s"}}/>
          </div>
          <div style={{marginTop:12,fontSize:12,color:C.textDim}}>
            {mi>=12?"⚠ CRITICAL: System will drift exploitative without active governance."
            :mi>=7?"⚡ HIGH: Significant misalignment detected. Structural intervention likely needed."
            :mi>=4?"◆ MODERATE: Observable tensions. Monitor and apply targeted steering."
            :"✓ LOW: Incentives reasonably coherent. Maintain visibility and governance."}
          </div>
        </Panel>
      </div>
    )}

    {/* REFERENCE TAB */}
    {tab==="ref" && (
      <div>
        <SectionHead sub="Canonical classes, steering operators, and pattern library.">
          IAL Reference Doctrine
        </SectionHead>

        <div style={{marginBottom:16}}>
          <div style={{fontSize:12,color:C.accent,marginBottom:10,letterSpacing:"0.1em"}}>6 CANONICAL MISALIGNMENT CLASSES</div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
            {MISALIGNMENT_TYPES.map(m=>(
              <Panel key={m.id} style={{borderLeft:`3px solid ${m.color}`}}>
                <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:6}}>
                  <span style={{fontSize:18}}>{m.icon}</span>
                  <span style={{fontWeight:700,color:m.color,fontSize:13}}>{m.label}</span>
                </div>
                <p style={{margin:0,fontSize:12,color:C.textDim}}>{m.desc}</p>
              </Panel>
            ))}
          </div>
        </div>

        <div style={{marginBottom:16}}>
          <div style={{fontSize:12,color:C.accent,marginBottom:10,letterSpacing:"0.1em"}}>6 STEERING OPERATORS</div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
            {STEERING_TOOLS.map(t=>(
              <Panel key={t.id} style={{borderLeft:`3px solid ${C.green}`}}>
                <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:6}}>
                  <span style={{fontSize:18}}>{t.icon}</span>
                  <span style={{fontWeight:700,color:C.green,fontSize:13}}>{t.label}</span>
                </div>
                <p style={{margin:0,fontSize:12,color:C.textDim}}>{t.desc}</p>
              </Panel>
            ))}
          </div>
        </div>

        <div style={{marginBottom:16}}>
          <div style={{fontSize:12,color:C.accent,marginBottom:10,letterSpacing:"0.1em"}}>INCENTIVE PATTERN LIBRARY</div>
          <Panel>
            <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
              {PATTERN_LIBRARY.map(p=><Tag key={p} label={p} color={C.raven}/>)}
            </div>
          </Panel>
        </div>

        <Panel style={{borderLeft:`3px solid ${C.accent}`}}>
          <div style={{fontSize:12,color:C.accent,marginBottom:10,letterSpacing:"0.1em"}}>PANTHEON WORKFLOW — T0→T4</div>
          {[
            {t:"T0",label:"Perception Governor",desc:"Slow down. Avoid moral overfitting. See the gradient, not the person."},
            {t:"T1",label:"Spider + Hound",desc:"Map actors, flows, constraints, objective functions → actor graph, incentive cards, reward/penalty edges."},
            {t:"T2",label:"Dragonfly + Combinatorix",desc:"Generate alternative payoff geometries → candidate reforms, second-order effects, positive-sum opportunities."},
            {t:"T3",label:"Raven + Mirror",desc:"Narrative synthesis + invariant check: preserves agency? reversible? who gets squeezed? new exploits?"},
            {t:"T4",label:"Elysara Frame",desc:"Can conflict be transmuted into coordination? Not always. But often enough to check."},
          ].map(s=>(
            <div key={s.t} style={{display:"flex",gap:12,marginBottom:10,alignItems:"flex-start"}}>
              <div style={{
                flexShrink:0,width:36,height:22,borderRadius:3,
                background:`${C.accent}22`,border:`1px solid ${C.accentD}`,
                display:"flex",alignItems:"center",justifyContent:"center",
                fontSize:10,fontWeight:700,color:C.accent
              }}>{s.t}</div>
              <div>
                <div style={{fontSize:12,fontWeight:700,color:C.text,marginBottom:2}}>{s.label}</div>
                <div style={{fontSize:11,color:C.textDim}}>{s.desc}</div>
              </div>
            </div>
          ))}
        </Panel>

        <Panel style={{marginTop:12,background:"#0c1016",borderStyle:"dashed"}}>
          <div style={{fontSize:11,color:C.accent,letterSpacing:"0.1em",marginBottom:8}}>CORE INVARIANTS</div>
          {[
            "Do not confuse incentives with essence",
            "Do not optimize one proxy at the expense of mission",
            "Preserve reversibility where possible",
            "Increase legibility before increasing force",
            "Prefer positive-sum redesign over coercive control",
            "Surface hidden costs to their source",
            "Align timescale of reward with timescale of consequence",
          ].map((r,i)=>(
            <div key={i} style={{fontSize:12,color:C.textDim,marginBottom:4}}>
              <span style={{color:C.accentD}}>◆</span> {r}
            </div>
          ))}
        </Panel>
      </div>
    )}

    {/* ANALYSIS TAB */}
    {tab==="analysis" && (
      <div>
        <SectionHead sub="Spider → Hound → Goblin → Dragonfly → Mirror → Badger">
          IAL Analysis Output
        </SectionHead>
        {loading && (
          <Panel style={{textAlign:"center",padding:40}}>
            <div style={{fontSize:24,marginBottom:12,animation:"spin 1s linear infinite"}}>⟳</div>
            <div style={{color:C.textDim,fontSize:13}}>Running incentive field analysis...</div>
            <div style={{color:C.accentD,fontSize:11,marginTop:8}}>Mapping gradients · Detecting misalignments · Forging redesigns</div>
          </Panel>
        )}
        {!loading && !result && (
          <Panel style={{textAlign:"center",padding:40,border:`1px dashed ${C.border}`}}>
            <div style={{fontSize:28,marginBottom:12}}>⚖</div>
            <div style={{color:C.textDim,fontSize:13}}>No analysis yet.</div>
            <div style={{color:C.accentD,fontSize:11,marginTop:8}}>
              Describe the system, map actors, set scores, then click RUN IAL ANALYSIS.
            </div>
          </Panel>
        )}
        {result && <AnalysisPanel result={result}/>}
      </div>
    )}
  </div>

  <style>{`
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    input[type=range] { height: 4px; }
    select option { background: #12171e; }
    * { box-sizing: border-box; }
    ::-webkit-scrollbar { width: 6px; } 
    ::-webkit-scrollbar-track { background: ${C.bg}; }
    ::-webkit-scrollbar-thumb { background: ${C.border}; border-radius: 3px; }
  `}</style>
</div>
```

);
