class SignalFilter:
    def classify(self, input_data):
        """
        Classify input into signal tiers
        """
        if self.is_direct_observation(input_data):
            return "TIER_1_REALITY"
        elif self.is_repeatable_model(input_data):
            return "TIER_2_MODEL"
        else:
            return "TIER_3_SPECULATION"

    def is_direct_observation(self, data):
        return "measured" in data or "observed" in data

    def is_repeatable_model(self, data):
        return "pattern" in data or "framework" in data

    def should_update_state(self, tier):
        return tier in ["TIER_1_REALITY", "TIER_2_MODEL"]


