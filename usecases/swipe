export default function PokemonOracle() {
const [screen, setScreen] = useState(“search”); // search | loading | swipe | done
const [activePokemon, setActivePokemon] = useState(null);
const [deck, setDeck] = useState([]);
const [originalDeck, setOriginalDeck] = useState([]);
const [kept, setKept] = useState([]);
const [passed, setPassed] = useState([]);
const [unsure, setUnsure] = useState([]);
const [showProfile, setShowProfile] = useState(false);
const [toast, setToast] = useState(null);
const [error, setError] = useState(null);

// Persistent profile across sessions
const [profile, setProfile] = useState(() => {
try { return JSON.parse(localStorage.getItem(“tcg_oracle_profile”) || “{}”); } catch { return {}; }
});

const updateProfile = useCallback((card, action) => {
if (action === “pass”) return;
setProfile(prev => {
const next = {
…prev,
total: (prev.total||0) + 1,
era: { …(prev.era||{}), [ERA(card.set?.releaseDate)]: ((prev.era||{})[ERA(card.set?.releaseDate)]||0)+1 },
types: { …(prev.types||{}) },
rarity: { …(prev.rarity||{}), [card.rarity||“Common”]: ((prev.rarity||{})[card.rarity||“Common”]||0)+1 },
pokemon: { …(prev.pokemon||{}), [activePokemon]: ((prev.pokemon||{})[activePokemon]||0)+1 },
kept: action === “keep” ? […(prev.kept||[]), card] : (prev.kept||[]),
};
(card.types||[“Colorless”]).forEach(t => { next.types[t] = (next.types[t]||0)+1; });
try { localStorage.setItem(“tcg_oracle_profile”, JSON.stringify(next)); } catch {}
return next;
});
}, [activePokemon]);

const selectPokemon = async (name) => {
setActivePokemon(name);
setScreen(“loading”);
setError(null);
try {
const cards = await fetchAllCardsForPokemon(name);
if (!cards.length) {
setError(`No cards found for "${name}"`);
setScreen(“search”);
return;
}
const shuffled = shuffle(cards);
setDeck(shuffled);
setOriginalDeck(shuffled);
setKept([]);
setPassed([]);
setUnsure([]);
setScreen(“swipe”);
} catch (e) {
setError(“API error — check connection”);
setScreen(“search”);
}
};

const handleSwipe = useCallback((dir, card) => {
setDeck(d => d.filter(c => c.id !== card.id));
if (dir === “right”) {
setKept(k => [card, …k]);
updateProfile(card, “keep”);
setToast({ type:“kept”, name:card.name });
} else {
setPassed(p => [card, …p]);
updateProfile(card, “pass”);
setToast({ type:“passed”, name:card.name });
}
setTimeout(() => setToast(null), 1800);
}, [updateProfile]);

const handleUnsure = useCallback(() => {
const top = deck[deck.length - 1];
if (!top) return;
setDeck(d => d.filter(c => c.id !== top.id));
setUnsure(u => [top, …u]);
setToast({ type:“unsure”, name:top.name });
setTimeout(() => setToast(null), 1800);
}, [deck]);

const topCard = deck[deck.length - 1];
const theme = topCard ? getTheme(topCard) : { bg:”#000”, accent:”#FFD700”, glow:”#FFD700” };

// Keyboard shortcuts
useEffect(() => {
if (screen !== “swipe”) return;
const h = (e) => {
if (showProfile) return;
if (e.key === “ArrowLeft”) topCard && handleSwipe(“left”, topCard);
if (e.key === “ArrowRight”) topCard && handleSwipe(“right”, topCard);
if (e.key === “ “ || e.key === “ArrowDown”) { e.preventDefault(); handleUnsure(); }
if (e.key === “p” || e.key === “P”) setShowProfile(s=>!s);
if (e.key === “Escape”) setScreen(“search”);
};
window.addEventListener(“keydown”, h);
return () => window.removeEventListener(“keydown”, h);
}, [screen, topCard, handleSwipe, handleUnsure, showProfile]);

// Auto-advance to done
useEffect(() => {
if (screen === “swipe” && deck.length === 0) {
setTimeout(() => setScreen(“done”), 300);
}
}, [deck, screen]);

// ── RENDER ──
if (screen === “search”) return (
<>
{error && (
<div style={{
position:“fixed”, top:16, left:“50%”, transform:“translateX(-50%)”,
background:“rgba(255,23,68,0.12)”, border:“1px solid rgba(255,23,68,0.3)”,
borderRadius:20, padding:“6px 16px”, fontFamily:“monospace”,
fontSize:10, color:”#FF1744”, letterSpacing:“0.1em”, zIndex:999,
}}>{error}</div>
)}
<SearchScreen onSelect={selectPokemon} profile={profile} />
</>
);

if (screen === “loading”) return <LoadingScreen pokemon={activePokemon} />;

if (screen === “done”) return (
<>
<DoneScreen
pokemon={activePokemon}
kept={kept.length}
total={originalDeck.length}
onBack={() => setScreen(“search”)}
onViewProfile={() => setShowProfile(true)}
onShuffle={() => {
setDeck(shuffle(originalDeck));
setKept([]); setPassed([]); setUnsure([]);
setScreen(“swipe”);
}}
/>
{showProfile && <ProfilePanel profile={profile} onClose={()=>setShowProfile(false)} />}
</>
);

return (
<div style={{
minHeight:“100vh”,
background:`radial-gradient(ellipse at 50% 0%, ${theme.bg} 0%, #000 65%)`,
display:“flex”, flexDirection:“column”,
alignItems:“center”,
transition:“background 0.5s ease”,
overflow:“hidden”,
}}>
<Scanlines />
<style>{`@keyframes pulse{0%,100%{opacity:0.35}50%{opacity:1}} @keyframes fadeUp{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}} *{box-sizing:border-box} ::-webkit-scrollbar{width:3px} ::-webkit-scrollbar-thumb{background:#222;border-radius:2px} input{color-scheme:dark}`}</style>

