// ═══════════════════════════════════════════════════════════
// KEPLER SOLVER
// ═══════════════════════════════════════════════════════════
function keplerE(M,e,tol=1e-10){
  let E=e<.8?M:Math.PI;
  for(let i=0;i<60;i++){
    const dE=-(E-e*Math.sin(E)-M)/(1-e*Math.cos(E));
    E+=dE;if(Math.abs(dE)<tol)break;
  }
  return E;
}

function helioXYZ(body,t){
  const el=EL[body];
  const {a,e}=el;
  const i=el.i*D2R, Om=el.Om*D2R, lp=el.lp*D2R;
  const L0=el.L*D2R;
  const n=2*Math.PI/(365.256*(a**1.5)); // rad/day (Kepler 3)
  const L=L0+n*t;
  const M=((L-lp)%(2*Math.PI)+4*Math.PI)%(2*Math.PI);
  const w=((lp-Om)%(2*Math.PI)+4*Math.PI)%(2*Math.PI);
  const E=keplerE(M,e);
  const x=a*(Math.cos(E)-e);
  const y=a*Math.sqrt(1-e*e)*Math.sin(E);
  const cw=Math.cos(w),sw=Math.sin(w);
  const cO=Math.cos(Om),sO=Math.sin(Om);
  const ci=Math.cos(i),si=Math.sin(i);
  return[
    (cO*cw-sO*sw*ci)*x+(-cO*sw-sO*cw*ci)*y,
    (sO*cw+cO*sw*ci)*x+(-sO*sw+cO*cw*ci)*y,
    (sw*si)*x+(cw*si)*y
  ];
}

// ecliptic longitude (for zodiac)
function eclipticLon(body,t){
  const [X,Y,Z]=helioXYZ(body,t);
  return(((Math.atan2(Y,X)*180/Math.PI)%360)+360)%360;
}

