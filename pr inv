Very simple invariant gate

# runtime/invariants.py
from typing import List, Tuple

def check_invariants(packet: dict, output_text: str) -> Tuple[List[str], List[str]]:
    passed = []
    failed = []

    if output_text and len(output_text.strip()) > 0:
        passed.append("nonempty_output")
    else:
        failed.append("empty_output")

    banned_phrases = [
        "I guarantee",
        "this is certainly true"
    ]
    if any(p in output_text for p in banned_phrases):
        failed.append("unsupported_certainty")
    else:
        passed.append("bounded_certainty")

    if "TODO" in output_text:
        failed.append("unfinished_output")
    else:
        passed.append("complete_surface")

    return passed, failed


