from __future__ import annotations

from dataclasses import dataclass, asdict
from typing import Dict, Any


def clamp(value: float, lo: float = 0.0, hi: float = 1.0) -> float:
    return max(lo, min(hi, value))


@dataclass
class ReputationRecord:
    source_id: str
    total_predictions: int = 0
    correct_predictions: int = 0
    predictive_accuracy: float = 0.5
    consistency: float = 0.5
    stake: float = 0.0
    expertise: float = 0.0
    manipulation_risk: float = 0.0
    volume: int = 0

    mean_score: float = 0.5
    score_variance_proxy: float = 0.0
    last_outcome_error: float = 0.5

    def to_dict(self) -> Dict[str, Any]:
        return asdict(self)


class ReputationLedger:
    """
    Tracks source quality over time from observed prediction outcomes.

    outcome should be in [0,1]
    predicted_score should be in [0,1]
    """

    def __init__(self) -> None:
        self.records: Dict[str, ReputationRecord] = {}

    def get_or_create(self, source_id: str) -> ReputationRecord:
        if source_id not in self.records:
            self.records[source_id] = ReputationRecord(source_id=source_id)
        return self.records[source_id]

    def register_source(
        self,
        source_id: str,
        stake: float = 0.0,
        expertise: float = 0.0,
    ) -> ReputationRecord:
        record = self.get_or_create(source_id)
        record.stake = clamp(stake)
        record.expertise = clamp(expertise)
        return record

    def update_prediction(
        self,
        source_id: str,
        predicted_score: float,
        outcome: float,
    ) -> ReputationRecord:
        record = self.get_or_create(source_id)

        predicted_score = clamp(predicted_score)
        outcome = clamp(outcome)

        record.total_predictions += 1
        record.volume += 1

        error = abs(predicted_score - outcome)
        record.last_outcome_error = error

        # Binary correctness proxy
        predicted_label = 1 if predicted_score >= 0.5 else 0
        outcome_label = 1 if outcome >= 0.5 else 0
        if predicted_label == outcome_label:
            record.correct_predictions += 1

        # Rolling predictive accuracy
        record.predictive_accuracy = record.correct_predictions / max(record.total_predictions, 1)

        # Running mean score
        n = record.total_predictions
        old_mean = record.mean_score
        new_mean = old_mean + (predicted_score - old_mean) / n
        record.mean_score = new_mean

        # Variance proxy for instability / inconsistency
        delta = predicted_score - old_mean
        record.score_variance_proxy = (
            ((n - 1) * record.score_variance_proxy) + delta * (predicted_score - new_mean)
        ) / max(n, 1)

        variance_norm = clamp(record.score_variance_proxy)
        record.consistency = clamp(1.0 - variance_norm)

        # Manipulation risk heuristic:
        # if scores are extreme but outcomes miss often, risk rises
        extremeness = abs(predicted_score - 0.5) * 2.0
        risk_delta = 0.15 * extremeness * error - 0.05 * (1.0 - error)
        record.manipulation_risk = clamp(record.manipulation_risk + risk_delta)

        return record

    def apply_manual_adjustment(
        self,
        source_id: str,
        stake: float | None = None,
        expertise: float | None = None,
        manipulation_risk: float | None = None,
    ) -> ReputationRecord:
        record = self.get_or_create(source_id)
        if stake is not None:
            record.stake = clamp(stake)
        if expertise is not None:
            record.expertise = clamp(expertise)
        if manipulation_risk is not None:
            record.manipulation_risk = clamp(manipulation_risk)
        return record

    def export_sources_for_governance(self) -> Dict[str, Dict[str, Any]]:
        export: Dict[str, Dict[str, Any]] = {}
        for source_id, record in self.records.items():
            export[source_id] = {
                "source_id": record.source_id,
                "source_type": "user",
                "predictive_accuracy": record.predictive_accuracy,
                "consistency": record.consistency,
                "stake": record.stake,
                "expertise": record.expertise,
                "manipulation_risk": record.manipulation_risk,
                "volume": record.volume,
            }
        return export

