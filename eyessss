🔧 Minimal Working Version (Drop-in Repo Starter)

Here’s a clean single-file HTML prototype you can build from:

<!DOCTYPE html>
<html>
<head>
  <title>Pantheon Brain</title>
  <style>
    body { margin: 0; background: black; overflow: hidden; }
  </style>
</head>
<body>
<script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.174/build/three.module.js';
import { OrbitControls } from 'https://cdn.jsdelivr.net/npm/three@0.174/examples/jsm/controls/OrbitControls.js';
const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
camera.position.z = 10;
const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
document.body.appendChild(renderer.domElement);
const controls = new OrbitControls(camera, renderer.domElement);
// LIGHT
const light = new THREE.PointLight(0xffffff, 2);
light.position.set(10,10,10);
scene.add(light);
// MOCK DATA
const nodes = [
  { id: "hub", type: "hub", color: 0x00ffff, pos: [0,0,0] },
  { id: "daemon1", type: "category", color: 0xff00ff, pos: [3,0,0] },
  { id: "daemon2", type: "category", color: 0xffff00, pos: [-3,0,0] },
];
// CREATE NODES
const meshes = [];
nodes.forEach(n => {
  const geo = new THREE.SphereGeometry(0.3, 32, 32);
  const mat = new THREE.MeshStandardMaterial({ color: n.color, emissive: n.color, emissiveIntensity: 0.5 });
  const mesh = new THREE.Mesh(geo, mat);
  mesh.position.set(...n.pos);
  mesh.userData = n;
  scene.add(mesh);
  meshes.push(mesh);
});
// CONNECT HUB TO OTHERS
nodes.forEach(n => {
  if (n.type !== "hub") {
    const material = new THREE.LineBasicMaterial({ color: n.color });
    const points = [
      new THREE.Vector3(0,0,0),
      new THREE.Vector3(...n.pos)
    ];
    const geometry = new THREE.BufferGeometry().setFromPoints(points);
    const line = new THREE.Line(geometry, material);
    scene.add(line);
  }
});
// ANIMATION LOOP
function animate() {
  requestAnimationFrame(animate);
  const time = Date.now() * 0.001;
  meshes.forEach((m, i) => {
    m.scale.setScalar(1 + Math.sin(time + i) * 0.2); // breathing
  });
  controls.update();
  renderer.render(scene, camera);
}
animate();
</script>
</body>
</html>

