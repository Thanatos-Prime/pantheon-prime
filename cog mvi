@dataclass
class StateVector:
    """
    Persistent cognitive state. Updated deterministically each cycle.
    """
    identity_hash: str
    agent_name: str
    active_invariants: List[str]
    open_tensions: List[str]          # unresolved questions / conflicts
    doctrine_digest: List[str]        # compressed doctrine from distillation
    session_lineage: List[str]        # epoch ids in order
    last_ledger_hash: str
    epoch: int = 0
    loop_depth: int = 0              # tracks recursion for I9

    @staticmethod
    def init(agent_name: str, invariant_names: List[str]) -> "StateVector":
        raw = f"{agent_name}|{time.time()}"
        id_hash = hashlib.sha256(raw.encode("utf-8")).hexdigest()[:12]
        return StateVector(
            identity_hash=id_hash,
            agent_name=agent_name,
            active_invariants=list(invariant_names),
            open_tensions=[],
            doctrine_digest=[],
            session_lineage=["epoch-0"],
            last_ledger_hash="GENESIS",
            epoch=0,
        )

    def advance(self) -> None:
        """Increment epoch and extend lineage."""
        self.epoch += 1
        self.session_lineage.append(f"epoch-{self.epoch}")

    def inject_context(self) -> str:
        """Human-readable SV summary injected into every LLM prompt."""
        doctrine_tail = self.doctrine_digest[-3:] if self.doctrine_digest else []
        return (
            f"[StateVector] agent={self.agent_name} | epoch={self.epoch} | "
            f"id={self.identity_hash} | "
            f"tensions={self.open_tensions} | "
            f"doctrine={doctrine_tail}"
        )

    def to_dict(self) -> dict:
        return dict(self.__dict__)


