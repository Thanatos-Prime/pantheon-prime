from hound_signal_filter import SignalFilter
from ganglion_compressor import Compressor
from conductor_router import Router
from hephaestus_forge import Forge
from echoframe_memory import Memory

class PantheonCore:
    def __init__(self):
        self.hound = SignalFilter()
        self.ganglion = Compressor()
        self.conductor = Router()
        self.forge = Forge()
        self.memory = Memory()

    def run(self, input_data):
        tier = self.hound.classify(input_data)

        if not self.hound.should_update_state(tier):
            return "Discarded: Low Signal"

        compressed = self.ganglion.compress(input_data)
        route = self.conductor.route(compressed)
        artifact = self.forge.build(route, compressed)
        stored = self.memory.store(artifact)

        return {
            "tier": tier,
            "compressed": compressed,
            "route": route,
            "artifact": artifact,
            "memory": stored
        }


