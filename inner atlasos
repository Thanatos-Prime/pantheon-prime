// ─── MARKER DOT ───────────────────────────────────────────────────────────────
function MarkerDot({ zone, markers }) {
const zoneMarkers = markers.filter(m => m.zone === zone.id);
if (!zoneMarkers.length) return null;

// stack multiple markers
return zoneMarkers.map((m, i) => {
const t = getType(m.type);
const r = 4 + m.intensity * 2;
const offset = i * 6;
return (
<g key={`${m.zone}-${m.type}-${i}`}>
<circle
cx={zone.cx + offset}
cy={zone.cy + offset}
r={r}
fill={t.color}
opacity={0.2 + m.intensity * 0.08}
/>
<circle
cx={zone.cx + offset}
cy={zone.cy + offset}
r={r * 0.45}
fill={t.color}
opacity={0.9}
/>
</g>
);
});
}

// ─── ZONE HIT AREA ────────────────────────────────────────────────────────────
function ZoneHit({ zone, selected, onClick }) {
return (
<circle
cx={zone.cx}
cy={zone.cy}
r={16}
fill={selected ? “rgba(99,102,241,0.25)” : “transparent”}
stroke={selected ? “#818cf8” : “transparent”}
strokeWidth=“1.5”
style={{ cursor: “pointer” }}
onClick={() => onClick(zone.id)}
/>
);
}

