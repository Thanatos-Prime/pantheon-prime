Pseudocode

import math
import random
class ZPCMobiusEngine:
    def __init__(self,
                 omega=1.0,
                 gamma=0.05,
                 beta=0.01,
                 seam_eps=0.1,
                 capture_alpha=0.2,
                 leakage=0.01,
                 feedback_k=0.05,
                 dt=0.01):
        self.omega = omega
        self.gamma = gamma
        self.beta = beta
        self.seam_eps = seam_eps
        self.capture_alpha = capture_alpha
        self.leakage = leakage
        self.feedback_k = feedback_k
        self.dt = dt
        self.x = 0.5
        self.v = 0.0
        self.store = 0.0
        self.net_drift = 0.0
    def noise(self):
        return random.gauss(0, 0.2)
    def near_seam(self):
        return abs(self.x) < self.seam_eps
    def preferred_phase(self):
        return self.v > 0
    def step(self):
        # Feed-forward bias from stored gain
        u = self.feedback_k * self.store
        # Nonlinear oscillator dynamics
        a = (
            -self.gamma * self.v
            -self.omega**2 * self.x
            -self.beta * self.x**3
            + self.noise()
            + u
        )
        self.v += a * self.dt
        self.x += self.v * self.dt
        captured = 0.0
        # ZPC asymmetric gate
        if self.near_seam() and self.preferred_phase():
            captured = self.capture_alpha * abs(self.v)
            self.store += captured
            self.net_drift += captured
        # leakage / decay
        self.store *= (1.0 - self.leakage)
        return {
            "x": self.x,
            "v": self.v,
            "store": self.store,
            "captured": captured,
            "net_drift": self.net_drift,
            "near_seam": self.near_seam(),
        }

