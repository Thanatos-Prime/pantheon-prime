    zdX.beginPath();zdX.arc(px,py,r*2.5,0,Math.PI*2);zdX.fillStyle=g;zdX.fill();
    zdX.beginPath();zdX.arc(px,py,r,0,Math.PI*2);zdX.fillStyle=ph.col;zdX.fill();
    zdX.fillStyle='rgba(210,230,255,.7)';zdX.font=`${r*1.5}px serif`;
    zdX.textAlign='center';zdX.textBaseline='middle';zdX.fillText(ph.sym,px,py);
    zdX.beginPath();zdX.moveTo(cx+innerR*Math.cos(a),cy+innerR*Math.sin(a));
    zdX.lineTo(cx+outerR*Math.cos(a),cy+outerR*Math.sin(a));
    zdX.strokeStyle=ph.col+'55';zdX.lineWidth=.7;zdX.stroke();
  });
}

