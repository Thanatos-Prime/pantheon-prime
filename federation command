function updateGate() {
  scores = scores.map((s,i) => {
    drifts[i] += (Math.random()-0.5)*0.001;
    drifts[i] = Math.max(-0.003, Math.min(0.003, drifts[i]));
    return Math.max(0.72, Math.min(0.99, s + drifts[i]));
  });
  const sigma = scores.reduce((a,b)=>a+b,0)/scores.length;
  document.getElementById('sigma').textContent = sigma.toFixed(3);
  const gs = document.getElementById('gate-status');
  if (sigma >= 0.7) {
    gs.textContent = 'ALLOW — THRESHOLD MET';
    gs.style.color = 'var(--green)';
  } else {
    gs.textContent = 'DENY — BELOW THRESHOLD';
    gs.style.color = 'var(--red)';
  }
  scores.forEach((s,i) => {
    const el = document.getElementById(`sc-${i}`);
    if (el) el.textContent = s.toFixed(2);
  });
}

updateGate();
setInterval(updateGate, 2500);

// Nodes live counter flicker
setInterval(() => {
  const n = document.getElementById('nodes-live');
  n.textContent = Math.random() > 0.15 ? '4' : '3';
}, 5000);
</script>

