3. Identity layer

User

This is the sovereign root object.

type UserID = string;

interface User {
  id: UserID;
  createdAt: string;
  updatedAt: string;

  handle?: string;
  region?: string;
  riskProfile: "stable" | "balanced" | "growth" | "speculative";
  privacyProfile: "strict" | "balanced" | "open";
  intentProfile: Array<"profit" | "research" | "impact" | "personalization">;

  trustScore: number;           // anti-fraud / authenticity
  signalReputation: number;     // quality-weighted history
  status: "active" | "paused" | "suspended" | "deleted";
}


⸻

