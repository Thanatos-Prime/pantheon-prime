'use strict';
// ═══════════════════════════════════════════════════════════
// STAR FIELD
// ═══════════════════════════════════════════════════════════
(()=>{
  const c=document.getElementById('sf'),x=c.getContext('2d');
  let s=5923;const rng=()=>{s^=s<<13;s^=s>>17;s^=s<<5;return(s>>>0)/4294967296;};
  function draw(){
    c.width=innerWidth;c.height=innerHeight;
    for(let i=0;i<600;i++){
      const px=rng()*c.width,py=rng()*c.height,r=rng()*1.3;
      const a=.08+rng()*.5,h=210+rng()*40;
      x.beginPath();x.arc(px,py,r,0,Math.PI*2);
      x.fillStyle=`hsla(${h},55%,92%,${a})`;x.fill();
    }
  }
  draw();window.addEventListener('resize',draw);
})();

