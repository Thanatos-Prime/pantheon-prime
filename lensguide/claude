              <span className="hud-label hud-topleft">
                {loading ? "SCANNING…" : result ? `CONF ${confPct}%` : "READY"}
              </span>
              <span className="hud-label hud-topright">
                {result?.device_detected || "—"}
              </span>
              <span className="hud-label hud-botleft">
                STEP {result?.current_step ?? "?"} / {PROCEDURE_GRAPH.steps.length}
              </span>
              <span className="hud-label hud-botright">
                {result?.step_status?.toUpperCase() || "—"}
              </span>
            </>
          ) : (
            <div className="camera-idle">
              <div className="idle-icon">📷</div>
              <div className="idle-label">
                Upload image or use camera<br />to begin visual state analysis
              </div>
            </div>
          )}
        </div>

        {/* CONTROLS */}
        <div className="controls">
          <label className="upload-label">
            ⬆ LOAD IMAGE
            <input
              ref={fileRef}
              type="file"
              accept="image/*"
              capture="environment"
              style={{ display: "none" }}
              onChange={e => handleFile(e.target.files[0])}
            />
          </label>

          <button
            className={`btn btn-primary ${loading ? "loading" : ""}`}
            onClick={analyze}
            disabled={!imageB64 || loading}
          >
            {loading ? <><span className="spinner" />ANALYZING</> : "▶ ANALYZE"}
          </button>

          {image && (
            <button className="btn btn-secondary" onClick={reset}>
              RESET
            </button>
          )}
        </div>

        {/* Instruction card */}
        {result && (
          <div className={`instruction-card ${result.instruction_type === "anomaly" ? "anomaly" : result.instruction_type === "warn" ? "warn" : ""}`}>
            <div className={`step-badge ${result.instruction_type === "anomaly" ? "anomaly" : result.instruction_type === "warn" ? "warn" : ""}`}>
              {result.instruction_type === "anomaly" ? "⚠ HOUND FLAG" :
               result.instruction_type === "warn"    ? "◈ CAUTION" :
               `▸ STEP ${result.current_step ?? "?"} — NEXT ACTION`}
            </div>
            <div className="instruction-text">{result.next_instruction}</div>
          </div>
        )}

        {!result && !loading && (
          <div className="instruction-empty">
            — awaiting visual state input —
          </div>
        )}
      </div>

      {/* SIDEBAR */}
      <aside className="sidebar">

        {/* STATE RESOLVER */}
        <div className="sidebar-section">
          <div className="section-label">State Resolver</div>
          <div className="state-display">
            <div className="state-row">
              <span className="state-key">device</span>
              <span className={`state-val ${!result ? "unknown" : result.device_detected ? "" : "error"}`}>
                {result?.device_detected || "—"}
              </span>
            </div>
            <div className="state-row">
              <span className="state-key">step</span>
              <span className={`state-val ${!result ? "unknown" : ""}`}>
                {result ? `${result.current_step ?? "?"} / ${PROCEDURE_GRAPH.steps.length}` : "—"}
              </span>
            </div>
            <div className="state-row">
              <span className="state-key">status</span>
              <span className={`state-val ${
                result?.step_status === "blocked" ? "error" :
                result?.step_status === "complete" ? "ok" :
                result?.step_status === "in_progress" ? "" : "unknown"
              }`}>
                {result?.step_status?.toUpperCase() || "—"}
              </span>
            </div>
            <div className="state-row">
              <span className="state-key">confidence</span>
              <span className={`state-val ${!result ? "unknown" : confPct < 40 ? "error" : confPct < 70 ? "warn" : "ok"}`}>
                {result ? `${confPct}%` : "—"}
              </span>
            </div>
            {result && (
              <div className="confidence-bar-wrap">
                <div className="confidence-track">
                  <div
                    className={`confidence-fill ${confClass}`}
                    style={{ width: `${confPct}%` }}
                  />
                </div>
              </div>
            )}
            {result?.reasoning && (
              <div style={{ marginTop: 8, fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text-dim)", lineHeight: 1.6 }}>
                {result.reasoning}
              </div>
            )}
          </div>
        </div>

        {/* ANOMALIES */}
        <div className="sidebar-section">
          <div className="section-label">Hound · Anomaly Flags</div>
          {result?.anomalies?.length ? (
            <div className="anomaly-list">
              {result.anomalies.map((a, i) => (
                <div key={i} className="anomaly-item">
                  <div className="anomaly-dot" />
                  {a}
                </div>
              ))}
            </div>
          ) : (
            <div style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text-dim)" }}>
              {result ? "NO ANOMALIES DETECTED" : "— ARMED —"}
            </div>
          )}
        </div>

        {/* STEP GRAPH */}
        <div className="sidebar-section">
          <div className="section-label">Spider · Procedure Graph</div>
          <div className="step-graph">
            {PROCEDURE_GRAPH.steps.map(step => {
              const state = getStepState(step.id);
              return (
                <div key={step.id} className={`graph-step ${state}`}>
                  <span className="step-num">{String(step.id).padStart(2,"0")}</span>
                  <div className="step-dot" />
                  <span className="step-label">{step.label}</span>
                </div>
              );
            })}
          </div>
        </div>

        {/* ANALYSIS LOG */}
        <div className="sidebar-section" style={{ flex: 1 }}>
          <div className="section-label">Analysis Log</div>
          <div className="log-area" ref={logRef}>
            {logs.length === 0 && (
              <span className="log-line info">LENSGUIDE INITIALIZED · AWAITING INPUT</span>
            )}
            {logs.map((l, i) => (
              <span key={i} className={`log-line ${l.type}`}>
                {l.ts} {l.msg}
              </span>
            ))}
          </div>
        </div>

      </aside>
    </div>

    {/* FOOTER */}
    <footer className="footer">
      <span className="footer-left">
        PANTHEON OS · <span>LENSGUIDE</span> · PERCEPTION/INSTRUCTION · APACHE-2.0
      </span>
      <span className="footer-right">
        INVARIANT: instruction valid only if grounded in current physical state
      </span>
    </footer>

  </div>
</>
