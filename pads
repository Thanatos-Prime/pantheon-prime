4) termination_gate.py

from dataclasses import dataclass
from typing import List
from recursive_reasoner import ReasoningPass


@dataclass
class TerminationDecision:
    should_stop: bool
    reason: str


class TerminationGate:
    """
    Prevents wasted recursion and recursive delusion.
    """

    def evaluate(self, passes: List[ReasoningPass]) -> TerminationDecision:
        if not passes:
            return TerminationDecision(True, "No passes available")

        latest = passes[-1]

        if latest.confidence > 0.9 and latest.delta_score > 0.4:
            return TerminationDecision(
                True,
                "Confidence spike too high relative to instability; possible overreach"
            )

        if len(passes) >= 2:
            prev = passes[-2]
            if latest.delta_score < 0.08:
                return TerminationDecision(
                    True,
                    "Convergence reached; further recursion unlikely to help"
                )
            if latest.confidence < prev.confidence and latest.delta_score < 0.12:
                return TerminationDecision(
                    True,
                    "Reasoning quality appears to be degrading"
                )

        return TerminationDecision(False, "Continue")


