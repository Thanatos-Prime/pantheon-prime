@dataclass(frozen=True)
class ThoughtObject:
    """
    Immutable structured record of a single reasoning event.
    Once created, content cannot change. parent_uuid chains to prior TO.
    """
    uuid_: str
    timestamp: float
    origin_model: str
    content: str
    tags: Tuple[str, ...]
    state_hash: str  # hash(content + sv_epoch + prev_ledger_hash)
    invariant_scores: Tuple[float, ...]
    daemon_signature: str
    parent_uuid: Optional[str]

    @staticmethod
    def create(
        content: str,
        origin_model: str,
        sv_epoch: int,
        prev_ledger_hash: str,
        invariant_scores: List[float],
        tags: List[str],
        daemon_sig: str = "core",
        parent_uuid: Optional[str] = None,
    ) -> "ThoughtObject":
        uid = str(uuid.uuid4())
        raw = f"{content}|{sv_epoch}|{prev_ledger_hash}"
        state_hash = hashlib.sha256(raw.encode("utf-8")).hexdigest()[:16]
        return ThoughtObject(
            uuid_=uid,
            timestamp=time.time(),
            origin_model=origin_model,
            content=content,
            tags=tuple(tags),
            state_hash=state_hash,
            invariant_scores=tuple(invariant_scores),
            daemon_signature=daemon_sig,
            parent_uuid=parent_uuid,
        )

    def sc(self) -> float:
        """Aggregate coherence score — mean of all invariant scores."""
        if not self.invariant_scores:
            return 0.0
        return float(statistics.mean(self.invariant_scores))

    def to_dict(self) -> dict:
        return asdict(self)


