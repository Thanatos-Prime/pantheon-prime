from __future__ import annotations

from typing import Dict, List
import numpy as np


def cluster_user_vectors(user_vectors: Dict[str, List[float]], k: int = 3, iterations: int = 20) -> Dict[str, int]:
    if not user_vectors:
        return {}

    users = list(user_vectors.keys())
    vectors = np.array([user_vectors[u] for u in users], dtype=float)

    if len(users) <= k:
        return {u: i for i, u in enumerate(users)}

    centroids = vectors[:k].copy()

    for _ in range(iterations):
        distances = np.linalg.norm(vectors[:, None, :] - centroids[None, :, :], axis=2)
        labels = np.argmin(distances, axis=1)

        for idx in range(k):
            mask = labels == idx
            if np.any(mask):
                centroids[idx] = vectors[mask].mean(axis=0)

    return {users[i]: int(labels[i]) for i in range(len(users))}

