                    {s.markers.length} mark{s.markers.length !== 1 ? "s" : ""}
                  </div>
                </button>
              ))}
            </div>

            {/* Snapshot body map */}
            <div style={{
              flex: "0 0 380px",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              borderRight: "1px solid #0f172a",
              background: "#080c14",
              position: "relative",
            }} className="grid-line">
              <div style={{ position: "absolute", top: 12, left: 12, fontSize: 9, color: "#1e293b", letterSpacing: "0.12em" }}>
                {currentSnap ? `LOG·${fmtDate(currentSnap.timestamp)}·${fmtTime(currentSnap.timestamp)}` : "—"}
              </div>
              <svg width="380" height="480" viewBox="20 0 360 480">
                <defs>
                  <pattern id="grid2" width="40" height="40" patternUnits="userSpaceOnUse">
                    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0f172a" strokeWidth="0.5" />
                  </pattern>
                </defs>
                <rect x="20" width="360" height="480" fill="url(#grid2)" />
                <BodyOutline />
                {currentSnap && BODY_ZONES.map(zone => (
                  <MarkerDot key={zone.id} zone={zone} markers={currentSnap.markers} />
                ))}
              </svg>
            </div>

            {/* Delta + markers panel */}
            <div style={{
              flex: 1,
              padding: "24px 24px",
              overflowY: "auto",
              display: "flex",
              flexDirection: "column",
              gap: 24,
            }}>
              {/* Markers list */}
              <div>
                <div style={{ fontSize: 9, color: "#475569", letterSpacing: "0.15em", marginBottom: 10 }}>
                  MARKERS ({currentSnap?.markers?.length ?? 0})
                </div>
                <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
                  {(currentSnap?.markers ?? []).map((m, i) => {
                    const t = getType(m.type);
                    const z = getZone(m.zone);
                    return (
                      <div key={i} style={{
                        padding: "7px 10px",
                        background: "#0a0f1a",
                        border: "1px solid #0f172a",
                        borderLeft: `3px solid ${t.color}`,
                        borderRadius: 2,
                        display: "flex",
                        alignItems: "center",
                        gap: 10,
                      }}>
                        <span style={{ color: t.color }}>{t.glyph}</span>
                        <span style={{ fontSize: 11, color: "#cbd5e1" }}>{z?.label}</span>
                        <span style={{ fontSize: 10, color: "#475569" }}>{t.label.toLowerCase()}</span>
                        <span style={{ fontSize: 10, color: t.color, marginLeft: "auto" }}>{m.intensity}/10</span>
                      </div>
                    );
                  })}
                </div>
              </div>

              {/* Deltas */}
              {deltas.length > 0 && (
                <div>
                  <div style={{ fontSize: 9, color: "#475569", letterSpacing: "0.15em", marginBottom: 10 }}>
                    DELTA vs PREV LOG
                  </div>
                  <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
                    {deltas.map((d, i) => {
                      const t = getType(d.type);
                      const z = getZone(d.zone);
                      const positive = d.delta > 0;
                      return (
                        <div key={i} style={{
                          padding: "7px 10px",
                          background: "#0a0f1a",
                          border: `1px solid ${positive ? "#ef4444" : "#22c55e"}22`,
                          borderRadius: 2,
                          display: "flex",
                          alignItems: "center",
                          gap: 10,
                        }}>
                          <span style={{ color: positive ? "#ef4444" : "#22c55e", fontSize: 12 }}>
                            {positive ? "▲" : "▼"}
                          </span>
                          <span style={{ fontSize: 11, color: "#cbd5e1" }}>{z?.label}</span>
                          <span style={{ fontSize: 10, color: "#475569" }}>{t?.label.toLowerCase()}</span>
                          <span style={{ fontSize: 11, color: positive ? "#ef4444" : "#22c55e", marginLeft: "auto", fontWeight: 500 }}>
                            {positive ? "+" : ""}{d.delta}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>
          </>
        )}
      </div>
    )}

    {/* ── PATTERNS VIEW ── */}
    {view === "patterns" && (
      <div style={{ flex: 1, padding: "32px 40px", overflowY: "auto" }}>
        {snapshots.length < 2 ? (
          <div style={{ display: "flex", alignItems: "center", justifyContent: "center", height: "60%" }}>
            <div style={{ textAlign: "center" }}>
              <div style={{ fontSize: 32, marginBottom: 12, opacity: 0.2 }}>≈</div>
              <div style={{ fontSize: 12, color: "#475569", letterSpacing: "0.1em" }}>NEED 2+ LOGS FOR PATTERNS</div>
            </div>
          </div>
        ) : (
          <>
            <div style={{ fontSize: 9, color: "#475569", letterSpacing: "0.15em", marginBottom: 24 }}>
              PATTERN ENGINE — {snapshots.length} LOGS ANALYZED
            </div>

            {/* Top clusters */}
            <div style={{ marginBottom: 36 }}>
              <div style={{ fontSize: 11, color: "#64748b", letterSpacing: "0.1em", marginBottom: 16 }}>
                TOP RECURRING SIGNALS
              </div>
              <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                {clusters.map((c, i) => {
                  const t = getType(c.type);
                  const z = getZone(c.zone);
                  const pct = (c.count / snapshots.length) * 100;
                  return (
                    <div key={i} style={{
                      padding: "14px 16px",
                      background: "#0a0f1a",
                      border: "1px solid #0f172a",
                      borderRadius: 2,
                      position: "relative",
                      overflow: "hidden",
                    }}>
                      <div style={{
                        position: "absolute",
                        left: 0, top: 0, bottom: 0,
                        width: `${pct}%`,
                        background: `${t?.color}10`,
                        transition: "width 0.5s ease",
                      }} />
                      <div style={{ position: "relative", display: "flex", alignItems: "center", gap: 12 }}>
                        <span style={{ fontSize: 16, color: "#334155", fontFamily: "'Syne', sans-serif", fontWeight: 800 }}>
                          0{i + 1}
                        </span>
                        <span style={{ color: t?.color, fontSize: 13 }}>{t?.glyph}</span>
                        <div>
                          <div style={{ fontSize: 13, color: "#e2e8f0", fontFamily: "'Syne', sans-serif", fontWeight: 600 }}>
                            {z?.label} {t?.label}
                          </div>
                          <div style={{ fontSize: 10, color: "#475569", marginTop: 2, letterSpacing: "0.08em" }}>
                            {c.count} of {snapshots.length} logs · {Math.round(pct)}% occurrence
                          </div>
                        </div>
                        <div style={{ marginLeft: "auto", fontSize: 20, color: t?.color, opacity: 0.6, fontFamily: "'Syne', sans-serif", fontWeight: 800 }}>
                          {c.count}×
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* Per-type summary */}
            <div>
              <div style={{ fontSize: 11, color: "#64748b", letterSpacing: "0.1em", marginBottom: 16 }}>
                SIGNAL DISTRIBUTION
              </div>
              <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
                {MARKER_TYPES.map(t => {
                  const count = snapshots.reduce((acc, s) =>
                    acc + s.markers.filter(m => m.type === t.id).length, 0
                  );
                  const avgIntensity = count === 0 ? 0 : (
                    snapshots.reduce((acc, s) =>
                      acc + s.markers.filter(m => m.type === t.id).reduce((a, m) => a + m.intensity, 0), 0
                    ) / count
                  );
                  return (
                    <div key={t.id} style={{
                      padding: "14px 18px",
                      background: "#0a0f1a",
                      border: `1px solid ${t.color}22`,
                      borderTop: `2px solid ${t.color}`,
                      borderRadius: 2,
                      minWidth: 120,
                    }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 8 }}>
                        <span style={{ color: t.color }}>{t.glyph}</span>
                        <span style={{ fontSize: 10, color: "#64748b", letterSpacing: "0.1em" }}>
                          {t.label.toUpperCase()}
                        </span>
                      </div>
                      <div style={{ fontSize: 22, fontFamily: "'Syne', sans-serif", fontWeight: 800, color: count > 0 ? t.color : "#1e293b" }}>
                        {count}
                      </div>
                      <div style={{ fontSize: 9, color: "#475569", marginTop: 2 }}>
                        entries
                      </div>
                      {count > 0 && (
                        <div style={{ fontSize: 10, color: "#475569", marginTop: 6 }}>
                          avg intensity: <span style={{ color: t.color }}>{avgIntensity.toFixed(1)}</span>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          </>
        )}
      </div>
    )}
  </main>

  {/* ── STATUS BAR ── */}
  <footer style={{
    padding: "6px 24px",
    borderTop: "1px solid #0a0f1a",
    display: "flex",
    gap: 24,
    alignItems: "center",
  }}>
    <span style={{ fontSize: 9, color: "#1e293b", letterSpacing: "0.12em" }}>
      ATLAS·OS · ETI·v0.1 · STATE={view.toUpperCase()}
    </span>
    <span style={{ fontSize: 9, color: "#1e293b", letterSpacing: "0.1em" }}>
      ZONES·{BODY_ZONES.length} · TYPES·{MARKER_TYPES.length} · SNAPSHOTS·{snapshots.length}
    </span>
    <span style={{ marginLeft: "auto", fontSize: 9, color: "#1e293b", letterSpacing: "0.1em" }}>
      {currentMarkers.length > 0 ? `${currentMarkers.length} PENDING MARKS — SAVE STATE TO LOG` : "READY"}
    </span>
  </footer>
</div>
