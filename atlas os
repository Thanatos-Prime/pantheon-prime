5. 🧠 PATTERN ENGINE (v0 Logic)

Start simple:

function findClusters(snapshots: Snapshot[]) {
  const counts: Record<string, number> = {};

  snapshots.forEach(s => {
    s.markers.forEach(m => {
      const key = `${m.zone}_${m.type}`;
      counts[key] = (counts[key] || 0) + 1;
    });
  });

  return Object.entries(counts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 5);
}

