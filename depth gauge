Example usage

from adaptive_depth_v2 import AdaptiveDepthSystemV2

def simple_processor(text: str) -> dict:
    trimmed = " ".join(text.split())
    output = (
        "Refined analysis: "
        + trimmed[:400]
        + " | Focus on contradictions, grounded claims, next action, and failure modes."
    )
    confidence = 0.68 if len(trimmed) < 500 else 0.75
    return {
        "output": output,
        "confidence": confidence
    }

system = AdaptiveDepthSystemV2(memory_path="data/depth_memory.jsonl")

problem = (
    "We need to decide whether to prototype a new Pantheon module now, delay it, "
    "or kill it, based on uncertainty, leverage, and real-world usefulness."
)

context = {
    "uncertainty": 0.76,
    "impact": 0.84,
    "conflict": 0.32,
    "evidence_quality": 0.41,
    "novelty": 0.73
}

output = system.run(problem, context, simple_processor)

print("PROFILE:", output.profile)
print("BASELINE POLICY:", output.baseline_policy)
print("LEARNED POLICY:", output.learned_policy)
print("RESULT:", output.result)
print("ARTIFACT:", output.artifact)

# Later, after reality gives feedback:
system.record_feedback(
    output=output,
    artifact_quality=0.82,
    external_result_score=0.74,
    notes="Prototype was useful, but depth 5 would have been overkill."
)


