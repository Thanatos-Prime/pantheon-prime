    line-height: 1.7;
    color: rgba(244,244,244,0.88);
    white-space: pre-wrap;
    font-family: 'IBM Plex Serif', serif;
  }
  .script-body em { color: var(--gold); font-style: normal; }

  /* COALITION */
  .coalition-section { margin-bottom: 3rem; }
  .coalition-section h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    border-bottom: 2px solid var(--gold);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .coalition-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .coalition-card {
    border: 1px solid rgba(244,244,244,0.08);
    padding: 1rem;
    background: rgba(244,244,244,0.02);
  }
  .coalition-card h4 {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  .coalition-card p {
    font-size: 0.85rem;
    color: rgba(244,244,244,0.75);
    line-height: 1.5;
  }

  /* FLOOR VOTE SECTION */
  .floor-section {
    background: rgba(200,16,46,0.06);
    border: 1px solid rgba(200,16,46,0.25);
    padding: 1.5rem;
    margin-bottom: 3rem;
  }
  .floor-section h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: var(--red);
    margin-bottom: 1rem;
  }
  .floor-steps {
    counter-reset: step;
  }
  .floor-steps li {
    counter-increment: step;
    list-style: none;
    padding: 0.6rem 0 0.6rem 3rem;
    position: relative;
    border-bottom: 1px solid rgba(200,16,46,0.12);
    font-size: 0.9rem;
    color: rgba(244,244,244,0.85);
  }
  .floor-steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 2rem;
    height: 2rem;
    background: var(--red);
    color: var(--white);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid rgba(244,244,244,0.1);
    padding: 1.5rem 2.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    color: var(--steel);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
