// EVENTS
// ═══════════════════════════════════════════════════════════
const slider=document.getElementById('slider');
slider.addEventListener('input',()=>{
  S.t=+slider.value;
  lightRefresh();
});

document.querySelectorAll('.tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.pane').forEach(p=>p.classList.remove('active'));
    tab.classList.add('active');
    const id='pane-'+tab.dataset.tab;
    document.getElementById(id).classList.add('active');
    S.activeTab=tab.dataset.tab;
    setTimeout(()=>{
      if(S.activeTab==='sky'){sizeCanvas(skyC);drawSky();}
      if(S.activeTab==='zodiac'){sizeCanvas(zodC);drawZodiac();}
      if(S.activeTab==='delta')buildDelta();
      if(S.activeTab==='timeline')buildTimeline();
    },10);
  });
});

document.getElementById('selObs').addEventListener('change',fullRefresh);
document.getElementById('selSpan').addEventListener('change',()=>{
  S.span=+document.getElementById('selSpan').value;
  slider.max=S.span;
  if(S.t>S.span)S.t=0;
  MCACHE={};fullRefresh();
});
document.getElementById('selStep').addEventListener('change',()=>{
  S.step=+document.getElementById('selStep').value;
  MCACHE={};fullRefresh();
});

document.querySelectorAll('.spd').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.spd').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on');S.speed=+btn.dataset.s;
  });
});

const playBtn=document.getElementById('playBtn');
playBtn.addEventListener('click',()=>{
  S.playing=!S.playing;
  playBtn.textContent=S.playing?'⏸ PAUSE':'▶ PLAY';
  if(S.playing){
    function tick(){
      if(!S.playing)return;
      S.t=Math.min(S.span,S.t+S.speed*2);
      if(S.t>=S.span)S.t=0;
      slider.value=S.t;
      lightRefresh();
      raf=requestAnimationFrame(tick);
    }tick();
  } else {if(raf)cancelAnimationFrame(raf);}
});

const EPOCHS=[0,365,1826,3652,9132,18260,36524,54787,90520];
let epochI=0;
document.getElementById('epochBtn').addEventListener('click',()=>{
  epochI=(epochI+1)%EPOCHS.length;
  S.t=Math.min(S.span,EPOCHS[epochI]);
  slider.value=S.t;lightRefresh();
});

document.getElementById('computeBtn').addEventListener('click',()=>{
  MCACHE={};fullRefresh();
});

// ═══════════════════════════════════════════════════════════
// REFRESH PIPELINE
// ═══════════════════════════════════════════════════════════
function fullRefresh(){
  S.obs=document.getElementById('selObs').value;
  S.span=+document.getElementById('selSpan').value;
  S.step=+document.getElementById('selStep').value;
  slider.max=S.span;
  document.getElementById('stObs').textContent=S.obs;
  S.metrics=computeMetrics(S.obs,S.span,S.step,S.elongVis,S.elongMid);
  buildCards();
  buildLivePanel();
  buildHouseList();
  buildDelta();
  buildCulture();
  buildPantheon();
  buildTimeline();
  sizeCanvas(skyC);drawSky();
  sizeCanvas(zodC);drawZodiac();
  updateStats();
}

function lightRefresh(){
  drawSky();drawZodiac();
  buildLivePanel();
  buildHouseList();
  updateStats();
  if(S.activeTab==='delta')drawRadar(
    skySignature(computeMetrics('Earth',S.span,S.step),'Earth'),
    skySignature(S.metrics,S.obs),S.obs
  );
  if(S.activeTab==='timeline')drawTimeline();
}

window.addEventListener('resize',()=>{
  if(S.activeTab==='sky'){sizeCanvas(skyC);drawSky();}
  if(S.activeTab==='zodiac'){sizeCanvas(zodC);drawZodiac();}
  if(S.activeTab==='timeline')drawTimeline();
});

// ── INIT ──
fullRefresh();
</script>

