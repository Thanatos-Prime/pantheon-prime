@staticmethod
def init(agent_name: str, invariant_names: List[str]) -> "StateVector":
    raw = f"{agent_name}|{time.time()}"
    id_hash = hashlib.sha256(raw.encode()).hexdigest()[:12]
    return StateVector(
        identity_hash=id_hash,
        agent_name=agent_name,
        active_invariants=invariant_names,
        open_tensions=[],
        doctrine_digest=[],
        session_lineage=[f"epoch-0"],
