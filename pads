from dataclasses import dataclass
from typing import List
from uncertainty_estimator import UncertaintyProfile


@dataclass
class DepthDecision:
    depth: int
    require_grounding: bool
    require_external_check: bool
    require_artifact: bool
    notes: List[str]


class DepthController:
    """
    Converts an uncertainty profile into operational depth policy.
    """

    def decide(self, profile: UncertaintyProfile) -> DepthDecision:
        notes = []

        depth = profile.recommended_depth
        require_grounding = depth >= 2
        require_external_check = (
            profile.impact > 0.7 or
            profile.evidence_quality < 0.4 or
            profile.conflict > 0.6
        )
        require_artifact = True

        if depth >= 4:
            notes.append("Deep reasoning authorized")
        if require_grounding:
            notes.append("Grounding required before final output")
        if require_external_check:
            notes.append("External validation or reality-check required")

        return DepthDecision(
            depth=depth,
            require_grounding=require_grounding,
            require_external_check=require_external_check,
            require_artifact=require_artifact,
            notes=notes
        )


