:::writing{variant=“standard” id=“15490”}

from __future__ import annotations

from fastapi import FastAPI, HTTPException

from app.schemas import PreferenceEvent, UserProfile
from app.storage import init_db, insert_event
from app.trainer import rebuild_engine_from_storage
from app.clustering import cluster_user_vectors

app = FastAPI(title="Preference Signal Refinery")

_engine = None


def get_engine():
    global _engine
    if _engine is None:
        _engine = rebuild_engine_from_storage()
    return _engine


@app.on_event("startup")
def startup_event():
    init_db()
    get_engine()


@app.get("/")
def root():
    return {"status": "ok", "service": "Preference Signal Refinery"}


@app.post("/events")
def ingest_event(event: PreferenceEvent):
    insert_event(event.model_dump())

    engine = get_engine()
    result = engine.update(
        user_id=event.user_id,
        item_a=event.item_a,
        item_b=event.item_b,
        selected=event.selected,
        confidence=event.confidence,
        dwell_ms=event.dwell_ms,
        domain=event.domain,
        item_a_features=event.item_a_features,
        item_b_features=event.item_b_features,
    )

    return {
        "status": "ingested",
        "update": result,
    }


@app.get("/users/{user_id}/profile", response_model=UserProfile)
def user_profile(user_id: str):
    engine = get_engine()
    profile = engine.user_profile(user_id)
    return UserProfile(**profile)


@app.get("/clusters")
def clusters(k: int = 3):
    engine = get_engine()
    assignments = cluster_user_vectors(engine.all_user_vectors(), k=k)
    return {"clusters": assignments}


@app.post("/train/rebuild")
def rebuild():
    global _engine
    _engine = rebuild_engine_from_storage()
    return {"status": "rebuilt"}


@app.get("/items/similarity")
def item_similarity(item_x: str, item_y: str):
    engine = get_engine()
    try:
        similarity = engine.similarity(item_x, item_y)
    except KeyError as exc:
        raise HTTPException(status_code=404, detail=str(exc)) from exc

    return {
        "item_x": item_x,
        "item_y": item_y,
        "similarity": similarity,
    }

