// ── AI Analysis via Anthropic API ─────────────────────────────────────────────
async function runIALAnalysis(systemDesc, actors, scores) {
const actorSummary = actors.map(a=>
`Actor: ${a.name}\n  Objective: ${a.objective}\n  Reward: ${a.rewardChannel}\n  Penalty: ${a.penaltyChannel}\n  Horizon: ${a.horizon}\n  Visibility: ${a.visibility}/5\n  Externalities: ${a.externalities}\n  Lock-in: ${a.lockin}/5`
).join(”\n\n”);

const scoreSummary = SCORE_DIMS.map(d=>`${d.label}: ${scores[d.id]||0}/5`).join(”, “);
const mi = computeMI(scores);

const prompt = `You are the Incentive Alignment Layer (IAL v2.0) of PantheonOS — a Pantheon module for mapping, diagnosing, and redesigning incentive fields in complex systems.

Core doctrine: Most persistent dysfunction is not caused by bad stated values but by misaligned reward geometry across actors, timescales, and visibility layers. Incentives are gradients. Governance is terrain-shaping.

SYSTEM DESCRIPTION:
${systemDesc}

ACTOR MAP:
${actorSummary || “(no actors defined yet)”}

SCORING MATRIX:
${scoreSummary}
Misalignment Index: ${mi}/20 (${miLabel(mi)})

Respond ONLY with a valid JSON object (no markdown, no preamble) with this exact structure:
{
“summary”: “2-3 sentence diagnosis of the core incentive dysfunction”,
“misalignments”: [
{“type”: “one of: Proxy Capture / Externalized Harm / Timescale Inversion / Information Asymmetry / Lock-in Asymmetry / Moral Camouflage”, “actors”: “which actors”, “detail”: “specific manifestation in this system”}
],
“secondOrder”: [“3-5 second-order effects if misalignment continues unaddressed”],
“patterns”: [“2-3 matching canonical patterns from: Tragedy of the Commons, Principal-Agent Drift, Monopolistic Extraction, Prestige Spiral, Debt Lock-in, Dashboard Gaming, Moral Camouflage, Regulatory Capture, Race-to-Bottom Equilibrium, Positive-Sum Flywheel”],
“redesigns”: {
“light”: {“label”: “Light-Touch”, “operator”: “one of the 6 steering operators”, “action”: “specific intervention”, “risk”: “what could go wrong”},
“structural”: {“label”: “Structural”, “operator”: “one of the 6 steering operators”, “action”: “specific intervention”, “risk”: “what could go wrong”},
“ambitious”: {“label”: “Ambitious Positive-Sum”, “operator”: “Positive-Sum Reframe”, “action”: “specific intervention”, “risk”: “what could go wrong”}
},
“ethicsGate”: {“consent”: true, “reversibility”: true, “nonCoercion”: true, “dignity”: true, “gamingResistance”: true, “loadFairness”: true, “notes”: “brief ethics assessment”}
}`;

const res = await fetch(“https://api.anthropic.com/v1/messages”, {
method:“POST”,
headers:{“Content-Type”:“application/json”},
body: JSON.stringify({
model:“claude-sonnet-4-20250514”,
max_tokens:1000,
messages:[{role:“user”,content:prompt}]
})
});
const data = await res.json();
const text = data.content?.map(i=>i.text||””).join(””) || “”;
return JSON.parse(text.replace(/`json|`/g,””).trim());
}

