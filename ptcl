2️⃣ CLUSTER MEMORY

/core/problem_cluster_memory.py

from collections import defaultdict

class ProblemClusterMemory:
    def __init__(self):
        self.memory = defaultdict(list)

    def add(self, problem_type, record):
        self.memory[problem_type].append(record)

    def get(self, problem_type):
        return self.memory.get(problem_type, [])


