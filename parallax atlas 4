          const bm=computeMetrics(b,S.span,S.step,S.elongVis,S.elongMid);
          const bSim=cosine(skySignature(bm,b),earthSig);
          const bTop=bm.slice(0,2).map(m=>PHYS[m.name].sym+m.name.substring(0,3)).join(' ');
