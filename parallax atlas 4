    <div style="margin-top:16px;border-top:1px solid var(--rule);padding-top:10px">
      <div style="font-size:7px;letter-spacing:.3em;color:var(--text-d);text-transform:uppercase;margin-bottom:8px">All Observers vs Earth</div>
      <table class="data-table">
