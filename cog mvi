class DaemonHound:
    """Anomaly detection — flags statistical drift in TO stream."""

    def __init__(self, window: int = 10):
        self._window = int(window)
        self._baseline_sc: List[float] = []

    def observe(self, to: ThoughtObject) -> Optional[str]:
        sc = to.sc()
        self._baseline_sc.append(sc)
        if len(self._baseline_sc) < self._window:
            return None
        recent = self._baseline_sc[-self._window:]
        mean_sc = statistics.mean(recent)
        stdev = statistics.stdev(recent) if len(recent) > 1 else 0.0
        if stdev > 0 and abs(sc - mean_sc) > 2.5 * stdev:
            return f"[Hound] Anomaly detected: SC={sc:.3f} deviates >2.5σ from μ={mean_sc:.3f}"
        return None


class DaemonMirror:
    """Invariant engine — Solomon Score across five evaluation modes."""

    MODES = ["analytic", "combinatorial", "topological", "semantic", "empirical"]

    def solomon_score(
        self, to: ThoughtObject, sv: StateVector, invariants: Dict[str, InvariantFn]
    ) -> Tuple[float, Dict[str, float]]:
        """
        Five-mode coherence evaluation.
        Returns (solomon_score, mode_scores).
        """
        mode_scores: Dict[str, float] = {}

        # Analytic: direct invariant pass
        direct = [float(fn(to, sv)) for fn in invariants.values()]
        mode_scores["analytic"] = statistics.mean(direct) if direct else 0.0

        # Combinatorial: pairwise agreement between invariants
        if len(direct) >= 2:
            pairs = [
                abs(direct[i] - direct[j])
                for i in range(len(direct))
                for j in range(i + 1, len(direct))
            ]
            mode_scores["combinatorial"] = 1.0 - statistics.mean(pairs)
        else:
            mode_scores["combinatorial"] = mode_scores["analytic"]

        # Topological: does content reference structural terms?
        structural_terms = ["because", "therefore", "implies", "follows", "given"]
        hits = sum(1 for t in structural_terms if t in to.content.lower())
        mode_scores["topological"] = min(1.0, 0.5 + hits * 0.1)

        # Semantic: tag coherence (proxy)
        declared_tags = set(to.tags)
        mode_scores["semantic"] = 1.0 if declared_tags else 0.4

        # Empirical: use TO's own SC (proxy)
        mode_scores["empirical"] = to.sc()

        solomon = float(statistics.mean(mode_scores.values()))
        return solomon, mode_scores

    def approve(self, solomon: float) -> bool:
        return solomon >= 0.70


class DaemonSpider:
    """Graph archivist — builds and queries the TO relationship graph."""

    def __init__(self):
        self._graph: Dict[str, List[str]] = {}  # uuid -> [child uuids]
        self._index: Dict[str, ThoughtObject] = {}

    def register(self, to: ThoughtObject) -> None:
        self._index[to.uuid_] = to
        if to.parent_uuid and to.parent_uuid in self._index:
            self._graph.setdefault(to.parent_uuid, []).append(to.uuid_)

    def lineage(self, uuid_: str, depth: int = 5) -> List[ThoughtObject]:
        """Walk parent chain upward."""
        chain: List[ThoughtObject] = []
        current = self._index.get(uuid_)
        while current and len(chain) < depth:
            chain.append(current)
            current = self._index.get(current.parent_uuid or "")
        return chain

    def search_by_tag(self, tag: str) -> List[ThoughtObject]:
        return [to for to in self._index.values() if tag in to.tags]


class DaemonDragonfly:
    """Bayesian foresight — phi (expand) and sqrt2 (compress) modes."""

    def phi_mode(self, input_text: str, sv: StateVector) -> List[str]:
        """Exploratory expansion: generate candidate interpretations."""
        base = input_text.strip()
        return [
            f"[Dragonfly/φ] Interpretation A: {base} — optimistic trajectory",
            f"[Dragonfly/φ] Interpretation B: {base} — conservative trajectory",
            f"[Dragonfly/φ] Interpretation C: {base} — adversarial trajectory",
        ]

    def sqrt2_mode(self, candidates: List[str], sv: StateVector) -> str:
        """Compression: collapse candidates to most coherent single path."""
        return candidates[0] if candidates else "[Dragonfly/√2] No candidates."


class DaemonSisyphus:
    """Maintenance and timing — epoch management and distillation scheduling."""

    DISTILL_EVERY = 10

    def __init__(self):
        self._cycle_count = 0

    def tick(self) -> bool:
        """Returns True when distillation is due."""
        self._cycle_count += 1
        return self._cycle_count % self.DISTILL_EVERY == 0

    def kairos_signal(self, sv: StateVector) -> str:
        """Timing signal for high-tempo decisions."""
        return (
            f"[Sisyphus/Kairos] epoch={sv.epoch} | cycle={self._cycle_count} | "
            f"distill_due={self._cycle_count % self.DISTILL_EVERY == 0}"
        )


