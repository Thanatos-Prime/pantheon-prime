<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PARALLAX ATLAS — Planetary Sky Simulation</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap');

:root {
–void: #04050d;
–deep: #080c1a;
–mid: #0d1328;
–panel: #0f1530;
–border: rgba(120,140,220,0.12);
–border-bright: rgba(160,180,255,0.25);
–gold: #c8a84b;
–gold-dim: rgba(200,168,75,0.4);
–star: #e8ecff;
–star-dim: rgba(200,210,255,0.5);
–accent: #4a7fff;
–accent-glow: rgba(74,127,255,0.2);
–text: #b8c4e8;
–text-dim: rgba(180,196,232,0.5);
–text-bright: #dde4f8;
–myth-color: #9b7bff;
–myth-glow: rgba(155,123,255,0.15);
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–void);
color: var(–text);
font-family: ‘Space Mono’, monospace;
font-size: 11px;
min-height: 100vh;
overflow-x: hidden;
position: relative;
}

/* Star field background */
#starfield {
position: fixed;
inset: 0;
pointer-events: none;
z-index: 0;
}

.layout {
position: relative;
z-index: 1;
display: grid;
grid-template-rows: auto 1fr auto;
min-height: 100vh;
}

/* ── HEADER ── */
header {
padding: 28px 36px 20px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: flex-end;
gap: 48px;
}

.wordmark {
display: flex;
flex-direction: column;
}

.wordmark-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: 28px;
font-weight: 300;
letter-spacing: 0.18em;
color: var(–star);
line-height: 1;
}

.wordmark-sub {
font-size: 9px;
letter-spacing: 0.35em;
color: var(–text-dim);
margin-top: 6px;
text-transform: uppercase;
}

.header-controls {
display: flex;
gap: 24px;
align-items: center;
flex-wrap: wrap;
}

.control-group {
display: flex;
flex-direction: column;
gap: 6px;
}

.control-label {
font-size: 8px;
letter-spacing: 0.3em;
color: var(–text-dim);
text-transform: uppercase;
}

select, input[type=“range”] {
background: var(–panel);
border: 1px solid var(–border-bright);
color: var(–star);
font-family: ‘Space Mono’, monospace;
font-size: 10px;
padding: 5px 10px;
cursor: pointer;
appearance: none;
outline: none;
transition: border-color 0.2s;
}

select:hover, select:focus {
border-color: var(–accent);
}

select option { background: var(–deep); }

.tier-badge {
font-size: 8px;
letter-spacing: 0.2em;
color: var(–gold);
border: 1px solid var(–gold-dim);
padding: 3px 8px;
background: rgba(200,168,75,0.05);
}

/* ── MAIN BODY ── */
main {
display: grid;
grid-template-columns: 340px 1fr 280px;
gap: 0;
min-height: 0;
}

/* ── LEFT PANEL: METRICS TABLE ── */
.panel-left {
border-right: 1px solid var(–border);
padding: 20px;
overflow-y: auto;
display: flex;
flex-direction: column;
gap: 20px;
}

.panel-title {
font-size: 8px;
letter-spacing: 0.4em;
color: var(–text-dim);
text-transform: uppercase;
padding-bottom: 10px;
border-bottom: 1px solid var(–border);
}

.planet-card {
border: 1px solid var(–border);
padding: 12px;
cursor: pointer;
transition: all 0.2s;
position: relative;
overflow: hidden;
}

.planet-card::before {
content: ‘’;
position: absolute;
inset: 0;
opacity: 0;
transition: opacity 0.2s;
}

.planet-card:hover, .planet-card.selected {
border-color: var(–border-bright);
}

.planet-card.selected::before {
opacity: 1;
}

.card-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 8px;
}

.planet-name {
font-family: ‘Cormorant Garamond’, serif;
font-size: 16px;
font-weight: 400;
color: var(–star);
letter-spacing: 0.05em;
}

.planet-dot {
width: 10px;
height: 10px;
border-radius: 50%;
flex-shrink: 0;
}

.metric-row {
display: flex;
justify-content: space-between;
align-items: center;
padding: 2px 0;
border-top: 1px solid rgba(120,140,220,0.06);
}

.metric-key {
font-size: 8px;
letter-spacing: 0.15em;
color: var(–text-dim);
}

.metric-val {
font-size: 10px;
color: var(–text-bright);
font-variant-numeric: tabular-nums;
}

.vis-bar {
width: 100%;
height: 2px;
background: rgba(120,140,220,0.1);
margin-top: 6px;
position: relative;
}

.vis-fill {
position: absolute;
left: 0;
top: 0;
height: 100%;
transition: width 0.5s;
}

/* ── CENTER: SKY VIEW ── */
.panel-center {
display: flex;
flex-direction: column;
position: relative;
}

.sky-container {
flex: 1;
position: relative;
display: flex;
align-items: center;
justify-content: center;
padding: 30px;
}

#skyCanvas {
max-width: 100%;
max-height: 100%;
display: block;
}

.sky-label {
position: absolute;
top: 16px;
left: 50%;
transform: translateX(-50%);
font-size: 8px;
letter-spacing: 0.4em;
color: var(–text-dim);
text-transform: uppercase;
white-space: nowrap;
}

.time-display {
position: absolute;
bottom: 16px;
left: 50%;
transform: translateX(-50%);
font-size: 9px;
letter-spacing: 0.2em;
color: var(–text-dim);
white-space: nowrap;
}

/* timeline scrubber */
.timeline-bar {
border-top: 1px solid var(–border);
padding: 12px 30px;
display: flex;
align-items: center;
gap: 16px;
}

.timeline-label {
font-size: 8px;
letter-spacing: 0.3em;
color: var(–text-dim);
white-space: nowrap;
}

input[type=“range”] {
flex: 1;
height: 2px;
padding: 0;
border: none;
background: rgba(120,140,220,0.15);
cursor: pointer;
accent-color: var(–accent);
}

.play-btn {
background: none;
border: 1px solid var(–border-bright);
color: var(–star);
font-family: ‘Space Mono’, monospace;
font-size: 9px;
padding: 5px 12px;
cursor: pointer;
letter-spacing: 0.2em;
transition: all 0.2s;
white-space: nowrap;
}

.play-btn:hover {
border-color: var(–accent);
color: var(–accent);
}

/* ── RIGHT PANEL: MYTH ENGINE ── */
.panel-right {
border-left: 1px solid var(–border);
padding: 20px;
overflow-y: auto;
display: flex;
flex-direction: column;
gap: 16px;
background: linear-gradient(180deg, transparent, rgba(155,123,255,0.02));
}

.myth-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: 13px;
font-style: italic;
color: var(–myth-color);
letter-spacing: 0.05em;
opacity: 0.7;
}

.pantheon-card {
border: 1px solid rgba(155,123,255,0.15);
padding: 14px;
background: var(–myth-glow);
position: relative;
transition: all 0.3s;
}

.pantheon-card:hover {
border-color: rgba(155,123,255,0.3);
background: rgba(155,123,255,0.08);
}

.card-archetype {
font-family: ‘Cormorant Garamond’, serif;
font-size: 18px;
font-weight: 300;
color: var(–star);
letter-spacing: 0.05em;
line-height: 1.1;
margin-bottom: 4px;
}

.card-planet-name {
font-size: 8px;
letter-spacing: 0.35em;
color: var(–myth-color);
text-transform: uppercase;
margin-bottom: 10px;
opacity: 0.7;
}

.card-lore {
font-family: ‘Cormorant Garamond’, serif;
font-size: 12px;
font-style: italic;
color: var(–text-dim);
line-height: 1.6;
border-top: 1px solid rgba(155,123,255,0.1);
padding-top: 8px;
margin-top: 8px;
}

.card-domains {
display: flex;
flex-wrap: wrap;
gap: 4px;
margin-top: 8px;
}

.domain-tag {
font-size: 7px;
letter-spacing: 0.25em;
color: var(–gold);
border: 1px solid var(–gold-dim);
padding: 2px 6px;
background: rgba(200,168,75,0.03);
}

/* ── FOOTER ── */
footer {
border-top: 1px solid var(–border);
padding: 10px 36px;
display: flex;
justify-content: space-between;
align-items: center;
font-size: 8px;
letter-spacing: 0.2em;
color: var(–text-dim);
}

/* observation note */
.obs-note {
font-family: ‘Cormorant Garamond’, serif;
font-size: 11px;
font-style: italic;
color: var(–text-dim);
line-height: 1.6;
padding: 10px 12px;
border-left: 2px solid rgba(155,123,255,0.2);
}

/* scrollbar */
::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-track { background: var(–void); }
::-webkit-scrollbar-thumb { background: var(–border-bright); border-radius: 0; }

/* planet color map */
.col-mercury { background: #a0978a; }
.col-venus   { background: #e8c97a; }
.col-earth   { background: #4a90d9; }
.col-mars    { background: #c1440e; }
.col-jupiter { background: #c8a474; }
.col-saturn  { background: #e0c882; }
.col-uranus  { background: #7de8e8; }
.col-neptune { background: #4060d0; }
.col-pluto   { background: #a09080; }

.selected-highlight {
box-shadow: inset 0 0 20px rgba(74,127,255,0.06);
}

/* elongation heuristic annotation on canvas */
.canvas-wrap {
position: relative;
width: 520px;
height: 520px;
flex-shrink: 0;
}
</style>

</head>
