🔌 pantheon-adapter.js (THIS is the key)

export function fromPantheonState(state) {
  return {
    nodes: Object.values(state.daemons).map(d => ({
      id: d.name,
      type: "daemon",
      category: d.domain,
      weight: d.importance,
      activity: d.activity
    })),
    edges: state.links
  };
}

