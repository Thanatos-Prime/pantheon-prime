# Overlap functions

# —————————————————————————

def _token_overlap(text_a: str, text_b: str) -> float:
“”“Normalized token overlap between two strings (Jaccard-style).”””
if not text_a or not text_b:
return 0.0
tokens_a = set(text_a.lower().split())
tokens_b = set(text_b.lower().split())
if not tokens_a or not tokens_b:
return 0.0
intersection = tokens_a & tokens_b
union = tokens_a | tokens_b
return len(intersection) / len(union)

def _list_overlap(list_a: list[str], list_b: list[str]) -> float:
“”“Normalized overlap between two ID/string lists (Jaccard).”””
if not list_a or not list_b:
return 0.0
set_a = set(s.lower() for s in list_a)
set_b = set(s.lower() for s in list_b)
intersection = set_a & set_b
union = set_a | set_b
return len(intersection) / len(union)

def _failure_mode_overlap(modes_a: list[str], modes_b: list[str]) -> float:
“””
Overlap across failure mode text. Uses token-level matching since
failure modes are prose phrases, not IDs.
“””
if not modes_a or not modes_b:
return 0.0
tokens_a = set(w for m in modes_a for w in m.lower().split())
tokens_b = set(w for m in modes_b for w in m.lower().split())
# Remove stop words that add noise
stopwords = {“the”, “a”, “an”, “of”, “in”, “to”, “or”, “and”, “is”, “are”, “by”}
tokens_a -= stopwords
tokens_b -= stopwords
if not tokens_a or not tokens_b:
return 0.0
intersection = tokens_a & tokens_b
union = tokens_a | tokens_b
return len(intersection) / len(union)

