from dataclasses import dataclass

@dataclass
class Voxel:
    voxel_id: str
    name: str
    traffic: float
    competition: float
    price: float
    rating: float
    skill_modifier: float
    narrative: str

src/narrative.py

NARRATIVE_MULTIPLIERS = {
    "growing": 1.10,
    "trendy": 1.08,
    "up-and-coming": 1.15,
    "stable": 1.00,
    "declining": 0.85,
    "elite": 0.95,
    "underground": 1.05,
}

def get_narrative_multiplier(tag: str) -> float:
    return NARRATIVE_MULTIPLIERS.get(tag.strip().lower(), 1.00)

src/scoring.py

from narrative import get_narrative_multiplier
from models import Voxel

def safe_div(numerator: float, denominator: float) -> float:
    if denominator == 0:
        return 0.0
    return numerator / denominator

def base_score(voxel: Voxel) -> float:
    return safe_div(voxel.traffic * voxel.rating, voxel.competition * voxel.price)

def adjusted_score(voxel: Voxel) -> float:
    return base_score(voxel) * voxel.skill_modifier

def final_score(voxel: Voxel) -> float:
    return adjusted_score(voxel) * get_narrative_multiplier(voxel.narrative)

def recommendation(score: float) -> str:
    if score >= 2.0:
        return "strong candidate"
    if score >= 1.3:
        return "worth testing"
    if score >= 0.9:
        return "situational"
    return "avoid for now"

src/main.py

import csv
import os
from models import Voxel
from scoring import base_score, adjusted_score, final_score, recommendation

DATA_PATH = os.path.join("data", "voxels.csv")
OUTPUT_PATH = os.path.join("output", "ranked_voxels.csv")

def load_voxels(path: str) -> list[Voxel]:
    voxels = []
    with open(path, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        for row in reader:
            voxels.append(
                Voxel(
                    voxel_id=row["voxel_id"],
                    name=row["name"],
                    traffic=float(row["traffic"]),
                    competition=float(row["competition"]),
                    price=float(row["price"]),
                    rating=float(row["rating"]),
                    skill_modifier=float(row["skill_modifier"]),
                    narrative=row["narrative"],
                )
            )
    return voxels

def rank_voxels(voxels: list[Voxel]) -> list[dict]:
    ranked = []
    for voxel in voxels:
        b = base_score(voxel)
        a = adjusted_score(voxel)
        f = final_score(voxel)
        ranked.append({
            "voxel_id": voxel.voxel_id,
            "name": voxel.name,
            "base_score": round(b, 3),
            "adjusted_score": round(a, 3),
            "final_score": round(f, 3),
            "recommendation": recommendation(f),
            "narrative": voxel.narrative,
        })
    ranked.sort(key=lambda x: x["final_score"], reverse=True)
    return ranked

def save_ranked(path: str, rows: list[dict]) -> None:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(
            f,
            fieldnames=[
                "voxel_id",
                "name",
                "base_score",
                "adjusted_score",
                "final_score",
                "recommendation",
                "narrative",
            ],
        )
        writer.writeheader()
        writer.writerows(rows)

def main() -> None:
    voxels = load_voxels(DATA_PATH)
    ranked = rank_voxels(voxels)
    save_ranked(OUTPUT_PATH, ranked)

    print("\nTop opportunities:\n")
    for i, row in enumerate(ranked[:5], start=1):
        print(
            f"{i}. {row['name']} "
            f"(final_score={row['final_score']}, "
            f"{row['recommendation']}, narrative={row['narrative']})"
        )

if __name__ == "__main__":
    main()


