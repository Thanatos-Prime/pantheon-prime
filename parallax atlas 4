// ═══════════════════════════════════════════════════════════
// METRICS ENGINE
// ═══════════════════════════════════════════════════════════
let MCACHE={};

function computeMetrics(observer,spanDays,stepDays,elongVis=20,elongMid=90){
  const key=`${observer}_${spanDays}_${stepDays}_${elongVis}`;
  if(MCACHE[key])return MCACHE[key];

  const T=[];for(let t=0;t<=spanDays;t+=stepDays)T.push(t);
  const N=T.length;

  // pre-compute observer positions
  const obsPos=T.map(t=>helioXYZ(observer,t));

  const result=BODIES.filter(b=>b!==observer).map(target=>{
    let cVis=0,cMid=0,sumBVis=0,maxB=0,minD=1e9,maxD=0,maxEl=0;

    T.forEach((t,i)=>{
      const op=obsPos[i],tp=helioXYZ(target,t);
      const rel=[tp[0]-op[0],tp[1]-op[1],tp[2]-op[2]];
      const dist=Math.hypot(rel[0],rel[1],rel[2]);
      // sun hat (from observer toward sun = -observer pos)
      const sLen=Math.hypot(op[0],op[1],op[2]);
      const sH=[-op[0]/sLen,-op[1]/sLen,-op[2]/sLen];
      const rH=[rel[0]/dist,rel[1]/dist,rel[2]/dist];
      const cosE=Math.max(-1,Math.min(1,rH[0]*sH[0]+rH[1]*sH[1]+rH[2]*sH[2]));
      const elong=Math.acos(cosE)*180/Math.PI;

      // phase: angle at target between sun and observer
      const tLen=Math.hypot(tp[0],tp[1],tp[2]);
      const tsH=[-tp[0]/tLen,-tp[1]/tLen,-tp[2]/tLen];
      const toH=[-rel[0]/dist,-rel[1]/dist,-rel[2]/dist];
      const cosP=Math.max(-1,Math.min(1,tsH[0]*toH[0]+tsH[1]*toH[1]+tsH[2]*toH[2]));
      const phase=(1+Math.cos(Math.acos(cosP)))/2;

      const p=PHYS[target];
      const B=(p.R*p.R*p.A*phase)/(dist*dist);

      const vis=elong>=elongVis,mid=elong>=elongMid;
      if(vis){cVis++;sumBVis+=B;}
      if(mid)cMid++;
      if(B>maxB)maxB=B;
      if(dist<minD)minD=dist;
      if(dist>maxD)maxD=dist;
      if(elong>maxEl)maxEl=elong;
    });

    return{
      name:target,
      visFrac:cVis/N,
      midFrac:cMid/N,
      meanBVis:cVis>0?sumBVis/cVis:0,
      maxB,minDist:minD,maxDist:maxD,maxElong:maxEl,
      isInterior:EL[target].a<EL[observer].a,
      synodic:synodicDays(observer,target),
    };
  });

  result.sort((a,b)=>b.meanBVis-a.meanBVis);
  MCACHE[key]=result;
  return result;
}

function synodicDays(obs,tgt){
  const Po=365.256*(EL[obs].a**1.5),Pt=365.256*(EL[tgt].a**1.5);
  if(Math.abs(Po-Pt)<.1)return 999999;
  return Math.abs(1/(1/Math.min(Po,Pt)-1/Math.max(Po,Pt)));
}

// sky signature vector (mean brightness per body slot)
function skySignature(metrics,observer){
  const m={};metrics.forEach(x=>m[x.name]=x.meanBVis);
  return BODIES.map(b=>b===observer?0:(m[b]||0));
}

function cosine(a,b){
  let dot=0,na=0,nb=0;
  for(let i=0;i<a.length;i++){dot+=a[i]*b[i];na+=a[i]*a[i];nb+=b[i]*b[i];}
  return(na*nb)===0?0:dot/Math.sqrt(na*nb);
}

