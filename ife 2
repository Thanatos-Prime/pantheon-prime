// ── SIMULATION ENGINE ────────────────────────────────────────────────────────
function computePayoff(actor) {
  const baseReward = actor.rewardWeight * 5;
  const costPenalty =
    (actor.externalities / 5) * (1 - actor.rewardWeight) * 3;
  const lockBonus = actor.rewardWeight > 0.6 ? actor.lockin * 0.4 : 0;
  const infoBonus = actor.infoAdvantage * actor.rewardWeight * 0.3;

  const timeFactor =
    {
      Immediate: 1.2,
      Quarterly: 1.1,
      Annual: 1.0,
      Career: 0.85,
      Lifetime: 0.7,
      Intergenerational: 0.5,
    }[actor.horizon] || 1.0;

  const noise = (Math.random() - 0.5) * 0.3;

  return (baseReward + lockBonus + infoBonus - costPenalty) * timeFactor + noise;
}

function runSimulation(actors, constraints, edges, steps = 40) {
  if (actors.length === 0) {
    return {
      frames: [],
      equilibrium: null,
      collapseDetected: false,
      attractors: [],
    };
  }

  const hardConstraintPenalty =
    constraints
      .filter((c) => c.type === "Hard")
      .reduce((s, c) => s + c.impact, 0) / 10;

  const invisibleLoad =
    constraints
      .filter((c) => c.type === "Invisible")
      .reduce((s, c) => s + c.impact, 0) / 10;

  const frames = [];
  let systemState = actors.map(() => ({
    payoff: 3,
    welfare: 3,
    position: Math.random() * 4 + 1,
  }));

  for (let step = 0; step < steps; step++) {
    const newState = systemState.map((s, i) => {
      const actor = actors[i];
      const rawPayoff = computePayoff(actor);

      const edgeBonus = edges
        .filter((e) => e.from === i)
        .reduce((sum, e) => sum + e.weight * 0.15, 0);

      const edgeCost = edges
        .filter(
          (e) =>
            e.to === i &&
            ["extracts from", "locks in", "punishes"].includes(e.type)
        )
        .reduce((sum, e) => sum + e.weight * 0.2, 0);

      const payoff = Math.max(
        0,
        Math.min(10, rawPayoff + edgeBonus - edgeCost - hardConstraintPenalty * 0.5)
      );

      const welfare = Math.max(
        0,
        Math.min(10, payoff - (invisibleLoad * actor.externalities) / 5)
      );

      const drift = (payoff - s.payoff) * 0.3;
      const position = Math.max(
        0,
        Math.min(10, s.position + drift * 0.5 + (Math.random() - 0.5) * 0.2)
      );

      return { payoff, welfare, position };
    });

    frames.push(newState.map((s) => ({ ...s })));
    systemState = newState;
  }

  const lastN = frames.slice(-8);
  const variances = actors.map((_, i) => {
    const vals = lastN.map((f) => f[i].payoff);
    const mean = vals.reduce((s, v) => s + v, 0) / vals.length;
    return vals.reduce((s, v) => s + Math.pow(v - mean, 2), 0) / vals.length;
  });

  const maxVar = Math.max(...variances);

  let equilibrium = null;
  let collapseDetected = false;
  let attractors = [];

  if (maxVar < 0.15) {
    const finalPayoffs = actors.map(
      (_, i) => frames[frames.length - 1][i].payoff
    );
    const avgPayoff =
      finalPayoffs.reduce((s, v) => s + v, 0) / finalPayoffs.length;

    const lowActors = actors.filter(
      (_, i) => frames[frames.length - 1][i].welfare < 2.5
    );

    equilibrium = {
      stable: true,
      avgPayoff: avgPayoff.toFixed(2),
      type:
        avgPayoff > 6 ? "cooperative" : avgPayoff > 4 ? "neutral" : "extractive",
      trapped: lowActors.map((a) => a.name),
    };
  } else if (maxVar > 1.5) {
    collapseDetected = true;
  } else {
    const finalPositions = actors.map(
      (_, i) => frames[frames.length - 1][i].position
    );
    const high = actors
      .filter((_, i) => finalPositions[i] > 6)
      .map((a) => a.name);
    const low = actors
      .filter((_, i) => finalPositions[i] < 4)
      .map((a) => a.name);

    if (high.length > 0 && low.length > 0) {
      attractors = [
        { label: "High-payoff basin", actors: high },
        { label: "Low-payoff basin", actors: low },
      ];
    }
  }

  return { frames, equilibrium, collapseDetected, attractors };
}

// ── AI ANALYSIS CALL ─────────────────────────────────────────────────────────
async function callIFE(systemDesc, actors, constraints, edges, simResult) {
  const res = await fetch("/api/ife", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      systemDesc,
      actors,
      constraints,
      edges,
      simResult,
    }),
  });

  if (!res.ok) {
    const data = await res.json().catch(() => ({}));
    throw new Error(data?.error || `Request failed: ${res.status}`);
  }

  return await res.json();
}

