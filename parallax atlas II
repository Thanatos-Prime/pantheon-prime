  zodX.textAlign='center';zodX.textBaseline='middle';
  zodX.fillText(STATE.observer.toUpperCase()+' OBSERVER',cx,cy+innerR*.25);

  // Plot planets on zodiac
  PNAMES.forEach(n=>{
    if(n===STATE.observer) return;
    const deg=getPlanetLongitude(n,STATE.t);
    const a=(deg-90)*Math.PI/180;
    const p=PLANETS[n];
    // place at inner radius
    const pr=Math.max(4,Math.log(p.R+1)*2.2);
    const plotR=innerR*.8;
    const px=cx+plotR*Math.cos(a);
    const py=cy+plotR*Math.sin(a);

    // glow
    const grd=zodX.createRadialGradient(px,py,0,px,py,pr*2.5);
    grd.addColorStop(0,p.col+'88');grd.addColorStop(1,'transparent');
    zodX.beginPath();zodX.arc(px,py,pr*2.5,0,Math.PI*2);
    zodX.fillStyle=grd;zodX.fill();

    zodX.beginPath();zodX.arc(px,py,pr,0,Math.PI*2);
    zodX.fillStyle=p.col;zodX.fill();
    zodX.fillStyle='rgba(210,225,255,.7)';
    zodX.font=`${pr*1.4}px serif`;
    zodX.textAlign='center';zodX.textBaseline='middle';
    zodX.fillText(p.sym,px,py);

    // line to rim
    zodX.beginPath();
    zodX.moveTo(cx+innerR*Math.cos(a),cy+innerR*Math.sin(a));
    zodX.lineTo(cx+outerR*Math.cos(a),cy+outerR*Math.sin(a));
    zodX.strokeStyle=p.col+'44';zodX.lineWidth=.8;zodX.stroke();
  });
}

