Pseudocode for the engine

class PreferenceEngine:
    def __init__(self):
        self.user_vectors = {}
        self.item_vectors = {}
        self.user_confidence = {}
        self.item_confidence = {}

    def score(self, user, item, context):
        u = self.user_vectors[user]
        i = self.item_vectors[item]
        ctx = self.encode_context(context)
        return dot(u, i) + ctx

    def preference_prob(self, user, item_a, item_b, context):
        sa = self.score(user, item_a, context)
        sb = self.score(user, item_b, context)
        return sigmoid(sa - sb)

    def update_from_event(self, event):
        user = event["user_id"]
        a = event["options"]["left"]
        b = event["options"]["right"]
        selected = event["selected"]
        context = event["context"]
        weight = self.event_weight(event)

        p = self.preference_prob(user, a, b, context)
        y = 1 if selected == a else 0
        error = (y - p) * weight

        self.user_vectors[user] += self.user_lr(user) * error * (
            self.item_vectors[a] - self.item_vectors[b]
        )
        self.item_vectors[a] += self.item_lr(a) * error * self.user_vectors[user]
        self.item_vectors[b] -= self.item_lr(b) * error * self.user_vectors[user]

        self.update_confidence(user, a, b, event)

    def event_weight(self, event):
        dwell = normalize_dwell(event["decision_time_ms"])
        confidence = event.get("confidence", 0.5)
        return 0.5 * dwell + 0.5 * confidence

This is simplified, but it shows the skeleton.

