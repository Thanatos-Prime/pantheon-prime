from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional
from uuid import uuid4
@dataclass
class HydraStrand:
    id: str
    name: str
    family: str
    description: str
    payload: Dict[str, Any]
    parent_id: Optional[str] = None
    children: List[str] = field(default_factory=list)
    provenance: Dict[str, Any] = field(default_factory=dict)
    def branch(self, name: str, description: str, payload: Dict[str, Any]) -> "HydraStrand":
        child = HydraStrand(
            id=str(uuid4()),
            name=name,
            family=self.family,
            description=description,
            payload=payload,
            parent_id=self.id,
            provenance={"derived_from": self.id},
        )
        self.children.append(child.id)
        return child
class MedusaCore:
    """
    Medusa captures meaningful patterns and grows them as Hydra-like
    algorithmic strands. Each strand is both memory and reusable machinery.
    """
    def __init__(self):
        self.strands: Dict[str, HydraStrand] = {}
    def capture(
        self,
        name: str,
        family: str,
        description: str,
        payload: Dict[str, Any],
        provenance: Optional[Dict[str, Any]] = None,
    ) -> HydraStrand:
        strand = HydraStrand(
            id=str(uuid4()),
            name=name,
            family=family,
            description=description,
            payload=payload,
            provenance=provenance or {},
        )
        self.strands[strand.id] = strand
        return strand
    def branch(
        self,
        parent_id: str,
        name: str,
        description: str,
        payload: Dict[str, Any],
    ) -> HydraStrand:
        parent = self.strands[parent_id]
        child = parent.branch(name, description, payload)
        self.strands[child.id] = child
        return child
    def lineage(self, strand_id: str) -> List[HydraStrand]:
        strand = self.strands[strand_id]
        chain = [strand]
        while strand.parent_id:
            strand = self.strands[strand.parent_id]
            chain.append(strand)
        return list(reversed(chain))

