                      if(!t||!z) return null;
                      return (
                        <div key={i} style={{ padding:"7px 10px", background:"#0a0f1a", border:"1px solid #0f172a", borderLeft:"3px solid "+t.color, borderRadius:2, display:"flex", alignItems:"center", gap:10 }}>
                          <span style={{ color:t.color, fontFamily:"monospace" }}>{t.glyph}</span>
                          <span style={{ fontSize:11, color:"#cbd5e1" }}>{z.label}</span>
                          <span style={{ fontSize:10, color:"#475569" }}>{t.label.toLowerCase()}</span>
                          <span style={{ fontSize:10, color:t.color, marginLeft:"auto" }}>{m.intensity}/10</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
                {deltas.length>0&&(
                  <div>
                    <div style={{ fontSize:9, color:"#475569", letterSpacing:".15em", marginBottom:10 }}>DELTA vs PREV LOG</div>
                    <div style={{ display:"flex", flexDirection:"column", gap:4 }}>
                      {deltas.map((d,i)=>{
                        const t=getType(d.type), z=getZone(d.zone), up=d.delta>0;
                        return (
                          <div key={i} style={{ padding:"7px 10px", background:"#0a0f1a", border:"1px solid "+(up?"#ef4444":"#22c55e")+"22", borderRadius:2, display:"flex", alignItems:"center", gap:10 }}>
                            <span style={{ color:up?"#ef4444":"#22c55e", fontSize:12 }}>{up?"^":"v"}</span>
                            <span style={{ fontSize:11, color:"#cbd5e1" }}>{z?z.label:d.zone}</span>
                            <span style={{ fontSize:10, color:"#475569" }}>{t?t.label.toLowerCase():d.type}</span>
                            <span style={{ fontSize:11, color:up?"#ef4444":"#22c55e", marginLeft:"auto", fontWeight:500 }}>{up?"+":""}{d.delta}</span>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                )}
                {!deltas.length&&prevSnap&&<div style={{ fontSize:11, color:"#334155", fontStyle:"italic" }}>no changes from previous log</div>}
              </div>
            </>
        }
      </div>
    )}

    {/* PATTERNS */}
    {view==="patterns"&&(
      <div style={{ flex:1, padding:"32px 40px", overflowY:"auto" }}>
        {snapshots.length<2
          ? <div style={{ display:"flex", alignItems:"center", justifyContent:"center", height:"60%" }}>
              <div style={{ textAlign:"center" }}>
                <div style={{ fontSize:32, marginBottom:12, opacity:.15 }}>~</div>
                <div style={{ fontSize:12, color:"#475569", letterSpacing:".1em" }}>NEED 2+ LOGS FOR PATTERNS</div>
                <div style={{ fontSize:11, color:"#334155", marginTop:6 }}>Build history in Map view</div>
              </div>
            </div>
          : <>
              <div style={{ fontSize:9, color:"#475569", letterSpacing:".15em", marginBottom:24 }}>PATTERN ENGINE -- {snapshots.length} LOGS ANALYZED</div>
              <div style={{ marginBottom:36 }}>
                <div style={{ fontSize:11, color:"#64748b", letterSpacing:".1em", marginBottom:16 }}>TOP RECURRING SIGNALS</div>
                <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
                  {clusters.map((c,i)=>{
                    const t=getType(c.type), z=getZone(c.zone), pct=(c.count/snapshots.length)*100, col=t?t.color:"#fff";
                    return (
                      <div key={i} style={{ padding:"14px 16px", background:"#0a0f1a", border:"1px solid #0f172a", borderRadius:2, position:"relative", overflow:"hidden" }}>
                        <div style={{ position:"absolute", left:0, top:0, bottom:0, width:pct+"%", background:col+"10", transition:"width .5s ease" }}/>
                        <div style={{ position:"relative", display:"flex", alignItems:"center", gap:12 }}>
                          <span style={{ fontSize:16, color:"#334155", fontFamily:"'Syne',sans-serif", fontWeight:800 }}>0{i+1}</span>
                          <span style={{ color:col, fontSize:13, fontFamily:"monospace" }}>{t?t.glyph:"?"}</span>
                          <div>
                            <div style={{ fontSize:13, color:"#e2e8f0", fontFamily:"'Syne',sans-serif", fontWeight:600 }}>{z?z.label:c.zone} {t?t.label:c.type}</div>
                            <div style={{ fontSize:10, color:"#475569", marginTop:2, letterSpacing:".08em" }}>{c.count} of {snapshots.length} logs -- {Math.round(pct)}% occurrence</div>
                          </div>
                          <div style={{ marginLeft:"auto", fontSize:20, color:col, opacity:.6, fontFamily:"'Syne',sans-serif", fontWeight:800 }}>{c.count}x</div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
              <div>
                <div style={{ fontSize:11, color:"#64748b", letterSpacing:".1em", marginBottom:16 }}>SIGNAL DISTRIBUTION</div>
                <div style={{ display:"flex", gap:10, flexWrap:"wrap" }}>
                  {MARKER_TYPES.map(t=>{
                    const entries=snapshots.reduce((acc,s)=>acc+s.markers.filter(m=>m.type===t.id).length,0);
                    const avg=entries===0?0:snapshots.reduce((acc,s)=>acc+s.markers.filter(m=>m.type===t.id).reduce((a,m)=>a+m.intensity,0),0)/entries;
                    return (
                      <div key={t.id} style={{ padding:"14px 18px", background:"#0a0f1a", border:"1px solid "+t.color+"22", borderTop:"2px solid "+t.color, borderRadius:2, minWidth:120 }}>
                        <div style={{ display:"flex", alignItems:"center", gap:6, marginBottom:8 }}>
                          <span style={{ color:t.color, fontFamily:"monospace" }}>{t.glyph}</span>
                          <span style={{ fontSize:10, color:"#64748b", letterSpacing:".1em" }}>{t.label.toUpperCase()}</span>
                        </div>
                        <div style={{ fontSize:22, fontFamily:"'Syne',sans-serif", fontWeight:800, color:entries>0?t.color:"#1e293b" }}>{entries}</div>
                        <div style={{ fontSize:9, color:"#475569", marginTop:2 }}>entries</div>
                        {entries>0&&<div style={{ fontSize:10, color:"#475569", marginTop:6 }}>avg intensity: <span style={{ color:t.color }}>{avg.toFixed(1)}</span></div>}
                      </div>
                    );
                  })}
                </div>
              </div>
            </>
        }
      </div>
    )}
  </main>

  <footer style={{ padding:"6px 24px", borderTop:"1px solid #0a0f1a", display:"flex", gap:24, alignItems:"center" }}>
    <span style={{ fontSize:9, color:"#1e293b", letterSpacing:".12em" }}>ATLAS-OS -- ETI-v0.2 -- STATE={view.toUpperCase()}</span>
    <span style={{ fontSize:9, color:"#1e293b", letterSpacing:".1em" }}>ZONES={BODY_ZONES.length} -- TYPES={MARKER_TYPES.length} -- LOGS={snapshots.length}</span>
    <span style={{ marginLeft:"auto", fontSize:9, color:"#1e293b", letterSpacing:".1em" }}>
      {currentMarkers.length>0?currentMarkers.length+" PENDING -- SAVE STATE TO LOG":"READY"}
    </span>
  </footer>
</div>
