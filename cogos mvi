# SECTION 5 — LEDGER

# Append-only, cryptographically chained sequence of ThoughtObjects.

# Each entry hashes the previous — any gap or tampering is detectable.

# ═══════════════════════════════════════════════════════════════════════════════

class Ledger:
def **init**(self):
self._chain: List[ThoughtObject] = []
self._hashes: List[str] = []

```
def head_hash(self) -> str:
    return self._hashes[-1] if self._hashes else "GENESIS"

def append(self, to: ThoughtObject) -> str:
    """Append TO; return new chain hash."""
    raw = f"{to.uuid_}|{to.state_hash}|{self.head_hash()}"
    chain_hash = hashlib.sha256(raw.encode()).hexdigest()[:16]
    self._chain.append(to)
    self._hashes.append(chain_hash)
    return chain_hash

def verify_integrity(self) -> Tuple[bool, str]:
    """Recompute chain; return (ok, message)."""
    if not self._chain:
        return True, "Ledger empty — integrity trivially holds."
    prev = "GENESIS"
    for i, to in enumerate(self._chain):
        raw = f"{to.uuid_}|{to.state_hash}|{prev}"
        expected = hashlib.sha256(raw.encode()).hexdigest()[:16]
        if expected != self._hashes[i]:
            return False, f"Chain break at position {i} (uuid={to.uuid_})"
        prev = self._hashes[i]
    return True, f"Ledger intact — {len(self._chain)} entries verified."

def history(self) -> List[dict]:
    return [to.to_dict() for to in self._chain]

def __len__(self) -> int:
    return len(self._chain)

def tail(self, n: int = 5) -> List[ThoughtObject]:
    return self._chain[-n:]
```

