function getDeltaNarrative(obs,metrics,sim){
  const top=metrics[0]?.name||'Jupiter';
  const interior=metrics.filter(m=>m.isInterior).map(m=>m.name);
  const obsP=EL[obs];

  if(obs==='Earth') return `Earth's sky is the reference frame. Jupiter dominates at night, Saturn as boundary-keeper, Venus as the brilliant dawn/dusk herald. This configuration produced classical polytheism with a clear authority hierarchy.`;
  if(sim>0.95) return `<em>Near-identical sky character to Earth.</em> ${obs} shares the same dominant hierarchy — Jupiter ruling, Saturn as boundary. The cast is the same; only the timing shifts. Interior/exterior structure is preserved. A civilization here would produce a mythology structurally indistinguishable from Earth's classical pantheons. The details differ; the grammar does not.`;
  if(sim>0.8) return `<em>Recognizably Earthlike.</em> ${obs}'s sky preserves the Jupiter-dominant structure, but the inner system has reorganized. ${interior.length>0?`${interior.join(', ')} ${interior.length===1?'is':'are'} now interior — a dawn/dusk herald instead of a midnight wanderer.`:''} A civilization here would recognize the same gods-as-planets template, but the cast assignments differ enough to generate distinct mythological traditions.`;
  if(sim>0.3) return `<em>Divergent sky cast.</em> From ${obs}, the inner solar system has collapsed toward the Sun. ${interior.join(', ')} are all interior — appearing only at dawn and dusk, never at midnight. The dominant night presence shifts to ${top}. Mythology here diverges substantially from Earth's: the inner gods form a Solar Court (a cluster of near-sun heralds), while the outer giants become the primary actors in the divine drama.`;
  if(sim>0.05) return `<em>Alien pantheon structure.</em> From ${obs}, the familiar inner system has almost entirely dissolved into the solar glare. ${top} becomes the primary deity — the nearest massive mover defines meaning. The Sun itself transitions from "god-face blazing overhead" to "distant lawgiver." Religion becomes adjacency-based: whoever is nearest and brightest is king. The concept of a "herald star" trapped near the Sun becomes almost meaningless — everything near the Sun is invisible.`;
  return `<em>Different religion entirely.</em> From ${obs}, the Sun is a star, not a face. ${top} is the unchallenged sovereign of the sky — no inner planet rivals it. The theological tradition here would be unrecognizable to an Earth culture: there is no blazing sun-god, no Venus-as-morning-star trope, no Mercury-as-messenger. The cosmos is cold, vast, patient. Religious cycles are measured in decades, not months. The nearest massive neighbor — ${top} — defines the calendar, the pantheon, and the concept of divinity itself.`;
}

function drawRadar(earthSig,obsSig,obsName){
  const W=radarC.width,H=radarC.height,cx=W/2,cy=H/2;
  radX.clearRect(0,0,W,H);
  const bg=radX.createRadialGradient(cx,cy,0,cx,cy,cx);
  bg.addColorStop(0,'rgba(11,15,28,.97)');bg.addColorStop(1,'rgba(5,7,14,.99)');
  radX.fillStyle=bg;radX.fillRect(0,0,W,H);

  const labels=BODIES.filter(b=>b!==obsName&&b!=='Sun');
  const N=labels.length;
  const R=cx*.75;

  // grid rings
  [.25,.5,.75,1].forEach(f=>{
    radX.beginPath();
    for(let i=0;i<N;i++){
      const a=(i/N)*2*Math.PI-Math.PI/2;
      const x=cx+R*f*Math.cos(a),y=cy+R*f*Math.sin(a);
      i===0?radX.moveTo(x,y):radX.lineTo(x,y);
    }
    radX.closePath();
    radX.strokeStyle=`rgba(100,130,200,${f===1?.12:.06})`;radX.lineWidth=f===1?.7:.4;radX.stroke();
  });

  // axes
  for(let i=0;i<N;i++){
    const a=(i/N)*2*Math.PI-Math.PI/2;
    radX.beginPath();radX.moveTo(cx,cy);
    radX.lineTo(cx+R*Math.cos(a),cy+R*Math.sin(a));
    radX.strokeStyle='rgba(100,130,200,.1)';radX.lineWidth=.5;radX.stroke();
    const lx=cx+(R+18)*Math.cos(a),ly=cy+(R+18)*Math.sin(a);
    const nm=labels[i];
    if(nm){
      const ph=PHYS[nm];
      radX.fillStyle=ph?ph.col+'cc':'rgba(160,180,200,.6)';
      radX.font=`9px "IBM Plex Mono"`;
      radX.textAlign='center';radX.textBaseline='middle';
      radX.fillText(ph?ph.sym+nm.substring(0,3):nm.substring(0,3),lx,ly);
    }
  }

  // normalize both to max of earth sig
  const maxE=Math.max(...earthSig,.0001);

  function plotPoly(sig,bodyList,color,fill){
    radX.beginPath();
    bodyList.forEach((b,i)=>{
      const bIdx=BODIES.indexOf(b);
      const val=bIdx>=0?(sig[bIdx]||0)/maxE:0;
      const capped=Math.min(1,val);
      const a=(i/N)*2*Math.PI-Math.PI/2;
      const x=cx+R*capped*Math.cos(a),y=cy+R*capped*Math.sin(a);
      i===0?radX.moveTo(x,y):radX.lineTo(x,y);
    });
    radX.closePath();
    if(fill){radX.fillStyle=color.replace(')',',0.1)').replace('rgb','rgba').replace('#','')||color+'18';radX.fill();}
    radX.strokeStyle=color;radX.lineWidth=1.5;radX.stroke();
  }

  // Earth in amber
  plotPoly(earthSig,labels,'rgba(212,150,26,.7)',true);
  // Observer in teal/green
  if(obsName!=='Earth') plotPoly(obsSig,labels,'rgba(61,186,110,.8)',true);

  // Legend
  radX.fillStyle='rgba(212,150,26,.7)';radX.font='8px "IBM Plex Mono"';
  radX.textAlign='left';radX.fillText('— Earth reference',10,H-22);
  if(obsName!=='Earth'){
    radX.fillStyle='rgba(61,186,110,.8)';
    radX.fillText(`— ${obsName} observer`,10,H-10);
  }
}

