State store, phase 1

# runtime/state_store.py
import json
from dataclasses import asdict
from pathlib import Path

class StateStore:
    def __init__(self, path="data/thought_objects.jsonl"):
        self.path = Path(path)
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self.sessions = {}

    def save_thought_object(self, thought):
        with self.path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(asdict(thought), ensure_ascii=False) + "\n")

    def update_session(self, session_id, thought):
        self.sessions.setdefault(session_id, [])
        self.sessions[session_id].append(thought.id)

    def recent_for_session(self, session_id, limit=10):
        if not self.path.exists():
            return []
        out = []
        with self.path.open("r", encoding="utf-8") as f:
            for line in f:
                obj = json.loads(line)
                if obj["session_id"] == session_id:
                    out.append(obj)
        return out[-limit:]


