  // Local year name
  const yearNames={Mercury:'Hermaean',Venus:'Cytherean',Earth:'Solar',Mars:'Martian',Jupiter:'Jovian',Saturn:'Cronian',Uranus:'Uranian',Neptune:'Neptunian',Pluto:'Plutonian'};
