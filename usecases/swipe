// ─── POKÉMON TCG API ──────────────────────────────────────────────────────────
// Public API — no key needed for basic use. Open source, free tier ~1000 req/day
const TCG_API = “https://api.pokemontcg.io/v2”;

async function fetchCardsByPokemon(name, page = 1) {
const q = encodeURIComponent(`name:"${name}"`);
const res = await fetch(`${TCG_API}/cards?q=${q}&pageSize=20&page=${page}&orderBy=set.releaseDate`);
const data = await res.json();
return data.data || [];
}

async function searchPokemon(query) {
// Search by pokemon name prefix — returns unique pokemon names from cards
const q = encodeURIComponent(`name:"${query}*"`);
const res = await fetch(`${TCG_API}/cards?q=${q}&pageSize=50&select=name`);
const data = await res.json();
const names = […new Set((data.data || []).map(c => {
// Extract base Pokémon name (strip EX, GX, V, VMAX etc.)
return c.name.replace(/\s+(EX|GX|V|VMAX|VSTAR|ex|Tag Team|Lv.X|Prime|δ|☆|●|★|◆).*/gi, “”).trim();
}))].sort();
return names.slice(0, 12);
}

async function fetchAllCardsForPokemon(name) {
// Fetch up to 3 pages (60 cards) for a Pokémon
const pages = await Promise.all([
fetchCardsByPokemon(name, 1),
fetchCardsByPokemon(name, 2),
]);
return pages.flat().filter(c => c.images?.large);
}

