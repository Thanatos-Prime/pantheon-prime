Parser Sketch in Python

from __future__ import annotations

from dataclasses import dataclass
from typing import Union
import re


@dataclass
class Interval:
    low: float
    high: float


@dataclass
class CPUExpression:
    left: str
    operator: str
    right: str
    context: str
    perspective: str
    uncertainty: Union[float, str, Interval]


CPU_PATTERN = re.compile(
    r"""
    ^\s*
    (?P<left>.+?)
    \s*(?P<op>≈|≡|~|=|→)\s*
    (?P<right>.+?)
    \s*⟨\s*
    (?P<context>.+?)
    \s*,\s*
    (?P<perspective>.+?)
    \s*,\s*
    (?P<uncertainty>.+?)
    \s*⟩\s*$
    """,
    re.VERBOSE,
)


INTERVAL_PATTERN = re.compile(
    r"^interval\(\s*(?P<low>\d+(?:\.\d+)?)\s*,\s*(?P<high>\d+(?:\.\d+)?)\s*\)$"
)


def parse_uncertainty(raw: str) -> Union[float, str, Interval]:
    raw = raw.strip()

    try:
        return float(raw)
    except ValueError:
        pass

    interval_match = INTERVAL_PATTERN.match(raw)
    if interval_match:
        return Interval(
            low=float(interval_match.group("low")),
            high=float(interval_match.group("high")),
        )

    return raw


def parse_cpu_expression(text: str) -> CPUExpression:
    match = CPU_PATTERN.match(text)
    if not match:
        raise ValueError(f"Invalid CPU expression: {text}")

    return CPUExpression(
        left=match.group("left").strip(),
        operator=match.group("op").strip(),
        right=match.group("right").strip(),
        context=match.group("context").strip(),
        perspective=match.group("perspective").strip(),
        uncertainty=parse_uncertainty(match.group("uncertainty")),
    )


if __name__ == "__main__":
    sample = "dog ≈ wolf ⟨taxonomic frame, biological observer, 0.88⟩"
    parsed = parse_cpu_expression(sample)
    print(parsed)


