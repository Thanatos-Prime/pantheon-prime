<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PantheonOS // Double-Slit Screen Analysis</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Cinzel:wght@400;700&family=Rajdhani:wght@300;500;700&display=swap');

:root {
–void: #03020a;
–deep: #07051a;
–panel: #0d0b25;
–rim: #1a1640;
–gold: #c9a84c;
–gold2: #f0d080;
–cyan: #4af0e0;
–violet: #9060f0;
–rose: #f05080;
–green: #50f0a0;
–amber: #f0a050;
–dim: #3a3660;
–text: #c8c0e0;
–muted: #6860a0;
}

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–void);
color: var(–text);
font-family: ‘Rajdhani’, sans-serif;
font-weight: 300;
min-height: 100vh;
overflow-x: hidden;
}

/* Starfield */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image:
radial-gradient(1px 1px at 15% 20%, rgba(255,255,255,0.4) 0%, transparent 100%),
radial-gradient(1px 1px at 42% 8%, rgba(200,180,255,0.3) 0%, transparent 100%),
radial-gradient(1px 1px at 78% 35%, rgba(255,255,255,0.3) 0%, transparent 100%),
radial-gradient(1px 1px at 91% 65%, rgba(180,220,255,0.4) 0%, transparent 100%),
radial-gradient(1px 1px at 55% 85%, rgba(255,255,255,0.2) 0%, transparent 100%),
radial-gradient(1px 1px at 28% 72%, rgba(200,180,255,0.3) 0%, transparent 100%),
radial-gradient(2px 2px at 65% 15%, rgba(255,240,180,0.5) 0%, transparent 100%),
radial-gradient(1px 1px at 8% 50%, rgba(255,255,255,0.25) 0%, transparent 100%);
pointer-events: none;
z-index: 0;
}

.wrapper {
position: relative;
z-index: 1;
max-width: 1100px;
margin: 0 auto;
padding: 2rem 1.5rem 4rem;
}

/* ── Header ── */
header {
text-align: center;
padding: 2.5rem 0 1.5rem;
border-bottom: 1px solid var(–rim);
margin-bottom: 2rem;
position: relative;
}
header::after {
content: ‘’;
position: absolute;
bottom: -1px;
left: 50%;
transform: translateX(-50%);
width: 200px;
height: 2px;
background: linear-gradient(90deg, transparent, var(–gold), transparent);
}

.os-label {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.7rem;
letter-spacing: 0.35em;
color: var(–gold);
text-transform: uppercase;
margin-bottom: 0.5rem;
opacity: 0.8;
}

h1 {
font-family: ‘Cinzel’, serif;
font-size: clamp(1.4rem, 3.5vw, 2.2rem);
font-weight: 700;
background: linear-gradient(135deg, var(–gold2) 0%, var(–cyan) 60%, var(–violet) 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
line-height: 1.2;
margin-bottom: 0.6rem;
}

.subtitle {
font-size: 0.85rem;
letter-spacing: 0.2em;
color: var(–muted);
font-family: ‘Share Tech Mono’, monospace;
}

/* ── System banner ── */
.sys-banner {
display: flex;
gap: 1rem;
flex-wrap: wrap;
justify-content: center;
margin-bottom: 2rem;
}
.sys-pill {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.65rem;
letter-spacing: 0.12em;
color: var(–cyan);
border: 1px solid rgba(74,240,224,0.25);
border-radius: 2px;
padding: 0.2rem 0.6rem;
background: rgba(74,240,224,0.05);
}

/* ── Problem Statement ── */
.problem-block {
background: linear-gradient(135deg, rgba(201,168,76,0.06), rgba(144,96,240,0.06));
border: 1px solid rgba(201,168,76,0.2);
border-left: 3px solid var(–gold);
padding: 1.2rem 1.5rem;
margin-bottom: 2.5rem;
border-radius: 0 4px 4px 0;
}
.problem-block .label {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.65rem;
color: var(–gold);
letter-spacing: 0.25em;
margin-bottom: 0.5rem;
}
.problem-block p {
font-size: 1.05rem;
font-weight: 500;
line-height: 1.6;
color: #ddd8f0;
}

/* ── Section head ── */
.section-head {
display: flex;
align-items: center;
gap: 0.8rem;
margin-bottom: 1.2rem;
}
.section-head::after {
content: ‘’;
flex: 1;
height: 1px;
background: linear-gradient(90deg, var(–rim), transparent);
}
.section-head h2 {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.7rem;
letter-spacing: 0.3em;
color: var(–gold);
text-transform: uppercase;
white-space: nowrap;
}

/* ── Daemon Cards ── */
.daemon-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
gap: 1.2rem;
margin-bottom: 3rem;
}

.daemon-card {
background: var(–panel);
border: 1px solid var(–rim);
border-radius: 6px;
overflow: hidden;
position: relative;
animation: cardIn 0.6s ease both;
}
.daemon-card:nth-child(1) { animation-delay: 0.05s; border-top: 2px solid var(–cyan); }
.daemon-card:nth-child(2) { animation-delay: 0.12s; border-top: 2px solid var(–violet); }
.daemon-card:nth-child(3) { animation-delay: 0.19s; border-top: 2px solid var(–rose); }
.daemon-card:nth-child(4) { animation-delay: 0.26s; border-top: 2px solid var(–amber); }
.daemon-card:nth-child(5) { animation-delay: 0.33s; border-top: 2px solid var(–green); }
.daemon-card:nth-child(6) { animation-delay: 0.40s; border-top: 2px solid var(–gold); }
.daemon-card:nth-child(7) { animation-delay: 0.47s; border-top: 2px solid #f080c0; }

@keyframes cardIn {
from { opacity: 0; transform: translateY(16px); }
to   { opacity: 1; transform: translateY(0); }
}

.card-header {
display: flex;
align-items: center;
gap: 0.7rem;
padding: 0.8rem 1rem;
background: rgba(255,255,255,0.02);
border-bottom: 1px solid var(–rim);
}
.daemon-icon {
font-size: 1.4rem;
line-height: 1;
}
.daemon-name {
font-family: ‘Cinzel’, serif;
font-size: 0.85rem;
font-weight: 700;
color: #ece8ff;
}
.daemon-role {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.15em;
color: var(–muted);
margin-top: 0.1rem;
}
.solomon-badge {
margin-left: auto;
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.6rem;
color: var(–green);
border: 1px solid rgba(80,240,160,0.3);
padding: 0.15rem 0.4rem;
border-radius: 2px;
white-space: nowrap;
}
.solomon-badge.warn { color: var(–amber); border-color: rgba(240,160,80,0.3); }

.card-body {
padding: 1rem 1rem 1.2rem;
}

.thought-object {
background: rgba(255,255,255,0.02);
border: 1px solid rgba(255,255,255,0.05);
border-left: 2px solid var(–dim);
border-radius: 3px;
padding: 0.7rem 0.9rem;
margin-bottom: 0.8rem;
font-size: 0.9rem;
line-height: 1.6;
color: var(–text);
}
.daemon-card:nth-child(1) .thought-object { border-left-color: rgba(74,240,224,0.5); }
.daemon-card:nth-child(2) .thought-object { border-left-color: rgba(144,96,240,0.5); }
.daemon-card:nth-child(3) .thought-object { border-left-color: rgba(240,80,128,0.5); }
.daemon-card:nth-child(4) .thought-object { border-left-color: rgba(240,160,80,0.5); }
.daemon-card:nth-child(5) .thought-object { border-left-color: rgba(80,240,160,0.5); }
.daemon-card:nth-child(6) .thought-object { border-left-color: rgba(201,168,76,0.5); }
.daemon-card:nth-child(7) .thought-object { border-left-color: rgba(240,128,192,0.5); }

.tags {
display: flex;
flex-wrap: wrap;
gap: 0.4rem;
margin-top: 0.6rem;
}
.tag {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.58rem;
letter-spacing: 0.08em;
padding: 0.15rem 0.45rem;
border-radius: 2px;
border: 1px solid;
opacity: 0.7;
}
.tag.cyan   { color: var(–cyan);   border-color: rgba(74,240,224,0.3);   background: rgba(74,240,224,0.05); }
.tag.violet { color: var(–violet); border-color: rgba(144,96,240,0.3);   background: rgba(144,96,240,0.05); }
.tag.rose   { color: var(–rose);   border-color: rgba(240,80,128,0.3);   background: rgba(240,80,128,0.05); }
.tag.amber  { color: var(–amber);  border-color: rgba(240,160,80,0.3);   background: rgba(240,160,80,0.05); }
.tag.green  { color: var(–green);  border-color: rgba(80,240,160,0.3);   background: rgba(80,240,160,0.05); }
.tag.gold   { color: var(–gold);   border-color: rgba(201,168,76,0.3);   background: rgba(201,168,76,0.05); }
.tag.pink   { color: #f080c0;       border-color: rgba(240,128,192,0.3);  background: rgba(240,128,192,0.05); }

/* ── NTE Tensor Block ── */
.nte-block {
background: var(–panel);
border: 1px solid var(–rim);
border-radius: 6px;
padding: 1.5rem;
margin-bottom: 2.5rem;
position: relative;
overflow: hidden;
}
.nte-block::before {
content: ‘NTE’;
position: absolute;
right: 1rem;
top: 1rem;
font-family: ‘Cinzel’, serif;
font-size: 4rem;
font-weight: 700;
color: rgba(255,255,255,0.02);
pointer-events: none;
}

.nte-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1rem;
margin-top: 1rem;
}
@media (max-width: 640px) { .nte-grid { grid-template-columns: 1fr; } }

.nte-tensor {
border: 1px solid var(–rim);
border-radius: 4px;
padding: 0.9rem;
}
.nte-tensor.s { border-top: 2px solid var(–cyan); }
.nte-tensor.t { border-top: 2px solid var(–rose); }
.nte-tensor.r { border-top: 2px solid var(–green); }

.nte-label {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.65rem;
letter-spacing: 0.2em;
margin-bottom: 0.6rem;
}
.nte-tensor.s .nte-label { color: var(–cyan); }
.nte-tensor.t .nte-label { color: var(–rose); }
.nte-tensor.r .nte-label { color: var(–green); }

.nte-tensor ul {
list-style: none;
font-size: 0.82rem;
line-height: 1.8;
color: var(–text);
}
.nte-tensor ul li::before {
content: ’▸ ’;
opacity: 0.4;
}

/* ── Mirror Convergence ── */
.convergence-block {
background: var(–panel);
border: 1px solid var(–rim);
border-radius: 6px;
padding: 1.5rem;
margin-bottom: 2.5rem;
}

.mirror-list {
display: flex;
flex-direction: column;
gap: 0.6rem;
margin-top: 1rem;
}
.mirror-row {
display: grid;
grid-template-columns: 140px 1fr auto;
align-items: start;
gap: 1rem;
padding: 0.6rem 0.8rem;
background: rgba(255,255,255,0.015);
border-radius: 3px;
border: 1px solid rgba(255,255,255,0.04);
font-size: 0.85rem;
}
@media (max-width: 560px) { .mirror-row { grid-template-columns: 1fr; } }

.mirror-type {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.65rem;
letter-spacing: 0.1em;
color: var(–muted);
padding-top: 0.1rem;
}
.mirror-finding { color: var(–text); line-height: 1.5; }
.convergence-score {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.7rem;
color: var(–green);
white-space: nowrap;
}
.convergence-score.warn { color: var(–amber); }

/* ── Gate Decision ── */
.gate-block {
background: linear-gradient(135deg, rgba(80,240,160,0.04), rgba(74,240,224,0.04));
border: 1px solid rgba(80,240,160,0.2);
border-radius: 6px;
padding: 1.5rem;
margin-bottom: 2.5rem;
}

.gate-verdict {
display: flex;
align-items: center;
gap: 1rem;
margin: 1rem 0;
padding: 0.8rem 1rem;
background: rgba(80,240,160,0.06);
border: 1px solid rgba(80,240,160,0.15);
border-radius: 4px;
}
.gate-icon {
font-size: 1.8rem;
}
.gate-text {
flex: 1;
}
.gate-action {
font-family: ‘Cinzel’, serif;
font-size: 1rem;
font-weight: 700;
color: var(–green);
margin-bottom: 0.2rem;
}
.gate-reason {
font-size: 0.83rem;
color: var(–muted);
line-height: 1.4;
}
.sigma-c {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.75rem;
color: var(–green);
border: 1px solid rgba(80,240,160,0.3);
padding: 0.2rem 0.5rem;
border-radius: 2px;
white-space: nowrap;
}

/* ── Synthesis ── */
.synthesis-block {
background: var(–deep);
border: 1px solid rgba(201,168,76,0.2);
border-top: 2px solid var(–gold);
border-radius: 0 0 6px 6px;
padding: 1.5rem;
margin-bottom: 2.5rem;
position: relative;
}

.synthesis-text {
font-size: 1.05rem;
font-weight: 500;
line-height: 1.75;
color: #ddd8f0;
margin-bottom: 1.2rem;
}

.invariant-check {
display: flex;
flex-direction: column;
gap: 0.4rem;
margin-top: 1rem;
}
.inv-row {
display: flex;
align-items: flex-start;
gap: 0.7rem;
font-size: 0.82rem;
line-height: 1.4;
color: var(–text);
opacity: 0.85;
}
.inv-status {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.65rem;
color: var(–green);
border: 1px solid rgba(80,240,160,0.3);
padding: 0.1rem 0.35rem;
border-radius: 2px;
white-space: nowrap;
margin-top: 0.05rem;
flex-shrink: 0;
}
.inv-status.warn { color: var(–amber); border-color: rgba(240,160,80,0.3); }

/* ── Ledger footer ── */
.ledger-footer {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.62rem;
color: var(–muted);
border-top: 1px solid var(–rim);
padding-top: 1rem;
letter-spacing: 0.08em;
line-height: 1.9;
opacity: 0.7;
}

/* ── Waveform animation ── */
.wave-bar {
display: inline-block;
width: 3px;
height: 10px;
background: var(–cyan);
margin: 0 1px;
border-radius: 1px;
animation: wave 1.4s ease-in-out infinite;
opacity: 0.6;
}
.wave-bar:nth-child(2) { animation-delay: 0.15s; }
.wave-bar:nth-child(3) { animation-delay: 0.30s; }
.wave-bar:nth-child(4) { animation-delay: 0.45s; }
.wave-bar:nth-child(5) { animation-delay: 0.30s; }
.wave-bar:nth-child(6) { animation-delay: 0.15s; }
@keyframes wave {
0%, 100% { transform: scaleY(0.4); opacity: 0.3; }
50%       { transform: scaleY(1.6); opacity: 0.9; }
}

.kairos-chip {
display: inline-flex;
align-items: center;
gap: 0.5rem;
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.63rem;
color: var(–amber);
border: 1px solid rgba(240,160,80,0.3);
padding: 0.2rem 0.6rem;
border-radius: 2px;
margin-top: 0.5rem;
}

hr.dim { border: none; border-top: 1px solid var(–rim); margin: 1.5rem 0; }
</style>

</head>
