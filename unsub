🕷️ content.js (Spider — finds unsubscribe paths)

function findUnsubscribeLinks() {
  const links = [...document.querySelectorAll("a")];
  return links
    .filter(link =>
      link.innerText.toLowerCase().includes("unsubscribe") ||
      link.href.toLowerCase().includes("unsubscribe")
    )
    .map(link => ({
      text: link.innerText,
      url: link.href
    }));
}
// Listen for popup request
chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  if (msg.type === "SCAN_UNSUBS") {
    const results = findUnsubscribeLinks();
    sendResponse(results);
  }
});

