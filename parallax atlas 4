  'Earth_Mars':{name:'Aethos',title:'The Red Wanderer',domains:['War','Ambition','Iron Will','Retrogression','Cycles'],lore:'Crosses the full arc of night. When it blazes at opposition, no other object challenges its dominance except Jupiter. Its retrograde loops confused the first astronomers and were never fully explained until Copernicus. The red color alone was enough — blood, embers, iron, the will that refuses to halt. Every culture that watched the sky made it a warrior.',fests:['Opposition (~26 mo cycle)','The Retrograde Vigil','The Red New Year']},
  'Earth_Jupiter':{name:'Kronarch',title:'The Kingmaker',domains:['Authority','Justice','Abundance','The Long Cycle','Royalty'],lore:'From Earth, Jupiter dominates the night more than any wanderer except Venus — and unlike Venus, it roams the full sky, opposing the Sun. Its 11.9-year cycle through the zodiac divides time into 12, one house per year. Every civilization that looked up long enough made it the ruler of the sky. Not brightness alone, but the 12-year period: the length of a generation\'s childhood, a king\'s first term, a tree\'s first maturity.',fests:['Annual Opposition — the Kingship Rite','The 12-Year Great Return','The Grand Seal (with Saturn, ~20 yr)']},
  'Earth_Saturn':{name:'Chronael',title:'The Boundary Walker',domains:['Time','Limits','Old Age','The Known Edge','Patience'],lore:'The slowest naked-eye wanderer, 29 years to complete one circuit. Ancient astronomers placed it at the boundary between the human world and the divine — the last god before the fixed stars, the gatekeeper of eternity. It rules time not because it moves fast but because it moves with inevitability: steadily, without mercy, without haste.',fests:['Saturn Return (age 29 — rite of passage)','Saturnalia (winter solstice inversion)','The Waning Gate']},
  'Mars_Earth':{name:'Korveth',title:'The Blue Lantern',domains:['Home','Memory','Water','Promise','Origin','Longing'],lore:'From the dust-red plains of Mars, the blue one never rises above 41° from the Sun. A true morning star or evening star — never a midnight companion. When it appears, it hangs as a brilliant blue-white jewel unlike anything else in the sky. Civilizations here associate it with water (the color declares it), with distant origin, with unattainable beauty. The star of memory. The star of longing. The home you cannot return to.',fests:['Greatest Elongation East (Blue Rising)','Greatest Elongation West (Blue Setting)','Inferior Conjunction — Blue Silence']},
  'Jupiter_Saturn':{name:'Yalgeth',title:'The Slow Companion',domains:['The Long Walk','Patience','Stone','The Near Horizon','Time\'s Elder'],lore:'From the Jovian cloud-tops, Saturn is not the outermost naked-eye wanderer but a neighbor — and its rings become visible, a miracle possessed by no inner-world civilization. It takes 29 years to circle the sky, but from Jupiter the conjunction cycle runs every 19.6 years. The two giants appear together sometimes in the Grand Seal — a once-per-generation event that would mark the most sacred moment in any Jovian calendar.',fests:['Jupiter-Saturn Conjunction (~20 yr) — The Grand Seal','Saturn at Opposition — The Ring-God Rises']},
};

function getDeity(target,metrics,obs){
  const key=`${obs}_${target}`;
  if(DEITY_DB[key])return{...DEITY_DB[key],planet:target};

  const m=metrics.find(x=>x.name===target)||{};
  const ph=PHYS[target];
  const isInt=m.isInterior;

  function genName(seed){
    const C=['K','V','R','Th','Z','N','M','L','S','Gh','Yr','Ax','Or','El'];
    const V=['a','e','i','o','eth','an','ur','el','os','is'];
    let h=0;for(let c of seed)h=(h*31+c.charCodeAt(0))>>>0;
    const r=n=>((h=Math.imul(h^h>>>16,0x45d9f3b)>>>0)%n);
    return C[r(C.length)]+V[r(V.length)]+C[r(C.length)]+V[r(V.length)];
  }

  if(isInt&&m.maxElong<50) return {
    name:genName(target+obs+'herald'),planet:target,
    title:'The Gate Herald',
    domains:['Threshold','Messages','Liminal Hour','Speed','Impermanence'],
    lore:`Bound to the Sun's vicinity from ${obs}, this wanderer never appears in the deep night — only in the liminal zone where day and night negotiate. Civilizations on ${obs} associate it with messengers, with things that cannot be owned for long, with the moment between sleep and waking. Its synodic period of ~${synodicDays(obs,target).toFixed(0)} days governs the short sacred calendar.`,
    fests:['Greatest Elongation East','Greatest Elongation West','Inferior Conjunction — The Vanishing'],
  };
  if(m.midFrac>0.5) return {
    name:genName(target+obs+'lord'),planet:target,
    title:`Lord of the ${obs} Night`,
    domains:['Authority','Navigation','Constancy','The Outer Dark','Sovereignty'],
    lore:`Visible at midnight more than half the time, this wanderer roams the full night sky from ${obs} — a reliable anchor for any astronomical civilization. Its presence at midnight is the template for divine authority: something that can be directly overhead, hours from the horizon, available for systematic measurement, undeniable. First calendars built around this body; first astrology designed to track it.`,
    fests:['Annual Opposition — when brightest','The Zenith Crossing','The Midnight Culmination'],
  };
  return {
    name:genName(target+obs+'shadow'),planet:target,
    title:'The Distant Sovereign',
    domains:['The Far Shore','Distance','The Limit of Vision','Deep Time','The Unknown'],
    lore:`Visible but faint, this body hovers at the edge of reliable observation from ${obs}. Ancient astronomers who tracked it were those who feared what they could not see. When it returns from conjunction or from the limits of visibility, it carries intelligence from beyond the edge of the world. Its very rarity grants power — the god you cannot depend on commands the most reverence.`,
    fests:['Return from Conjunction','The Dim Rising','The Edge Crossing'],
  };
}

function buildPantheon(){
  const grid=document.getElementById('pantheonGrid');grid.innerHTML='';
  S.metrics.forEach(m=>{
    const deity=getDeity(m.name,S.metrics,S.obs);
    const ph=PHYS[m.name];
    const card=document.createElement('div');
    card.className='deity';
    card.style.borderColor=ph.col+'22';
    card.style.setProperty('--dc',ph.col);
    card.innerHTML=`
      <span class="deity-sym" style="color:${ph.col}">${ph.sym}</span>
      <div class="deity-name">${deity.name}</div>
      <div class="deity-pl">${m.name} · from ${S.obs}</div>
      <div class="deity-title">"${deity.title}"</div>
      <div class="deity-lore">${deity.lore}</div>
      <div class="deity-tags">${deity.domains.map(d=>`<span class="dtag">${d}</span>`).join('')}</div>
      <div class="deity-fests">
        <div style="font-size:7px;letter-spacing:.2em;color:var(--text-d);margin-bottom:3px">SACRED FESTIVALS</div>
        ${deity.fests.map(f=>`<div class="feast-item">· ${f}</div>`).join('')}
        <div style="margin-top:6px;font-size:8px;color:var(--text-d)">
          Synodic: ${m.synodic>50000?'—':m.synodic.toFixed(1)+' d'} ·
          Vis: ${(m.visFrac*100).toFixed(1)}% ·
          Mid: ${(m.midFrac*100).toFixed(1)}%
        </div>
      </div>
    `;
    grid.appendChild(card);
  });
}

