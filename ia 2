function MarkerDot({ zone, markers }) {
const zm = markers.filter(m => m.zone === zone.id);
if (!zm.length) return null;
return (
<>
{zm.map((m, i) => {
const t = getType(m.type);
if (!t) return null;
const r = 4 + m.intensity * 2;
const total = zm.length;
const angle = total === 1 ? 0 : (i / total) * Math.PI * 2;
const spread = total === 1 ? 0 : 9;
const ox = Math.cos(angle) * spread;
const oy = Math.sin(angle) * spread;
return (
<g key={m.zone + m.type + i}>
<circle cx={zone.cx + ox} cy={zone.cy + oy} r={r}        fill={t.color} opacity={0.15 + m.intensity * 0.07} />
<circle cx={zone.cx + ox} cy={zone.cy + oy} r={r * 0.42} fill={t.color} opacity={0.9} />
</g>
);
})}
</>
);
}

function ZoneHit({ zone, selected, onClick }) {
return (
<circle cx={zone.cx} cy={zone.cy} r={16}
fill={selected ? “rgba(99,102,241,0.22)” : “transparent”}
stroke={selected ? “#818cf8” : “transparent”}
strokeWidth=“1.5” style={{ cursor: “pointer” }}
onClick={() => onClick(zone.id)} />
);
}

