  // degree ticks
  for(let d=0;d<360;d+=5){
    const a=(d-90)*D2R,isBig=d%30===0;
    const r2=isBig?innerR-14:innerR-5;
    zdX.beginPath();zdX.moveTo(cx+innerR*Math.cos(a),cy+innerR*Math.sin(a));
