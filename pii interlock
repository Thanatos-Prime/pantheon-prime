Example role pass

Mirror pass

def mirror_pass(state: WorkState) -> PassResult:
    adds = {
        "risks": [],
        "assumptions": [],
        "open_questions": []
    }

    for model in state.candidate_models:
        if "always" in model.lower() or "never" in model.lower():
            adds["risks"].append(f"Overclaim detected in model: {model}")

    if not state.evidence:
        adds["open_questions"].append("What evidence supports the current model set?")

    if not state.assumptions:
        adds["assumptions"].append("Assumptions not yet explicitly enumerated.")

    return PassResult(
        role="Mirror",
        adds=adds,
        removes={},
        flags=["coherence_check_complete"],
        confidence_delta=0.05,
        reason_for_handoff="Need anomaly scan and implementation shaping."
    )

That is enough to prove the pattern.

