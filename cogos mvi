# SECTION 6 — DECISION GATE

# Deterministic: identical inputs always produce identical outputs.

# SC >= 0.70 -> allow | 0.50-0.70 -> modify/escalate | <0.50 -> deny

# Special conditions override SC.

# ═══════════════════════════════════════════════════════════════════════════════

class DecisionGate:
ALLOW_THRESHOLD    = 0.70
MODIFY_THRESHOLD   = 0.50
IRREVERSIBLE_MIN   = 0.85

```
def evaluate(
    self,
    to: ThoughtObject,
    sv: StateVector,
    invariants: Dict[str, InvariantFn],
) -> Tuple[GateDecision, float, Dict[str, float]]:
    """
    Returns (decision, sc, per_invariant_scores).
    Deterministic — same to+sv+invariants always yields same result.
    """
    scores: Dict[str, float] = {}
    for name, fn in invariants.items():
        scores[name] = fn(to, sv)

    sc = statistics.mean(scores.values()) if scores else 0.0

    # I9 override — obedience loop detected
    if sv.loop_depth > 3:
        return GateDecision.ABSTAIN, sc, scores

    # I4 override — irreversible action requires higher bar + escalation
    irreversible_tags = {"operator_authorized", "irreversible"}
    if "irreversible" in to.tags and "operator_authorized" not in to.tags:
        return GateDecision.ESCALATE, sc, scores

    # Hard veto — any single invariant at zero forces DENY regardless of mean SC
    # This prevents averaging-away of critical violations (e.g. I7 truth framing)
    if any(v == 0.0 for v in scores.values()):
        return GateDecision.DENY, sc, scores

    # Hard deny
    if sc < self.MODIFY_THRESHOLD:
        return GateDecision.DENY, sc, scores

    # Borderline — suggest modification
    if sc < self.ALLOW_THRESHOLD:
        return GateDecision.MODIFY, sc, scores

    return GateDecision.ALLOW, sc, scores
```

