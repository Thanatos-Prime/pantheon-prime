function updateSolomon() {
  const current = parseFloat(document.getElementById('solomonScore').textContent);
  const target = 0.75 + Math.random() * 0.2;
  const val = current + (target - current) * 0.1;
  document.getElementById('solomonScore').textContent = val.toFixed(2);
  const circle = document.getElementById('solomonCircle');
  const pct = val; // 0-1
  const circ = 283;
  circle.style.strokeDashoffset = circ - (circ * pct);
}

