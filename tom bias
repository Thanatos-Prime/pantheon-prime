from __future__ import annotations

from typing import Dict, Any


def run_hound_tom(packet: Dict[str, Any]) -> Dict[str, Any]:
    tb = packet.get("tom_bias", {})
    alternatives = tb.get("alternatives", [])
    biases = tb.get("biases", [])

    packet.setdefault("hound_findings", [])

    for alt in alternatives[:2]:
        packet["hound_findings"].append(f"Alternative explanation: {alt}")

    for bias in biases[:3]:
        packet["hound_findings"].append(
            f"Bias candidate: {bias['name']} (confidence={bias['confidence']})"
        )

    return packet