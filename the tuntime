15. Minimal Runtime Algorithm

def run_mission(event: Event, runtime: Runtime) -> Mission:
    mission = runtime.intake.receive(event)
    mission.status = MissionStatus.INTERPRETING
    mission = runtime.interpreter.interpret(mission)
    mission.status = MissionStatus.RECONSTRUCTING
    context = runtime.context_reconstructor.build(mission)
    mission.status = MissionStatus.SENSING
    situation = runtime.sensors.inspect(mission, context)
    mission.status = MissionStatus.SELECTING
    capabilities = runtime.selector.select(
        mission=mission,
        context=context,
        situation=situation,
    )
    mission.status = MissionStatus.PLANNING
    contributions = [
        capability.propose(
            RuntimeContext(
                mission=mission,
                context=context,
                situation=situation,
            )
        )
        for capability in capabilities
    ]
    plan = runtime.orchestrator.compose_plan(
        mission=mission,
        contributions=contributions,
    )
    mission.status = MissionStatus.GATING
    gate = runtime.governor.evaluate(
        plan=plan,
        context=RuntimeContext(
            mission=mission,
            context=context,
            situation=situation,
        ),
    )
    mission.gate_decision = gate
    if gate.result == "deny":
        mission.status = MissionStatus.REJECTED
        return mission
    if gate.result == "revise":
        mission.status = MissionStatus.REVISION_REQUIRED
        return mission
    if gate.result == "require_approval":
        mission.status = MissionStatus.AWAITING_APPROVAL
        return mission
    mission.status = MissionStatus.EXECUTING
    for step in plan.steps:
        if runtime.should_stop(mission, step):
            mission.status = MissionStatus.PAUSED
            break
        record = runtime.executor.execute(step, mission)
        mission.execution_records.append(record)
        if not record.success:
            runtime.handle_failure(mission, step, record)
            break
    mission.status = MissionStatus.OBSERVING
    runtime.observer.observe(mission)
    mission.status = MissionStatus.EVALUATING
    mission.evaluation = runtime.evaluator.evaluate(mission)
    mission.status = MissionStatus.INTEGRATING
    mission.integration = runtime.integrator.decide(mission)
    runtime.memory.integrate(mission.integration)
    mission.status = MissionStatus.COMPLETED
    return mission

