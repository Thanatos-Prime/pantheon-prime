import { NextRequest, NextResponse } from "next/server";
import { openai } from "@/lib/openai";
import { buildImageSummaryPrompt } from "@/lib/imagePrompt";

interface AnalyzeImagesBody {
  images: string[]; // data URLs
}

interface AnalyzeImagesOutput {
  summaries: string[];
}

export async function POST(req: NextRequest) {
  try {
    const body = (await req.json()) as AnalyzeImagesBody;

    if (!body.images || !Array.isArray(body.images) || body.images.length === 0) {
      return NextResponse.json(
        { error: "images array is required" },
        { status: 400 }
      );
    }

    if (body.images.length > 5) {
      return NextResponse.json(
        { error: "Maximum 5 images per request" },
        { status: 400 }
      );
    }

    const input = [
      {
        role: "user",
        content: [
          {
            type: "input_text",
            text: buildImageSummaryPrompt(),
          },
          ...body.images.map((image) => ({
            type: "input_image" as const,
            image_url: image,
            detail: "high" as const,
          })),
        ],
      },
    ];

    const response = await openai.responses.create({
      model: "gpt-5",
      input,
    });

    const text = response.output_text?.trim();

    if (!text) {
      return NextResponse.json(
        { error: "Model returned empty output" },
        { status: 500 }
      );
    }

    let parsed: AnalyzeImagesOutput;
    try {
      parsed = JSON.parse(text) as AnalyzeImagesOutput;
    } catch {
      return NextResponse.json(
        { error: "Model returned invalid JSON", raw: text },
        { status: 500 }
      );
    }

    if (!Array.isArray(parsed.summaries)) {
      return NextResponse.json(
        { error: "Invalid summaries payload", raw: parsed },
        { status: 500 }
      );
    }

    return NextResponse.json(parsed);
  } catch (error) {
    console.error(error);
    return NextResponse.json(
      { error: "Failed to analyze images" },
      { status: 500 }
    );
  }
}


