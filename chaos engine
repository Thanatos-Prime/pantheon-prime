import math

def calculate_asymmetric_upside(velocity_coefficient, engagement_density, source_weight):
    """
    Calculates the alpha score for a weak signal. 
    High velocity + lower initial volume = asymmetric explosive potential.
    """
    if velocity_coefficient <= 0:
        return 0.0
        
    # Logarithmic scaling to prevent massive baseline spikes from drowning out faint signals
    density_factor = math.log1p(engagement_density)
    
    # Goblin calculation model
    upside_score = (velocity_coefficient * source_weight) / (density_factor + 1)
    return round(upside_score, 4)

def track_propagation_vector(historical_scores):
    """
    The Thing's tracking mechanism: measures the second derivative (acceleration) 
    of the signal's spread across nodes.
    """
    if len(historical_scores) < 3:
        return 0.0
    
    v1 = historical_scores[-2] - historical_scores[-3]
    v2 = historical_scores[-1] - historical_scores[-2]
    
    # Acceleration coefficient
    propagation_acceleration = v2 - v1
    return round(propagation_acceleration, 4)

```
