class ProblemTypeLearner:
    """
    Learns optimal depth per problem type
    """

    def recommend_depth(self, problem_type, records, baseline_depth):
        if len(records) < 3:
            return baseline_depth, "Insufficient data"

        depth_scores = {}

        for r in records:
            depth_scores.setdefault(r["depth"], []).append(r["score"])

        best_depth = baseline_depth
        best_score = 0

        for depth, scores in depth_scores.items():
            avg = sum(scores) / len(scores)
            if avg > best_score:
                best_score = avg
                best_depth = depth

        return best_depth, f"Learned from {len(records)} records"


