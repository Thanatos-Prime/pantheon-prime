const tlC=document.getElementById('tlCanvas');
const tlX=tlC.getContext('2d');

function buildTimeline(){
  const legend=document.getElementById('tlLegend');
  legend.innerHTML='';
  PNAMES.filter(n=>n!==STATE.observer).forEach(n=>{
    const div=document.createElement('div');
    div.className='tl-leg-item';
    div.innerHTML=`<div class="tl-leg-dot" style="background:${PLANETS[n].col}"></div>${PLANETS[n].sym} ${n}`;
    legend.appendChild(div);
  });
  drawTimeline();
}

function drawTimeline(){
  const container=document.getElementById('tlCanvas').parentElement;
  const CH=Math.max(300,container.clientHeight-20);
  const targets=PNAMES.filter(n=>n!==STATE.observer);
  const TRACK_H=Math.floor(CH/targets.length);
  const CW=Math.max(2400,container.clientWidth);
  tlC.width=CW; tlC.height=CH;

  tlX.fillStyle='rgba(2,3,10,.98)';tlX.fillRect(0,0,CW,CH);

  const STEP=30; // sample every 30 days
  const totalDays=MAX_DAYS;
  const pixPerDay=CW/totalDays;

  // Year markers
  for(let yr=0;yr*365<=totalDays;yr+=10){
    const px=yr*365*pixPerDay;
    tlX.beginPath();tlX.moveTo(px,0);tlX.lineTo(px,CH);
    tlX.strokeStyle=yr%50===0?'rgba(200,168,76,.15)':'rgba(100,130,200,.06)';
    tlX.lineWidth=yr%50===0?1:.5;tlX.stroke();
    if(yr>0&&yr%50===0){
      tlX.fillStyle='rgba(200,168,76,.4)';
      tlX.font='8px "Share Tech Mono"';
      tlX.textAlign='center';
      tlX.fillText(`Yr ${yr}`,px,10);
    }
  }

  targets.forEach((name,ti)=>{
    const yBase=ti*TRACK_H+TRACK_H*.5;
    const p=PLANETS[name];

    // track label
    tlX.fillStyle=p.col+'cc';tlX.font='8px "Share Tech Mono"';
    tlX.textAlign='left';tlX.fillText(`${p.sym} ${name}`,4,yBase-TRACK_H*.3);

    // visibility stripe
    let prevVis=false,lineStart=0;
    for(let t=0;t<=totalDays;t+=STEP){
      const op=xy(STATE.observer,t),tp=xy(name,t);
      const rel=[tp[0]-op[0],tp[1]-op[1]];
      const dist=Math.hypot(rel[0],rel[1]);
      const sunV=[-op[0],-op[1]];
      const cosE=(rel[0]*sunV[0]+rel[1]*sunV[1])/(dist*Math.hypot(sunV[0],sunV[1]));
      const elong=Math.acos(Math.max(-1,Math.min(1,cosE)))*180/Math.PI;
      const vis=elong>=STATE.elongThresh;

      // brightness as vertical position
      const stL=Math.hypot(tp[0],tp[1]);
      const stH=[-tp[0]/stL,-tp[1]/stL];
      const otH=[-rel[0]/dist,-rel[1]/dist];
      const cosP=Math.max(-1,Math.min(1,stH[0]*otH[0]+stH[1]*otH[1]));
      const phase=(1+Math.cos(Math.acos(cosP)))/2;
      const bright=(p.albedo*p.R**2*phase)/(dist**2);
      const brightN=Math.min(1,bright/Math.max(.001,STATE.metrics.find(m=>m.name===name)?.maxBright||1));
      const px=t*pixPerDay;
      const py=yBase+TRACK_H*.35*(1-brightN*2);

      if(t===0){
        tlX.beginPath();tlX.moveTo(px,py);
      } else {
        if(vis){
          tlX.lineTo(px,py);
        } else {
          tlX.strokeStyle=p.col+'88';tlX.lineWidth=1;tlX.stroke();
          tlX.beginPath();tlX.moveTo(px,py);
        }
      }
    }
    tlX.strokeStyle=p.col+'88';tlX.lineWidth=1;tlX.stroke();

    // Divider
    tlX.beginPath();
    tlX.moveTo(0,ti*TRACK_H+TRACK_H);
    tlX.lineTo(CW,ti*TRACK_H+TRACK_H);
    tlX.strokeStyle='rgba(100,130,200,.08)';tlX.lineWidth=.5;tlX.stroke();
  });

  // Current time marker
  const tx=STATE.t*pixPerDay;
  tlX.beginPath();tlX.moveTo(tx,0);tlX.lineTo(tx,CH);
  tlX.strokeStyle='rgba(200,168,76,.8)';tlX.lineWidth=1.5;tlX.stroke();
  // Scroll to keep current time in view
  const wrap=tlC.parentElement;
  wrap.scrollLeft=Math.max(0,tx-wrap.clientWidth/2);
}

// ═══════════════════════════════════════════════════════════
// HEADER STATS
// ═══════════════════════════════════════════════════════════
function updateStats(){
  const obs=PLANETS[STATE.observer];
  const localYear=(STATE.t/obs.P).toFixed(2);
  document.getElementById('statYear').textContent=localYear;
  document.getElementById('statDays').textContent=Math.round(STATE.t).toLocaleString();

  // count visible
  let vis=0;
  PNAMES.forEach(n=>{
    if(n===STATE.observer) return;
    const op=xy(STATE.observer,STATE.t),tp=xy(n,STATE.t);
    const rel=[tp[0]-op[0],tp[1]-op[1]];
    const dist=Math.hypot(rel[0],rel[1]);
    const sunV=[-op[0],-op[1]];
    const cosE=(rel[0]*sunV[0]+rel[1]*sunV[1])/(dist*Math.hypot(sunV[0],sunV[1]));
    const elong=Math.acos(Math.max(-1,Math.min(1,cosE)))*180/Math.PI;
    if(elong>=STATE.elongThresh) vis++;
  });
  document.getElementById('statVisible').textContent=`${vis}/${PNAMES.length-1}`;
}

function updateFooterTime(){
  const obs=PLANETS[STATE.observer];
  const localYear=(STATE.t/obs.P).toFixed(2);
  document.getElementById('ftTime').textContent=`T+${Math.round(STATE.t).toLocaleString()} days · ${STATE.observer} Year ${localYear}`;
}

// ═══════════════════════════════════════════════════════════
// FULL REFRESH
// ═══════════════════════════════════════════════════════════
function fullRefresh(){
  STATE.observer=document.getElementById('selObs').value;
  STATE.elongThresh=parseInt(document.getElementById('selElong').value);
  METRICS_CACHE={};
  STATE.metrics=computeMetrics(STATE.observer,STATE.elongThresh);
  buildCards();
  buildVisPanel();
  buildHouseList();
  buildCulture();
  buildPantheon();
  buildTimeline();
  drawSky();
  drawZodiac();
  updateStats();
  updateFooterTime();
}

function lightRefresh(){
  drawSky();
  drawZodiac();
  buildVisPanel();
  buildHouseList();
  updateStats();
  updateFooterTime();
  if(STATE.activeTab==='timeline') drawTimeline();
}

// ═══════════════════════════════════════════════════════════
// TABS
// ═══════════════════════════════════════════════════════════
document.querySelectorAll('.tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.pane').forEach(p=>p.classList.remove('active'));
    tab.classList.add('active');
    const id='pane-'+tab.dataset.tab;
    document.getElementById(id).classList.add('active');
    STATE.activeTab=tab.dataset.tab;
    if(STATE.activeTab==='sky'){resizeSky();}
    if(STATE.activeTab==='zodiac'){resizeZod();}
    if(STATE.activeTab==='timeline'){buildTimeline();}
  });
});

// ═══════════════════════════════════════════════════════════
// CONTROLS
// ═══════════════════════════════════════════════════════════
document.getElementById('selObs').addEventListener('change',fullRefresh);
document.getElementById('selElong').addEventListener('change',fullRefresh);
document.getElementById('selZod').addEventListener('change',fullRefresh);

const slider=document.getElementById('masterSlider');
slider.addEventListener('input',()=>{
  STATE.t=parseInt(slider.value);
  lightRefresh();
});

// Speed buttons
document.querySelectorAll('.spd-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.spd-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    STATE.speed=parseInt(btn.dataset.spd);
  });
});

// Play
const playBtn=document.getElementById('playBtn');
playBtn.addEventListener('click',()=>{
  STATE.playing=!STATE.playing;
  playBtn.textContent=STATE.playing?'⏸ PAUSE':'▶ PLAY';
  if(STATE.playing){
    function tick(){
      if(!STATE.playing) return;
      STATE.t+=STATE.speed*2;
      if(STATE.t>MAX_DAYS) STATE.t=0;
      slider.value=STATE.t;
      lightRefresh();
      playTimer=requestAnimationFrame(tick);
    }
    tick();
  } else {
    if(playTimer) cancelAnimationFrame(playTimer);
  }
});

// Epoch button
const epochBtn=document.getElementById('epochBtn');
const EPOCHS=[0,9056,18112,27168,45280,63392,90519];
let epochIdx=0;
epochBtn.addEventListener('click',()=>{
  epochIdx=(epochIdx+1)%EPOCHS.length;
  STATE.t=EPOCHS[epochIdx];
  slider.value=STATE.t;
  lightRefresh();
});

// ═══════════════════════════════════════════════════════════
// RESIZE
// ═══════════════════════════════════════════════════════════
window.addEventListener('resize',()=>{
  if(STATE.activeTab==='sky') resizeSky();
  if(STATE.activeTab==='zodiac') resizeZod();
  if(STATE.activeTab==='timeline') drawTimeline();
});

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
fullRefresh();
setTimeout(()=>{resizeSky();resizeZod();},100);
</script>

