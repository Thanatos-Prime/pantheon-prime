# ─────────────────────────────────────────────

def has_ambiguity(state: WorkState) -> bool:
vague = {“optimize”, “improve”, “best”, “better”, “fix”, “good”, “enhance”}
return any(w in state.goal.lower().split() for w in vague)

def has_risk_or_high_stakes(state: WorkState) -> bool:
high_stakes = {“deploy”, “production”, “delete”, “migrate”, “refactor”, “launch”, “legal”, “finance”}
return any(w in state.goal.lower() for w in high_stakes) or len(state.risks) > 2

def needs_novelty(state: WorkState) -> bool:
novelty = {“new”, “novel”, “creative”, “invent”, “design”, “imagine”, “explore”}
return any(w in state.goal.lower() for w in novelty)

def needs_edge_cases(state: WorkState) -> bool:
return “edge” in state.goal.lower() or “failure” in state.goal.lower() or “break” in state.goal.lower()

def needs_leverage(state: WorkState) -> bool:
return any(w in state.goal.lower() for w in {“monetize”, “revenue”, “leverage”, “value”, “profit”})

def select_initial_roles(state: WorkState) -> List[str]:
roles = [“Mirror”, “Blacksmith”]

```
if has_ambiguity(state):
    roles.insert(0, "Aevum")

if has_risk_or_high_stakes(state):
    roles.append("Badger")

if needs_novelty(state):
    roles.append("Spider")
    roles.append("Dragonfly")

if needs_edge_cases(state):
    roles.insert(1, "Hound")

# Deduplicate while preserving order
seen = set()
unique_roles = []
for r in roles:
    if r not in seen:
        seen.add(r)
        unique_roles.append(r)

return unique_roles
```

def reprioritize_queue(state: WorkState, queue: List[str]) -> List[str]:
“”“Dynamic re-routing based on evolving state.”””
adjusted = list(queue)

```
# If risks are piling up and Badger isn't already queued, push it forward
if len(state.risks) > 4 and "Badger" not in adjusted:
    adjusted.insert(0, "Badger")

# If no artifact plan exists and Blacksmith already ran, don't re-run
if not state.artifact_plan and "Blacksmith" not in adjusted:
    adjusted.append("Blacksmith")

return adjusted
```

# ─────────────────────────────────────────────

# TERMINATION

# ─────────────────────────────────────────────

CONFIDENCE_THRESHOLD = 0.70
CONTRADICTION_THRESHOLD = 5  # open_questions acting as proxy

def should_terminate(state: WorkState) -> bool:
if state.termination_status != TerminationStatus.INCOMPLETE:
return True

```
if state.confidence >= CONFIDENCE_THRESHOLD:
    if state.artifact_plan:
        if len(state.open_questions) < CONTRADICTION_THRESHOLD:
            state.termination_status = TerminationStatus.CONVERGED
            return True

if not state.evidence and len(state.risks) > 5:
    state.termination_status = TerminationStatus.INSUFFICIENT_EVIDENCE
    return True

return False
```

