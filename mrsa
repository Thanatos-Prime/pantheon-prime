<title>Star Act — Wicker & Johnson Pressure Package</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Serif:ital,wght@0,400;0,600;1,400&display=swap');

  :root {
    --black: #0A0A0A;
    --white: #F4F4F4;
    --red: #C8102E;
    --gold: #C9A84C;
    --steel: #6B7B8D;
    --line: rgba(200,16,46,0.3);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'IBM Plex Serif', Georgia, serif;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* HEADER */
  .masthead {
    border-bottom: 3px solid var(--red);
    padding: 2rem 2.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .masthead-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    letter-spacing: 0.04em;
    color: var(--white);
    line-height: 1;
  }
  .masthead-title span { color: var(--red); }
  .masthead-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    color: var(--steel);
    text-align: right;
