function pickTeam(persona) {
  if (persona.includes("kid")) {
    return [
      "Pikachu",
      "Scorbunny",
      "Piplup",
      "Yamper",
      "Teddiursa",
      "Poliwag"
    ];
  }
  return ["Togepi", "Pichu", "Munchlax", "Wooper", "Rockruff", "Stufful"];
}

