3. Delta logic should also detect removals

Right now computeDelta only maps over current markers, so if a marker disappeared from the previous snapshot, you miss that change.

A better version compares the union of marker keys from both snapshots.

function computeDelta(curr, prev) {
  if (!curr || !prev) return [];

  const keyOf = m => `${m.zone}__${m.type}`;
  const currMap = new Map(curr.markers.map(m => [keyOf(m), m]));
  const prevMap = new Map(prev.markers.map(m => [keyOf(m), m]));
  const allKeys = new Set([...currMap.keys(), ...prevMap.keys()]);

  return [...allKeys]
    .map(key => {
      const c = currMap.get(key);
      const p = prevMap.get(key);
      const [zone, type] = key.split("__");
      return {
        zone,
        type,
        delta: (c?.intensity ?? 0) - (p?.intensity ?? 0),
      };
    })
    .filter(d => d.delta !== 0);
}

That’s a real upgrade.

