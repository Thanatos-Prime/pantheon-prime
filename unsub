🧠 popup.js (Hound + Goblin — decision + action)

let unsubLinks = [];
document.getElementById("scan").onclick = async () => {
  const [tab] = await chrome.tabs.query({ active: true, currentWindow: true });
  chrome.tabs.sendMessage(tab.id, { type: "SCAN_UNSUBS" }, (response) => {
    unsubLinks = response || [];
    renderList(unsubLinks);
  });
};
function renderList(links) {
  const list = document.getElementById("results");
  list.innerHTML = "";
  links.forEach(link => {
    const li = document.createElement("li");
    li.innerHTML = `<a href="${link.url}" target="_blank">${link.text}</a>`;
    list.appendChild(li);
  });
}
document.getElementById("execute").onclick = () => {
  unsubLinks.forEach(link => {
    window.open(link.url, "_blank");
  });
};

