🧠 models.py

from pydantic import BaseModel
from typing import Optional

class Item(BaseModel):
    id: str
    name: str
    description: str
    condition: float  # 0-1
    completeness: float  # 0-1
    estimated_value: Optional[float] = None

class User(BaseModel):
    id: str
    credits: float = 0.0


