let terminalLiveIdx = 0;
function appendTerminal() {
  const el = document.getElementById('terminal');
  const cursor = el.querySelector('.t-cursor');
  const raw = TERMINAL_LIVE[terminalLiveIdx % TERMINAL_LIVE.length];
  terminalLiveIdx++;
  const text = raw
    .replace('{N}', Math.floor(Math.random()*500+100))
    .replace('{T}', Date.now());
