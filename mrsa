  .rebuttal-block strong { color: var(--gold); }

  .pressure-points li {
    font-size: 0.88rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid rgba(244,244,244,0.06);
    list-style: none;
    padding-left: 1.2rem;
    position: relative;
    color: rgba(244,244,244,0.85);
  }
  .pressure-points li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--red);
    font-size: 0.7rem;
