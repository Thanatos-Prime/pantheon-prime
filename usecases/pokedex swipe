export default function PokedexSwipe() {
const [deck, setDeck] = useState(() => […CARDS].sort(() => Math.random() - 0.5));
const [kept, setKept] = useState([]);
const [passed, setPassed] = useState([]);
const [unsure, setUnsure] = useState([]);
const [showProfile, setShowProfile] = useState(false);
const [lastAction, setLastAction] = useState(null); // for undo toast

const [metadata, setMetadata] = useState({
decisions: 0,
era_signal: {},
type_signal: {},
style_signal: {},
});

const topCard = deck[deck.length - 1];
const theme = topCard ? (TYPE_THEME[topCard.primaryType] || TYPE_THEME.Normal) : TYPE_THEME.Normal;

const recordSignal = (card, action) => {
if (action === “pass”) return;
setMetadata(prev => {
const next = { …prev, decisions: prev.decisions + 1 };
const era = ERA_MAP[card.year] || “Other”;
next.era_signal = { …prev.era_signal, [era]: (prev.era_signal[era] || 0) + 1 };
card.types.forEach(t => {
next.type_signal = { …prev.type_signal, [t]: (prev.type_signal[t] || 0) + 1 };
});
card.tags.forEach(tag => {
next.style_signal = { …prev.style_signal, [tag]: (prev.style_signal[tag] || 0) + 1 };
});
return next;
});
};

const handleSwipe = (direction, card) => {
setDeck(d => d.filter(c => c.id !== card.id));
if (direction === “right”) {
setKept(k => [card, …k]);
recordSignal(card, “keep”);
setLastAction({ type: “kept”, card });
} else {
setPassed(p => [card, …p]);
setLastAction({ type: “passed”, card });
}
setTimeout(() => setLastAction(null), 2000);
};

const handleUnsure = () => {
if (!topCard) return;
setDeck(d => d.filter(c => c.id !== topCard.id));
setUnsure(u => [topCard, …u]);
setLastAction({ type: “unsure”, card: topCard });
setTimeout(() => setLastAction(null), 2000);
};

const handleRestart = () => {
const all = […kept, …passed, …unsure, …deck].sort(() => Math.random() - 0.5);
setDeck(all);
setKept([]); setPassed([]); setUnsure([]);
setLastAction(null);
};

// Keyboard
useEffect(() => {
const handler = (e) => {
if (showProfile) return;
if (e.key === “ArrowLeft”) topCard && handleSwipe(“left”, topCard);
if (e.key === “ArrowRight”) topCard && handleSwipe(“right”, topCard);
if (e.key === “ “ || e.key === “ArrowDown”) { e.preventDefault(); handleUnsure(); }
if (e.key === “p”) setShowProfile(s => !s);
};
window.addEventListener(“keydown”, handler);
return () => window.removeEventListener(“keydown”, handler);
}, [topCard, showProfile]);

const isEmpty = deck.length === 0;

return (
<div style={{
minHeight: “100vh”,
background: isEmpty ? “#000” : `radial-gradient(ellipse at 50% 0%, ${theme.bg} 0%, #000 70%)`,
display: “flex”, flexDirection: “column”,
alignItems: “center”,
transition: “background 0.6s ease”,
fontFamily: “‘Courier New’, monospace”,
color: “#fff”,
overflow: “hidden”,
}}>
<Scanlines />

