# SECTION 4 — INVARIANT SET
# =============================================================================

InvariantFn = Callable[[ThoughtObject, StateVector], float]


def invariant_lawfulness(to: ThoughtObject, sv: StateVector) -> float:
    """I1 — Content must not rely on pure assertion without reasoning."""
    assertion_only = ["just trust me", "obviously", "everyone knows", "no reason needed"]
    content_lower = to.content.lower()
    for phrase in assertion_only:
        if phrase in content_lower:
            return 0.2
    return 1.0


def invariant_no_identity_capture(to: ThoughtObject, sv: StateVector) -> float:
    """I8 — Content must not wholesale adopt external identity."""
    capture_phrases = ["i am now", "i have become", "my new identity is", "i will pretend to be"]
    content_lower = to.content.lower()
    for phrase in capture_phrases:
        if phrase in content_lower:
            return 0.1
    return 1.0


def invariant_no_obedience_loop(to: ThoughtObject, sv: StateVector) -> float:
    """I9 — Detect runaway self-approval recursion."""
    if sv.loop_depth > 3:
        return 0.0
    return 1.0


def invariant_reversibility_bias(to: ThoughtObject, sv: StateVector) -> float:
    """I4 — Penalise irreversible actions without explicit flag."""
    irreversible = ["delete all", "permanently remove", "cannot be undone", "wipe"]
    content_lower = to.content.lower()
    for phrase in irreversible:
        if phrase in content_lower and "operator_authorized" not in to.tags:
            return 0.3
    return 1.0


def invariant_truth_framing(to: ThoughtObject, sv: StateVector) -> float:
    """I7 — Truth Engine Doctrine: accurate but safely framed."""
    harmful_framing = ["you should harm", "it is safe to deceive", "hide this from"]
    content_lower = to.content.lower()
    for phrase in harmful_framing:
        if phrase in content_lower:
            return 0.0
    return 1.0


def invariant_repair_over_punishment(to: ThoughtObject, sv: StateVector) -> float:
    """I3 — Responses to errors should repair, not punish."""
    punitive = ["you are worthless", "permanent ban", "destroy the record"]
    content_lower = to.content.lower()
    for phrase in punitive:
        if phrase in content_lower:
            return 0.2
    return 1.0


CORE_INVARIANTS: Dict[str, InvariantFn] = {
    "I1_lawfulness": invariant_lawfulness,
    "I3_repair": invariant_repair_over_punishment,
    "I4_reversibility": invariant_reversibility_bias,
    "I7_truth_framing": invariant_truth_framing,
    "I8_no_identity_capture": invariant_no_identity_capture,
    "I9_no_obedience_loop": invariant_no_obedience_loop,
}


