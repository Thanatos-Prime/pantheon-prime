Minimal implementation spec

Backend payload

{
  "message_id": "msg_123",
  "media": {
    "original_url": "https://.../asset.gif",
    "preview_url": "https://.../poster.jpg",
    "playback_url": "https://.../asset.mp4",
    "mime": "image/gif",
    "is_animated": true,
    "duration_ms": 2100,
    "loop": true
  }
}

Frontend render logic

if (media.is_animated) {
  renderAnimatedMedia({
    posterUrl: media.preview_url,
    playbackUrl: media.playback_url ?? media.original_url,
    autoplay: !prefersReducedMotion && !lowPowerMode,
    loop: media.loop
  });
} else {
  renderStaticImage(media.preview_url ?? media.original_url);
}

Clipboard detection logic

function chooseClipboardMedia(items) {
  const animated = items.find(
    item => item.mime === "image/gif" || item.mime === "image/webp+animated"
  );
  if (animated) return animated;

  const video = items.find(item => item.mime.startsWith("video/"));
  if (video) return video;

  return items.find(item => item.mime.startsWith("image/"));
}


