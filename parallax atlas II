const PLANETS = {
  Mercury: {a:.387, P:87.969,   R:.383,  albedo:.12, col:'#b0a090', sym:'☿', L0:1.24},
  Venus:   {a:.723, P:224.701,  R:.949,  albedo:.65, col:'#e8c97a', sym:'♀', L0:2.71},
  Earth:   {a:1.00, P:365.256,  R:1.00,  albedo:.30, col:'#4a90d9', sym:'⊕', L0:0.52},
  Mars:    {a:1.524,P:686.980,  R:.532,  albedo:.15, col:'#c1440e', sym:'♂', L0:4.03},
  Jupiter: {a:5.203,P:4332.589, R:11.21, albedo:.52, col:'#c8a474', sym:'♃', L0:0.93},
  Saturn:  {a:9.537,P:10759.22, R:9.45,  albedo:.47, col:'#e0c882', sym:'♄', L0:3.14},
  Uranus:  {a:19.19,P:30685.4,  R:4.01,  albedo:.51, col:'#7de8e8', sym:'⛢', L0:1.77},
  Neptune: {a:30.07,P:60190.0,  R:3.88,  albedo:.41, col:'#4060d0', sym:'♆', L0:5.02},
  Pluto:   {a:39.48,P:90560.0,  R:.186,  albedo:.49, col:'#a09080', sym:'♇', L0:2.28},
};
const PNAMES = Object.keys(PLANETS);
const MAX_DAYS = 90560; // full Pluto cycle

function xy(name,t){
  const p=PLANETS[name],theta=p.L0+2*Math.PI*(t/p.P);
  return [p.a*Math.cos(theta),p.a*Math.sin(theta)];
}

