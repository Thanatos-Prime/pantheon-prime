6) Minimal runnable code (Tier 0)

If you drop this into the repo, it produces the same style of summary I used.

import numpy as np
import pandas as pd

PLANETS = {
    "Mercury": {"a": 0.387,  "P": 87.969,   "R": 0.383},
    "Venus":   {"a": 0.723,  "P": 224.701,  "R": 0.949},
    "Earth":   {"a": 1.000,  "P": 365.256,  "R": 1.000},
    "Mars":    {"a": 1.524,  "P": 686.980,  "R": 0.532},
    "Jupiter": {"a": 5.203,  "P": 4332.589, "R": 11.21},
    "Saturn":  {"a": 9.537,  "P": 10759.22, "R": 9.45},
    "Uranus":  {"a": 19.191, "P": 30685.4,  "R": 4.01},
    "Neptune": {"a": 30.07,  "P": 60190.0,  "R": 3.88},
    "Pluto":   {"a": 39.48,  "P": 90560.0,  "R": 0.186},
}

_rng = np.random.default_rng(42)
for k in PLANETS:
    PLANETS[k]["L0"] = _rng.uniform(0, 2*np.pi)

def heliocentric_xy(body: str, t_days: float) -> np.ndarray:
    a = PLANETS[body]["a"]
    P = PLANETS[body]["P"]
    L0 = PLANETS[body]["L0"]
    theta = L0 + 2*np.pi*(t_days / P)
    return np.array([a*np.cos(theta), a*np.sin(theta)])

def summarize(observer: str, t_days: np.ndarray, elong_thresh_deg: float = 10.0) -> pd.DataFrame:
    obs_pos = np.array([heliocentric_xy(observer, t) for t in t_days])
    sun_vec = -obs_pos
    sun_hat = sun_vec / np.linalg.norm(sun_vec, axis=1)[:, None]

    rows = []
    for target in PLANETS:
        if target == observer:
            continue

        targ_pos = np.array([heliocentric_xy(target, t) for t in t_days])
        rel = targ_pos - obs_pos
        dist = np.linalg.norm(rel, axis=1)
        rel_hat = rel / dist[:, None]

        # elongation from Sun (simple visibility heuristic)
        cosang = np.clip(np.sum(rel_hat * sun_hat, axis=1), -1, 1)
        elong = np.degrees(np.arccos(cosang))
        visible = elong >= elong_thresh_deg

        # phase proxy: angle at target between (target->Sun) and (target->observer)
        st = -targ_pos
        st_hat = st / np.linalg.norm(st, axis=1)[:, None]
        ot_hat = (-rel) / dist[:, None]
        cosphase = np.clip(np.sum(st_hat * ot_hat, axis=1), -1, 1)
        phase_angle = np.arccos(cosphase)     # 0 full, pi new
        phase = (1 + np.cos(phase_angle)) / 2

        bright = (PLANETS[target]["R"]**2) * phase / (dist**2)

        rows.append({
            "target": target,
            "visible_frac": float(visible.mean()),
            "mean_bright_visible": float(np.mean(bright[visible])) if visible.any() else np.nan,
            "max_bright": float(np.max(bright)),
            "min_dist_AU": float(np.min(dist)),
            "max_dist_AU": float(np.max(dist)),
            "max_elong_deg": float(np.max(elong)),
        })

    df = pd.DataFrame(rows).sort_values("mean_bright_visible", ascending=False)
    return df

if __name__ == "__main__":
    t = np.arange(0, 5*365, 5)  # 5 years, 5-day step
    print("Earth observer:")
    print(summarize("Earth", t).head(10).to_string(index=False))
    print("\nMars observer:")
    print(summarize("Mars", t).head(10).to_string(index=False))


