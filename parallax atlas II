function synodic(obs,target){
  const po=PLANETS[obs].P, pt=PLANETS[target].P;
  if(po===pt) return Infinity;
  return Math.abs(1/(1/Math.min(po,pt)-1/Math.max(po,pt)));
}

function genName(seed){
  const cons=['K','V','R','Th','Z','N','M','L','S','Gh','Yr','Ax'];
  const vow=['a','e','i','o','eth','an','ur','el'];
  let h=0; for(let i=0;i<seed.length;i++) h=(h*31+seed.charCodeAt(i))>>>0;
  const r=n=>((h=Math.imul(h^h>>>16,0x45d9f3b))>>>0)%n;
  return cons[r(cons.length)]+vow[r(vow.length)]+cons[r(cons.length)]+vow[r(vow.length)];
}

