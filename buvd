Pseudocode

class BUVD:
    def __init__(self, weights=None):
        self.weights = weights or {
            "agency_fracture": 0.25,
            "latency_suspicion": 0.15,
            "embodiment_incoherence": 0.15,
            "narrative_conflict": 0.15,
            "human_shadow": 0.20,
            "surface_honesty": 0.10,
        }

    def score(self, obs):
        af = self.agency_fracture(obs)
        ls = self.latency_suspicion(obs)
        ei = self.embodiment_incoherence(obs)
        nc = self.narrative_conflict(obs)
        hs = self.human_shadow(obs)
        sh = self.surface_honesty(obs)

        buv = (
            self.weights["agency_fracture"] * af +
            self.weights["latency_suspicion"] * ls +
            self.weights["embodiment_incoherence"] * ei +
            self.weights["narrative_conflict"] * nc +
            self.weights["human_shadow"] * hs -
            self.weights["surface_honesty"] * sh
        )

        return {
            "BUV_score": max(0.0, min(1.0, buv)),
            "subscores": {
                "agency_fracture": af,
                "latency_suspicion": ls,
                "embodiment_incoherence": ei,
                "narrative_conflict": nc,
                "human_shadow": hs,
                "surface_honesty": sh,
            }
        }


