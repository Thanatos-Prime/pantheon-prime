<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PantheonOS ‚Äî Mission Control</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap');

:root {
‚Äìbg: #030609;
‚Äìsurface: #060d14;
‚Äìborder: #0d2233;
‚Äìborder-glow: #0a4a6e;
‚Äìgold: #c9a227;
‚Äìgold-dim: #7a6118;
‚Äìcyan: #00d4ff;
‚Äìcyan-dim: #005f73;
‚Äìred: #ff3b3b;
‚Äìgreen: #00ff88;
‚Äìgreen-dim: #004d2a;
‚Äìpurple: #8b5cf6;
‚Äìorange: #ff6b35;
‚Äìtext: #a8c4d4;
‚Äìtext-bright: #e2f0f7;
‚Äìtext-dim: #3a5a6e;
‚Äìscanline: rgba(0,212,255,0.02);
}

- { margin:0; padding:0; box-sizing:border-box; }

body {
background: var(‚Äìbg);
color: var(‚Äìtext);
font-family: ‚ÄòSpace Mono‚Äô, monospace;
font-size: 11px;
min-height: 100vh;
overflow-x: hidden;
position: relative;
}

body::before {
content:‚Äô‚Äô;
position:fixed; inset:0;
background: repeating-linear-gradient(
0deg,
transparent,
transparent 2px,
var(‚Äìscanline) 2px,
var(‚Äìscanline) 4px
);
pointer-events:none;
z-index:9999;
}

body::after {
content:‚Äô‚Äô;
position:fixed; inset:0;
background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,80,120,0.15) 0%, transparent 70%);
pointer-events:none;
z-index:0;
}

/* HEADER */
.header {
position: relative;
z-index: 10;
display: flex;
align-items: center;
justify-content: space-between;
padding: 12px 24px;
border-bottom: 1px solid var(‚Äìborder-glow);
background: linear-gradient(180deg, rgba(0,30,50,0.9) 0%, transparent 100%);
}

.logo {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-weight: 900;
font-size: 20px;
color: var(‚Äìcyan);
text-shadow: 0 0 20px var(‚Äìcyan), 0 0 40px rgba(0,212,255,0.3);
letter-spacing: 4px;
}

.logo span { color: var(‚Äìgold); }

.header-center {
text-align: center;
}

.header-title {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 10px;
letter-spacing: 6px;
color: var(‚Äìtext-dim);
text-transform: uppercase;
}

.status-bar {
display: flex;
gap: 16px;
align-items: center;
}

.status-item {
display: flex;
align-items: center;
gap: 6px;
font-size: 10px;
}

.dot {
width: 6px; height: 6px;
border-radius: 50%;
animation: pulse 2s infinite;
}
.dot.green { background: var(‚Äìgreen); box-shadow: 0 0 6px var(‚Äìgreen); }
.dot.gold { background: var(‚Äìgold); box-shadow: 0 0 6px var(‚Äìgold); }
.dot.cyan { background: var(‚Äìcyan); box-shadow: 0 0 6px var(‚Äìcyan); }

@keyframes pulse {
0%,100% { opacity:1; }
50% { opacity:0.4; }
}

/* MAIN GRID */
.grid {
position: relative;
z-index: 1;
display: grid;
grid-template-columns: 220px 1fr 220px;
grid-template-rows: auto auto auto;
gap: 1px;
padding: 1px;
min-height: calc(100vh - 56px);
}

.panel {
background: var(‚Äìsurface);
border: 1px solid var(‚Äìborder);
padding: 14px;
position: relative;
overflow: hidden;
transition: border-color 0.3s;
}

.panel:hover {
border-color: var(‚Äìborder-glow);
}

.panel::before {
content: ‚Äò‚Äô;
position: absolute;
inset: 0;
background: linear-gradient(135deg, rgba(0,212,255,0.02) 0%, transparent 60%);
pointer-events: none;
}

.panel-label {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 9px;
letter-spacing: 3px;
color: var(‚Äìcyan-dim);
text-transform: uppercase;
margin-bottom: 10px;
display: flex;
align-items: center;
gap: 8px;
}

.panel-label::after {
content: ‚Äò‚Äô;
flex: 1;
height: 1px;
background: linear-gradient(90deg, var(‚Äìborder-glow), transparent);
}

/* LEFT COLUMN */
.left-col {
grid-column: 1;
grid-row: 1 / 4;
display: flex;
flex-direction: column;
gap: 1px;
}

/* CENTER */
.center-main {
grid-column: 2;
grid-row: 1 / 3;
}

.center-bottom {
grid-column: 2;
grid-row: 3;
}

/* RIGHT COLUMN */
.right-col {
grid-column: 3;
grid-row: 1 / 4;
display: flex;
flex-direction: column;
gap: 1px;
}

/* SOLOMON SCORE */
.solomon {
text-align: center;
padding: 20px 10px;
}

.solomon-ring {
position: relative;
width: 110px;
height: 110px;
margin: 0 auto 12px;
}

.solomon-ring svg {
transform: rotate(-90deg);
}

.solomon-ring .track {
fill: none;
stroke: var(‚Äìborder);
stroke-width: 8;
}

.solomon-ring .fill {
fill: none;
stroke: var(‚Äìgold);
stroke-width: 8;
stroke-linecap: round;
stroke-dasharray: 283;
stroke-dashoffset: 57;
filter: drop-shadow(0 0 6px var(‚Äìgold));
transition: stroke-dashoffset 1s ease;
}

.solomon-center {
position: absolute;
inset: 0;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
}

.solomon-score {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 22px;
font-weight: 900;
color: var(‚Äìgold);
text-shadow: 0 0 12px var(‚Äìgold);
line-height: 1;
}

.solomon-label {
font-size: 8px;
color: var(‚Äìgold-dim);
letter-spacing: 2px;
margin-top: 3px;
}

.threshold-bar {
display: flex;
align-items: center;
gap: 6px;
font-size: 10px;
color: var(‚Äìgreen);
justify-content: center;
}

/* DAEMONS */
.daemon-list { display: flex; flex-direction: column; gap: 8px; }

.daemon {
display: flex;
align-items: center;
gap: 8px;
padding: 7px 10px;
border: 1px solid var(‚Äìborder);
border-radius: 2px;
cursor: pointer;
transition: all 0.2s;
position: relative;
overflow: hidden;
}

.daemon:hover {
border-color: var(‚Äìcyan-dim);
background: rgba(0,212,255,0.03);
}

.daemon.active {
border-color: var(‚Äìgreen);
background: rgba(0,255,136,0.04);
}

.daemon.active::after {
content: ‚Äò‚Äô;
position: absolute;
left: 0; top: 0; bottom: 0;
width: 2px;
background: var(‚Äìgreen);
box-shadow: 0 0 8px var(‚Äìgreen);
}

.daemon-icon {
font-size: 14px;
width: 20px;
text-align: center;
}

.daemon-info { flex: 1; }
.daemon-name {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 9px;
color: var(‚Äìtext-bright);
letter-spacing: 1px;
}
.daemon-role { font-size: 9px; color: var(‚Äìtext-dim); margin-top: 1px; }

.daemon-status {
font-size: 8px;
padding: 2px 5px;
border-radius: 1px;
}
.daemon-status.run { color: var(‚Äìgreen); border: 1px solid var(‚Äìgreen-dim); }
.daemon-status.idle { color: var(‚Äìtext-dim); border: 1px solid var(‚Äìborder); }
.daemon-status.watch { color: var(‚Äìgold); border: 1px solid var(‚Äìgold-dim); }

/* CENTER: LAYER STACK */
.layer-stack {
display: flex;
flex-direction: column;
gap: 6px;
padding: 10px 0;
}

.layer {
display: flex;
align-items: stretch;
gap: 10px;
position: relative;
cursor: pointer;
}

.layer-num {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 10px;
color: var(‚Äìtext-dim);
width: 20px;
flex-shrink: 0;
display: flex;
align-items: center;
justify-content: center;
letter-spacing: 1px;
}

.layer-bar {
flex: 1;
padding: 10px 14px;
border: 1px solid var(‚Äìborder);
position: relative;
overflow: hidden;
transition: all 0.3s;
}

.layer-bar:hover, .layer-bar.active {
border-color: var(‚Äìcyan-dim);
}

.layer-bar::before {
content: ‚Äò‚Äô;
position: absolute;
left: 0; top: 0; bottom: 0;
width: 3px;
transition: background 0.3s;
}

.layer-bar.l1::before { background: linear-gradient(180deg, #00d4ff, #005f73); }
.layer-bar.l2::before { background: linear-gradient(180deg, #c9a227, #7a6118); }
.layer-bar.l3::before { background: linear-gradient(180deg, #8b5cf6, #4c1d95); }
.layer-bar.l4::before { background: linear-gradient(180deg, #ff6b35, #7a3010); }
.layer-bar.l5::before { background: linear-gradient(180deg, #ff3b3b, #7a1010); }
.layer-bar.l6::before { background: linear-gradient(180deg, #00ff88, #004d2a); }
.layer-bar.l7::before { background: linear-gradient(180deg, #ffd700, #7a6000); }

.layer-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 3px;
}

.layer-name {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 11px;
font-weight: 700;
color: var(‚Äìtext-bright);
letter-spacing: 2px;
}

.layer-tag {
font-size: 9px;
padding: 2px 7px;
border-radius: 1px;
letter-spacing: 1px;
}

.layer-desc { font-size: 10px; color: var(‚Äìtext-dim); line-height: 1.5; }

.layer-bar.active .layer-name { text-shadow: 0 0 10px var(‚Äìcyan); }

.layer-detail {
display: none;
margin-top: 8px;
padding-top: 8px;
border-top: 1px solid var(‚Äìborder);
font-size: 10px;
color: var(‚Äìtext);
line-height: 1.7;
animation: fadeIn 0.2s ease;
}

.layer-detail.open { display: block; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(-4px); } to { opacity:1; transform:none; } }

/* COGNITIVE LOOP */
.loop-display {
display: flex;
align-items: center;
justify-content: center;
gap: 0;
flex-wrap: wrap;
padding: 10px 0;
}

.loop-step {
display: flex;
align-items: center;
}

.step-node {
padding: 6px 10px;
border: 1px solid var(‚Äìborder);
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 9px;
letter-spacing: 1px;
color: var(‚Äìtext-dim);
transition: all 0.3s;
cursor: pointer;
position: relative;
}

.step-node.current {
border-color: var(‚Äìcyan);
color: var(‚Äìcyan);
background: rgba(0,212,255,0.07);
box-shadow: 0 0 12px rgba(0,212,255,0.2);
animation: stepGlow 1.5s ease infinite;
}

.step-node.done {
border-color: var(‚Äìgreen-dim);
color: var(‚Äìgreen);
}

@keyframes stepGlow {
0%,100% { box-shadow: 0 0 8px rgba(0,212,255,0.2); }
50% { box-shadow: 0 0 20px rgba(0,212,255,0.5); }
}

.step-arrow {
color: var(‚Äìtext-dim);
font-size: 12px;
padding: 0 3px;
}

/* INVARIANTS */
.invariant-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 5px;
}

.inv-item {
padding: 7px 8px;
border: 1px solid var(‚Äìborder);
cursor: pointer;
transition: all 0.2s;
}

.inv-item:hover { border-color: var(‚Äìcyan-dim); }

.inv-num {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 16px;
font-weight: 900;
color: var(‚Äìborder-glow);
line-height: 1;
margin-bottom: 3px;
}

.inv-name {
font-size: 9px;
color: var(‚Äìtext);
line-height: 1.3;
}

.inv-item:hover .inv-num { color: var(‚Äìcyan); }

/* GATE FUNCTION */
.gate-display {
text-align: center;
padding: 10px;
}

.gate-formula {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 11px;
color: var(‚Äìgold);
text-shadow: 0 0 10px rgba(201,162,39,0.5);
letter-spacing: 2px;
margin-bottom: 8px;
line-height: 1.8;
}

.gate-outcomes {
display: flex;
gap: 5px;
justify-content: center;
flex-wrap: wrap;
}

.outcome {
padding: 4px 8px;
border: 1px solid;
font-size: 9px;
letter-spacing: 1px;
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
border-radius: 1px;
}
.outcome.allow { border-color: var(‚Äìgreen); color: var(‚Äìgreen); }
.outcome.deny { border-color: var(‚Äìred); color: var(‚Äìred); }
.outcome.modify { border-color: var(‚Äìgold); color: var(‚Äìgold); }
.outcome.escalate { border-color: var(‚Äìorange); color: var(‚Äìorange); }
.outcome.abstain { border-color: var(‚Äìpurple); color: var(‚Äìpurple); }

/* THOUGHT OBJECT */
.to-display {
font-family: ‚ÄòShare Tech Mono‚Äô, monospace;
font-size: 10px;
color: var(‚Äìgreen);
line-height: 1.6;
border: 1px solid var(‚Äìgreen-dim);
padding: 10px;
background: rgba(0,255,136,0.02);
position: relative;
overflow: hidden;
}

.to-display::before {
content: ‚ÄòTHOUGHT_OBJECT‚Äô;
position: absolute;
top: 6px; right: 8px;
font-size: 8px;
color: var(‚Äìgreen-dim);
letter-spacing: 2px;
}

.to-key { color: var(‚Äìcyan-dim); }
.to-val { color: var(‚Äìgreen); }
.to-str { color: var(‚Äìgold); }

/* LEDGER */
.ledger-entries {
display: flex;
flex-direction: column;
gap: 4px;
max-height: 180px;
overflow-y: auto;
}

.ledger-entries::-webkit-scrollbar { width: 3px; }
.ledger-entries::-webkit-scrollbar-track { background: var(‚Äìborder); }
.ledger-entries::-webkit-scrollbar-thumb { background: var(‚Äìcyan-dim); }

.ledger-entry {
display: flex;
gap: 8px;
padding: 5px 8px;
border-left: 2px solid var(‚Äìborder);
font-size: 10px;
line-height: 1.4;
animation: entrySlide 0.4s ease;
}

@keyframes entrySlide { from { opacity:0; transform: translateX(-8px); } to { opacity:1; transform:none; } }

.ledger-entry.append { border-color: var(‚Äìgreen); }
.ledger-entry.gate { border-color: var(‚Äìgold); }
.ledger-entry.distill { border-color: var(‚Äìpurple); }
.ledger-entry.warn { border-color: var(‚Äìred); }

.l-time { color: var(‚Äìtext-dim); flex-shrink: 0; font-size: 9px; }
.l-type { flex-shrink: 0; width: 48px; font-size: 9px; letter-spacing: 1px; }
.l-type.append { color: var(‚Äìgreen); }
.l-type.gate { color: var(‚Äìgold); }
.l-type.distill { color: var(‚Äìpurple); }
.l-type.warn { color: var(‚Äìred); }
.l-msg { color: var(‚Äìtext); }

/* STATE VECTOR */
.sv-grid {
display: flex;
flex-direction: column;
gap: 6px;
}

.sv-row {
display: flex;
align-items: center;
gap: 8px;
}

.sv-key {
font-size: 9px;
color: var(‚Äìtext-dim);
width: 80px;
flex-shrink: 0;
letter-spacing: 1px;
}

.sv-bar-outer {
flex: 1;
height: 4px;
background: var(‚Äìborder);
position: relative;
overflow: hidden;
}

.sv-bar-inner {
height: 100%;
transition: width 1.5s ease;
position: relative;
}

.sv-bar-inner::after {
content: ‚Äò‚Äô;
position: absolute;
right: 0; top: 0; bottom: 0;
width: 3px;
background: white;
opacity: 0.5;
}

.sv-val {
font-size: 10px;
width: 30px;
text-align: right;
color: var(‚Äìtext-bright);
}

/* TERMINAL */
.terminal {
background: #010507;
border: 1px solid var(‚Äìborder);
padding: 10px;
font-family: ‚ÄòShare Tech Mono‚Äô, monospace;
font-size: 10px;
line-height: 1.7;
max-height: 160px;
overflow-y: auto;
}

.terminal::-webkit-scrollbar { width: 3px; }
.terminal::-webkit-scrollbar-thumb { background: var(‚Äìcyan-dim); }

.t-line { display: block; }
.t-prompt { color: var(‚Äìcyan-dim); }
.t-cmd { color: var(‚Äìtext-bright); }
.t-out { color: var(‚Äìtext-dim); }
.t-ok { color: var(‚Äìgreen); }
.t-warn { color: var(‚Äìgold); }
.t-err { color: var(‚Äìred); }
.t-cursor {
display: inline-block;
width: 7px; height: 11px;
background: var(‚Äìcyan);
animation: blink 1s step-end infinite;
vertical-align: text-bottom;
}

@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

/* MODES */
.mode-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 5px;
}

.mode-btn {
padding: 8px 6px;
border: 1px solid var(‚Äìborder);
text-align: center;
cursor: pointer;
transition: all 0.2s;
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 8px;
letter-spacing: 1px;
color: var(‚Äìtext-dim);
}

.mode-btn:hover { border-color: var(‚Äìcyan-dim); color: var(‚Äìtext); }
.mode-btn.on {
border-color: var(‚Äìcyan);
color: var(‚Äìcyan);
background: rgba(0,212,255,0.05);
box-shadow: inset 0 0 12px rgba(0,212,255,0.05);
}

.mode-btn .mode-icon { font-size: 16px; display: block; margin-bottom: 4px; }

/* BOTTOM STRIP */
.bottom-strip {
grid-column: 1 / 4;
display: flex;
align-items: center;
gap: 20px;
padding: 8px 20px;
border-top: 1px solid var(‚Äìborder);
background: var(‚Äìsurface);
font-size: 9px;
color: var(‚Äìtext-dim);
overflow: hidden;
letter-spacing: 1px;
}

.ticker-label {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
color: var(‚Äìgold);
font-size: 9px;
letter-spacing: 2px;
flex-shrink: 0;
}

.ticker-scroll {
overflow: hidden;
flex: 1;
position: relative;
}

.ticker-inner {
white-space: nowrap;
animation: scroll 40s linear infinite;
}

@keyframes scroll {
from { transform: translateX(100%); }
to { transform: translateX(-100%); }
}

/* METRIC BARS */
.metric {
display: flex;
align-items: center;
gap: 8px;
margin-bottom: 7px;
}

.metric-name {
font-size: 9px;
color: var(‚Äìtext-dim);
width: 70px;
flex-shrink: 0;
letter-spacing: 1px;
}

.metric-track {
flex: 1;
height: 3px;
background: var(‚Äìborder);
}

.metric-fill {
height: 100%;
transition: width 2s ease;
}

.metric-val {
font-size: 9px;
color: var(‚Äìtext-bright);
width: 28px;
text-align: right;
}

/* NTE DISPLAY */
.nte-tensor {
font-family: ‚ÄòShare Tech Mono‚Äô, monospace;
font-size: 10px;
color: var(‚Äìtext);
line-height: 1.8;
}

.nte-s { color: var(‚Äìcyan); }
.nte-t { color: var(‚Äìred); }
.nte-r { color: var(‚Äìgreen); }

/* HOGGE SYMBOLS */
.symbol-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 5px;
}

.symbol-card {
padding: 7px 6px;
border: 1px solid var(‚Äìborder);
text-align: center;
cursor: pointer;
transition: all 0.2s;
}

.symbol-card:hover {
border-color: var(‚Äìgold-dim);
background: rgba(201,162,39,0.03);
}

.symbol-name {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 8px;
color: var(‚Äìgold);
letter-spacing: 1px;
margin-bottom: 3px;
}

.symbol-def {
font-size: 8px;
color: var(‚Äìtext-dim);
line-height: 1.3;
}

/* OASA */
.oasa {
display: flex;
align-items: center;
justify-content: center;
gap: 8px;
padding: 10px 0;
}

.oasa-step {
text-align: center;
padding: 10px 8px;
border: 1px solid var(‚Äìborder);
min-width: 50px;
transition: all 0.3s;
}

.oasa-step.active {
border-color: var(‚Äìcyan);
background: rgba(0,212,255,0.05);
}

.oasa-letter {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 18px;
font-weight: 900;
line-height: 1;
}

.oasa-word {
font-size: 8px;
color: var(‚Äìtext-dim);
margin-top: 4px;
letter-spacing: 1px;
}

.oasa-arrow { color: var(‚Äìtext-dim); font-size: 14px; }

/* TOOLTIP */
.tooltip {
position: fixed;
background: rgba(6,13,20,0.97);
border: 1px solid var(‚Äìcyan-dim);
padding: 10px 14px;
font-size: 10px;
max-width: 260px;
z-index: 99999;
pointer-events: none;
display: none;
line-height: 1.6;
color: var(‚Äìtext);
}

.tooltip.visible { display: block; }
.tooltip-title {
font-family: ‚ÄòOrbitron‚Äô, sans-serif;
font-size: 10px;
