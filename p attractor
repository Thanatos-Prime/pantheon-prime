                <span style={{ fontSize: 9, color: active ? PALETTE.text : PALETTE.dim, letterSpacing: 0.5 }}>
                  {inv}
                </span>
              </div>
            );
          })}
        </div>
      </div>

      {/* STATE VECTOR */}
      <div style={{ padding: "16px 18px", borderBottom: `1px solid ${PALETTE.border}` }}>
        <Label>State Vector · SV</Label>
        {[
          ["MODE", stage >= 7 ? "T=1 ATTRACTOR" : stage >= 5 ? "T=1 ACTIVE" : "T=1 FORMING"],
          ["COHERENCE", `${Math.round((stage / 7) * 100)}%`],
          ["ENTROPY", `${Math.round((1 - stage / 7) * 100)}%`],
          ["LOOP_STATE", loopRunning ? "RUNNING" : "PAUSED"],
          ["KAIROS", stage >= 5 ? "ARMED" : "DORMANT"],
          ["BOMBADIL", stage <= 2 ? "ACTIVE" : "STANDBY"],
        ].map(([k, v]) => (
          <div key={k} style={{ display: "flex", justifyContent: "space-between", padding: "3px 0", borderBottom: `1px solid ${PALETTE.border}22` }}>
            <span style={{ fontSize: 9, color: PALETTE.dim, letterSpacing: 1 }}>{k}</span>
            <span style={{ fontSize: 10, color: PALETTE.accent }}>{v}</span>
          </div>
        ))}
      </div>

      {/* OASA LOOP */}
      <div style={{ padding: "16px 18px", borderBottom: `1px solid ${PALETTE.border}` }}>
        <Label>OASA Loop</Label>
        {["OBSERVE", "ASSESS", "SHAPE", "ACT"].map((phase, i) => {
          const active = Math.floor(tick / 4) % 4 === i && loopRunning;
          return (
            <div key={phase} style={{
              display: "flex", alignItems: "center", gap: 10, padding: "5px 0",
            }}>
              <div style={{
                width: 20, height: 20,
                border: `1px solid ${active ? PALETTE.gold : PALETTE.border}`,
                display: "flex", alignItems: "center", justifyContent: "center",
                fontSize: 9, color: active ? PALETTE.gold : PALETTE.dim,
                background: active ? "rgba(240,192,64,0.08)" : "transparent",
                transition: "all 0.3s",
                flexShrink: 0,
              }}>
                {i + 1}
              </div>
              <span style={{ fontSize: 10, color: active ? PALETTE.gold : PALETTE.dim, letterSpacing: 2 }}>
                {phase}
              </span>
            </div>
          );
        })}
      </div>

      {/* DISTILLATION PIPELINE */}
      <div style={{ padding: "16px 18px" }}>
        <Label>Distillation Pipeline</Label>
        {[
          ["experience", stage >= 1],
          ["patterns", stage >= 2],
          ["heuristics", stage >= 3],
          ["doctrine", stage >= 5],
          ["identity", stage >= 7],
        ].map(([label, reached]) => (
          <div key={label} style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 8 }}>
            <div style={{
              width: 8, height: 8,
              border: `1.5px solid ${reached ? PALETTE.green : PALETTE.border}`,
              borderRadius: "50%",
              background: reached ? PALETTE.green : "transparent",
              flexShrink: 0,
              boxShadow: reached ? `0 0 8px ${PALETTE.green}` : "none",
            }} />
            <span style={{ fontSize: 10, color: reached ? PALETTE.text : PALETTE.dim, letterSpacing: 1 }}>
              {label}
            </span>
            {reached && label === "identity" && (
              <span style={{ fontSize: 8, color: PALETTE.green, letterSpacing: 1, marginLeft: "auto" }}>
                ATTRACTOR COMPLETE
              </span>
            )}
          </div>
        ))}
        <div style={{ marginTop: 8, fontSize: 9, color: PALETTE.dim, lineHeight: 1.6 }}>
          experience→patterns→heuristics→doctrine→identity
        </div>
      </div>
    </div>
  </div>
</div>
