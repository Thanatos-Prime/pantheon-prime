let METRICS_CACHE = {};

function computeMetrics(observer, elongThresh=10, sampleStep=30){
  const key=`${observer}_${elongThresh}_${sampleStep}`;
  if(METRICS_CACHE[key]) return METRICS_CACHE[key];

  const tArr=[];
  for(let t=0;t<=MAX_DAYS;t+=sampleStep) tArr.push(t);
  const N=tArr.length;
  const results={};

  PNAMES.forEach(target=>{
    if(target===observer) return;
    let cntVis=0,sumBVis=0,maxB=0,minD=1e9,maxD=0,maxElong=0;

    tArr.forEach(t=>{
      const op=xy(observer,t),tp=xy(target,t);
      const sunV=[-op[0],-op[1]],sL=Math.hypot(sunV[0],sunV[1]);
      const sH=[sunV[0]/sL,sunV[1]/sL];
      const rel=[tp[0]-op[0],tp[1]-op[1]];
      const dist=Math.hypot(rel[0],rel[1]);
      const rH=[rel[0]/dist,rel[1]/dist];
      const cosE=Math.max(-1,Math.min(1,rH[0]*sH[0]+rH[1]*sH[1]));
      const elong=Math.acos(cosE)*180/Math.PI;
      const stL=Math.hypot(tp[0],tp[1]);
      const stH=[-tp[0]/stL,-tp[1]/stL];
      const otH=[-rel[0]/dist,-rel[1]/dist];
      const cosP=Math.max(-1,Math.min(1,stH[0]*otH[0]+stH[1]*otH[1]));
      const phase=(1+Math.cos(Math.acos(cosP)))/2;
      const p=PLANETS[target];
      const bright=(p.albedo*p.R**2*phase)/(dist**2);
      if(elong>=elongThresh){cntVis++;sumBVis+=bright;}
      if(bright>maxB)maxB=bright;
      if(dist<minD)minD=dist;
      if(dist>maxD)maxD=dist;
      if(elong>maxElong)maxElong=elong;
    });

    results[target]={
      visFrac:cntVis/N,
      meanBrightVis:cntVis>0?sumBVis/cntVis:0,
      maxBright:maxB,minDist:minD,maxDist:maxD,maxElong,
      isInterior:PLANETS[target].a<PLANETS[observer].a,
    };
  });

  const sorted=Object.entries(results)
    .sort((a,b)=>b[1].meanBrightVis-a[1].meanBrightVis)
    .map(([name,m])=>({name,...m}));
  METRICS_CACHE[key]=sorted;
  return sorted;
}

