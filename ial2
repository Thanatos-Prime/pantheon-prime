async function callIAL(systemDesc, actors, scores) {
const actorSummary = actors.length > 0
? actors.map(a =>
`Actor: ${a.name}\n  Objective: ${a.objective}\n  Reward: ${a.rewardChannel}\n  Penalty: ${a.penaltyChannel}\n  Horizon: ${a.horizon}\n  Visibility: ${a.visibility}/5\n  Externalities: ${a.externalities}\n  Lock-in: ${a.lockin}/5`
).join(”\n\n”)
: “(no actors defined)”;

const scoreSummary = SCORE_DIMS.map(d => `${d.label}: ${scores[d.id] || 0}/5`).join(”, “);
const mi = computeMI(scores);

const prompt = `You are the Incentive Alignment Layer (IAL v2.0) of PantheonOS.

Doctrine: Most persistent dysfunction is not caused by bad stated values but by misaligned reward geometry across actors, timescales, and visibility layers. Incentives are gradients. Governance is terrain-shaping. Alignment means making the good path the easy path.

SYSTEM DESCRIPTION:
${systemDesc}

ACTOR MAP:
${actorSummary}

SCORING MATRIX:
${scoreSummary}
Misalignment Index: ${mi}/20 (${miLabel(mi)})

Respond ONLY with a valid JSON object. No markdown fences, no preamble, no explanation outside the JSON. Use this exact structure:
{
“summary”: “2-3 sentence diagnosis of the core incentive dysfunction in this specific system”,
“misalignments”: [
{
“type”: “MUST be one of exactly: Proxy Capture, Externalized Harm, Timescale Inversion, Information Asymmetry, Lock-in Asymmetry, Moral Camouflage”,
“actors”: “which specific actors are involved”,
“detail”: “how this misalignment manifests in this specific system”
}
],
“secondOrder”: [
“specific second-order effect 1”,
“specific second-order effect 2”,
“specific second-order effect 3”
],
“patterns”: [“matching canonical pattern name 1”, “matching canonical pattern name 2”],
“redesigns”: {
“light”: {
“label”: “Light-Touch”,
“operator”: “MUST be one of: Reward Rewrite, Cost Reinternalization, Delay Injection, Visibility Correction, Exit Restoration, Positive-Sum Reframe”,
“action”: “specific concrete intervention”,
“risk”: “main failure mode or unintended consequence”
},
“structural”: {
“label”: “Structural”,
“operator”: “MUST be one of: Reward Rewrite, Cost Reinternalization, Delay Injection, Visibility Correction, Exit Restoration, Positive-Sum Reframe”,
“action”: “specific concrete intervention”,
“risk”: “main failure mode or unintended consequence”
},
“ambitious”: {
“label”: “Ambitious Positive-Sum”,
“operator”: “Positive-Sum Reframe”,
“action”: “specific concrete intervention that redesigns the game so cooperation pays more”,
“risk”: “main failure mode or unintended consequence”
}
},
“ethicsGate”: {
“consent”: true,
“reversibility”: true,
“nonCoercion”: true,
“dignity”: true,
“gamingResistance”: true,
“loadFairness”: true,
“notes”: “brief assessment of ethical risks in proposed redesigns”
}
}`;

const res = await fetch(“https://api.anthropic.com/v1/messages”, {
method: “POST”,
headers: { “Content-Type”: “application/json” },
body: JSON.stringify({
model: “claude-sonnet-4-20250514”,
max_tokens: 1500,
messages: [{ role: “user”, content: prompt }],
}),
});

if (!res.ok) {
const err = await res.text().catch(() => “unknown error”);
throw new Error(`API error ${res.status}: ${err}`);
}

const data = await res.json();
const text = (data.content || []).map(b => b.text || “”).join(””).trim();

// Strip any accidental markdown fences
const clean = text.replace(/^`(?:json)?\s*/i, "").replace(/\s*`\s*$/i, “”).trim();

let parsed;
try {
parsed = JSON.parse(clean);
} catch {
// Attempt to extract JSON object from surrounding text
const match = clean.match(/{[\s\S]*}/);
if (match) {
parsed = JSON.parse(match[0]);
} else {
throw new Error(“Model did not return valid JSON. Try again.”);
}
}

return safeParseResult(parsed);
}

