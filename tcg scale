from __future__ import annotations

import json
import sqlite3
from pathlib import Path
from typing import Any, Dict, List

DB_PATH = Path("psr.db")


def get_conn() -> sqlite3.Connection:
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def init_db() -> None:
    conn = get_conn()
    cur = conn.cursor()

    cur.execute(
        """
        CREATE TABLE IF NOT EXISTS events (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id TEXT NOT NULL,
            item_a TEXT NOT NULL,
            item_b TEXT NOT NULL,
            selected TEXT NOT NULL,
            confidence REAL NOT NULL,
            dwell_ms INTEGER NOT NULL,
            domain TEXT NOT NULL,
            context_json TEXT NOT NULL,
            item_a_features_json TEXT NOT NULL,
            item_b_features_json TEXT NOT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
        """
    )

    conn.commit()
    conn.close()


def insert_event(event: Dict[str, Any]) -> None:
    conn = get_conn()
    cur = conn.cursor()

    cur.execute(
        """
        INSERT INTO events (
            user_id, item_a, item_b, selected, confidence, dwell_ms, domain,
            context_json, item_a_features_json, item_b_features_json
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (
            event["user_id"],
            event["item_a"],
            event["item_b"],
            event["selected"],
            event["confidence"],
            event["dwell_ms"],
            event["domain"],
            json.dumps(event.get("context", {}), sort_keys=True),
            json.dumps(event.get("item_a_features", {}), sort_keys=True),
            json.dumps(event.get("item_b_features", {}), sort_keys=True),
        ),
    )

    conn.commit()
    conn.close()


def fetch_all_events() -> List[Dict[str, Any]]:
    conn = get_conn()
    cur = conn.cursor()
    rows = cur.execute("SELECT * FROM events ORDER BY id ASC").fetchall()
    conn.close()

    events: List[Dict[str, Any]] = []
    for row in rows:
        events.append(
            {
                "user_id": row["user_id"],
                "item_a": row["item_a"],
                "item_b": row["item_b"],
                "selected": row["selected"],
                "confidence": row["confidence"],
                "dwell_ms": row["dwell_ms"],
                "domain": row["domain"],
                "context": json.loads(row["context_json"]),
                "item_a_features": json.loads(row["item_a_features_json"]),
                "item_b_features": json.loads(row["item_b_features_json"]),
            }
        )
    return events

