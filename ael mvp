🚀 main.py

from fastapi import FastAPI
from models import Item, User
from appraisal import appraise
from credit import issue_credit, deduct_credit
from inventory import add_item, get_all_items, get_item
import uuid

app = FastAPI()

# In-memory store
users = {"user_1": User(id="user_1")}

# --- Deposit Item ---
@app.post("/deposit")
def deposit(item: Item):
    item.id = str(uuid.uuid4())

    value = appraise(item)
    item.estimated_value = value

    add_item(item)

    user = users["user_1"]
    issue_credit(user, value)

    return {
        "item": item,
        "credits_added": value,
        "total_credits": user.credits
    }

# --- View Inventory ---
@app.get("/inventory")
def inventory():
    return get_all_items()

# --- Borrow Item ---
@app.post("/borrow/{item_id}")
def borrow(item_id: str):
    user = users["user_1"]
    item = get_item(item_id)

    if not item:
        return {"error": "Item not found"}

    if deduct_credit(user, item.estimated_value):
        return {
            "status": "borrowed",
            "item": item,
            "remaining_credits": user.credits
        }

    return {"error": "Not enough credits"}

# --- Check Credits ---
@app.get("/credits")
def credits():
    return users["user_1"]


