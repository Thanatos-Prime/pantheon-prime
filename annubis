class TransitionEvent:
    def __init__(self, prior_state, trigger, actor, context, expected_invariants, resulting_state):
        self.prior_state = prior_state
        self.trigger = trigger
        self.actor = actor
        self.context = context
        self.expected_invariants = expected_invariants
        self.resulting_state = resulting_state

class Gatejackal:
    def evaluate(self, event):
        scores = {
            "context_continuity": self.check_context(event),
            "meaning_preservation": self.check_meaning(event),
            "authority_legitimacy": self.check_authority(event),
            "mechanism_narrative_agreement": self.check_mechanism(event),
            "reversibility": self.check_reversibility(event),
        }

        failures = [k for k, v in scores.items() if not v]

        if len(failures) >= 2:
            return {
                "action": "isolate_transition",
                "failures": failures,
                "mode": self.choose_mode(event, failures)
            }

        return {
            "action": "allow_with_trace",
            "failures": failures,
            "mode": "silent_flank"
        }


