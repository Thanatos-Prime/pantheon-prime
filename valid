from **future** import annotations
from dataclasses import dataclass, field
import yaml
import os
import sys
import argparse

# —————————————————————————

# Required fields by status level

# —————————————————————————

REQUIRED_ALWAYS = [
“id”, “name”, “type”, “summary”, “core_invariant”,
“compression_phrase”, “domains”, “neighbors”,
“failure_modes”, “transfers”, “safety_constraints”,
]

VALID_TYPES = {“concept”, “daemon”, “invariant”, “protocol”, “pattern”, “field”, “metric”}
VALID_STATUSES = {“draft”, “canonical”, “deprecated”, “fossil”}
VALID_SPECTRAL = {“low”, “medium”, “high”}

# Canon promotion requires all five gates

CANON_GATES = [“compression”, “transfer”, “failure”, “safety”, “retrieval”]

# —————————————————————————

# Result objects

# —————————————————————————

@dataclass
class ValidationIssue:
severity: str  # error | warning | info
field: str
message: str

```
def __str__(self) -> str:
    return f"  [{self.severity.upper():7s}] {self.field}: {self.message}"
```

@dataclass
class ValidationResult:
node_id: str
node_path: str
issues: list[ValidationIssue] = field(default_factory=list)
canon_gates: dict[str, bool] = field(default_factory=dict)

```
@property
def errors(self) -> list[ValidationIssue]:
    return [i for i in self.issues if i.severity == "error"]

@property
def warnings(self) -> list[ValidationIssue]:
    return [i for i in self.issues if i.severity == "warning"]

@property
def passed(self) -> bool:
    return len(self.errors) == 0

@property
def canon_ready(self) -> bool:
    return all(self.canon_gates.values()) and self.passed

def explain(self) -> str:
    lines = [
        f"Node: {self.node_id}  ({self.node_path})",
        f"  Valid: {'YES' if self.passed else 'NO'}",
        f"  Canon-ready: {'YES' if self.canon_ready else 'NO'}",
    ]
    if self.canon_gates:
        lines.append("  Canon gates:")
        for gate, passed in self.canon_gates.items():
            lines.append(f"    {'✓' if passed else '✗'} {gate}")
    if self.issues:
        lines.append("  Issues:")
        for issue in self.issues:
            lines.append(str(issue))
    return "\n".join(lines)
```

