<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PantheonOS — The Herald</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Courier+Prime:wght@400;700&display=swap');

:root {
–void: #020408;
–silver: #c8d4e0;
–silver-bright: #e8f0f8;
–silver-dim: #5a6a7a;
–gold: #b8960a;
–gold-bright: #d4a80c;
–pulse: #4a8ab0;
–glow: rgba(200, 212, 224, 0.08);
}

- { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
width: 100%; height: 100%;
background: var(–void);
color: var(–silver);
font-family: ‘Cormorant Garamond’, Georgia, serif;
overflow: hidden;
cursor: none;
}

/* Custom cursor */
#cursor {
position: fixed;
width: 6px; height: 6px;
background: var(–silver-bright);
border-radius: 50%;
pointer-events: none;
z-index: 9999;
transition: transform 0.1s ease;
box-shadow: 0 0 12px 4px rgba(232,240,248,0.4);
}
#cursor-ring {
position: fixed;
width: 32px; height: 32px;
border: 1px solid rgba(200,212,224,0.3);
border-radius: 50%;
pointer-events: none;
z-index: 9998;
transition: all 0.2s ease;
transform: translate(-50%, -50%);
}

/* Star field */
#starfield {
position: fixed;
inset: 0;
z-index: 0;
}

/* Main stage */
#stage {
position: fixed;
inset: 0;
z-index: 10;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
}

/* Herald intro screen */
#herald {
position: absolute;
inset: 0;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
opacity: 0;
animation: fadeIn 2s ease 0.5s forwards;
}

.surfer-container {
position: relative;
width: 120px;
height: 180px;
margin-bottom: 48px;
}

.surfer-glow {
position: absolute;
inset: -30px;
background: radial-gradient(ellipse, rgba(200,212,224,0.12) 0%, transparent 70%);
animation: breathe 4s ease-in-out infinite;
}

.surfer-figure {
position: absolute;
inset: 0;
display: flex;
align-items: center;
justify-content: center;
}

.surfer-svg {
width: 80px;
filter: drop-shadow(0 0 20px rgba(200,212,224,0.6));
animation: float 6s ease-in-out infinite;
}

.board {
position: absolute;
bottom: 20px;
left: 50%;
transform: translateX(-50%);
width: 90px;
height: 14px;
background: linear-gradient(135deg, #e8f0f8, #8a9ab0, #e8f0f8);
border-radius: 50%;
filter: drop-shadow(0 0 16px rgba(200,212,224,0.8));
animation: float 6s ease-in-out infinite;
animation-delay: 0.3s;
}

.board-trail {
position: absolute;
bottom: 14px;
left: 50%;
transform: translateX(-50%);
width: 60px;
height: 40px;
background: linear-gradient(to bottom, rgba(200,212,224,0.15), transparent);
filter: blur(8px);
animation: float 6s ease-in-out infinite;
animation-delay: 0.3s;
}

.headline {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(36px, 5vw, 64px);
font-weight: 300;
letter-spacing: 0.3em;
text-transform: uppercase;
color: var(–silver-bright);
text-align: center;
line-height: 1;
margin-bottom: 16px;
text-shadow: 0 0 40px rgba(200,212,224,0.3);
}

.subhead {
font-size: clamp(13px, 1.5vw, 16px);
font-weight: 300;
letter-spacing: 0.5em;
text-transform: uppercase;
color: var(–silver-dim);
text-align: center;
margin-bottom: 64px;
}

.enter-btn {
font-family: ‘Courier Prime’, monospace;
font-size: 11px;
letter-spacing: 0.4em;
text-transform: uppercase;
color: var(–silver-dim);
background: none;
border: 1px solid rgba(200,212,224,0.2);
padding: 14px 40px;
cursor: none;
transition: all 0.4s ease;
position: relative;
overflow: hidden;
}

.enter-btn::before {
content: ‘’;
position: absolute;
inset: 0;
background: linear-gradient(135deg, transparent, rgba(200,212,224,0.05), transparent);
transform: translateX(-100%);
transition: transform 0.6s ease;
}

.enter-btn:hover {
color: var(–silver-bright);
border-color: rgba(200,212,224,0.6);
box-shadow: 0 0 30px rgba(200,212,224,0.1);
}
.enter-btn:hover::before { transform: translateX(100%); }

/* Transmission screens */
#transmission {
position: absolute;
inset: 0;
display: none;
flex-direction: column;
align-items: center;
justify-content: center;
padding: 40px;
}

.transmission-inner {
max-width: 860px;
width: 100%;
}

/* Progress bar */
.progress-bar {
width: 100%;
height: 1px;
background: rgba(200,212,224,0.1);
margin-bottom: 60px;
position: relative;
}

.progress-fill {
height: 100%;
background: linear-gradient(90deg, transparent, var(–silver-dim), var(–silver-bright));
transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
box-shadow: 0 0 10px rgba(200,212,224,0.4);
}

.progress-label {
position: absolute;
right: 0;
top: -20px;
font-family: ‘Courier Prime’, monospace;
font-size: 10px;
letter-spacing: 0.3em;
color: var(–silver-dim);
}

/* Card */
.card {
display: none;
opacity: 0;
animation: slideUp 0.8s ease forwards;
}
.card.active { display: block; }

.card-tag {
font-family: ‘Courier Prime’, monospace;
font-size: 10px;
letter-spacing: 0.5em;
color: var(–gold);
text-transform: uppercase;
margin-bottom: 20px;
display: flex;
align-items: center;
gap: 12px;
}

.card-tag::before {
content: ‘’;
display: block;
width: 40px;
height: 1px;
background: var(–gold);
opacity: 0.5;
}

.card-title {
font-size: clamp(32px, 4vw, 52px);
font-weight: 300;
font-style: italic;
color: var(–silver-bright);
line-height: 1.15;
margin-bottom: 32px;
letter-spacing: 0.02em;
}

.card-body {
font-size: clamp(16px, 1.8vw, 20px);
font-weight: 300;
line-height: 1.8;
color: var(–silver-dim);
max-width: 640px;
margin-bottom: 40px;
}

.card-body strong {
color: var(–silver);
font-weight: 400;
}

.card-axiom {
font-family: ‘Courier Prime’, monospace;
font-size: 13px;
letter-spacing: 0.15em;
color: var(–pulse);
border-left: 2px solid var(–pulse);
padding-left: 20px;
margin-bottom: 48px;
opacity: 0.8;
}

/* Invariant pills */
.invariants-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
gap: 12px;
margin-bottom: 48px;
}

.inv-pill {
font-family: ‘Courier Prime’, monospace;
font-size: 11px;
letter-spacing: 0.1em;
color: var(–silver-dim);
border: 1px solid rgba(200,212,224,0.1);
padding: 10px 16px;
transition: all 0.3s ease;
position: relative;
overflow: hidden;
}

.inv-pill:hover {
color: var(–silver);
border-color: rgba(200,212,224,0.4);
background: rgba(200,212,224,0.03);
}

.inv-num {
color: var(–gold);
margin-right: 8px;
opacity: 0.7;
}

/* Layer stack visualization */
.layer-stack {
display: flex;
flex-direction: column;
gap: 6px;
margin-bottom: 48px;
}

.layer-row {
display: flex;
align-items: center;
gap: 16px;
opacity: 0;
animation: slideRight 0.5s ease forwards;
}

.layer-num {
font-family: ‘Courier Prime’, monospace;
font-size: 10px;
color: var(–gold);
width: 20px;
text-align: right;
flex-shrink: 0;
}

.layer-bar {
height: 32px;
background: linear-gradient(90deg, rgba(200,212,224,0.08), rgba(200,212,224,0.03));
border: 1px solid rgba(200,212,224,0.12);
border-left: 2px solid rgba(200,212,224,0.3);
display: flex;
align-items: center;
padding: 0 16px;
flex: 1;
transition: all 0.3s ease;
}

.layer-bar:hover {
background: rgba(200,212,224,0.06);
border-color: rgba(200,212,224,0.3);
}

.layer-label {
font-family: ‘Courier Prime’, monospace;
font-size: 11px;
letter-spacing: 0.15em;
color: var(–silver-dim);
}

.layer-desc {
font-size: 12px;
color: rgba(200,212,224,0.3);
margin-left: auto;
font-family: ‘Cormorant Garamond’, serif;
font-style: italic;
}

/* Navigation */
.nav-row {
display: flex;
align-items: center;
justify-content: space-between;
margin-top: 8px;
}

.nav-btn {
font-family: ‘Courier Prime’, monospace;
font-size: 10px;
letter-spacing: 0.4em;
text-transform: uppercase;
color: var(–silver-dim);
background: none;
border: none;
cursor: none;
padding: 12px 0;
transition: color 0.3s ease;
display: flex;
align-items: center;
gap: 12px;
}

.nav-btn:hover { color: var(–silver-bright); }

.nav-btn .arrow {
font-size: 16px;
transition: transform 0.3s ease;
}

.nav-btn:hover .arrow { transform: translateX(4px); }
.nav-btn.prev:hover .arrow { transform: translateX(-4px); }

.nav-dots {
display: flex;
gap: 8px;
align-items: center;
}

.dot {
width: 4px; height: 4px;
border-radius: 50%;
background: rgba(200,212,224,0.2);
transition: all 0.3s ease;
cursor: none;
}
.dot.active {
background: var(–silver);
box-shadow: 0 0 8px rgba(200,212,224,0.6);
}

/* Final screen */
.final-links {
display: flex;
gap: 24px;
flex-wrap: wrap;
margin-bottom: 48px;
}

.link-card {
font-family: ‘Courier Prime’, monospace;
font-size: 11px;
letter-spacing: 0.2em;
color: var(–silver-dim);
border: 1px solid rgba(200,212,224,0.15);
padding: 16px 24px;
text-decoration: none;
transition: all 0.3s ease;
display: flex;
flex-direction: column;
gap: 6px;
cursor: none;
}

.link-card:hover {
color: var(–silver-bright);
border-color: rgba(200,212,224,0.5);
background: rgba(200,212,224,0.03);
}

.link-card .lc-title { color: var(–gold); font-size: 10px; letter-spacing: 0.3em; }

/* Animations */
@keyframes fadeIn {
from { opacity: 0; transform: translateY(10px); }
to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
from { opacity: 0; transform: translateY(20px); }
to { opacity: 1; transform: translateY(0); }
}

@keyframes slideRight {
from { opacity: 0; transform: translateX(-10px); }
to { opacity: 1; transform: translateX(0); }
}

@keyframes breathe {
0%, 100% { transform: scale(1); opacity: 1; }
50% { transform: scale(1.15); opacity: 0.7; }
}

@keyframes float {
0%, 100% { transform: translateY(0px); }
50% { transform: translateY(-12px); }
}

@keyframes twinkle {
0%, 100% { opacity: 0.3; }
50% { opacity: 1; }
}

/* Scanline overlay */
body::after {
content: ‘’;
position: fixed;
inset: 0;
background: repeating-linear-gradient(
0deg,
transparent,
transparent 2px,
rgba(0,0,0,0.03) 2px,
rgba(0,0,0,0.03) 4px
);
pointer-events: none;
z-index: 9990;
}

/* Vignette */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background: radial-gradient(ellipse at center, transparent 40%, rgba(2,4,8,0.7) 100%);
pointer-events: none;
z-index: 1;
}

.cosmic-line {
position: fixed;
top: 50%;
left: 0;
width: 100%;
height: 1px;
background: linear-gradient(90deg, transparent, rgba(200,212,224,0.03), transparent);
z-index: 2;
pointer-events: none;
}
</style>

