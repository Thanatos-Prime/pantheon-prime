# Core similarity function

# —————————————————————————

@dataclass
class SimilarityResult:
node_a: str
node_b: str
score: float
breakdown: dict[str, float]
weights: dict[str, float]

```
def explain(self) -> str:
    lines = [
        f"Similarity({self.node_a}, {self.node_b}) = {self.score:.4f}",
        "",
        "Breakdown:",
    ]
    for component, raw in self.breakdown.items():
        w = self.weights.get(component, 0.0)
        contribution = raw * w
        lines.append(f"  {component:25s}  raw={raw:.3f}  weight={w:.2f}  contribution={contribution:.4f}")
    return "\n".join(lines)
```

def similarity(
a: NodeRecord,
b: NodeRecord,
weights: Optional[dict[str, float]] = None,
) -> SimilarityResult:
“””
Compute semantic similarity between two PSCL nodes.

```
Returns a SimilarityResult with the composite score and component breakdown.
"""
w = weights or DEFAULT_WEIGHTS

invariant_score = _token_overlap(a.core_invariant, b.core_invariant)
neighbor_score = _list_overlap(a.neighbors, b.neighbors)
domain_score = _list_overlap(a.domains, b.domains)
failure_score = _failure_mode_overlap(a.failure_modes, b.failure_modes)
transfer_score = _list_overlap(a.transfers, b.transfers)

breakdown = {
    "invariant": invariant_score,
    "neighbor": neighbor_score,
    "domain": domain_score,
    "failure_mode": failure_score,
    "transfer": transfer_score,
}

score = (
    w.get("invariant", 0) * invariant_score +
    w.get("neighbor", 0) * neighbor_score +
    w.get("domain", 0) * domain_score +
    w.get("failure_mode", 0) * failure_score +
    w.get("transfer", 0) * transfer_score
)

return SimilarityResult(
    node_a=a.id,
    node_b=b.id,
    score=round(score, 6),
    breakdown=breakdown,
    weights=w,
)
```

