// ── FIELD CANVAS ─────────────────────────────────────────────────────────────
function FieldCanvas({ actors, edges, frames, currentStep }) {
  const canvasRef = useRef(null);
  const W = 480;
  const H = 280;
  const actorColors = [C.accent, C.blue, C.green, C.red, C.purple, C.teal, C.yellow];

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    ctx.clearRect(0, 0, W, H);

    ctx.strokeStyle = `${C.border}88`;
    ctx.lineWidth = 0.5;
    for (let x = 0; x <= W; x += 40) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, H);
      ctx.stroke();
    }
    for (let y = 0; y <= H; y += 40) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(W, y);
      ctx.stroke();
    }

    const grad = ctx.createLinearGradient(0, 0, W, 0);
    grad.addColorStop(0, `${C.red}22`);
    grad.addColorStop(0.5, `${C.yellow}11`);
    grad.addColorStop(1, `${C.green}22`);
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, W, H);

    ctx.fillStyle = C.dim;
    ctx.font = "9px 'IBM Plex Mono', monospace";
    ctx.fillText("← EXTRACTION", 6, H - 6);
    ctx.fillText("COOPERATION →", W - 88, H - 6);
    ctx.fillText("PAYOFF", 6, 14);

    if (actors.length === 0) {
      ctx.fillStyle = C.dim;
      ctx.font = "12px 'IBM Plex Mono', monospace";
      ctx.textAlign = "center";
      ctx.fillText("Add actors to see field", W / 2, H / 2);
      ctx.textAlign = "left";
      return;
    }

    const step = Math.min(currentStep, Math.max((frames?.length || 1) - 1, 0));

    const positions = actors.map((a, i) => {
      const frame = frames?.length ? frames[step][i] : null;
      const x =
        frame
          ? (frame.position / 10) * (W - 60) + 30
          : actors.length > 1
          ? (i / (actors.length - 1)) * (W - 80) + 40
          : W / 2;
      const payoff = frame ? frame.payoff : 5;
      const y = H - 30 - (payoff / 10) * (H - 60);
      return { x, y };
    });

    edges.forEach((e) => {
      if (e.from >= actors.length || e.to >= actors.length) return;
      const src = positions[e.from];
      const dst = positions[e.to];
      const col = ["extracts from", "locks in", "punishes"].includes(e.type)
        ? C.red
        : C.green;

      ctx.beginPath();
      ctx.moveTo(src.x, src.y);
      const cx = (src.x + dst.x) / 2;
      const cy = Math.min(src.y, dst.y) - 30;
      ctx.quadraticCurveTo(cx, cy, dst.x, dst.y);
      ctx.strokeStyle = `${col}66`;
      ctx.lineWidth = e.weight * 0.6;
      ctx.stroke();

      const angle = Math.atan2(dst.y - cy, dst.x - cx);
      ctx.beginPath();
      ctx.moveTo(dst.x, dst.y);
      ctx.lineTo(
        dst.x - 8 * Math.cos(angle - 0.4),
        dst.y - 8 * Math.sin(angle - 0.4)
      );
      ctx.lineTo(
        dst.x - 8 * Math.cos(angle + 0.4),
        dst.y - 8 * Math.sin(angle + 0.4)
      );
      ctx.closePath();
      ctx.fillStyle = `${col}99`;
      ctx.fill();
    });

    actors.forEach((a, i) => {
      const frame = frames?.length ? frames[step][i] : null;
      const x =
        frame
          ? (frame.position / 10) * (W - 60) + 30
          : actors.length > 1
          ? (i / (actors.length - 1)) * (W - 80) + 40
          : W / 2;
      const payoff = frame ? frame.payoff : 5;
      const welfare = frame ? frame.welfare : 5;
      const y = H - 30 - (payoff / 10) * (H - 60);
      const col = actorColors[i % actorColors.length];
      const r = 8 + a.lockin;

      const glow = ctx.createRadialGradient(x, y, 0, x, y, r + 10);
      glow.addColorStop(0, `${col}44`);
      glow.addColorStop(1, "transparent");
      ctx.fillStyle = glow;
      ctx.beginPath();
      ctx.arc(x, y, r + 10, 0, Math.PI * 2);
      ctx.fill();

      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = `${col}cc`;
      ctx.fill();
      ctx.strokeStyle = col;
      ctx.lineWidth = 2;
      ctx.stroke();

      const barW = 28;
      const barH = 4;
      ctx.fillStyle = C.border;
      ctx.fillRect(x - barW / 2, y + r + 4, barW, barH);
      const wCol = welfare > 6 ? C.green : welfare > 3 ? C.yellow : C.red;
      ctx.fillStyle = wCol;
      ctx.fillRect(x - barW / 2, y + r + 4, barW * (welfare / 10), barH);

      ctx.fillStyle = C.text;
      ctx.font = "bold 10px 'IBM Plex Mono', monospace";
      ctx.textAlign = "center";
      ctx.fillText((a.name || "Actor").slice(0, 10), x, y + r + 18);
      ctx.textAlign = "left";
    });
  }, [actors, edges, frames, currentStep]);

  return (
    <canvas
      ref={canvasRef}
      width={W}
      height={H}
      style={{
        width: "100%",
        height: "auto",
        borderRadius: 4,
        display: "block",
        background: C.bg,
      }}
    />
  );
}

// ── PAYOFF CHART ─────────────────────────────────────────────────────────────
function PayoffChart({ actors, frames, currentStep }) {
  const W = 480;
  const H = 160;
  const canvasRef = useRef(null);
  const actorColors = [C.accent, C.blue, C.green, C.red, C.purple, C.teal, C.yellow];

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    ctx.clearRect(0, 0, W, H);

    ctx.strokeStyle = `${C.border}88`;
    ctx.lineWidth = 0.5;
    for (let y = 0; y <= H; y += H / 5) {
      ctx.beginPath();
      ctx.moveTo(30, y);
      ctx.lineTo(W, y);
      ctx.stroke();
    }

    ctx.fillStyle = C.dim;
    ctx.font = "8px monospace";
    [10, 7.5, 5, 2.5, 0].forEach((v, i) =>
      ctx.fillText(String(v), 2, 10 + i * (H / 5))
    );

    if (!frames.length || !actors.length) return;

    const xScale = (W - 30) / Math.max(frames.length - 1, 1);

    actors.forEach((a, i) => {
      const col = actorColors[i % actorColors.length];
      ctx.beginPath();

      frames.forEach((f, s) => {
        const x = 30 + s * xScale;
        const y = H - (f[i].welfare / 10) * H;
        if (s === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });

      ctx.strokeStyle = col;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      if (currentStep < frames.length) {
        const x = 30 + currentStep * xScale;
        const y = H - (frames[currentStep][i].welfare / 10) * H;
        ctx.beginPath();
        ctx.arc(x, y, 3, 0, Math.PI * 2);
        ctx.fillStyle = col;
        ctx.fill();
      }
    });

    if (currentStep < frames.length) {
      const x = 30 + currentStep * xScale;
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, H);
      ctx.strokeStyle = `${C.accent}66`;
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);
      ctx.stroke();
      ctx.setLineDash([]);
    }
  }, [actors, frames, currentStep]);

  return (
    <canvas
      ref={canvasRef}
      width={W}
      height={H}
      style={{
        width: "100%",
        height: "auto",
        display: "block",
        borderRadius: 4,
        background: C.bg,
      }}
    />
  );
}

