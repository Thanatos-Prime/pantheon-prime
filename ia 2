function uid() { return Math.random().toString(36).slice(2, 10); }
function fmtTime(ts) { return new Date(ts).toLocaleTimeString([], { hour: “2-digit”, minute: “2-digit” }); }
function fmtDate(ts) { return new Date(ts).toLocaleDateString([], { month: “short”, day: “numeric” }); }
function keyOf(m) { return m.zone + “__” + m.type; }

function computeDelta(curr, prev) {
if (!curr || !prev) return [];
const currMap = new Map(curr.markers.map(m => [keyOf(m), m]));
const prevMap = new Map(prev.markers.map(m => [keyOf(m), m]));
const allKeys = new Set([…currMap.keys(), …prevMap.keys()]);
return Array.from(allKeys)
.map(key => {
const c = currMap.get(key);
const p = prevMap.get(key);
const parts = key.split(”__”);
return { zone: parts[0], type: parts[1], delta: (c ? c.intensity : 0) - (p ? p.intensity : 0) };
})
.filter(d => d.delta !== 0);
}

function findClusters(snapshots) {
const counts = {};
snapshots.forEach(s => s.markers.forEach(m => {
const k = keyOf(m);
counts[k] = (counts[k] || 0) + 1;
}));
return Object.entries(counts)
.sort((a, b) => b[1] - a[1])
.slice(0, 5)
.map(([k, count]) => { const p = k.split(”__”); return { zone: p[0], type: p[1], count }; });
}

function getZone(id) { return BODY_ZONES.find(z => z.id === id); }
function getType(id) { return MARKER_TYPES.find(t => t.id === id); }

